# Go Docker Example — kuu WASM bridge demo

kuu_root := justfile_directory() + "/../.."

# Build kuu WASM for bridge
build-wasm:
    moon build --directory {{kuu_root}} --target wasm-gc --release

# Build Go binary
build-go: build-wasm
    go build -buildvcs=false -o mydocker .

# Run all Docker CLI parsing scenarios
run: build-go
    ./mydocker

# Run a specific scenario
run-scenario name: build-go
    ./mydocker --scenario "{{name}}"

# Clean Go artifacts
clean:
    rm -f mydocker
