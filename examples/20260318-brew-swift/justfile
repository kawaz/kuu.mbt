# Homebrew CLI parser demo using kuu

default: build test

# Build the Swift executable
build:
    swift build 2>&1

# Run all test scenarios
test: build
    @echo "=== brew-swift Test Scenarios ==="
    @echo ""
    @echo "--- brew install --verbose --formula node npm typescript ---"
    swift run brew-swift install --verbose --formula node npm typescript
    @echo ""
    @echo "--- brew install --force --build-from-source --cask firefox ---"
    swift run brew-swift install --force --build-from-source --cask firefox
    @echo ""
    @echo "--- brew install -fsn --HEAD --cc=gcc-9 openssl ---"
    swift run brew-swift install -fsn --HEAD --cc=gcc-9 openssl
    @echo ""
    @echo "--- brew search --desc json ---"
    swift run brew-swift search --desc json
    @echo ""
    @echo "--- brew search --formula node ---"
    swift run brew-swift search --formula node
    @echo ""
    @echo "--- brew tap homebrew/cask ---"
    swift run brew-swift tap homebrew/cask
    @echo ""
    @echo "--- brew tap user/repo https://example.com/repo.git ---"
    swift run brew-swift tap user/repo https://example.com/repo.git
    @echo ""
    @echo "--- brew upgrade --dry-run --greedy ---"
    swift run brew-swift upgrade --dry-run --greedy
    @echo ""
    @echo "--- brew upgrade --formula node npm ---"
    swift run brew-swift upgrade --formula node npm
    @echo ""
    @echo "--- brew list --versions --formula ---"
    swift run brew-swift list --versions --formula
    @echo ""
    @echo "--- brew list --pinned ---"
    swift run brew-swift list --pinned
    @echo ""
    @echo "--- brew ls --full-name --one-per-line ---"
    swift run brew-swift ls --full-name --one-per-line
    @echo ""
    @echo "--- brew list -1lrt (short flag combining) ---"
    swift run brew-swift list -1lrt
    @echo ""
    @echo "--- brew --help ---"
    swift run brew-swift --help || true
    @echo ""
    @echo "--- brew install --help ---"
    swift run brew-swift install --help || true
    @echo ""
    @echo "--- exclusive error: brew install --formula --cask node ---"
    swift run brew-swift install --formula --cask node 2>&1 || true
    @echo ""
    @echo "=== All scenarios complete ==="

# Run a single scenario
run *ARGS:
    swift run brew-swift {{ARGS}}

# Clean build artifacts
clean:
    swift package clean
