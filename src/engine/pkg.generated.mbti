pub impl @debug.Debug for &CollectorExt

pub(open) trait CompleterExt {
  fn name(Self) -> String
}

pub(open) trait EntityExt {
  fn encode(Self) -> Json = _
  fn complete_candidate(Self, Candidate) -> Candidate
}
pub impl Eq for &EntityExt
