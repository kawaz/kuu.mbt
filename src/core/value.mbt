// value.mbt вҖ” value cells, provenance tags, and the tolerant number/bool parsers.
//
// These are the leaf currency of the evaluator: a parsed CLI token becomes a
// `Value`, tagged with the `Source` seat it came from (DR-031 ladder), and
// collected as `Binding`s onto a result path.
//
// DR-074 fixes the canonical number/bool еӯ—еҸҘ; DR-075 fixes int's еҖӨз©әй–“еҲӨе®ҡ and
// the `int_round` rounding modes (with the binary64-йқһзөҢз”ұ requirement realized by
// lexical scanning here). MDR-002 В§3: value.mbt depends on node.mbt only.
//
// `Binding` / `ParseError` (DR-066 5-field with reason) live here; `Branch` and `Cand` live in
// node.mbt. The matcher builds bindings via the mkb / cat / pe_parse / depr_marker helpers at the
// end of this file.

///|
/// A resolved value that can land in the result object.
pub(all) enum Value {
  VStr(String)
  VNum(Double)
  VBool(Bool)
} derive(Eq, Debug)

///|
/// Provenance of a value cell (DR-031 / DR-016 source tag).
/// The evaluator preserves this so an appconfig store (DR-030) can ask
/// "where did this value come from" without the ladder order being movable.
pub(all) enum Source {
  Cli // CLI explicit / link вҖ” highest seat (DR-031 #1)
  Env // environment variable seat (DR-031 #2)
  Config // config-file seat (DR-050 #3) вҖ” below env, above inherit
  Inherit // nearest ancestor scope's same-named value (DR-031 #4 / DR-013)
  Default // fixed fallback (DR-031 #5)
} derive(Eq, Debug)

///|
/// A JSON-еҗҢеһӢ hierarchical config value (DR-050 В§2): what a config_provider returns. kuu core
/// never sees TOML/YAML вҖ” only this shape. Leaf values are typed (string / number / bool); arrays
/// feed a multiple element's pieces; objects mirror the name-scope hierarchy (еҗҢеһӢеҜҫеҝң).
pub(all) enum ConfigVal {
  CStr(String)
  CNum(Double)
  CBool(Bool)
  CArr(Array[ConfigVal])
  CObj(Array[(String, ConfigVal)])
  CNull // JSON null (DR-050 В§4 / DR-051): treated as дҫӣзөҰгҒӘгҒ— вҖ” the config seat supplies nothing
} derive(Eq, Debug)

///|
/// The int rounding mode (DR-075 В§2). Direction 4 (`floor`/`ceil`/`trunc`/`away`) Г— {plain, half}
/// + `half_even` + `error` = 10 modes, дҪ“зі»е®ҢеӮҷ. `error` is the canonical default (int silently
/// coerces nothing; a non-integer VALUE is rejected). DirectionиӘһ name 0-иө·зӮ№ (`trunc`/`away`) гҒЁ
/// з„Ўйҷҗ-иө·зӮ№ (`floor`/`ceil`) гӮ’еҲҶгҒ‘гҖҒJava/Python гҒ® "UP"/"DOWN" еӨҡзҫ©гӮ’жҢҒгҒЎиҫјгҒҫгҒӘгҒ„ (DR-075 В§3).
pub(all) enum RoundMode {
  RFloor // вҶ’вҲ’вҲһ
  RCeil // вҶ’+вҲһ
  RTrunc // вҶ’0 ж–№еҗ‘ (е°Ҹж•°йғЁгӮ’жҚЁгҒҰгӮӢ)
  RAway // вҶ’0 гҒ®еҸҚеҜҫж–№еҗ‘ (зө¶еҜҫеҖӨеҲҮгӮҠдёҠгҒ’)
  RHalfFloor // tieвҶ’вҲ’вҲһ
  RHalfCeil // tieвҶ’+вҲһ
  RHalfTrunc // tieвҶ’0 ж–№еҗ‘
  RHalfAway // tieвҶ’0 гҒ®еҸҚеҜҫ (еӯҰж ЎеӣӣжҚЁдә”е…Ҙ)
  RHalfEven // banker's rounding
  RError // йқһж•ҙж•°еҖӨгҒҜ Error
} derive(Eq, Debug)

///|
/// DESIGN В§7.2 / DR-096 В§1: scope config `long_eq_sep` гҒ® 3 еҖӨгҖӮlong гҒ® eq еҲҶеүІеҪў (`key=value`) гҒЁ
/// space еҲҶеүІеҪў (`key value`) гҒ®е…ҘеҸЈгӮ’гғҖгӮӨгғӨгғ«гҒҷгӮӢгҖӮ`EsRequire` = eq еҲҶеүІеҪўгҒ®гҒҝеҸ—зҗҶ (space-form main
/// entry гӮ’ withholdгҖҒDR-091 В§3 гҒ® eq еҝ…й Ҳж„Ҹе‘іи«–)гҖҒ`EsAllow` (ж—ўе®ҡ) = дёЎж–№еҸ—зҗҶгҖҒ
/// `EsDeny` = eq еҲҶеүІ matcher гӮ’з”ҹжҲҗгҒӣгҒҡ space еҲҶеүІеҪўгҒ®гҒҝеҸ—зҗҶгҖӮ
/// 3 еҖӨ enum гҒ®гҒҹгӮҒгҖҢeq еҝ…й ҲгҒӢгҒӨ eq зҰҒжӯўгҖҚгҒ®гӮҲгҒҶгҒӘзө„еҗҲгҒӣгҒҜгҒқгӮӮгҒқгӮӮж§Ӣж–Үзҡ„гҒ«иЎЁзҸҫгҒ§гҒҚгҒӘгҒ„ (illegal
/// states unrepresentableгҖҒDR-096 В§1)гҖӮ
pub(all) enum EqSepMode {
  EsRequire
  EsAllow
  EsDeny
} derive(Eq, Debug)

///|
/// Decode a canonical `long_eq_sep` config string (DR-096 В§1) to its `EqSepMode`. Returns None on an
/// unknown token вҖ” the caller surfaces this as a `DecodeSkip` (`int_round`/`round_mode_of` гҒЁеҗҢгҒҳ
/// еүҚдҫӢгғ‘гӮҝгғјгғігҖҒ`json_conformance_wbtest.mbt` гҒ®е‘јгҒіеҮәгҒ—еҒҙ)гҖӮ
pub fn eq_sep_mode_of(s : String) -> EqSepMode? {
  match s {
    "require" => Some(EsRequire)
    "allow" => Some(EsAllow)
    "deny" => Some(EsDeny)
    _ => None
  }
}

///|
/// DESIGN В§7.2 / DR-096 В§2: scope config `short_attached_value` гҒ® 3 еҖӨгҖӮеҖӨжҢҒгҒЎ short гҒ®д»ҳзқҖеҪў
/// (`-O2`) гҒЁ space еҲҶеүІеҪў (`-O 2`) гҒ®е…ҘеҸЈгӮ’гғҖгӮӨгғӨгғ«гҒҷгӮӢгҖӮ`AtRequire` = д»ҳзқҖеҪўгҒ®гҒҝеҸ—зҗҶгҒ— space-form
/// гҒ®иӘӯгҒҝжһқгҒҢз«ӢгҒҹгҒӘгҒ„ (gcc/clang гҒ® `-O`/`-W` еһӢ)гҖҒ`AtAllow` (ж—ўе®ҡ) = дёЎж–№еҸ—зҗҶ (DR-041 В§4 гҒ®еҖӨгӮ№гғӯгғғгғҲ
/// дёҖиҲ¬иҰҸеүҮгҒқгҒ®гҒҫгҒҫ)гҖҒ`AtDeny` = д»ҳзқҖиӘӯгҒҝгҒ®жһқгӮ’з”ҹжҲҗгҒӣгҒҡ space еҲҶеүІеҪўгҒ®гҒҝеҸ—зҗҶгҒҷгӮӢгҖӮеҖӨгӮ№гғӯгғғгғҲгӮ’жҢҒгҒҹгҒӘгҒ„
/// иҰҒзҙ  (flag/count) гҒ«гҒҜгғҖгӮӨгғӨгғ«гҒҢеұҠгҒ„гҒҰгӮӮ inert (DR-096 В§3.2)гҖӮ`long_eq_sep` (`EqSepMode`) гҒЁгҒҜ
/// и»ёгҒқгҒ®гӮӮгҒ®гҒҢз•°гҒӘгӮӢеҲҘеһӢ вҖ” short гҒ« eq еҲҶеүІеҪўгҒҜеӯҳеңЁгҒ—гҒӘгҒ„ (DR-096 В§3.4)гҖӮ
pub(all) enum AttachMode {
  AtRequire
  AtAllow
  AtDeny
} derive(Eq, Debug)

///|
/// Decode a canonical `short_attached_value` config string (DR-096 В§2) to its `AttachMode`.
/// Returns None on an unknown token (`eq_sep_mode_of` гҒЁеҗҢеһӢгҒ®еүҚдҫӢгғ‘гӮҝгғјгғі)гҖӮ
pub fn attach_mode_of(s : String) -> AttachMode? {
  match s {
    "require" => Some(AtRequire)
    "allow" => Some(AtAllow)
    "deny" => Some(AtDeny)
    _ => None
  }
}

///|
/// bool гҒ® factory config (DR-074 В§3/В§4 `bool_parser`, DR-061 В§3 configurable factory)гҖӮcanonical
/// default (`bool_config_canonical`) гҒҜ `true_values: ["true","1"]` / `false_values: ["false","0",""]`
/// / `case_insensitive: true` вҖ” ж—ўеӯҳ `parse_bool` гҒ®гғҸгғјгғүгӮігғјгғүиӘһеҪҷгҒЁеҗҢеҖӨ (зҪ®гҒҚжҸӣгҒҲгҒ§гҒҜгҒӘгҒҸеҗҢгҒҳиЎЁгӮ’
/// гғҮгғјгӮҝеҢ–гҒ—гҒҹгҒ гҒ‘гҖҒеҜҫжҘөзўәиӘҚгҒҜ wbtest еҒҙ)гҖӮopt-in гҒ§ `true_values`/`false_values` гҒ« `yes`/`on` зӯүгӮ’
/// иҝҪеҠ гҒҷгӮӢ (DR-074 В§4 гҒ® `+[...]` иЎЁиЁҳгҒҜгҖҢdefault й…ҚеҲ—гҒ«иӘһеҪҷгӮ’и¶ігҒ—гҒҹе®ҢжҲҗеҪўгӮ’гҒқгҒ®гҒҫгҒҫжёЎгҒҷгҖҚгҒ®ж„Ҹ вҖ” wire
/// дёҠгҒҜзҪ®жҸӣгҒ§гҒӮгҒЈгҒҰ merge гҒ§гҒҜгҒӘгҒ„гҖҒconfig гҒҜзҙ”гғҮгғјгӮҝгҒЁгҒ„гҒҶ DR-061 В§4 гҒ®еҺҹеүҮйҖҡгӮҠ)гҖӮ
pub(all) struct BoolConfig {
  true_values : Array[String]
  false_values : Array[String]
  case_insensitive : Bool
} derive(Eq, Debug)

///|
/// canonical default config (DR-074 В§3)гҖӮTypeShadow/ElemDef гҒ® bool_config ж—ўе®ҡеҖӨгҖҒгҒҠгӮҲгҒі
/// `parse_bool`(configгҒӘгҒ—е‘јгҒіеҮәгҒ—) гҒҢе§”иӯІгҒҷгӮӢе…ҲгҖӮ
pub fn bool_config_canonical() -> BoolConfig {
  {
    true_values: ["true", "1"],
    false_values: ["false", "0", ""],
    case_insensitive: true,
  }
}

///|
/// Parse a String token as a bool through a configurable vocab (DR-074 В§3/В§4 `bool_parser` factory
/// config). `case_insensitive` gates whether the token is compared against `true_values`/
/// `false_values` case-insensitively (canonical `true`) or exactly (opt-in dialect, JSON/TOML жә–жӢ 
/// `false`). A token matching neither list is None (вҶ’ Error at the call site, same `not_a_bool`
/// posture as the canonical-only `parse_bool`). `parse_bool(s)` below is this function specialized to
/// `bool_config_canonical()` вҖ” the SAME canonical table, just expressed as data instead of literal
/// `if` branches (DR-061 В§3 гҖҢгӮҜгғӯгғјгӮёгғЈгӮ’гғҮгғјгӮҝеҢ–гҖҚ).
pub fn parse_bool_ext(s : String, config : BoolConfig) -> Bool? {
  for t in config.true_values {
    if (config.case_insensitive && eq_ci(s, t)) ||
      (!config.case_insensitive && s == t) {
      return Some(true)
    }
  }
  for f in config.false_values {
    if (config.case_insensitive && eq_ci(s, f)) ||
      (!config.case_insensitive && s == f) {
      return Some(false)
    }
  }
  None
}

///|
/// The reason an int/number parse failed (DR-066 иӘһеҪҷ): `NotANumber` = not a number at all,
/// `NotAnInteger` = a non-integer value under `int_round: error`. `IntOutOfRange` = a readable
/// integer VALUE whose magnitude exceeds Int64's range (issue
/// 2026-07-07-parse-int-value-huge-exponent-overflow: `"1e300"` etc. used to silently wrap via
/// `digits_to_i64` instead of erroring). DR-066 v1 has no reason for this yet вҖ” `int_out_of_range`
/// is a provisional reason, the SAME kind of gap-fill as `pe_parse_bool`'s `not_a_bool`
/// (docs/issue/2026-07-07-bool-invalid-reason-vocab-gap.md); the spec-side vocab decision is
/// tracked separately (spec repo kawaz/kuu issue, filed by the team lead).
pub(all) enum ParseFail {
  NotANumber
  NotAnInteger
  IntOutOfRange
} derive(Eq, Debug)

///|
/// Whether a double is integer-valued (for the int type on a config NATIVE number, DR-075 В§5:
/// a JSON-з”ұжқҘ native number is already binary64, so this seatеҲӨе®ҡ is binary64-based вҖ” the
/// non-transit requirement applies to Stringжәҗ only, handled by `parse_int_value`).
pub fn is_integer(d : Double) -> Bool {
  d.to_int().to_double() == d
}

///|
/// The category of a held Error (DR-053 В§2 / DR-037 / DR-047): `parse` = type parse failure,
/// `filter` = a piece/value/cell filter reject (a value that parsed but failed a filter), `constraint` = a
/// delayed-predicate violation (required жңӘе……и¶і etc., DR-047). All three ride the errors array.
pub(all) enum ErrKind {
  KParse
  KFilter
  KConstraint
} derive(Eq, Debug)

///|
/// One held Error (DR-053 В§2 + DR-066): which element, the argv position it failed at, its kind, a
/// machine-readable `reason` (snake_case, DR-066 В§3 v1 vocab: missing_operand / unexpected_token /
/// not_a_number / not_an_integer / <attr>_violated), the human message, and `path` (DR-066 В§4): the
/// root-first ancestor scope names the error fired under (snoc form вҖ” `path` = ancestors, `element` =
/// self; `path: []` = root зӣҙдёӢ, no separate null case, Maybe вҠӮ List). The errors array keeps ALL of
/// them (еҲҘеҖҷиЈңзөҢи·ҜгҒ®еҲҘ Error); primary = max argv_pos. Conformance compares errors by
/// (element, argv_pos, kind, reason) вҖ” message is always ignored (CONFORMANCE В§3), path is optional
/// (DR-066 В§4) вҖ” so every construction site emits a reason from the v1 vocabulary and a path (`[]`
/// when the error has no ancestor scope to record, which conformance treats identically to "no path
/// asserted" when the fixture opts out).
pub(all) struct ParseError {
  element : String
  argv_pos : Int
  kind : ErrKind
  reason : String // DR-066 В§3: machine-readable failure identifier (snake_case v1 vocab)
  message : String
  path : Array[String] // DR-066 В§4: root-first ancestor scope names (snoc form, [] = root зӣҙдёӢ)
} derive(Eq, Debug)

///|
/// JSON-standard string form of a config number (DR-050 В§4 stringification). An integer-valued
/// double renders without a fractional part (1.0 вҶ’ "1"); otherwise the decimal form (1.5 вҶ’ "1.5").
fn num_to_string(d : Double) -> String {
  let i = d.to_int()
  if i.to_double() == d {
    i.to_string()
  } else {
    d.to_string()
  }
}

// в”Җв”Җ canonical number еӯ—еҸҘгӮ№гӮӯгғЈгғі (DR-074 В§1, В§7) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

///|
/// String indexing (`s[i]`) yields a UTF-16 code unit, not a Char, so the number еӯ—еҸҘгӮ№гӮӯгғЈгғі works
/// on Array[Char] (iterating a String yields Char). Test tokens are ASCII.
fn chars_of(s : String) -> Array[Char] {
  let a : Array[Char] = []
  for c in s {
    a.push(c)
  }
  a
}

///|
/// Scan a maximal digit group starting at `start`, writing the digits (WITHOUT the `_`
/// separators) into `buf`. DR-074 В§7 `_` placement: a `_` is legal ONLY between two digits вҖ”
/// no leading (`_1`), trailing (`1_`), consecutive (`1__0`), or edge-adjacent `_`. Returns the
/// index just past the group, or None if a `_` is misplaced. An empty group is legal (returns
/// `start` unchanged) вҖ” the caller decides whether at least one mantissa digit was seen.
fn scan_digits(cs : Array[Char], start : Int, buf : StringBuilder) -> Int? {
  let n = cs.length()
  let mut i = start
  let mut last_digit = false
  while i < n {
    let c = cs[i]
    if c >= '0' && c <= '9' {
      buf.write_char(c)
      last_digit = true
      i = i + 1
    } else if c == '_' {
      // `_` must have a digit on BOTH sides (DR-074 В§7)
      if !last_digit {
        return None
      }
      if i + 1 >= n {
        return None
      }
      let nx = cs[i + 1]
      if !(nx >= '0' && nx <= '9') {
        return None
      }
      last_digit = false
      i = i + 1 // skip `_`, do not write it
    } else {
      break
    }
  }
  Some(i)
}

///|
/// Split a token into canonical number parts: `(neg, int_digits, frac_digits, exp)`, or None if the
/// token is not a canonical number lexeme (DR-074 В§1). Rejects base prefixes (`0x`/`0o`/`0b` вҖ” Error
/// in canonical, В§2), type suffix (`1.0f`), inf/nan, and any trailing junk. `int_digits`/`frac_digits`
/// have their `_` separators stripped; a leading `.` gives empty `int_digits`, a trailing `.` gives
/// empty `frac_digits`. At least one mantissa digit is required (`.` / `+` alone вҶ’ None).
fn scan_number_parts(s : String) -> (Bool, String, String, Int)? {
  let cs = chars_of(s)
  let n = cs.length()
  if n == 0 {
    return None
  }
  let mut i = 0
  let mut neg = false
  // leading sign (DR-074 В§1: [+-] both accepted)
  if cs[i] == '+' || cs[i] == '-' {
    neg = cs[i] == '-'
    i = i + 1
  }
  // reject base prefix вҖ” canonical does not accept 0x/0o/0b (В§2, opt-in only)
  if i + 1 < n && cs[i] == '0' {
    let c1 = cs[i + 1]
    if c1 == 'x' ||
      c1 == 'X' ||
      c1 == 'o' ||
      c1 == 'O' ||
      c1 == 'b' ||
      c1 == 'B' {
      return None
    }
  }
  // integer digit group (may be empty for a leading-`.` form like `.5`)
  let ibuf = StringBuilder::new()
  let after_int = match scan_digits(cs, i, ibuf) {
    None => return None
    Some(x) => x
  }
  i = after_int
  let int_digits = ibuf.to_string()
  let mut saw_digit = int_digits.length() > 0
  // fraction
  let fbuf = StringBuilder::new()
  if i < n && cs[i] == '.' {
    i = i + 1
    let after_frac = match scan_digits(cs, i, fbuf) {
      None => return None
      Some(x) => x
    }
    i = after_frac
  }
  let frac_digits = fbuf.to_string()
  if frac_digits.length() > 0 {
    saw_digit = true
  }
  // at least one mantissa digit required (`.` alone or `+` alone вҶ’ None)
  if !saw_digit {
    return None
  }
  // exponent (e/E, optional [+-] sign, digits required вҖ” DR-074 В§7)
  let mut exp = 0
  if i < n && (cs[i] == 'e' || cs[i] == 'E') {
    i = i + 1
    let mut esign = 1
    if i < n && (cs[i] == '+' || cs[i] == '-') {
      if cs[i] == '-' {
        esign = -1
      }
      i = i + 1
    }
    let ebuf = StringBuilder::new()
    let after_exp = match scan_digits(cs, i, ebuf) {
      None => return None
      Some(x) => x
    }
    i = after_exp
    let edigits = ebuf.to_string()
    if edigits.length() == 0 {
      return None // exponent marker with no digits
    }
    exp = esign * digits_to_int(edigits)
  }
  // any trailing character (incl. `f` suffix / inf / nan / stray char) rejects the whole token
  if i != n {
    return None
  }
  Some((neg, int_digits, frac_digits, exp))
}

// в”Җв”Җ DR-074 В§2 / В§7 opt-in base prefix (0x / 0o / 0b) + hex float в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

///|
/// hex digit value 0-15 (case-insensitive, DR-074 В§7 гҖҢhex гҒ®жЎҒ a-f / A-F гҒҜ case-insensitiveгҖҚ),
/// or None for non-hex characters. Used by scan_hex_digits / parse_hex_body гҒ®еҖӨиЁҲз®—.
fn hex_val(c : Char) -> Int? {
  if c >= '0' && c <= '9' {
    Some(c.to_int() - '0'.to_int())
  } else if c >= 'a' && c <= 'f' {
    Some(10 + c.to_int() - 'a'.to_int())
  } else if c >= 'A' && c <= 'F' {
    Some(10 + c.to_int() - 'A'.to_int())
  } else {
    None
  }
}

///|
/// Scan a maximal hex digit group starting at `start`, writing the digits (WITHOUT the `_`
/// separators) into `buf`. DR-074 В§7 `_` placement: дёЎйҡЈгҒҢ hex жЎҒгҒ®гҒҝиЁұе®№ вҖ” йҖЈз¶ҡ (`ff__ff`) дёҚеҸҜгҖҒ
/// е…Ҳй ӯ (`_ff`) / жң«е°ҫ (`ff_`) / йқһ hex йҡЈжҺҘдёҚеҸҜгҖӮ`0x_ff` гҒҜ caller гҒҢжӢ’еҗҰгҒҷгӮӢ (prefix йҡЈжҺҘ = е…Ҳй ӯгҒ«зӣёеҪ“)гҖӮ
/// з©ә group гҒҜ legal (0 гӮ’иҝ”гҒҷ) вҖ” caller гҒҢгҖҢе°‘гҒӘгҒҸгҒЁгӮӮ 1 жЎҒгҖҚгӮ’еҲӨе®ҡгҖӮ
fn scan_hex_digits(cs : Array[Char], start : Int, buf : StringBuilder) -> Int? {
  let n = cs.length()
  let mut i = start
  let mut last_hex = false
  while i < n {
    let c = cs[i]
    match hex_val(c) {
      Some(_) => {
        buf.write_char(c)
        last_hex = true
        i = i + 1
      }
      None =>
        if c == '_' {
          if !last_hex {
            return None
          }
          if i + 1 >= n {
            return None
          }
          if hex_val(cs[i + 1]) is None {
            return None
          }
          last_hex = false
          i = i + 1
        } else {
          break
        }
    }
  }
  Some(i)
}

///|
/// Scan a maximal octal digit group [0-7] with `_` between digits (DR-074 В§7 гҒЁеҗҢдёҖиҰҸеүҮгҒ® base=8 зүҲ)гҖӮ
fn scan_oct_digits(cs : Array[Char], start : Int, buf : StringBuilder) -> Int? {
  let n = cs.length()
  let mut i = start
  let mut last_oct = false
  while i < n {
    let c = cs[i]
    if c >= '0' && c <= '7' {
      buf.write_char(c)
      last_oct = true
      i = i + 1
    } else if c == '_' {
      if !last_oct {
        return None
      }
      if i + 1 >= n {
        return None
      }
      let nx = cs[i + 1]
      if !(nx >= '0' && nx <= '7') {
        return None
      }
      last_oct = false
      i = i + 1
    } else {
      break
    }
  }
  Some(i)
}

///|
/// Scan a maximal binary digit group [01] with `_` between digits (base=2)гҖӮ
fn scan_bin_digits(cs : Array[Char], start : Int, buf : StringBuilder) -> Int? {
  let n = cs.length()
  let mut i = start
  let mut last_bin = false
  while i < n {
    let c = cs[i]
    if c == '0' || c == '1' {
      buf.write_char(c)
      last_bin = true
      i = i + 1
    } else if c == '_' {
      if !last_bin {
        return None
      }
      if i + 1 >= n {
        return None
      }
      let nx = cs[i + 1]
      if !(nx == '0' || nx == '1') {
        return None
      }
      last_bin = false
      i = i + 1
    } else {
      break
    }
  }
  Some(i)
}

///|
/// 2^exp гӮ’ Double гҒ§иЁҲз®— (еҚҳзҙ”гғ«гғјгғ—гҖҒhex float дәҢйҖІжҢҮж•°гҒ®йҒ©з”ЁгҒ«дҪҝгҒҶ)гҖӮfixture гҒҢдҪҝгҒҶзҜ„еӣІ (|exp| < 20
/// зЁӢеәҰ) гҒ§гҒҜ overflow гҒӘгҒ—гҖӮжҘөз«ҜеҖӨгҒ§гҒҜ Вұ0 / Вұinf гҒ«йЈҪе’ҢгҒҷгӮӢ (spec гҒҜеўғз•ҢгӮ’иҰҸе®ҡгҒ—гҒӘгҒ„гҒ®гҒ§еҗҲзҗҶзҡ„ж—ўе®ҡ)гҖӮ
fn pow2_double(exp : Int) -> Double {
  if exp >= 0 {
    let mut r = 1.0
    let mut i = 0
    while i < exp {
      r = r * 2.0
      i = i + 1
    }
    r
  } else {
    let mut r = 1.0
    let mut i = 0
    while i < -exp {
      r = r * 2.0
      i = i + 1
    }
    1.0 / r
  }
}

///|
/// DR-074 В§2 hex ж•ҙж•° or hex float гҒ® body parse (`0x`/`0X` prefix гҒҜ caller гҒҢж—ўгҒ«ж¶ҲиІ»)гҖӮиҮіжҖҘиҰҒжұӮ =
/// (mantissa hex жЎҒгҒҢ int/frac гҒ«дёҖгҒӨд»ҘдёҠ) + optional `.frac_hex` + optional `p[+-]?dec`гҖӮfraction гҒҫгҒҹгҒҜ
/// exponent гҒҢгҒӮгӮӢе ҙеҗҲгҒҜ hex floatгҖҒдёЎж–№з„ЎгҒ‘гӮҢгҒ° hex integer (еҗҢгҒҳгғӯгӮёгғғгӮҜгҒ§ value еҢ–гҒҷгӮӢ вҖ” integer гҒҜ
/// exp=0 гҒӢгҒӨ frac з©ә)гҖӮtrailing junk (i != n) гҒҜ NoneгҖӮDR-074 В§7 pin: `_` й…ҚзҪ®ж–Үжі•гҒҜ дёЎйҡЈжЎҒгҒ®гҒҝгҖҒ
/// `0x_ff` (prefix йҡЈжҺҘ) гҒҜе…Ҳй ӯз©ә int_digits вҶ’ з¶ҡгҒҸ `_` гҒҢ scan_hex_digits гҒ§ NG (е…Ҳй ӯ `_`) гҒ§жӢ’еҗҰгҖӮ
fn parse_hex_body(cs : Array[Char], i_start : Int, neg : Bool) -> Double? {
  let n = cs.length()
  let mut i = i_start
  // integer hex жЎҒзҫӨ (з©ә legalгҖҒfraction гҒҢгҒӮгӮӢе ҙеҗҲгҒ®гҒҝ)
  let ibuf = StringBuilder::new()
  let after_int = match scan_hex_digits(cs, i, ibuf) {
    None => return None
    Some(x) => x
  }
  i = after_int
  let int_digits = ibuf.to_string()
  let mut saw_digit = int_digits.length() > 0
  // fraction: е°Ҹж•°зӮ№гҒӮгӮҠжҷӮгҒ®гҒҝгҖҒ`_` й…ҚзҪ®гҒҜеҗҢдёҖиҰҸеүҮ
  let fbuf = StringBuilder::new()
  if i < n && cs[i] == '.' {
    i = i + 1
    let after_frac = match scan_hex_digits(cs, i, fbuf) {
      None => return None
      Some(x) => x
    }
    i = after_frac
  }
  let frac_digits = fbuf.to_string()
  if frac_digits.length() > 0 {
    saw_digit = true
  }
  // е°‘гҒӘгҒҸгҒЁгӮӮ 1 mantissa жЎҒ (`0x.p3` / `0x` гҒҜз©ә mantissa гҒ§ NoneгҖҒDR-074 В§1 гҒ® scan_number_parts гҒЁеҗҢеһӢ)
  if !saw_digit {
    return None
  }
  // дәҢйҖІжҢҮж•° `p[+-]?dec+` (д»»ж„ҸгҖҒDR-074 В§2 гҖҢp д»»ж„Ҹ = C strtod жөҒгҖҚ)
  let mut exp = 0
  if i < n && (cs[i] == 'p' || cs[i] == 'P') {
    i = i + 1
    let mut esign = 1
    if i < n && (cs[i] == '+' || cs[i] == '-') {
      if cs[i] == '-' {
        esign = -1
      }
      i = i + 1
    }
    let ebuf = StringBuilder::new()
    let after_exp = match scan_digits(cs, i, ebuf) {
      None => return None
      Some(x) => x
    }
    i = after_exp
    let edigits = ebuf.to_string()
    if edigits.length() == 0 {
      return None
    }
    exp = esign * digits_to_int(edigits)
  }
  // trailing junk
  if i != n {
    return None
  }
  // value иЁҲз®—: mantissa = ОЈ hex_val * 16^k (int) + ОЈ hex_val * 16^(-(k+1)) (frac)гҖҒscale = 2^exp
  let mut val = 0.0
  for c in int_digits {
    val = val * 16.0 + hex_val(c).unwrap().to_double()
  }
  let mut frac_mul = 1.0 / 16.0
  for c in frac_digits {
    val = val + hex_val(c).unwrap().to_double() * frac_mul
    frac_mul = frac_mul / 16.0
  }
  val = val * pow2_double(exp)
  Some(if neg { -val } else { val })
}

///|
/// DR-074 В§2 opt-in `0o` 8 йҖІж•ҙж•° (`0o` prefix гҒҜ caller гҒҢж¶ҲиІ»жёҲгҒҝ)гҖӮВ§7 pin: `0o1.5` / `0o1p3` гҒҜ
/// е°Ҹж•°зӮ№гғ»жҢҮж•° hex float йҷҗе®ҡгҒӘгҒ®гҒ§гҖҒfraction / exponent гҒҜ accept гҒӣгҒҡгҖҒtrailing char гҒ§ NoneгҖӮ
fn parse_oct_body(cs : Array[Char], i_start : Int, neg : Bool) -> Double? {
  let n = cs.length()
  let mut i = i_start
  let ibuf = StringBuilder::new()
  let after_int = match scan_oct_digits(cs, i, ibuf) {
    None => return None
    Some(x) => x
  }
  i = after_int
  let int_digits = ibuf.to_string()
  if int_digits.length() == 0 {
    return None
  }
  if i != n {
    return None
  }
  let mut val = 0.0
  for c in int_digits {
    val = val * 8.0 + (c.to_int() - 48).to_double()
  }
  Some(if neg { -val } else { val })
}

///|
/// DR-074 В§2 opt-in `0b` 2 йҖІж•ҙж•° (parse_oct_body гҒ® base=2 зүҲгҖҒВ§7 pin гҒ«гӮҲгӮҠе°Ҹж•°гғ»жҢҮж•°дёҚеҸҜ)гҖӮ
fn parse_bin_body(cs : Array[Char], i_start : Int, neg : Bool) -> Double? {
  let n = cs.length()
  let mut i = i_start
  let ibuf = StringBuilder::new()
  let after_int = match scan_bin_digits(cs, i, ibuf) {
    None => return None
    Some(x) => x
  }
  i = after_int
  let int_digits = ibuf.to_string()
  if int_digits.length() == 0 {
    return None
  }
  if i != n {
    return None
  }
  let mut val = 0.0
  for c in int_digits {
    val = val * 2.0 + (c.to_int() - 48).to_double()
  }
  Some(if neg { -val } else { val })
}

///|
/// DR-074 В§2 opt-in base prefix (`0x` / `0X` / `0o` / `0O` / `0b` / `0B`) гҒ®з·ҸеҗҲ dispatcherгҖӮе…Ҳй ӯз¬ҰеҸ·
/// `[+-]` гӮ’еҗҲжҲҗеҸҜ (В§7 pinгҖҒ-0xff гӮ„ +0x1.8p3 гӮӮеҸ—зҗҶ)гҖӮprefix еҲӨе®ҡеҫҢгҖҒbody гҒ«еҝңгҒҳгҒҰ hex (float or int) /
/// oct / bin гҒ®еҗ„ parser гҒ«жҢҜгӮҠеҲҶгҒ‘гӮӢгҖӮcanonical (allow=false) гҒӢгӮүгҒҜе‘јгҒ°гӮҢгҒҡгҖҒopt-in жҷӮгҒ®гҒҝи©ҰгҒ•гӮҢгӮӢгҖӮ
fn parse_base_prefixed(s : String) -> Double? {
  let cs = chars_of(s)
  let n = cs.length()
  if n == 0 {
    return None
  }
  let mut i = 0
  let mut neg = false
  if cs[i] == '+' || cs[i] == '-' {
    neg = cs[i] == '-'
    i = i + 1
  }
  if i + 1 >= n {
    return None
  }
  if cs[i] != '0' {
    return None
  }
  let c1 = cs[i + 1]
  i = i + 2
  match c1 {
    'x' | 'X' => parse_hex_body(cs, i, neg)
    'o' | 'O' => parse_oct_body(cs, i, neg)
    'b' | 'B' => parse_bin_body(cs, i, neg)
    _ => None
  }
}

///|
/// DR-074 В§2 зөұеҗҲ opt-in гҒ® number parser: `allow_base_prefix=false` гҒҜж—ўеӯҳ canonical parse_number гҒЁ
/// зӯүдҫЎ (10 йҖІгҒ®гҒҝгҖҒbase prefix гҒҜ None)гҖӮ`true` гҒ§гҒҜ 10 йҖІгӮ’е…ҲгҒ«и©ҰгҒ—гҖҒеӨұж•—жҷӮгҒ®гҒҝ base prefix гӮ’и©ҰгҒҷ
/// (canonical гҒЁ opt-in гҒ®еҸ—зҗҶеҹҹгҒҢжҺ’д»–гҒӘгҒ®гҒ§й ҶеәҸгҒ«еҪұйҹҝгҒӘгҒ—гҖҒDR-074 В§2 гҖҢдёЎж–№гҒҢдёҖжӢ¬гҒ§жҲҗеҠҹгҒ«и»ўгҒҳгӮӢгҖҚ)гҖӮ
pub fn parse_number_ext(s : String, allow_base_prefix : Bool) -> Double? {
  match parse_number(s) {
    Some(d) => return Some(d)
    None => ()
  }
  if allow_base_prefix {
    parse_base_prefixed(s)
  } else {
    None
  }
}

///|
/// DR-075 В§ еҖӨз©әй–“еҲӨе®ҡ + DR-074 В§2 opt-in гҒ® int parserгҖӮcanonical (allow=false) гҒҜж—ўеӯҳ parse_int_value
/// гҒЁзӯүдҫЎгҖӮopt-in жҷӮгҒҜ base prefix зөҢи·ҜгӮӮи©ҰгҒ—гҖҒhex integer (0xff=255) гҒҜж•ҙж•°еҖӨгҖҒhex float (0x1.8p3=12) гҒҜ
/// binary64 гҒ®еҖӨгҒҢж•ҙж•°гҒӘгӮүеҸ—зҗҶгҖҒйқһж•ҙж•° (0x1.8=1.5) гҒҜ int_round гҒ«еҫ“гҒҶ (DR-074 В§2 гҖҢ10 йҖІгҒЁеҗҢдёҖиҰҸеүҮгӮ’
/// hex гҒ«гӮӮйҒ©з”ЁгҖҚ)гҖӮDR-075 В§5 гҒ® binary64 йқһзөҢз”ұиҰҒд»¶гҒҜ 10 йҖІ tie еҲӨе®ҡгҒ«еҜҫгҒҷгӮӢиҰҸе®ҡгҒ§гҖҒhex float гҒҜ
/// base-2 aligned гҒ§ binary64 гҒ« exactly иЎЁзҸҫеҸҜиғҪгҒӘгҒ®гҒ§жң¬зөҢи·ҜгҒ® binary64 зөҢз”ұгҒҜ spec ж„ҸеӣігҒЁж•ҙеҗҲгҖӮ
/// NB: exact гҒӘгҒ®гҒҜ mantissa 53 bit (hex ~13 жЎҒ) гҒҫгҒ§ вҖ” гҒқгӮҢгӮ’и¶…гҒҲгӮӢ hex mantissa гҒҜ binary64 дёёгӮҒгҒҢ
/// е…ҘгӮҠ tie еҲӨе®ҡгҒҢ 10 йҖІ false-tie гҒЁеҗҢеһӢгҒ®е•ҸйЎҢгӮ’жҢҒгҒЎгҒҶгӮӢгҒҢгҖҒгҒқгҒ®еҖӨеҹҹгҒ®жҢҷеӢ•гҒҜ DR-074 В§2 гҒҢжңӘиҰҸе®ҡ
/// (fixture жңӘеӣәе®ҡгҖҒз—…зҡ„е…ҘеҠӣеҹҹ)гҖӮspec гҒҢиҰҸе®ҡгҒ—гҒҹгӮүиҝҪеҫ“гҒҷгӮӢгҖӮ
pub fn parse_int_value_ext(
  s : String,
  mode : RoundMode,
  allow_base_prefix : Bool,
) -> Result[Int64, ParseFail] {
  // 10 йҖІзөҢи·ҜгӮ’е…ҲгҒ«и©ҰгҒҷ (canonical гҒЁ opt-in гҒ§жҢҷеӢ•еҗҢдёҖ)
  match parse_int_value(s, mode) {
    Ok(i) => return Ok(i)
    Err(NotANumber) => () // 10 йҖІ lexer гҒ§ not_a_number = base prefix и©ҰиЎҢгҒ«иҗҪгҒЁгҒҷ
    Err(e) => return Err(e) // NotAnInteger / IntOutOfRange гҒҜ 10 йҖІзөҢи·ҜгҒ§зўәе®ҡгҒ—гҒҹ Error гҒӘгҒ®гҒ§дјқж’ӯ
  }
  if !allow_base_prefix {
    return Err(NotANumber)
  }
  match parse_base_prefixed(s) {
    None => Err(NotANumber)
    Some(d) =>
      if is_integer(d) {
        // ж•ҙж•°еҖӨ: mode е•ҸгӮҸгҒҡеҸ—зҗҶгҖӮInt64 еҹҹеҶ…гғҒгӮ§гғғгӮҜгҒҜеўғз•ҢгҒ®гҒҝ (fixture гҒҜ 0xff=255 гғ¬гғҷгғ«)
        let i = d.to_int64()
        if i.to_double() == d {
          Ok(i)
        } else {
          Err(IntOutOfRange)
        }
      } else {
        // fractional hex float: mode гҒ«еҫ“гҒҶ
        match mode {
          RError => Err(NotAnInteger)
          _ => {
            // еҚҳзҙ”еҢ–: binary64 дёҠгҒ§ is_integer еҲӨе®ҡ + дёёгӮҒгҖӮDR-075 В§5 гҒ®еҺіеҜҶеҲӨе®ҡгҒҜ 10 йҖІ tie гҒ®гҒҹгӮҒгҒ®
            // иҰҸе®ҡ (findings 2026-07-06 гҒ® false-tie еҹҹ) гҒ§гҖҒhex float гҒҜ base-2 aligned гҒӘгҒ®гҒ§ binary64
            // дёҠгҒ®дёёгӮҒгҒҜ exactгҖӮround-mode гӮ’ Double гҒ«йҒ©з”ЁгҒҷгӮӢз°Ўжҳ“е®ҹиЈ…:
            let rounded = round_double_by_mode(d, mode)
            let i = rounded.to_int64()
            if i.to_double() == rounded {
              Ok(i)
            } else {
              Err(IntOutOfRange)
            }
          }
        }
      }
  }
}

///|
/// DR-075 В§2 гҒ® 10 гғўгғјгғүгӮ’ Double дёҠгҒ§йҒ©з”Ё (hex float з”ЁгҒ®з°Ўжҳ“е®ҹиЈ…)гҖӮbase-2 aligned гҒӘ hex float гҒҜ
/// binary64 гҒ§ exact гҒӘгҒ®гҒ§гҖҒtie еҲӨе®ҡгғ»еўғз•ҢеҲӨе®ҡгҒ« false-tie гҒ®жҮёеҝөгҒӘгҒ—гҖӮ
fn round_double_by_mode(d : Double, mode : RoundMode) -> Double {
  // ж•ҙж•°еҖӨгҒҜзҙ йҖҡгҒ— (е‘јгҒіеҮәгҒ—еҒҙгҒ§ is_integer гғҒгӮ§гғғгӮҜжёҲгҒҝгҒ гҒҢйҳІеҫЎзҡ„гҒ«)
  let floor_d = if d >= 0.0 {
    d.to_int64().to_double()
  } else {
    let f = d.to_int64().to_double()
    if f == d {
      f
    } else {
      f - 1.0
    }
  }
  let ceil_d = if d >= 0.0 {
    let f = d.to_int64().to_double()
    if f == d {
      f
    } else {
      f + 1.0
    }
  } else {
    d.to_int64().to_double()
  }
  let frac = d - floor_d // >= 0
  let is_tie = frac == 0.5
  let gt_half = frac > 0.5
  match mode {
    RFloor => floor_d
    RCeil => ceil_d
    RTrunc => if d >= 0.0 { floor_d } else { ceil_d }
    RAway => if d >= 0.0 { ceil_d } else { floor_d }
    RHalfFloor =>
      if is_tie {
        floor_d
      } else if gt_half {
        ceil_d
      } else {
        floor_d
      }
    RHalfCeil =>
      if is_tie {
        ceil_d
      } else if gt_half {
        ceil_d
      } else {
        floor_d
      }
    RHalfTrunc =>
      if is_tie {
        if d >= 0.0 {
          floor_d
        } else {
          ceil_d
        }
      } else if gt_half {
        ceil_d
      } else {
        floor_d
      }
    RHalfAway =>
      if is_tie {
        if d >= 0.0 {
          ceil_d
        } else {
          floor_d
        }
      } else if gt_half {
        ceil_d
      } else {
        floor_d
      }
    RHalfEven =>
      if is_tie {
        let fi = floor_d.to_int64()
        if fi % 2L == 0L {
          floor_d
        } else {
          ceil_d
        }
      } else if gt_half {
        ceil_d
      } else {
        floor_d
      }
    RError => d // caller гҒ®жҳҜйқһеҲӨе®ҡгҒ§жӢҫгӮҸгӮҢгӮӢ
  }
}

///|
fn digits_to_int(s : String) -> Int {
  let mut acc = 0
  for c in s {
    acc = acc * 10 + (c.to_int() - 48)
  }
  acc
}

///|
fn digits_to_i64(s : String) -> Int64 {
  let mut acc : Int64 = 0
  for c in s {
    acc = acc * 10L + (c.to_int() - 48).to_int64()
  }
  acc
}

///|
/// Tolerant number parser (DR-074 В§1 canonical): optional leading sign, decimal digits with an
/// optional single decimal point (`.5` / `1.` accepted), `_` thousands separators (default vocab),
/// and an optional `e`/`E` exponent with an optional sign. Base prefixes, type suffixes (`1.0f`),
/// inf/nan are NOT accepted (all вҶ’ None). The value conversion delegates to the host's binary64
/// parser on a normalized, `_`-stripped lexeme (validating the еӯ—еҸҘ is this leaf's job; DR-075's
/// binary64-йқһзөҢз”ұ requirement is on INT rounding only, handled in `parse_int_value`).
pub fn parse_number(s : String) -> Double? {
  match scan_number_parts(s) {
    None => None
    Some((neg, int_d, frac_d, exp)) => {
      let buf = StringBuilder::new()
      if neg {
        buf.write_char('-')
      }
      buf.write_string(if int_d.length() > 0 { int_d } else { "0" })
      if frac_d.length() > 0 {
        buf.write_char('.')
        buf.write_string(frac_d)
      }
      if exp != 0 {
        buf.write_char('e')
        buf.write_string(exp.to_string())
      }
      try_parse_double(buf.to_string())
    }
  }
}

///|
fn try_parse_double(clean : String) -> Double? {
  Some(@string.parse_double(clean)) catch {
    _ => None
  }
}

///|
/// Recognize the DR-074 В§7 inf lexeme: an optional leading `[+-]` sign (the same rule as
/// `scan_number_parts`'s sign, В§1) followed by a case-insensitive `inf` or `infinity` вҖ” the
/// confirmed 2-word set (`Inf`/`INF`/`Infinity` are case variants, not separately enumerated).
/// Returns the signed Double infinity, or None if `s` is not this exact lexeme (nan is NEVER
/// matched here вҖ” nan has no lexeme at all in canonical, DR-074 В§1/В§3 "жҺЎз”ЁгҒ—гҒӘгҒӢгҒЈгҒҹжЎҲ").
fn scan_inf(s : String) -> Double? {
  let cs = chars_of(s)
  let n = cs.length()
  if n == 0 {
    return None
  }
  let mut i = 0
  let mut neg = false
  if cs[i] == '+' || cs[i] == '-' {
    neg = cs[i] == '-'
    i = i + 1
  }
  let rest = chars_to_str_from(cs, i)
  if !(eq_ci(rest, "inf") || eq_ci(rest, "infinity")) {
    return None
  }
  let inf : Double = 1.0 / 0.0
  Some(if neg { -inf } else { inf })
}

///|
fn chars_to_str_from(cs : Array[Char], start : Int) -> String {
  let buf = StringBuilder::new()
  let mut i = start
  while i < cs.length() {
    buf.write_char(cs[i])
    i = i + 1
  }
  buf.to_string()
}

///|
/// Tolerant FLOAT parser (DR-074 В§1/В§7): the `float` type's acceptеҹҹ is `parse_number`'s canonical
/// number lexicon PLUS the 2-word inf/infinity vocab (case-insensitive, sign-еҗҲжҲҗеҸҜ) вҖ” nan is Error
/// for BOTH number and float (no lexeme accepted here, ever). A separate function from
/// `parse_number` because the accept-еҹҹ differs per TYPE (`Ty::TNum` rejects inf, `Ty::TFloat`
/// accepts it, DR-074 В§1) вҖ” `parse_number` itself stays number-canonical so every OTHER caller
/// (int's еҖӨз©әй–“еҲӨе®ҡ, config's TNum path, matcher's TNum/TInt eq-split) is unaffected.
pub fn parse_float(s : String) -> Double? {
  match parse_number(s) {
    Some(d) => Some(d)
    None => scan_inf(s)
  }
}

// в”Җв”Җ int еҖӨз©әй–“еҲӨе®ҡ + int_round (DR-075) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

///|
fn repeat_zero(k : Int) -> String {
  let buf = StringBuilder::new()
  let mut j = 0
  while j < k {
    buf.write_char('0')
    j = j + 1
  }
  buf.to_string()
}

///|
fn all_zero(s : String) -> Bool {
  for c in s {
    if c != '0' {
      return false
    }
  }
  true
}

///|
fn has_nonzero(s : String, from : Int) -> Bool {
  let cs = chars_of(s)
  let mut i = from
  while i < cs.length() {
    if cs[i] != '0' {
      return true
    }
    i = i + 1
  }
  false
}

///|
/// Fold the exponent into the digitеҲ—, yielding the plain `(integer_part_digits, frac_part_digits)`
/// with the decimal point materialized (no exponent left). e.g. int="1" frac="" exp=3 вҶ’ ("1000","");
/// int="2" frac="5" exp=0 вҶ’ ("2","5"); int="" frac="5" exp=0 вҶ’ ("","5"). This is decimal жЎҒгӮ·гғ•гғҲ,
/// done purely on digit strings so no binary64 rounding enters the integer/tie decision (DR-075 В§5).
fn apply_exponent(
  int_d : String,
  frac_d : String,
  exp : Int,
) -> (String, String) {
  let combined = int_d + frac_d
  let point = int_d.length() + exp
  if point <= 0 {
    ("", repeat_zero(-point) + combined)
  } else if point >= combined.length() {
    (combined + repeat_zero(point - combined.length()), "")
  } else {
    (combined[0:point].to_owned(), combined[point:].to_owned())
  }
}

// в”Җв”Җ Int64 range check (DR-075 В§1-В§2, issue 2026-07-07-parse-int-value-huge-exponent-overflow) в”Җв”Җ

///|
/// Int64's two boundary magnitudes as canonical decimal digit strings, each exactly 19 digits: the
/// positive max `9223372036854775807`, and the negative min's ABSOLUTE magnitude `9223372036854775808`
/// (one more вҖ” two's-complement asymmetry). `digits_to_i64` cannot even REPRESENT
/// +9223372036854775808 as an intermediate positive value, so the min boundary needs its own
/// literal (`signed_magnitude_of` below), never "negate a would-be-overflowing positive".
let int64_max_mag : String = "9223372036854775807"

///|
let int64_min_mag : String = "9223372036854775808"

///|
fn count_leading_zeros(s : String) -> Int {
  let cs = chars_of(s)
  let n = cs.length()
  let mut i = 0
  while i < n && cs[i] == '0' {
    i = i + 1
  }
  i
}

///|
/// Lexicographic magnitude comparison for two EQUAL-LENGTH all-digit strings вҖ” valid without
/// numeric conversion because both operands have the same length (no leading-zero ambiguity):
/// `true` iff `a`'s magnitude is strictly greater than `b`'s.
fn digits_gt(a : String, b : String) -> Bool {
  let ca = chars_of(a)
  let cb = chars_of(b)
  let mut i = 0
  while i < ca.length() {
    if ca[i] != cb[i] {
      return ca[i] > cb[i]
    }
    i = i + 1
  }
  false
}

///|
/// The significant (leading-zeros-stripped) digit count the int-typed magnitude `int_d`/`frac_d`/
/// `exp` WOULD have after `apply_exponent`'s exponent shift вҖ” computed WITHOUT materializing that
/// shift, so a huge `exp` (`"1e300"`) never builds a giant digit string just to discover it
/// overflows. `int_d`/`frac_d` are never huge themselves (bounded by the literal input length вҖ”
/// only the exponent-driven zero-padding explodes), so this is O(len(int_d)+len(frac_d)) regardless
/// of `exp`'s magnitude. The caller rejects outright when this exceeds 19 (Int64's max digit count);
/// at exactly 19 it must still compare against the exact boundary (a value could be `1e18` = 19
/// digits `1000000000000000000`, well within range, or `1e19` = 20 digits, always out of range).
fn int_part_significant_len(int_d : String, frac_d : String, exp : Int) -> Int {
  let combined = int_d + frac_d
  let point = int_d.length() + exp
  if point <= 0 || all_zero(combined) {
    0
  } else {
    let lead = count_leading_zeros(combined)
    let capped_lead = if lead < point { lead } else { point }
    point - capped_lead
  }
}

///|
/// Convert an already-materialized `ipart` (the caller has verified, via
/// `int_part_significant_len`, that its significant digit count is <= 19 вҖ” so `ipart` itself is
/// bounded/small regardless of how huge the ORIGINAL exponent was) to its FINAL SIGNED Int64 value,
/// or `None` if the magnitude exceeds Int64's per-sign range. `neg` selects the boundary: a
/// positive value's magnitude tops out at `int64_max_mag`, a negative value's at the one-larger
/// `int64_min_mag` вҖ” and the `-9223372036854775808` case is returned directly as a literal, since
/// `digits_to_i64` cannot even represent its magnitude as an intermediate positive value to negate.
fn signed_magnitude_of(ipart : String, neg : Bool) -> Int64? {
  let lead = count_leading_zeros(ipart)
  let sig_len = ipart.length() - lead
  if sig_len < 19 {
    let m = digits_to_i64(ipart)
    return Some(if neg { -m } else { m })
  }
  // sig_len == 19 here (the caller already rejected > 19 before ipart was even materialized).
  let sig = ipart[lead:].to_owned()
  let boundary = if neg { int64_min_mag } else { int64_max_mag }
  if digits_gt(sig, boundary) {
    None
  } else if neg && sig == int64_min_mag {
    Some(-9223372036854775808L)
  } else {
    let m = digits_to_i64(ipart)
    Some(if neg { -m } else { m })
  }
}

///|
/// Convert `ipart` to its UNSIGNED (always non-negative) magnitude, checked ONLY against the
/// positive boundary `int64_max_mag` regardless of the value's actual sign вҖ” this is what
/// `round_magnitude` needs (DR-075 В§2: it applies `+1`/the sign itself on this unsigned magnitude).
/// A truncated magnitude that sits exactly at Int64::min's boundary (9223372036854775808) can't be
/// represented unsigned at all, so it is (narrowly, conservatively) reported out-of-range here too
/// вҖ” an accepted residual gap: that exact magnitude, ALSO genuinely fractional, under a non-error
/// rounding mode is astronomically rare and outside this issue's test matrix.
fn unsigned_magnitude_of(ipart : String) -> Int64? {
  let lead = count_leading_zeros(ipart)
  let sig_len = ipart.length() - lead
  if sig_len < 19 {
    return Some(digits_to_i64(ipart))
  }
  let sig = ipart[lead:].to_owned()
  if digits_gt(sig, int64_max_mag) {
    None
  } else {
    Some(digits_to_i64(ipart))
  }
}

///|
/// Round a non-negative magnitude `m` (the integerйғЁ) given the first fractional digit `d0` and
/// whether any later fractional digit is non-zero, plus the sign and the mode (DR-075 В§2 table).
/// The tie/half classification is lexical (d0<5 / d0=5&rest=0 / else) вҖ” no binary64 involved.
fn round_magnitude(
  m : Int64,
  d0 : Int,
  rest_nonzero : Bool,
  neg : Bool,
  mode : RoundMode,
) -> Int64 {
  let gt_half = d0 > 5 || (d0 == 5 && rest_nonzero)
  let is_tie = d0 == 5 && !rest_nonzero
  let up = m + 1L
  match mode {
    RFloor => if neg { up } else { m } // вҶ’вҲ’вҲһ
    RCeil => if neg { m } else { up } // вҶ’+вҲһ
    RTrunc => m // вҶ’0 (drop fraction)
    RAway => up // вҶ’0 гҒ®еҸҚеҜҫ (abs еҲҮгӮҠдёҠгҒ’)
    RHalfFloor =>
      if is_tie {
        if neg {
          up
        } else {
          m
        }
      } else if gt_half {
        up
      } else {
        m
      }
    RHalfCeil =>
      if is_tie {
        if neg {
          m
        } else {
          up
        }
      } else if gt_half {
        up
      } else {
        m
      }
    RHalfTrunc => if is_tie { m } else if gt_half { up } else { m }
    RHalfAway => if is_tie { up } else if gt_half { up } else { m }
    RHalfEven =>
      if is_tie {
        if m % 2L == 0L {
          m
        } else {
          up
        }
      } else if gt_half {
        up
      } else {
        m
      }
    RError => m // caller handles RError before reaching here
  }
}

///|
/// Decode a canonical `int_round` config string (DR-061 В§4 е№іеқҰ config гӮӯгғјгҖҒDR-075 В§2 гҒ® 10 зЁ®иӘһеҪҷ)
/// to its `RoundMode`. Returns None on an unknown token (typo / non-canonical vocab) вҖ” the caller
/// surfaces this as a `DecodeSkip` or a factory-config Error (DR-061 В§4: config еҖӨгҒ®жӨңиЁјгҒҜ factory
/// иІ¬еӢҷ). The 10 tokens are byte-identical to DR-075's naming (no HALF_UP/HALF_DOWN aliases).
pub fn round_mode_of(s : String) -> RoundMode? {
  match s {
    "error" => Some(RError)
    "floor" => Some(RFloor)
    "ceil" => Some(RCeil)
    "trunc" => Some(RTrunc)
    "away" => Some(RAway)
    "half_floor" => Some(RHalfFloor)
    "half_ceil" => Some(RHalfCeil)
    "half_trunc" => Some(RHalfTrunc)
    "half_away" => Some(RHalfAway)
    "half_even" => Some(RHalfEven)
    _ => None
  }
}

///|
/// Parse a String token as an `int` element per DR-075: еҖӨз©әй–“еҲӨе®ҡ. Parse the token as a canonical
/// number, then judge its VALUE. An integer value (`"3.0"`вҶ’3 / `"1e3"`вҶ’1000 / `"1_000"`вҶ’1000) is
/// accepted directly under every mode. A truly-fractional value follows `mode`: `RError` (canonical
/// default) вҶ’ `NotAnInteger`; any rounding mode вҶ’ the rounded Int64. A non-number token вҶ’ `NotANumber`.
/// Theж•ҙж•°жҖ§ and tie decisions are lexical (binary64-йқһзөҢз”ұ, DR-075 В§5).
pub fn parse_int_value(
  s : String,
  mode : RoundMode,
) -> Result[Int64, ParseFail] {
  match scan_number_parts(s) {
    None => Err(NotANumber)
    Some((neg, int_d, frac_d, exp)) => {
      // Range guard BEFORE materializing apply_exponent's zero-padding (issue
      // 2026-07-07-parse-int-value-huge-exponent-overflow): reject up front when the significant
      // digit count already exceeds Int64's 19-digit max, so a huge `exp` (`"1e300"`) never builds
      // the giant digit string just to discover it overflows.
      if int_part_significant_len(int_d, frac_d, exp) > 19 {
        return Err(IntOutOfRange)
      }
      let (ipart, fpart) = apply_exponent(int_d, frac_d, exp)
      if all_zero(fpart) {
        // integer value вҖ” accepted under every mode, no rounding
        match signed_magnitude_of(ipart, neg) {
          None => Err(IntOutOfRange)
          Some(m) => Ok(m)
        }
      } else {
        match mode {
          RError => Err(NotAnInteger)
          _ =>
            // round_magnitude needs an UNSIGNED magnitude (it applies +1 / the sign itself, DR-075
            // В§2), so the pre-rounding range check always uses the POSITIVE boundary regardless of
            // `neg` вҖ” see `unsigned_magnitude_of`'s doc for the narrow residual gap this implies.
            match unsigned_magnitude_of(ipart) {
              None => Err(IntOutOfRange)
              Some(m) => {
                let d0 = fpart[0].to_int() - 48
                let rest_nonzero = has_nonzero(fpart, 1)
                let mag = round_magnitude(m, d0, rest_nonzero, neg, mode)
                if mag < 0L {
                  // `m + 1` silently wrapped past Int64::max (m was already at the exact boundary
                  // and rounding pushed it over) вҖ” surface as out-of-range, not a wrapped sign.
                  Err(IntOutOfRange)
                } else {
                  Ok(if neg { -mag } else { mag })
                }
              }
            }
        }
      }
    }
  }
}

// в”Җв”Җ bool canonical еӯ—еҸҘ (DR-074 В§3) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

///|
fn eq_ci(s : String, target : String) -> Bool {
  let a = chars_of(s)
  let b = chars_of(target)
  if a.length() != b.length() {
    return false
  }
  for i in 0..<a.length() {
    if lower_code(a[i]) != lower_code(b[i]) {
      return false
    }
  }
  true
}

///|
fn lower_code(c : Char) -> Int {
  let x = c.to_int()
  if x >= 65 && x <= 90 {
    x + 32 // ASCII 'A'-'Z' вҶ’ 'a'-'z'
  } else {
    x
  }
}

///|
/// Parse a String token as a bool (DR-074 В§3 canonical): `true_values = ["true","1"]`,
/// `false_values = ["false","0",""]`, `case_insensitive = true`. An unrecognized token is None
/// (вҶ’ Error at the call site вҖ” no silent boolеҢ–, DR-021 е§ҝеӢў). The empty string is false (env's
/// `FLAG=` pattern); `yes`/`no`/`on`/`off` are canonical-еӨ– (Norway problem еӣһйҒҝ). Every call site
/// that has no `bool_parser` factory config to consult (config_to_value/env_value's canonical-only
/// arms) keeps calling this вҖ” it is `parse_bool_ext` specialized to `bool_config_canonical()`.
pub fn parse_bool(s : String) -> Bool? {
  parse_bool_ext(s, bool_config_canonical())
}

///|
/// Convert one leaf config value to the element's expected type (DR-050 В§4). Leniency is
/// BIDIRECTIONALLY SYMMETRIC (DR-040 canonical): a string parses into any type (`"8080"` вҶ’ number),
/// AND a JSON scalar stringifies into a string element (`1.5` вҶ’ "1.5", `true` вҶ’ "true"). The int
/// path is еҖӨз©әй–“еҲӨе®ҡ with canonical `int_round: error` (DR-075): `"3.0"` вҶ’ 3, `"2.5"` вҶ’ Error. Bool
/// is the canonical vocab (DR-074 В§3). Only the ж„Ҹе‘ігҒ®йЈӣиәҚ (bool вҶ” number) and ж§ӢйҖ дёҚдёҖиҮҙ
/// (array/object вҶ’ scalar) are DR-037 Errors.
///
/// `piece_filters` (DR-050 В§4 "string вҶ’ CLI/env гҒЁе®Ңе…ЁгҒ«еҗҢдёҖгҒ®е…Ёж®ө pipeline"гҖҒissue
/// 2026-07-09-config-string-pieceprocessor-gap): applied ONCE, up front, ONLY when the JSON source
/// is a string (`CStr`) вҖ” a non-string source matching its type (`CNum`/`CBool`) has no
/// StringвҶ’String step to gate, per В§4's "еһӢдёҖиҮҙгҒӘгӮү piece_filters/parse гҒҜгӮ№гӮӯгғғгғ—" (the type's own
/// consequence, not a special case here; mirrors `resolve.mbt`'s `env_value`, whose source is
/// ALWAYS a string so it always runs piece_filters вҖ” config's source varies, so this runs it exactly
/// when config's source happens to be a string). Every `(CStr(s), _)` arm below sees the
/// ALREADY-filtered string.
///
/// Error shape `(ErrKind, reason, message)`: `KFilter` for a piece_filters rejection (mirrors
/// `resolve.mbt`'s `filter_err`), `KParse` for every type-mismatch/parse-failure arm (mirrors
/// `ladder_err`) вҖ” the caller picks the matching `ParseError` constructor by this tag. `message`
/// is caller-facing text only (conformance ignores it, per this file's `ParseError` doc comment).
pub fn config_to_value(
  cv : ConfigVal,
  ty : Ty,
  piece_filters : Array[FilterSpelling],
) -> Result[Value, (ErrKind, String, String)] {
  let cv = match cv {
    CStr(raw) =>
      match apply_piece_filters(piece_filters, raw) {
        Ok(s) => CStr(s)
        Err((reason, msg)) => return Err((KFilter, reason, msg))
      }
    other => other
  }
  match (cv, ty) {
    // string element: accept anything вҖ” string / lenient parse / JSON stringification
    (CStr(s), TStr) => Ok(VStr(s))
    (CNum(d), TStr) => Ok(VStr(num_to_string(d))) // 1.5 вҶ’ "1.5" (еҜӣе®№гҒ®еҸҢж–№еҗ‘еҜҫз§°)
    (CBool(b), TStr) => Ok(VStr(if b { "true" } else { "false" })) // true вҶ’ "true"
    // string вҶ’ number: lenient canonical parse (DR-074). `TCount` folded in defensively (DR-077
    // В§3: count's config seat sets a plain number, never increments вҖ” `Entity.ty` is already
    // collapsed to TNum for every real count cell by `ensure_entity`, so this arm never actually
    // sees TCount in practice).
    (CStr(s), TNum) | (CStr(s), TCount) =>
      match parse_number(s) {
        Some(d) => Ok(VNum(d))
        None =>
          Err((KParse, "not_a_number", "config value \"\{s}\" is not a number"))
      }
    // string вҶ’ float: wider acceptеҹҹ (number + inf, DR-074 В§1) via parse_float
    (CStr(s), TFloat) =>
      match parse_float(s) {
        Some(d) => Ok(VNum(d))
        None =>
          Err((KParse, "not_a_number", "config value \"\{s}\" is not a number"))
      }
    // string вҶ’ int: еҖӨз©әй–“еҲӨе®ҡ, canonical int_round = error (DR-075 В§1-В§2)
    (CStr(s), TInt) =>
      match parse_int_value(s, RError) {
        Ok(i) => Ok(VNum(i.to_double()))
        Err(NotAnInteger) =>
          Err(
            (
              KParse,
              "not_an_integer",
              "config value \"\{s}\" is not an integer",
            ),
          )
        Err(IntOutOfRange) =>
          Err(
            (
              KParse,
              "int_out_of_range",
              "config value \"\{s}\" is out of Int64 range",
            ),
          )
        Err(NotANumber) =>
          Err((KParse, "not_a_number", "config value \"\{s}\" is not a number"))
      }
    // string вҶ’ bool: canonical vocab (DR-074 В§3), unrecognized вҶ’ Error (no silent еӨүжҸӣ). Applies
    // identically to a presence-only flag (TFlag) and a value-typed bool (TBool) вҖ” config's string
    // seat doesn't distinguish the CLI-side eq-split capability (installer.mbt), only the value type.
    (CStr(s), TFlag) | (CStr(s), TBool) =>
      match parse_bool(s) {
        Some(b) => Ok(VBool(b))
        None =>
          Err((KParse, "not_a_bool", "config value \"\{s}\" is not a bool"))
      }
    // typed number matching a number element (any) / a float element (a JSON-native number is
    // already a valid float value вҖ” inf has no JSON literal, so this arm never carries it) / an
    // int element (integer only)
    (CNum(d), TNum) | (CNum(d), TFloat) | (CNum(d), TCount) => Ok(VNum(d))
    // native number вҶ’ int: JSON з”ұжқҘ binary64 зөҢз”ұеҲӨе®ҡ (DR-075 В§5 гҒ®йқһеҜҫз§°)
    (CNum(d), TInt) =>
      if is_integer(d) {
        Ok(VNum(d))
      } else {
        Err(
          (
            KParse,
            "not_an_integer",
            "config value \"\{num_to_string(d)}\" is not an integer",
          ),
        )
      }
    (CBool(b), TFlag) | (CBool(b), TBool) => Ok(VBool(b))
    // ж„Ҹе‘ігҒ®йЈӣиәҚ (bool вҶ” number) гҒҜ Error вҖ” no coercion
    (CNum(_), TFlag) | (CNum(_), TBool) =>
      Err(
        (
          KParse,
          "config_type_mismatch",
          "config number for a bool element (no numberвҶ”bool coercion)",
        ),
      )
    (CBool(_), TNum) | (CBool(_), TFloat) | (CBool(_), TCount) =>
      Err(
        (
          KParse,
          "config_type_mismatch",
          "config bool for a number element (no numberвҶ”bool coercion)",
        ),
      )
    // DR-089: none has no value space at all, so a config seat is a structural mismatch regardless
    // of the JSON scalar kind supplied (same family as the CArr/CObj structural-mismatch arms
    // below, just against a scalarless element instead of a non-scalar JSON value).
    (CStr(_), TNone) | (CNum(_), TNone) | (CBool(_), TNone) =>
      Err(
        (
          KParse,
          "config_type_mismatch",
          "config value for a none element (no value space)",
        ),
      )
    (CBool(_), TInt) =>
      Err(
        (
          KParse,
          "config_type_mismatch",
          "config bool for an int element (no numberвҶ”bool coercion)",
        ),
      )
    // ж§ӢйҖ дёҚдёҖиҮҙ (array / object вҶ’ scalar element) гҒҜ Error
    (CArr(_), _) =>
      Err(
        (
          KParse,
          "config_structural_mismatch",
          "config array for a scalar element (structural mismatch)",
        ),
      )
    (CObj(_), _) =>
      Err(
        (
          KParse,
          "config_structural_mismatch",
          "config object for a scalar element (structural mismatch)",
        ),
      )
    // null is дҫӣзөҰгҒӘгҒ— (handled before this by resolve; defensive arm for exhaustiveness, DR-050 В§4)
    (CNull, _) =>
      Err(
        (
          KParse,
          "config_type_mismatch",
          "config null is дҫӣзөҰгҒӘгҒ— (should be handled as no-supply, not converted)",
        ),
      )
  }
}

///|
/// DR-083 В§2: a declared default's stored piece is already a `Value` (decoded straight off the
/// JSON literal, `VStr`/`VNum`/`VBool` вҖ” never `VStr` coerced to the element's `Ty` at decode time,
/// mirroring how a config array's piece is stored as an untyped `ConfigVal` until READ). This is
/// the bridge that lets `resolve_ladder_below_cli`'s default seat reuse `config_to_value` VERBATIM
/// (DR-083 В§2 "config array гҒЁеҗҢеһӢгҒ«жүұгҒҶ") instead of re-deriving the same string/number/bool
/// leniency table a second time вҖ” `Value`'s 3 variants map 1:1 onto `ConfigVal`'s 3 scalar ones.
pub fn value_to_configval(v : Value) -> ConfigVal {
  match v {
    VStr(s) => CStr(s)
    VNum(d) => CNum(d)
    VBool(b) => CBool(b)
  }
}

///|
/// The effect an entry's firing applies to a value cell (DR-045). It is PURE DATA
/// `{op, operand?}`: the op names the operation, the operand is the Binding's `value`.
/// A normal value bind (a value slot consuming a token and writing it) is the SET
/// degenerate form, so every effect-column element is uniform (entity, op, operand,
/// source, order). `default`/`unset`/`empty` carry NO operand (the Binding's value is a
/// placeholder). The four ops correspond 1:1 to DR-011's variant effect vocabulary.
pub(all) enum EffectOp {
  Set // write the operand; committed (the degenerate form of a plain value bind)
  Default // reset to the default value; committed (the user explicitly wants default)
  Unset // reset to the default; NOT committed вҖ” later ladder seats (env/config/inherit) may override
  Empty // clear a collection (array / map) to empty; committed
  // DR-077 В§1 (5th op): apply an old-dependent transform to the linked cell вҖ” `cell = f(old)`. No
  // operand (the Binding's value is a placeholder, same as default/unset/empty) вҖ” the RESULT
  // depends on the cell's running value at fire time, which resolve.mbt's CLI-seat fold computes,
  // not something the parser can precompute at consume time. `String` is the transform's filters-
  // registry name (DR-077 В§2, e.g. "increment"); `Array[String]` are that transform's own args (the
  // registry name is arity-1 of the colon DSL, remaining segments are its args вҖ” same nesting
  // convention filters already use). committed = true (a user-explicit CLI op, like set).
  Update(String, Array[String])
  // DR-080 В§2 (merge accumulator piece marker vocabulary): a `remove`/`splice` PIECE within one
  // CLI firing's separator-split value list, distinct in kind from the 5 CELL-level ops above (a
  // merge-accumulator cell's own effect is still `Set` вҖ” these two only ever appear on the
  // per-piece Bindings `resolve_entity_raw`'s accum fold groups by `at_pos`, DR-080 жіўеҸҠзҜҖ "1
  // зҷәзҒ« = еҗҢдёҖ argv дҪҚзҪ®гҒ® piece еҲ—"). `Remove`'s operand (the Binding's `value`) is type-parsed
  // like any add piece (DR-080 В§2 "operand гҒҜиҰҒзҙ  type гҒ§ parse гҒ•гӮҢгӮӢ"); `Splice` (`@`) carries
  // no operand (the Binding's value is a placeholder, same convention as default/unset/empty).
  // committed = true for both (mirrors `Update`) вҖ” `resolve_entity_raw`'s accum branch (which
  // interprets the piece sequence) owns whether the OVERALL fire commits, not this per-piece tag
  // (the DR-045 `committed` helper below never sees these вҖ” they never reach the scalar branch,
  // only the accum one, which computes committed_now from its own marker-presence check).
  Remove
  Splice
} derive(Eq, Debug)

///|
/// committed is DERIVED from the op, never a separate field (DR-045 В§2: selected and
/// committed are independent, and the effect explicitly controls committed). Only `unset`
/// is un-committed, which is exactly what opens the later value-source ladder seats.
pub fn committed(op : EffectOp) -> Bool {
  match op {
    Unset => false
    _ => true
  }
}

///|
/// One EFFECT written onto a result path: `key`'s cell gets operation `op` with operand
/// `value`, from `source` (DR-045). `key` is the leaf name; same-key bindings from
/// different entries (e.g. `--port` satellite and `-p` matcher) merge onto one cell =
/// link еҗҲжөҒ. `scope` is the result nesting path (DR-025): a binding produced inside a
/// command / name scope carries that scope's labels, outermost first.
///
/// Path-counting (DR-038) treats the whole binding as identity, so op/operand are part of
/// the effect-sequence key (DR-045 В§1 зІҫеҜҶеҢ–): the same cell reset by `unset` vs written by
/// `set` are DIFFERENT effects even at the same position. A value in `serve` differs from
/// the same leaf at root (scope is in the key too).
pub(all) struct Binding {
  key : String
  op : EffectOp // the operation on the cell (DR-045); Set for a plain value bind
  value : Value // the operand (a placeholder for default/unset/empty, which carry none)
  source : Source
  scope : Array[String]
  link : Int // a link/global-copy binding (DR-042/007): the number of result-nesting levels it
  //           still ESCAPES before settling at its declaring scope. 0 = a normal binding (every
  //           CmdSat/Scoped level prepends its label). N>0 = a global copied N scopes BELOW its
  //           declaration; the next N nest levels skip prepending (decrementing), then it nests
  //           normally вҖ” so an intermediate-scope global (DR-042 shadow) lands at its declaring
  //           scope, not the absolute root. A root global (declared at depth 0) has N = its firing
  //           depth, which escapes all the way to the root (the original bool-`link` behaviour).
  // DR-034/DR-062 piece_filters + issue 2026-07-09-accum-entity-filters-wiring: the argv token
  // position this binding's VALUE was read from, when it has one. `Some(pos)` for a CLI-seat
  // binding built at token-consumption time (eval.mbt/matcher.mbt's `mkb` call sites вҖ” a separator
  // piece carries the position of the WHOLE token it split from, not a per-piece offset, since a
  // piece is not itself a token). `None` for every non-token-consumption source (env/config/
  // inherit/default seats, resolve.mbt) вҖ” those values were never read off an argv token, so there
  // is no position to attribute a later value_filters(each) reject to (`apply_entity_filters`'s
  // `filter_err` falls back to the ladder's own `at_pos`, unchanged behavior, when this is `None`).
  at_pos : Int?
} derive(Eq, Debug)

// в”Җв”Җ Binding/ParseError helpers the matcher builds (Branch itself lives in node.mbt) в”Җв”Җ

///|
/// A plain value bind = the SET degenerate form of an effect (DR-045 В§1). `at_pos` (issue
/// 2026-07-09-accum-entity-filters-wiring): the CLI-seat call sites (eval.mbt/matcher.mbt) pass
/// `Some(pos)` вҖ” the token this binding's value was read from; every other caller (resolve.mbt's
/// env/config/inherit/default seats) omits it, defaulting to `None`.
fn mkb(
  key : String,
  value : Value,
  source : Source,
  at_pos? : Int? = None,
) -> Binding {
  { key, op: Set, value, source, scope: [], link: 0, at_pos }
}

///|
/// Concatenate two binding arrays (accumulate readings along a path).
fn cat(a : Array[Binding], b : Array[Binding]) -> Array[Binding] {
  let r : Array[Binding] = []
  for x in a {
    r.push(x)
  }
  for x in b {
    r.push(x)
  }
  r
}

///|
/// A `kind: parse` held Error for a value that failed to parse as a number (DR-053 В§2). The reason is
/// `not_a_number` (DR-066 В§3): a token that does not read as a number at all вҖ” an int element also
/// lands here for a non-number token (int judges via the number еӯ—еҸҘ), while `not_an_integer` is the
/// separate reason for a readable-but-fractional value under int_round=error.
fn pe_parse(element : String, tok : String, pos : Int) -> ParseError {
  {
    element,
    argv_pos: pos,
    kind: KParse,
    reason: "not_a_number",
    message: "\"\{tok}\" is not a number",
    path: [], // DR-066 В§4: prepended by scope boundaries on the way out (nest_branches / CmdSat)
  }
}

///|
/// A `kind: parse` held Error for a value that read as a number but is not an integer value under
/// canonical `int_round: error` (DR-075 В§2 / DR-066 В§3). The reason `not_an_integer` is emitted ONLY
/// when `int_round=error` (any rounding mode rounds to Ok and never raises this); a token that does
/// not read as a number at all lands in `pe_parse` with reason `not_a_number`.
fn pe_parse_int(element : String, tok : String, pos : Int) -> ParseError {
  {
    element,
    argv_pos: pos,
    kind: KParse,
    reason: "not_an_integer",
    message: "\"\{tok}\" is not an integer",
    path: [],
  }
}

///|
/// A `kind: parse` held Error for a readable integer VALUE whose magnitude exceeds Int64's range
/// (issue 2026-07-07-parse-int-value-huge-exponent-overflow). The provisional reason
/// `int_out_of_range` follows the `pe_parse_bool`/`not_a_bool` precedent (DR-066 v1 has no reason
/// for this yet).
fn pe_int_out_of_range(element : String, tok : String, pos : Int) -> ParseError {
  {
    element,
    argv_pos: pos,
    kind: KParse,
    reason: "int_out_of_range",
    message: "\"\{tok}\" is out of Int64 range",
    path: [],
  }
}

///|
/// A `kind: parse` held Error for a value that failed to parse as a bool (DR-074 В§3 canonical vocab:
/// unrecognized tokens like `yes`/`on` are canonical-еӨ–, Error not silent еӨүжҸӣ). DR-066 v1's reason
/// vocab only lists `not_a_number`/`not_an_integer` (bool has no entry yet); this reason is the
/// provisional `not_a_bool` used by resolve.mbt's config-path bool Error (В§952 of resolve.mbt),
/// kept until DR-066 v1 vocab is amended (docs/issue/2026-07-07-bool-invalid-reason-vocab-gap.md).
fn pe_parse_bool(element : String, tok : String, pos : Int) -> ParseError {
  {
    element,
    argv_pos: pos,
    kind: KParse,
    reason: "not_a_bool",
    message: "\"\{tok}\" is not a bool",
    path: [],
  }
}

///|
/// A `kind: parse` held Error for a `kv_map` accumulator piece with no `=` (DR-091 В§2, team-lead
/// иЈҒе®ҡ 2026-07-11: "= гҒӘгҒ— piece гҒҜ rejectгҖҒеһӢ parse еӨұж•—гҒЁеҗҢгҒҳжүұгҒ„" вҖ” same `KParse` kind /
/// error-vocab family as `pe_parse`/`pe_parse_bool`, this is kv_map's own structural-shape check).
fn pe_parse_kv(element : String, tok : String, pos : Int) -> ParseError {
  {
    element,
    argv_pos: pos,
    kind: KParse,
    reason: "not_a_kv_pair",
    message: "\"\{tok}\" does not contain '=' (expected key=value)",
    path: [],
  }
}

///|
/// A `kind: filter` held Error for a piece_filters chain that rejected a raw token/piece before it
/// ever reached its type parser (DR-034/DR-062, DR-037's Reject/Error distinction вҖ” see
/// `apply_piece_filters`'s doc comment for why a filter chain's `Err` always becomes a `Held`, never
/// a silent `[]`: the Or/path-search machinery already discards a `Held` branch whenever a sibling
/// branch `Accept`s, so a single `Held(kind: KFilter, ...)` return realizes BOTH DR-037 outcomes вҖ”
/// no separate silent-Reject channel is needed). Token-consumption callers (eval.mbt's value-
/// primitive arms, matcher.mbt's `run_eq_split`) pass `reason`/`message` straight from
/// `apply_piece_filters`'s `Err` tuple. Mirrors `resolve.mbt`'s `filter_err` (the ladder-layer
/// counterpart, used by `env_value`) вҖ” kept as a separate builder here because eval.mbt/value.mbt
/// sit below resolve.mbt in the dependency graph (MDR-002 В§3) and cannot call it.
fn pe_filter(
  element : String,
  pos : Int,
  reason : String,
  message : String,
) -> ParseError {
  { element, argv_pos: pos, kind: KFilter, reason, message, path: [] }
}

///|
/// A deprecation marker binding (DR-058): key `@depr:<element>`, recording that a deprecated entry
/// (DR-057 alias) was used to reach the canonical cell. Rides in the effect column like any binding;
/// the result builder skips it (bookkeeping, not a value), and `warnings_of` collects it.
fn depr_marker(element : String) -> Binding {
  {
    key: "@depr:" + element,
    op: Set,
    value: VBool(false),
    source: Cli,
    scope: [],
    link: 0,
    at_pos: None,
  }
}
