// node.mbt вАФ the AtomicAST node ADT and its two-face scope.
//
// DR-039: AtomicAST = a declarative serialization of the bottom-up engine's node
// graph. The core grammar is atomic (exact / or / seq / primitive + multiple)
// plus name (result scope). DR-041 ¬І1: matchers add runtime reading capability
// WITHOUT adding schema вАФ so `NativeMatch` carries matcher DATA (not an opaque
// closure), keeping the whole AST comparable (`derive(Eq, Debug)`) for the
// order-independence permutation test (DR-042).
//
// MDR-002 ¬І3: this file is the dependency-free leaf (behaviour-free ADTs only).
// MDR-003: reserved-word collisions (`alias` / `export` / `inherit` еНШзЛђ) take a
// trailing underscore. Here only `Entity.inherit` collides вЖТ `inherit_`; compound
// spellings (`export_key`, `ExportKey`, `is_config_file`) are already safe.

///|
/// A definition-time (parse_definition) Error category (DR-054 ¬І1). All are "lowering гБМжІЛжИРгБІгБНгБ™гБД
/// / еЕ®еЕ•еКЫгБІе£КгВМгВЛ" вАФ Error, not warn. (warn е±§ = дЄАйГ®еЕ•еКЫгБІй©ЪгБНгБЖгВЛгБ†гБС, гБѓ lint гБЃйЦҐењГгБІ PoC е∞Дз®Ле§Ц.)
pub(all) enum DefErrKind {
  DVocabIntersection // two installers own the same vocab (DR-042вСҐ)
  DUnknownVocab // a special vocab owned by no installer in the chain (DR-042вС†)
  DInvalidRange // an invalid value range (repeat min > max, etc., DR-052 гБїгБЛ)
  DAbsentRef // a ref target resolvable nowhere (scope + definitions, DR-032)
  DCircularRef // a ref cycle with infinite structural expansion (DR-007/032)
  DZeroProgress // a repeat unfold whose 1 iteration consumes no token (DR-043)
  DConfigCycle // a config_file element taking its own path from config (DR-050 ¬І5)
  // a single argument value itself is outside a registry device's acceptance range (DR-054 ¬І4
  // жЫіжЦ∞2 / DR-082 ¬І3, DR-085 ¬І1 и®Вж≠£) вАФ e.g. regex_match's pattern failing to compile. Distinct
  // from DInvalidRange (a COMBINATION of attributes is out of range, e.g. repeat min > max):
  // DInvalidArgument is about a single value's own internal validity.
  DInvalidArgument
} derive(Eq, Debug)

///|
/// One definition-time Error (DR-054 ¬І4): {element, kind, message, hint}. `hint` is theгАМжђ°гБЃжЙЛгАН
/// (DR-042 еЃМеЕ®жАІж§ЬжЯїгБЃжІШеЉП). parse_definition enumerates ALL of these (no first-error жЙУгБ°еИЗгВК).
pub(all) struct DefError {
  element : String
  kind : DefErrKind
  message : String
  hint : String
} derive(Eq, Debug)

///|
/// The result-key axis of an element (DR-052). `export_key: string | null` unified: unspecified =
/// name-derived key, a string = key-name override, null (or "" вАФ normalized to null) = NO result
/// key = nameless-еРМеМЦ йАПйБО (the value still propagates; only the key is gone). This is a RESULT
/// concern only вАФ lexical scope (name, DR-033) and id (ref/link, DR-046) are orthogonal, unchanged.
pub(all) enum ExportKey {
  EkUnset // unspecified вЖТ the name is the key (DR-046 default supply)
  EkKey(String) // a string override вЖТ that key name
  EkNull // null / "" вЖТ зµРжЮЬгВ≠гГЉиїЄгБ™гБЧ вЖТ йАПйБО (kv: value gone; seq: value stays as an array element)
} derive(Eq, Debug)

///|
/// Type category of a value cell / primitive. `number` (TNum) accepts integers and floats but
/// rejects inf/nan (DR-074 ¬І1); `int` (TInt) is integer-constrained by еА§з©ЇйЦУеИ§еЃЪ вАФ a non-integer
/// VALUE follows `int_round` (DR-075, canonical default `error`). `float` (TFloat) shares TNum's
/// acceptеЯЯ PLUS inf (case-insensitive `inf`/`infinity`, sign-еРИжИРеПѓ) вАФ nan stays Error for both
/// (DR-074 ¬І1/¬І7). `TFlag` is a PRESENCE-only trigger (bare `--x` fires name=true, no value token
/// ever вАФ e.g. `--help`/`--verbose`). `TBool` is DR-074 ¬І3's value-typed canonical bool: the bare
/// trigger ALSO fires true (same degenerate as TFlag), but it additionally takes an eq-split value
/// (`--enabled=true`, parsed through the canonical bool vocab) UNLESS the element carries variant
/// spellings (`--x`/`--no-x`) вАФ a variant-bearing bool already has a dedicated true/false pair of
/// triggers, so no separate `=value` form is registered for it (installer.mbt `inst_long`).
pub(all) enum Ty {
  TStr
  TNum
  TInt
  TFloat
  TFlag
  TBool
  /// count з≥Ци°£гБЃ PRE-normalize marker (DR-077 ¬І3, LOWERING ¬ІA.5): mirrors `TFlag`'s standing to
  /// `TBool` вАФ a bare `--x` fire applies the `increment` update effect (0-token, no value ever,
  /// same presence-only shape as `TFlag`'s bare-true). `normalize_option` differentiates
  /// `long:true` sugar (`[":update:increment"]` vs bool's `[":set:true"]`) and default-presets
  /// (0 vs false) by this
  /// tag BEFORE collapsing it to `TNum` вАФ once lowered there is no other channel to tell a count
  /// cell apart from an ordinary number cell (installer.mbt `normalize_option`).
  TCount
  /// DR-089: еА§з©ЇйЦУгБМз©ЇгБЃеЮЛ вАФ type зЬБзХ•гБЃз≥Ци°£еЕИ (¬І2гАМtype зЬБзХ• = noneгАН)гАВtype гБМи¶ПеЃЪгБЩгВЛгБЃгБѓеА§
  /// з©ЇйЦУгБ†гБСгБІжґИи≤їгБѓжІЛйА† (repeat/еА§гВєгГ≠гГГгГИ/exact/filter гБЃ Accept е†±еСК) гБЃйЦҐењГгБ®гБДгБЖзЫідЇ§ (¬І1) гБЃ
  /// еЄ∞зµРгБ®гБЧгБ¶гАБnone гБѓгАМзЩЇзБЂгБЧгБ¶гВВеА§гВТйБЛгБ∞гБ™гБДгАНгБУгБ®гБ†гБСгВТжДПеС≥гБЧгАБжґИи≤їжХ∞гБЭгБЃгВВгБЃгБѓеИґзіДгБЧгБ™гБД вАФ
  /// жґИи≤ї 0 гБЃзіФгГИгГ™гВђ (long гБЃгБњ) гБЂгВВгАБrepeat+filter гБІгАМй£ЯгБ£гБ¶жН®гБ¶гВЛгАНжІЛйА†гБЂгВВдљњгБИгВЛгАВеА§еЕЕиґ≥гВТ
  /// и¶Бж±ВгБЩгВЛеЄ≠ (requires гБЃзЫЃзЪДи™Ю) гБЂгБѓзЂЛгБ¶гБ™гБД (йЭЩзЪД definition-errorгАБ¬І4)гАВзµРжЮЬгБЂгБѓзПЊгВМгБ™гБД
  /// (гГХгВ£гГЉгГЂгГЙйЭЮжО≤иЉЙгАБDR-051 ¬І1/¬І4) вАФ зЩЇзБЂгБЃи¶≥жЄђгБѓ ParserContext/explains е±§гБЃзЃ°жОМгБІгАБгБУгБЃеЮЛгБѓ
  /// йЦҐдЄОгБЧгБ™гБДгАВ
  TNone
} derive(Eq, Debug)

///|
/// One filter-chain DSL entry (DR-009 ¬ІDSL жЦЗж≥Х, `piece_filters`/`value_filters`/`cell_filters`):
/// name + args, structured вАФ either from the colon shorthand (`"in_range:1:65535"` decodes to
/// `{name:"in_range", args:["1","65535"]}`) or the DESIGN ¬І8.4 / DR-085 ¬І3 object form
/// (`{"name":"regex_match","args":["^https?://"]}`, needed when an arg itself contains a colon,
/// e.g. `regex_match`'s `^https?://` pattern). Both forms decode to the SAME `FilterSpelling` shape
/// (issue filter-spelling-inband-encoding-retyping) вАФ no in-band string encoding / magic-tag scheme
/// is needed since `args` carries the object form's values verbatim in a real `Array[String]` field
/// rather than a single joined string. Colon-splitting for the shorthand happens ONCE at the decode
/// boundary (`json_conformance_wbtest.mbt`'s `dec_filter_chain`); every downstream consumer
/// (filters.mbt/installer.mbt/eval.mbt/matcher.mbt/resolve.mbt/value.mbt) reads `name`/`args`
/// directly, never re-parses a spelling string.
pub(all) struct FilterSpelling {
  name : String
  args : Array[String]
} derive(Eq, Debug)

///|
/// A node of the AtomicAST. Consumption is measured in whole argv tokens.
pub(all) enum Node {
  /// literal token match; binds nothing, consumes 1.
  Exact(String)
  /// string value primitive: consume 1 token, bind name=VStr(token). Maximally permissive (DR-041 ¬І5).
  /// 2nd field is DR-034's piece_filters (StringвЖТString FilterChain, DR-062 дЇМељҐгБЃгБЖгБ° kuu.mbt гБМеЃЯи£Е
  /// гБЩгВЛ `FilterSpelling` йЕНеИЧгБЃгБњ вАФ filters.mbt гГШгГГгГАж≥®и®ШеПВзЕІ): applied to the raw token BEFORE
  /// this node's own (identity, for TStr) parse step. installer.mbt `value_prim` embeds it from
  /// `ElemDef.piece_filters` (same carrier pattern as `IntArg`'s `int_round` / `allow_base_prefix`);
  /// eval.mbt's consumption arms run it via `apply_piece_filters` immediately after reading
  /// `ctx.toks[pos]`, before the value ever reaches its type parser.
  StrArg(String, Array[FilterSpelling])
  /// separator-splitting value primitive (DR-034 separator pipeline): consume 1 token, split it
  /// on the separator char, and bind ONE `name=part` per split piece, EACH piece parsed through
  /// its own type (issue 2026-07-09-separator-non-string-type-parse-gap ¬ІжЃµ4 вАФ a piece's type is
  /// independent of whether it came via separator or not, DR-034 ¬І6.2's pieceProcessor). Fields:
  /// name, sep, ty (the element's declared type вАФ TStr is the historical identity-parse default),
  /// int_round (TInt only, mirrors `IntArg`'s carrier), allow_base_prefix (TNum/TInt), bool_config
  /// (TBool only, mirrors `BoolArg`'s carrier вАФ DR-074 ¬І4 `bool_parser` factory config), piece_filters
  /// (applied to EACH split piece вАФ not the whole raw token вАФ right before that piece's own parse
  /// step, DESIGN ¬І6.2: separator вЖТ piece_filters вЖТ parse вЖТ cell_filters, one piece at a time).
  /// `sep_binds` (eval.mbt) threads all of this through the split loop; a piece that fails its
  /// type parse is `kind: KParse` (same reason vocab as the scalar value primitives), NOT a
  /// piece_filters-style `KFilter` reject вАФ these are distinct pipeline stages (жЃµ3 vs жЃµ4).
  /// 2nd field is `String?`, not `String` (codex Medium ињљеЊУ, 2026-07-10): a merge-declared element
  /// with NO `separator` still needs piece semantics (DR-034 ¬І6.3's degenerate form вАФ no separator
  /// IS a 1-piece split, `sep_binds` treats `None` as `[tok]` rather than calling `split_on`). This
  /// is what lets `--fields -a` (no separator declared) recognize `-a` as a merge remove marker
  /// instead of silently degrading to a literal add вАФ without this, marker vocabulary was INERT for
  /// any merge element that omitted `separator` (issue: markers only worked when a comma actually
  /// split the token into вЙ•1 piece via the OLD mandatory-separator SepArg gate).
  /// 8th field (DR-080 ж≥ҐеПКзѓА): `merge` вАФ whether the declaring element's `multiple.accumulator`
  /// is `"merge"`. Threaded from `ElemDef.accumulator` via `installer.mbt`'s `value_prim` so
  /// `sep_binds` (eval.mbt) knows whether to run `classify_merge_piece` on each split piece
  /// (merge-declared elements only, DR-080 ¬І1) or treat every piece as a plain add (everyone else,
  /// unchanged pre-DR-080 behavior).
  SepArg(
    String,
    String?,
    Ty,
    RoundMode,
    Bool,
    BoolConfig,
    Array[FilterSpelling],
    Bool
  )
  /// DR-091 ¬І2: kv_map accumulator гБЃ consume-time gate вАФ consume 1 token, apply piece_filters,
  /// then require the (filtered) token to contain `=` (the structural precondition "piece `k=v`
  /// гВТжЬАеИЭгБЃ `=` гБІеИЖеЙ≤" needs). A token with no `=` is a Held Error (kind=KParse, same family as
  /// any other type-parse failure per team-lead и£БеЃЪ 2026-07-11 вАФ гАМpiece гБЃеЮЛ parse е§±жХЧгБ®еРМгБШ
  /// жЙ±гБДгАН) вАФ this node does NOT split at `=` itself (that's `resolve.mbt`'s `build_result` job,
  /// once every accepted binding is guaranteed to contain `=`); it only gates malformed pieces
  /// out at the same layer every other type mismatch surfaces at. Installer.mbt's `value_prim`
  /// emits this instead of `StrArg` when `ElemDef.accumulator == Some("kv_map")`.
  KvArg(String, Array[FilterSpelling])
  /// number value primitive (DR-074 ¬І1 canonical + ¬І2 opt-in `number_allow_base_prefix`)гАВconsume 1
  /// token, parse via `parse_number_ext(_, allow_base_prefix)`гАВallow=false гБѓ canonical (10 йА≤гБЃгБњгАБ
  /// base prefix Error)гАБallow=true гБІ `0xff` / `0x1.8p3` / `0o777` / `0b1010` гВВеПЧзРЖгБЩгВЛзµ±еРИ opt-inгАВ
  /// flag гБѓ installer гБМ ElemDef.allow_base_prefix гБЛгВЙеЯЛгВБиЊЉгВА (`number_parser` factory configгАБ
  /// DR-061 ¬І4)гАВparse-fail гБѓ `kind: parse` (DR-053)гАВ4th field is DR-034's piece_filters (same
  /// carrier pattern as `StrArg`'s 2nd field) вАФ applied to the raw token before `parse_number_ext`.
  NumArg(String, Bool, Array[FilterSpelling])
  /// float value primitive (DR-074 ¬І1/¬І7): consume 1 token, parsed through the WIDER float lexicon
  /// (canonical number + the 2-word inf/infinity vocab, case-insensitive, sign-еРИжИРеПѓ вАФ nan stays
  /// Error for both number and float). A separate node from `NumArg` because the accept-еЯЯ differs
  /// per TYPE (`number` rejects inf, `float` accepts it) and `Ty::TNum`/`Ty::TFloat` is the only
  /// place that distinction is known (installer.mbt `value_prim`); once lowered to a bare value node
  /// there is no other channel to carry it. Parse-fail is `kind: parse`, same reason vocab as NumArg.
  /// 2nd field is DR-034's piece_filters (same carrier pattern as `StrArg`).
  FloatArg(String, Array[FilterSpelling])
  /// int value primitive (DR-075 ¬І1 еА§з©ЇйЦУеИ§еЃЪ + ¬І2 int_round factory config). Consume 1 token, parse
  /// via `parse_int_value(_, mode)` where `mode` is the element's `int_round` (canonical default
  /// `RError`, opt-in via `int_parser` factory config, DR-061 ¬І4). RError: fractional гБѓ
  /// `not_an_integer`гАБгБЭгВМдї•е§Ц (RFloor/RCeil/RTrunc/RAway/RHalf{Floor,Ceil,Trunc,Away,Even}) гБІгБѓ
  /// fractional еА§гВТдЄЄгВБгБ¶ OkгАВжХіжХ∞еА§ (`"3.0"` / `"1e3"` / `"1_000"`) гБѓеЕ®гГҐгГЉгГЙгБІдЄЄгВБгБ™гБЧгАВзХ™еПЈгБ®гБЧгБ¶
  /// еЕ®гБПи™≠гВБгБ™гБД token (`"abc"`) гБѓеЕ®гГҐгГЉгГЙгБІ `not_a_number`гАВmode гБѓ installer гБІ ElemDef.int_round
  /// гБЛгВЙеЯЛгВБиЊЉгБЊгВМгВЛ (parse зЫЄеЖЕйГ®и™њжХігАБDR-061 ¬І5); дЄАеЇ¶ lowered value node гБЂгБ™гВЛгБ®дїЦгБЃ carrier гБѓ
  /// зД°гБДгБЯгВБ mode гБѓ node иЗ™иЇЂгБМжМБгБ§гАВDR-074 ¬І2 `allow_base_prefix` гВТзђђ 3 еЉХжХ∞гБІињљеК†йБЛжРђ вАФ
  /// opt-in жЩВгБѓ `0xff` (жХіжХ∞еА§) / `0x1.8p3=12` (жХіжХ∞еА§) / `0x1.8p0=1.5` (йЭЮжХіжХ∞гАБmode гБЂеЊУгБЖ) гБЃ
  /// еА§з©ЇйЦУеИ§еЃЪгВТ hex гБЂгВВдЄАиИђеМЦгБЩгВЛгАВcanonical default гБѓ `false`гАВparse-fail гБѓ `kind: parse`гАВ
  /// 5th field is DR-034's piece_filters (same carrier pattern as the other value primitives).
  IntArg(String, RoundMode, Bool, Array[FilterSpelling])
  /// bool value primitive (DR-076 ¬І1/¬І4: bool is a normal value type, same standing as
  /// string/number). Consume 1 token, parsed via `parse_bool_ext(_, config)` where `config` is the
  /// element's `bool_config` (canonical default = `bool_config_canonical()`, opt-in via `bool_parser`
  /// factory config, DR-061 ¬І4/DR-074 ¬І4); an unrecognized token fails with reason `not_a_bool`
  /// (`pe_parse_bool`). A separate node from `NumArg`/`FloatArg`/`IntArg` for the same reason as
  /// those: `Ty::TBool` is the only place the value-typed-vs-presence-only (`Ty::TFlag`)
  /// distinction is known (installer.mbt `value_prim`); once lowered to a bare value node there is
  /// no other channel to carry it. A bare `--x` (presence-only) fire is `TFlag`'s job, not this
  /// node's вАФ `BoolArg` only appears where a definition's `:set` explicitly wants a value slot.
  /// 2nd field is the bool_config carrier (mirrors `IntArg`'s `RoundMode` field вАФ config is bundled
  /// into one struct here, rather than 3 flat fields, since the 3 keys always travel together and
  /// `RepeatSpec` already establishes the "bundle a multi-key factory config into one struct" pattern
  /// in this same file). 3rd field is DR-034's piece_filters (same carrier pattern as `StrArg`).
  BoolArg(String, BoolConfig, Array[FilterSpelling])
  /// a number value with a max post-filter (DR-034 filter / DR-053 kind demo): consume 1 token,
  /// parse a number; a parse failure is `kind: parse`, a value ABOVE `max` is a `kind: filter`
  /// held Error (a value that parsed but failed the filter вАФ cell_filters reject зЫЄељУ). Test-only
  /// (eval_wbtest.mbt): production lowering (`installer.mbt` гБЃ `elem_head`/`value_prim`) never
  /// constructs this node, so it carries no `piece_filters` field (DR-034 йЕНзЈЪеѓЊи±°е§ЦгАБissue
  /// 2026-07-09-pre-split-filters-execution-wiring).
  FilterArg(String, Int)
  /// a REQUIRED string positional (DR-047 еА§еЕЕиґ≥ / DR-053 kind: constraint): consumes a token if
  /// present; if there is NO token to consume, it is a `kind: constraint` held Error (required
  /// жЬ™еЕЕиґ≥) rather than a silent Reject вАФ a delayed-predicate violation surfaced as an Error.
  ReqArg(String)
  /// 0-token binder: bind name=value. Used to set a flag after its Exact trigger fired.
  /// This is the SET degenerate form of an effect (DR-045 ¬І1).
  Bind(String, Value)
  /// 0-token EFFECT binder (DR-045): apply a non-set op (default / unset / empty) to the
  /// named cell after an Exact trigger fired. This is the lowering of a variant entry's
  /// effect: `--no-color` вЖТ `Seq([Exact("--no-color"), EffMark("color", Unset)])` вАФ the
  /// `link` (to the color cell) is by-name, the `effect` is the op carried here.
  EffMark(String, EffectOp)
  /// 0-token deprecation mark (DR-058): records that a deprecated ENTRY (an alias with
  /// `deprecated: true`, DR-057) was used to reach the named canonical cell. Lowered by the long
  /// installer onto a deprecated element's satellite (`Seq([Exact("--old"), Bind("port", вА¶),
  /// DeprMark("port")])`); the short installer sets `depr: true` on the cluster entry instead. It
  /// rides in the effect column as a `@depr:<name>` marker binding (like a FailMark), collected
  /// into ParserContext.warnings. The value propagates normally вАФ only a warning is added.
  DeprMark(String)
  /// 0-token failure-action mark (DR-048): records that failure-action element `name` (e.g. help)
  /// was SELECTED at the current argv position. Lowered from a `fail_action` element's satellite
  /// (`Seq([Exact("--help"), Bind("help", true), FailMark("help")])`). On a FAILED parse (0
  /// complete paths) the recorded action fires in place of the held Error; еЕИй£ЯгБД/еЖЕйГ®дЄАдљУ keeps
  /// a dd-internal `--help` from being selected (its trigger is raw-consumed, so FailMark never runs).
  FailMark(String)
  /// choice вАФ every alternative's readings become branches (DR-037 / DR-041 ¬І3).
  Or(Array[Node])
  /// ordered consumption; bindings accumulate across the sequence.
  Seq(Array[Node])
  /// unbounded repeat (>= 0). Guarded against zero-progress loops. The `Bool` is the DR-043 lazy
  /// knob (issue 2026-07-08 min0-lazy-repeat-gap): mirrors `BoundedTail`'s 3rd field вАФ `Many` is
  /// the min:0 UNBOUNDED spine form the way `BoundedTail` is the bounded one, so it gets the SAME
  /// seat rather than a parallel mechanism (a min>=1 UNBOUNDED lazy repeat already threads its knob
  /// through the registry's `"lazy:" + name` marker, but `Many` re-enters the SAME node at the same
  /// `pidx` вАФ no named template, so no registry key to carry it on). `false` (installer default when
  /// a repeat has no `lazy` spec) preserves the pre-existing greedy-only behavior exactly.
  Many(Node, Bool)
  /// result scope label (DR-025). Light layer-3 hook; does not change path count.
  Scoped(String, Node)
  /// the two-face scope: greedy (order-free triggers) over a positional face (DR-041 ¬І4).
  ScopeNode(Scope)
  /// native matcher: data-driven token readings (DR-041 ¬І3-4), installed by long/short (DR-042).
  NativeMatch(Matcher)
  /// reference to a named template in the registry (DR-020 / DR-043). repeat lowers to
  /// a recursive `Seq([head, Opt(Ref(self))])`; a ref element (`{ref:"color"}`) points at
  /// a shared template. On the positional spine `Ref` unfolds POROUSLY (>= 1 head, greedy
  /// may interject between reps вАФ the unfold stays on the current backbone, DR-043).
  Ref(String)
  /// dashdash satellite (DR-041 dashdash, rev). A GREEDY-face resident: its matcher
  /// is a plain exact match on the trigger (usually `--`). Because it is a greedy
  /// entry, еЕИй£ЯгБД (greedy-only) keeps `--` from being raw-eaten; when it fires the
  /// spine walk switches to "severed" mode (greedy off) for the rest вАФ the sever is
  /// the "greedy internal consumption is дЄАдљУ" rule, not a dd special case.
  DdSat(String)
  /// DR-090: the 2-axis generalization of `DdSat` вАФ a SEPARATE variant (not `DdSat`'s own
  /// arity extended) to keep every existing `DdSat("--")` hand-construction (wbtest files,
  /// installer's canonical exact-dd path) untouched; the installer only ever emits THIS
  /// variant when the definition actually declares `match` and/or `self:"keep"` (¬І2).
  /// Fields: `(spelling, is_pattern, self_keep, elem_name)`.
  /// - `spelling`: the exact trigger string (`is_pattern=false`, same matching as `DdSat`)
  ///   OR a regex pattern source (`is_pattern=true`, compiled via `compile_regex` вАФ the SAME
  ///   host-dialect compile path DR-085's `regex_match` filter uses, unanchored substring-vs-
  ///   whole-token semantics per DR-090 ¬І2's "match" being a trigger test on the WHOLE token).
  /// - `self_keep`: `false` (drop, DR-090 ¬І2 жЧҐеЃЪ вАФ consume 1 token, discard it, same as `DdSat`)
  ///   | `true` (keep вАФ consume 0 tokens, Accept immediately; the triggering token itself
  ///   flows into the positional face along with everything after it, still severed).
  /// - `elem_name` (DR-093 ¬І2/¬І5): the declaring element's `name`, independent of `spelling`
  ///   (¬І2's "match гБМгБВгВЛгБ®гБН name гБѓгГИгГ™гВђзґігВКгБЂдљњгВПгВМгБЪгАБи¶Бзі†гБЃеРМдЄАжАІгГїи°®з§ЇиїЄгБЃгБњгБЂеКєгБП" вАФ
  ///   this is that axis, made concrete). Used ONLY to key the committed-observation binding
  ///   the firing arm produces (mirrors `DdSat`'s own trigger-string-as-name shortcut, which only
  ///   works there because `DdSat` never decouples spelling from name). Never used for matching.
  DdMatchSat(String, Bool, Bool, String)
  /// command satellite (DR-018 / DR-041 ¬І4). A GREEDY-face resident whose matcher is
  /// a plain exact match on the command name. Firing enters the child scope as a NEW
  /// backbone (the parent greedy face does not interject inside it). еЕИй£ЯгБД protects the
  /// command name from a positional raw-eat, which is the DR-018 "commands гБМеЕИ" priority.
  CmdSat(String, Scope)
  /// link/scope-targeted wrapper (DR-042 global link-sync / DR-007 link). Evaluates its inner
  /// node but marks every binding it produces as a link that escapes `Int` result-nesting levels
  /// (= the scopes this copied satellite sits BELOW its declaration). Those bindings climb out of
  /// the sub-scopes and land on the DECLARING scope's entity. The global installer copies an
  /// option's satellite into a descendant scope wrapped in `Rooted(node, depth)`, so the value
  /// syncs to the one declaring cell instead of a fresh child cell (depth 1 for a direct child,
  /// +1 per re-propagation level). A root global's depth = firing depth (escapes to the root).
  Rooted(Node, Int)
  /// a filtered string value (DR-037 pre_filter): consumes a token ONLY if it does not
  /// start with `-`; otherwise it REJECTS (no reading, silently drops вАФ not an Error).
  /// This is the structural stop that keeps a permissive repeat from eating a following
  /// `--socket` / `--upstream` trigger inside a no-backbone region (DR-041 ¬І4).
  NoDashStr(String)
  /// a BOUNDED repeat tail (DR-043 max жЬЙйЩР / LOWERING ¬ІB.8). Consumes 0..budget more heads
  /// on the spine, POROUSLY (via consume_head, so еЕИй£ЯгБД holds) and with the еПЦгВКеИЖйБЄе•љ
  /// preference (greedy default / lazy). A bounded `repeat: {min, max}` lowers to `min`
  /// mandatory heads on the spine followed by `BoundedTail(head, max-min, lazy)` вАФ NO Ref
  /// recursion (the bound is the recursion depth of the tail, not an unbounded self-ref).
  /// `optional: true` = `repeat: {min:0, max:1}` reduces to a lone `BoundedTail(head, 1, _)`.
  BoundedTail(Node, Int, Bool)
  /// a named indexed-array repeat (DR-043 repeat √Ч DR-025 name scope). Consumes its head
  /// GREEDILY (as many reps as the head allows), tagging rep k under `[label, "#k"]` so
  /// the result builder yields an ARRAY of one element per firing (multiple:"append").
  /// `min` is the required rep count (0 = may be empty). Greedy-max is the еПЦгВКеИЖйБЄе•љ
  /// default; for this raw pattern the split is bounded by the head's Reject / exact, so
  /// no downstream backtrack is needed (DR-043 ¬ІеПЦгВКеИЖгБЃйБЄе•љ, е§ІеЯЯеЃМеЕ®зµМиЈѓ).
  IdxRepeat(String, Node, Int)
  /// an OPTION's repeat value slot (DR-078 ¬І1 option-level repeat, new capability): wraps ONLY
  /// the repeat TAIL (`Ref`/`Many`/`BoundedTail`, the same node `lower_repeat_head` builds for a
  /// positional) вАФ the trigger/marker prefix ahead of it in the satellite's `Seq` stays plain. A
  /// bare greedy satellite is evaluated OFF-SPINE (`step_greedy`'s catch-all вЖТ plain `eval`, no
  /// `Scope`), which cannot apply еЕИй£ЯгБД (DR-041 ¬І4) to stop the repeat before it swallows a
  /// sibling trigger (e.g. a second `--hlcolors`). `step_greedy` detects this wrapper and
  /// evaluates `tail` through a throwaway `Scope` that BORROWS the real scope's `greedy` face (so
  /// suppression sees every sibling trigger, including a refire of the SAME option) but has its
  /// OWN single-slot `positional` (so the tail's internal repeat loop вАФ which re-enters at the
  /// same pidx for "more" вАФ cannot walk into the real scope's unrelated positional slots).
  /// Off-spine `eval` (completion probes etc.) degrades to plain `eval(tail, ..)`, losing
  /// suppression вАФ acceptable there (no sibling scope to suppress against).
  GreedyRepeat(Node)
} derive(Eq, Debug)

///|
/// A scope carries two faces (DR-041 ¬І4):
/// - `greedy`: order-independent trigger entries (long/short satellites + matchers).
///   Each fires as a bound unit; its internal value slots raw-consume (getopt еРМеЮЛ).
/// - `positional`: the ordered, porous token stream. Greedy may interject between items.
/// - `entities`: value cells with the source ladder (env/default seats, DR-030/031).
pub(all) struct Scope {
  greedy : Array[Node]
  positional : Array[Node]
  entities : Array[Entity]
  constraints : Array[Constraint] // delayed predicates (DR-055/047), declared by the constraint installer
} derive(Eq, Debug)

///|
/// A delayed-predicate constraint (DR-055 / DR-047), evaluated on a complete path's FINAL state. A
/// violation makes the path NOT a completeиІ£ж±ЇзµМиЈѓ (DR-047 ¬І2) вАФ a DR-037 Error of kind:constraint.
pub(all) enum Constraint {
  /// element committed вЖТ each target must have a value (default иЊЉгБњ). requires = ж≠£гБЃдЊЭе≠Ш (DR-055 ¬І3).
  CRequires(String, Array[String])
  /// value-dependent requires (DR-055 ¬І1 + DR-052 ¬ІеА§жЮЭ id зЫідЇ§): 4-tuple = (entity, branch_id,
  /// value, targets). Semantics: `entity` гБМ committed AND гБЭгБЃеА§ == `value` гБЃгБ®гБНгАБ`targets` гБЃеА§
  /// еЕЕиґ≥гВТи¶Бж±ВгБЩгВЛгАВйБХеПНжЩВгБЃ error.element гБѓ `branch_id` (= or еА§жЮЭгБЃеМњеРНи¶Бзі†гБЂдїШгБДгБЯ idгАБfixture
  /// гБЃ `id: "fmt_json"` гБЂзЫЄељУ) гВТ emit гБЩгВЛ вАФ еА§гБЃеЄ∞е±ЮеЕИгБѓи¶™ entity (format) гБ†гБМеИґзіДгБЃеЃ£и®АеЕГгБѓ
  /// жЮЭ (fmt_json) гБ™гБЃгБІгАБelement е±ЮжАІгБѓеЃ£и®АеЕГгВТжМЗгБЩ (DR-052 гБ®зЫідЇ§)гАВ`branch_id` == `entity` гБЃ
  /// гБ®гБНгБѓ or еМњеРНжЮЭгБЂ id гБМдїШгБДгБ¶гБДгБ™гБД (parent зЫіе±ЮгБЃ value_requires гВТж®°гБЧгБЯгГХгВ©гГЉгГЂгГРгГГгВѓ)гАВ
  CRequiresIf(String, String, String, Array[String])
  /// conflicts_with (DR-055 ¬І2, еѓЊзІ∞): element committed + any target committed вЖТ conflict. Declaring
  /// on one side works both ways (the check isгАМдЄ°жЦє committedгАНregardless of who declared it).
  CConflicts(String, Array[String])
  /// exclusive_group: at most one member of the group may be committed (DR-047 жМЗеЃЪињ∞и™Ю).
  CExclusive(String, Array[String])
  /// required (DR-093 ¬І1/¬І2): гБУгБЃ entity иЗ™иЇЂгБЃгАМиІ£ж±ЇеЊМгБЃеЕЕиґ≥гАНгАВеЕЕиґ≥гБЃеЃЪзЊ©гБѓеЮЛ (еА§з©ЇйЦУ) гБЄгБЃеІФи≠≤ вАФ
  /// еА§з©ЇйЦУгВТжМБгБ§и¶Бзі† (йАЪеЄЄгБЃ type) гБѓжЬАзµВзКґжЕЛгБЃеА§гБЃжЬЙзД° (default / env з≠ЙгБЃеА§жЇРиЊЉгБњгАБDR-047 ¬І5 дЄНе§Й)гАБ
  /// еА§з©ЇйЦУгБМз©ЇгБЃи¶Бзі† (`type: "none"`гАБdd еРЂгВАгАБDR-089) гБѓзЩЇзБЂгБЧгБЯгБУгБ® (committed)гАВеИ§еЃЪеЕ•еКЫгБЂ
  /// committed гВТдљњгБЖзВєгБѓ CRequires гБ®еРМгБШзЈЪ (DR-047 ¬І5 гБМ selected гВТи®ЇжЦ≠гГ°гВњгБЂзХЩгВБгБЯзЈЪгВТзґ≠жМБ)гАВ
  CRequired(String)
} derive(Eq, Debug)

///|
/// A value cell (DR-030 "entity-only node"). Satellites/matchers with the same
/// `name` all write here = link еРИжµБ. Carries the reduced value-source ladder:
/// env seat (declared by the env installer), inherit seat (declared by the inherit
/// installer), tty seat (declared by the tty installer, DR-098), and default seat.
/// Ladder order is engine-owned (DR-031/DR-098, invariant вС£): cli > env > config >
/// inherit > tty > default. The inherit seat looks up the nearest ancestor scope's
/// same-named entity value.
pub(all) struct Entity {
  name : String
  ty : Ty
  mut env_key : String? // env seat lookup; None = no env seat declared (env installer sets it)
  mut config_seat : Bool // config seat declared (DR-050): fill from the config object by path
  mut config_key : Array[String]? // explicit absolute config path (DR-050 ¬І3); None = еРМеЮЛ (scope path + name)
  is_config_file : Bool // this cell's value is the config-file PATH (DR-050): resolves the provider, no config seat
  mut inherit_ : Bool // inherit seat declared (inherit installer sets it, DR-031 / DR-013). MDR-003: `inherit` дЇИзіДи™ЮеЫЮйБњ
  // DR-098 ¬І3: tty seat lookup key вАФ the stream name ("stdin"|"stderr"|"stdout") the tty installer
  // read off the element's `tty` attribute. None = no tty seat declared. Mirrors `env_key` (еНШдЄА
  // гВєгГ≠гГГгГИ lookup keyгАБи§ЗжХ∞дЄНеПѓ вАФ tty гБѓ 3 еА§ enum гБЃеНШдЄАеА§гАБenv гБЃи§ЗжХ∞еАЩи£ЬйЕНеИЧгБ®гБѓйБХгБЖељҐ)гАВ
  mut tty_key : String?
  // The accumulators-registry name (DR-036) that folds this cell's effect list, or None for a
  // scalar cell. Built-ins: "flatten" (repeat's cons [T,[T,вА¶]] вЖТ T[], DR-043) and "append"
  // (multiple's value fold, DR-034). Both realize a value LIST here; the name records WHICH
  // registry accumulator so the AST is self-describing (a scalar cell has None).
  accum : String? // None = scalar; Some("flatten"|"append"|...) = accumulate via that registry entry
  // DR-036 collector: the T[]вЖТU transform applied to an `accum` cell's FINAL accumulated array
  // (build_result's ACCUMULATE branch, `resolve.mbt`'s `apply_collector`). Only meaningful when
  // `accum is Some(_)` вАФ a scalar cell has no accumulated array to collect from, so this stays
  // None there. `None` here (the common case) means "no collector, render the plain accumulated
  // array" вАФ the multiple registry's `append` preset's `collector: гБ™гБЧ` (DR-036 "зЬБзХ•жЩВ accumulator
  // йА£еЛХгГЗгГХгВ©гГЂгГИ"). Only `unwrap_single` is wired end-to-end today (issue
  // 2026-07-09-dec-multiple-collector-decode); `to_set`/`from_entries` are DR-036 registry
  // presets but not reachable through this simple by-name field yet.
  collector : String?
  // DR-083 ¬І1/¬Іж≥ҐеПК: default seat, stored as a length-1-degenerate UNIFORM array (`None` = no
  // declared default; a scalar cell's declared default is `Some([v])`, length exactly 1; a
  // `multiple`/repeat/merge (accum) cell's is `Some([v1, v2, ...])`, one piece per declared array
  // element вАФ DR-050 ¬І4's config-array precedent, "already split pieces" per DR-083 ¬І2). Every
  // reader that KNOWS its cell is scalar (bool-target checks, the scalar CLI-seat fold's Unset/
  // Update "old ?? default" arms) takes `vs[0]` (a scalar's array is always length 1 by
  // construction, `ensure_entity`'s only producer). The accum-cell-aware readers (`resolve_ladder_
  // below_cli`'s default seat, `collect_scalar_array_default`'s definition-time gate) iterate the
  // whole array вАФ this single field replaces the pre-DR-083 `default_value : Value?` (a design
  // taken up again after being shelved mid accum-fold-update-default-ops, now justified by DR-083).
  default_values : Array[Value]?
  // DR-034 multiple гБЃ separator (issue 2026-07-09-env-separator-split-gap): the env seat's OWN
  // copy, mirroring `piece_filters` below вАФ `resolve.mbt`'s `env_value` runs the pieceProcessor once
  // per piece exactly like `eval.mbt`'s `sep_binds` does for the CLI seat's raw token, but the CLI
  // seat's split already happened upstream (at token-consumption time); the env seat's raw string
  // hasn't been split at all until this field tells `resolve_entity_raw` to. `None` = no separator
  // declared (the common case, and every non-`multiple` cell) вАФ env value stays a single piece.
  separator : String?
  // DR-034/DR-062 piece_filters (StringвЖТString, per-piece / pre-parse зЫЄ): unlike `value_filters`/
  // `cell_filters` below (which run AFTER a ladder seat's value is already resolved, in
  // `resolve.mbt`'s `apply_entity_filters`), piece_filters only ever runs BEFORE a stringвЖТT parse вАФ
  // i.e. only for STRING-typed ladder inputs. The CLI seat's own piece_filters application happens
  // upstream in eval.mbt/matcher.mbt (token consumption, before the value ever reaches this
  // Entity) вАФ this copy exists so the ladder's OTHER string-sourced seats (env: DR-049 ¬І2 "env
  // еА§гВВ pieceProcessor гВТйАЪгВЛ") can run the SAME chain via `resolve.mbt`'s `env_value`. A non-
  // string ladder source (config number/bool matching the type, default, inherit) has no parse
  // step to gate, so this field is simply unused there (DR-050 ¬І4's "еЮЛдЄАиЗігБ™гВЙ cell_filters гБЃгБњ"
  // вАФ piece_filters/parse гБѓеЕГгАЕ StringвЖТT гБЃйЦҐжХ∞гБ™гБЃгБІгАБеЮЛдЄАиЗігБІдЊЫзµ¶гБХгВМгБЯйЭЮ string еА§гБЂгБѓйБ©зФ®еѓЊи±°
  // гБМзД°гБДгБ®гБДгБЖеЮЛгБЃеЄ∞зµРгАБзЙєеИ•и¶ПеЙЗгБІгБѓгБ™гБД).
  piece_filters : Array[FilterSpelling]
  // DR-009 value_filters (each, TвЖТT): applied to EVERY value this cell resolves from ANY ladder seat
  // (cli/env/config/inherit/default) right after that seat's own value is determined вАФ same timing
  // "type.parse гБЃеЊМгАБaccumulator гБЃеЙН" DR-009's [4]вЖТ[5] describes. For a scalar cell (no accum)
  // this collapses to "applied once, right before cell_filters" since only one seat ever wins.
  value_filters : Array[FilterSpelling]
  // DR-009 cell_filters (зіѓз©НеЊМгБЃжЬАзµВеА§гАБDR-077 ¬І1 "cell_filters гБѓ update гБЃзµРжЮЬгБЂгВВйАЪгБЩ" гБЃеЃЯи®ЉеѓЊи±°):
  // applied to the FINAL resolved value, after the ladder has picked a winning seat (and after any
  // accumulation, for a multiple cell). This is the one place both `set` and `update` effects
  // converge before the value leaves resolve_entity вАФ the whole point of this issue.
  cell_filters : Array[FilterSpelling]
} derive(Eq, Debug)

///|
/// A long-option entry the eq-split matcher can resolve (`--key=value`). `int_round` /
/// `allow_base_prefix` / `bool_config` carry the element's DR-075 / DR-074 ¬І2/¬І4 factory config into
/// the eq-split path (space form runs the greedy Num/IntArg/BoolArg node which already carries this
/// config; eq-split needs its own copy since the entry table is the only channel run_eq_split reads).
/// `int_round` гБѓ TInt гБЃгБњгАБ`allow_base_prefix` гБѓ TNum / TIntгАБ`bool_config` гБѓ TBool гБЃгБњгБМеПВзЕІгБЩгВЛ
/// (DR-076 ¬І1/¬І3: bool гБЃ eq-split `--enabled=true` гБѓ variant зґігВКгБ®еЕ±е≠ШгБЩгВЛ вАФ TFlag гБ®йБХгБДжКСеИґ
/// гБХгВМгБ™гБД)гАВдїЦ kind гБѓзД°и¶ЦгАВ
pub(all) struct LongEntry {
  key : String
  name : String
  kind : Ty
  int_round : RoundMode
  allow_base_prefix : Bool
  bool_config : BoolConfig
  // DR-034/DR-062 piece_filters (same carrier pattern as `int_round`/`allow_base_prefix`): run_eq_split
  // (matcher.mbt) applies it to `valstr` before the kind-specific parse. Ignored for TFlag/TCount
  // (no eq-split value slot to gate вАФ a presence-only fire has no raw string to filter).
  piece_filters : Array[FilterSpelling]
  // DR-034 separator (issue 2026-07-09-separator-non-string-type-parse-gap жЃµ1): `--key=a,b` eq-split
  // form goes through the SAME pieceProcessor as the space form вАФ separator splitting is a value-
  // axis concern independent of which entry point supplied the raw string (DR-034, matcher-readings/
  // entry-forms.json's "еЕ•еП£ељҐгБЂйЦҐгВПгВЙгБЪеРМгБШ pieceProcessor зЃ°гВТйАЪгВЛ" precedent for piece_filters
  // applies identically here). `None` = no split (single-piece degenerate, DR-034 ¬І6.3).
  separator : String?
  // DR-080 ж≥ҐеПКзѓА: `ElemDef.accumulator == Some("merge")` вАФ the eq-split form (`--key=a,-a`) shares
  // the SAME `sep_binds` pieceProcessor as the space form, so it needs the same merge-marker flag
  // (same rationale as `separator` above: the entry point doesn't change the value-axis pipeline).
  merge : Bool
} derive(Eq, Debug)

///|
/// A short-option entry the cluster matcher can resolve (`-abc`, `-n1.0`).
/// `depr` (DR-057/058): this entry is a deprecated alias spelling вАФ firing it emits a `@depr:<name>`
/// warning marker (the value binding is unchanged). Only a deprecated ALIAS sets it; a canonical or
/// non-deprecated alias short has `depr: false`.
pub(all) struct ShortEntry {
  ch : Char
  name : String
  kind : Ty
  depr : Bool
  // DR-075 int_round + DR-074 ¬І2 allow_base_prefix: short cluster / space-tail гБЃеА§ parse гБЂйБЛгБґ
  // (LongEntry гБ®еРМеЮЛ)гАВint_round гБѓ TInt гБЃгБњгАБallow_base_prefix гБѓ TNum/TInt гБМеПВзЕІгАВ
  int_round : RoundMode
  allow_base_prefix : Bool
  // DR-034/DR-062 piece_filters (same carrier pattern as LongEntry): `short_val` (matcher.mbt) applies
  // it to the in-cluster/space-form value string before the kind-specific parse. Ignored for
  // TFlag/TBool/TCount (no in-cluster/space-form VALUE attachment for those вАФ `short_val` already
  // returns None unconditionally for them).
  piece_filters : Array[FilterSpelling]
  // DR-034 separator (issue 2026-07-09-separator-non-string-type-parse-gap жЃµ1, same rationale as
  // LongEntry's field): in-cluster (`-p5,7`) and space-form (`-p 5,7`) both go through the same
  // pieceProcessor as the long-option space form. `None` = no split.
  separator : String?
  // DR-080 ж≥ҐеПКзѓА (same rationale as LongEntry's field): `ElemDef.accumulator == Some("merge")`.
  merge : Bool
  // DESIGN ¬І7.2 / DR-096 ¬І2 (kawaz и£БеЃЪ 2026-07-12 гБІ `AtLastOnly` ињљеК†): gates whether `walk_short`
  // may read this entry's value via in-cluster attach (`-O2`) vs. next-token space form (`-O 2`).
  // `AtRequire` withholds the space-form reading, `AtDeny` withholds the attach reading (both the
  // mid-token AND full-tail-length attach, plus the cluster-tail attach вАФ DR-096 ¬І3.1гАМдїШзЭАгБ®гБДгБЖ
  // ж©ЯжІЛиЗ™дљУгВТгГАгВ§гГ§гГЂгБЧгБ¶гБДгВЛгБЃгБІгБВгБ£гБ¶гАБеНШзЛђзЩЇзБЂжЩВгБЂйЩРгВЛи¶ПеЃЪгБІгБѓгБ™гБДгАН), `AtLastOnly` withholds
  // every MID-token split attach (only the full-tail "дЄЄеПЦгВК" reading remains вАФ GNU getopt жЕ£зњТгБЃ
  // еИЖеЙ≤ ambiguity жКСеИґ), `AtAllow` (жЧҐеЃЪ) withholds neither (`walk_short`, matcher.mbt, is the sole
  // consumer). Ignored for TFlag/TBool/TCount/TNone entries (DR-096 ¬І3.2 inert вАФ those kinds never
  // reach `short_val`'s in-cluster/space-form value attachment in the first place).
  short_attached_value : AttachMode
} derive(Eq, Debug)

///|
/// A native matcher (DR-041): reified token-reading capability as DATA.
/// The evaluator interprets it (`run_matcher`); installers construct it from
/// the collected entry table (DR-042: "еЫЮеПОгБЧгБЯгВ®гГ≥гГИгГ™и°®гБМ matcher гБЃжІЛжИРгГЗгГЉгВњ").
pub(all) enum Matcher {
  /// `--key=value` split. Fires only on tokens containing `=`. Undefined key = no reading (зі†йАЪгБЧ).
  EqSplit(prefix~ : String, entries~ : Array[LongEntry])
  /// `-abc` cluster + value attachment. Enumerates ALL readings (DR-041 ¬І3-4); ambiguous defs
  /// (the `-cv` problem) surface as multiple readings that both complete. `combine` (DR-014гАМ-abc
  /// гБЃзµРеРИи®±еПѓгАН, DESIGN ¬І7.2 scope config `short_combine`, issue scope-config-object-gap иІ£йЗИA
  /// team-lead и£БеЃЪ 2026-07-11): when `false`, only a SINGLE short entry may occupy a token вАФ
  /// multi-entry clustering (`-ab` вЖТ 2 entries in 1 token) is withheld, while a lone flag fire
  /// (`-p`) and a value-attach that consumes the ENTIRE token tail (`-p80`, no leftover chars for a
  /// further entry to combine with) remain unaffected (`run_short`/`walk_short`, matcher.mbt, is the
  /// sole consumer). Internal-only parameter вАФ never projected into a lowering fixture's golden
  ///жЦ≠йЭҐ (`proj_greedy`'s `NativeMatch(ShortCombine(prefix=_, entries~))` arm in
  /// json_conformance_wbtest.mbt already discards `prefix` too, DR-070 ¬І2 loose compare: matcher
  /// kind + entry table only). жЧҐеЃЪ `true` (зПЊи°МгБЃ cluster/еА§дїШзЭА еЕ®и™≠гБњжМЩеЛХгБѓдЄНе§Й)гАВ
  ShortCombine(prefix~ : String, entries~ : Array[ShortEntry], combine~ : Bool)
} derive(Eq, Debug)

// вФАвФА completion candidate еЮЛ (DR-060 ¬І3) вАФ еЮЛгБЃгБњзІїж§Н (slice complete.mbt 1-57) вФА
// The completionиµ∞жЯї (comp_scope з≠Й) is outcome.mbt's job (MDR-002 ¬І3); only the DATA the
// evaluator's `Pending` branch carries lives here. `Cand` uses `Ty`, so it sits beside it.

///|
/// A terminal hint on an exact candidate (DR-060 ¬І3): `WordEnd` = зҐЇеЃЪ, a space may follow; `Cont` =
/// зґЩзґЪ, no space (a value must follow вАФ e.g. a value-taking --port, or a `--key=` / dir `/` in prod).
pub(all) enum TermHint {
  WordEnd
  Cont
} derive(Eq, Debug)

///|
/// Declaration-layer meta a completion reads by reference (DR-056 / DR-057 / DR-058): whether a
/// spelling is an alias entry, hidden (excluded from candidates by default, kept in meta), deprecated.
pub(all) struct CandMeta {
  is_alias : Bool
  hidden : Bool
  deprecated : Bool
} derive(Eq, Debug)

///|
/// A completion candidate (DR-060 ¬І3): either an exact trigger spelling, or a value position (type +
/// completerеРН, PoC shows the type). Meta rides alongside; policy / replacement / landing is the
/// generator's & shell's (kuu returnsзі†жЭР only).
///
/// `path` (DR-066 ¬І4, issue 2026-07-08 pending-starvation-missing-operand-path): root-first ancestor
/// scope names, mirroring `ParseError.path`'s snoc form ([] = root зЫідЄЛ). `origin` already answers
/// "which element" a candidate came from; `path` answers "under which ancestor scopes" вАФ the same
/// pairing `ParseError` uses (`element` + `path`). Threaded the SAME way Held's path is (starts `[]`
/// at construction, `nest_branches`/CmdSat prepend the traversed scope labels on the way out) so a
/// `Pending`'s value-slot candidate can be converted to a `missing_operand` `ParseError` (parse()
/// top-level, DR-053 ¬І2.3) WITHOUT losing the ancestor path the way it used to (Held already worked;
/// Pending вАФ parse mode's other failure carrier вАФ did not, because prepend only touched Held). Also
/// carried by the exact-trigger (`is_value:false`) candidates for consistency, even though those
/// never feed `missing_operand` today вАФ DR-060's completion consumers are free to ignore the field
/// (additive, not a breaking change to the ¬І3 candidate structure).
pub(all) struct Cand {
  spelling : String // the exact spelling; "" for a value position
  is_value : Bool
  ty : Ty // for a value position
  origin : String // the element name it came from
  term : TermHint
  meta : CandMeta
  path : Array[String] // DR-066 ¬І4: root-first ancestor scope names (snoc form, [] = root зЫідЄЛ)
} derive(Eq, Debug)

///|
/// The outcome of trying a node against a token prefix (MDR-002 ¬І2.1). A missing branch == Reject
/// (silently dropped, DR-037); `Held` == Error (retained for failure display); `Accept(pos, binds)`
/// == a reading; `Pending(cands, binds)` == гГИгГ™гВђжґИи≤їгГїеА§ pending (parse гБІгБѓ Held зЫЄељУгАБcomplete гБІгБѓ
/// и£ЬеЃМеАЩи£ЬгБЃжЇР, MDR-002 ¬І2 ж°ИB). The matcher only CONSTRUCTS Accept/Held; the evaluator produces and
/// consumes Pending. (Kept in node.mbt so both matcher and eval can return it; single package.)
enum Branch {
  Accept(Int, Array[Binding]) // (new position, accumulated bindings)
  Held(ParseError, Array[Binding]) // a DR-037 Error + the partial state (acc) at the error point
  Pending(Array[Cand], Array[Binding]) // trigger consumed, value slot's input absent
} derive(Debug)
