///|
/// Canonical full installer chain (DR-042 آ§canonical set + DR-043/050/055/057/059).
fn full_installers() -> Array[Installer] {
  [
    LongInst,
    ShortInst,
    EnvInst,
    DdInst,
    CommandInst,
    GlobalInst,
    InheritInst,
    RepeatInst,
    MultipleInst,
    ConfigInst,
    ConstraintInst,
    AliasInst,
    InheritableInst,
  ]
}

// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
// SECTION 3 â€” LSec 5-face و–­é‌¢ model + renderers + projectors (mirrors slice/poc/lower_runner_wbtest.mbt)
// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ

///|
struct LEnt {
  name : String
  typ : String
  default_ : Value?
  env : String?
  inherit_ : Bool
  config_key : Array[String]?
  accum : String?
}

///|
enum GItem {
  GExact(String)
  GSet(String, Value, String)
  GEff(String, String, EffectOp)
  GSeqSat(String, String)
  GMatch(String, Array[(String, String)])
  GCmd(String, LSec)
}

///|
enum TNode {
  TSeq(Array[TNode])
  TRefEnt(String)
  TRefTmpl(String, Bool)
  TExact(String)
}

///|
struct LSec {
  greedy : Array[GItem]
  positionals : Array[TNode]
  entities : Array[LEnt]
  constraints : Array[Constraint]
  templates : Array[(String, TNode)]
}

///|
fn canon_tmpl(k : String) -> String {
  let buf = StringBuilder::new()
  for c in k {
    if c == '#' {
      break
    }
    buf.write_char(c)
  }
  buf.to_string() + "#T"
}

///|
fn lent_str(e : LEnt) -> String {
  let fs : Array[String] = ["type=" + e.typ]
  match e.default_ {
    Some(v) => fs.push("default=" + render_val(v))
    None => ()
  }
  match e.env {
    Some(k) => fs.push("env=" + k)
    None => ()
  }
  if e.inherit_ {
    fs.push("inherit_=true")
  }
  match e.config_key {
    Some(p) => fs.push("config_key=[" + join_comma(p) + "]")
    None => ()
  }
  match e.accum {
    Some(a) => fs.push("accumulator=" + a)
    None => ()
  }
  sort_items(fs)
  e.name + "{" + join_comma(fs) + "}"
}

///|
fn lcon_str(c : Constraint) -> String {
  fn sorted(xs : Array[String]) -> String {
    let ss : Array[String] = []
    for x in xs {
      ss.push(x)
    }
    sort_items(ss)
    join_comma(ss)
  }

  match c {
    CRequires(el, ts) =>
      "requires{element=" + el + ",targets=[" + sorted(ts) + "]}"
    CConflicts(el, ts) =>
      "conflicts_with{element=" + el + ",targets=[" + sorted(ts) + "]}"
    CRequiresIf(entity, branch_id, v, ts) =>
      // DR-055 آ§1 + DR-052 آ§ه€¤و‍‌ id ç›´ن؛¤: entity مپ¯ committed هˆ¤ه®ڑه¯¾è±،م€پbranch_id مپ¯éپ•هڈچو™‚ elementم€‚
      // و–­é‌¢مپ«مپ¯ن¸،و–¹ emit مپ™م‚‹ (entity مپ¨ branch_id مپŒهˆ¥مپھم‚‰مپ‌مپ®é‌‍ه¯¾ç§°مپŒèھ­م‚پم‚‹; id مپھمپ—مپ® parent ç›´ه±‍
      // ه€¤ن¾‌ه­ک requires مپ§مپ¯ entity == branch_id مپ¨مپھم‚ٹه†—é•·مپ مپŒ projection مپ¯ fixture هپ´مپ¨ه¯¾ç§°مپ«ن؟‌مپ¤)م€‚
      "requires_if{entity=" +
      entity +
      ",element=" +
      branch_id +
      ",value=" +
      v +
      ",targets=[" +
      sorted(ts) +
      "]}"
    CExclusive(g, ms) =>
      "exclusive_group{group=" + g + ",members=[" + sorted(ms) + "]}"
    CRequired(el) => "required{element=" + el + "}"
  }
}

///|
fn gmatch_entries_str(entries : Array[(String, String)]) -> String {
  let keys : Array[String] = []
  let vals : Array[String] = []
  for kv in entries {
    let mut found = false
    let mut i = 0
    while i < keys.length() {
      if keys[i] == kv.0 {
        found = true
        if vals[i] != kv.1 {
          vals[i] = vals[i] + "!" + kv.1
        }
      }
      i = i + 1
    }
    if !found {
      keys.push(kv.0)
      vals.push(kv.1)
    }
  }
  let items : Array[String] = []
  let mut i = 0
  while i < keys.length() {
    items.push(keys[i] + "->" + vals[i])
    i = i + 1
  }
  sort_items(items)
  join_comma(items)
}

///|
fn lower_eff_op(op : EffectOp) -> String {
  match op {
    Set => "set"
    Default => "default"
    Unset => "unset"
    Empty => "empty"
    Update(transform, args) =>
      if args.length() == 0 {
        "update:" + transform
      } else {
        "update:" + transform + ":" + join_comma(args)
      }
    // DR-080 آ§2 merge accumulator piece markers (eff_op مپ¨هگŒمپکèھ‍ه½™م€پlower path ç”¨مپ®ن¸¦è،Œه®ںè£…)م€‚
    Remove => "remove"
    Splice => "splice"
  }
}

///|
fn gitem_str(g : GItem) -> String {
  match g {
    GExact(s) => "exact(" + s + ")"
    GSet(ex, v, link) =>
      "set{exact=" + ex + ",value=" + render_val(v) + ",link=" + link + "}"
    GEff(ex, link, op) =>
      "eff{exact=" + ex + ",link=" + link + ",op=" + lower_eff_op(op) + "}"
    GSeqSat(trig, ref_) =>
      "seq{exact=" + trig + ",ref=" + ref_ + ",link=" + ref_ + "}"
    GMatch(kind, entries) =>
      "matcher(" + kind + "){" + gmatch_entries_str(entries) + "}"
    GCmd(name, child) =>
      "cmd{exact=" + name + ",scope=(" + lsec_str(child) + ")}"
  }
}

///|
fn tnode_str(t : TNode) -> String {
  match t {
    TSeq(xs) => {
      let items : Array[String] = []
      for x in xs {
        items.push(tnode_str(x))
      }
      "seq[" + join_comma(items) + "]"
    }
    TRefEnt(n) => "ref{" + n + ",link=" + n + "}"
    TRefTmpl(id, opt_) =>
      "ref{" + id + (if opt_ { ",optional" } else { "" }) + "}"
    TExact(s) => "exact(" + s + ")"
  }
}

///|
fn lsec_str(s : LSec) -> String {
  let parts : Array[String] = []
  if s.greedy.length() > 0 {
    let items : Array[String] = []
    for g in s.greedy {
      items.push(gitem_str(g))
    }
    sort_items(items)
    parts.push("G[" + join_comma(items) + "]")
  }
  if s.positionals.length() > 0 {
    let items : Array[String] = []
    for p in s.positionals {
      items.push(tnode_str(p))
    }
    parts.push("P[" + join_comma(items) + "]")
  }
  if s.entities.length() > 0 {
    let items : Array[String] = []
    for e in s.entities {
      items.push(lent_str(e))
    }
    sort_items(items)
    parts.push("E[" + join_comma(items) + "]")
  }
  if s.constraints.length() > 0 {
    let items : Array[String] = []
    for c in s.constraints {
      items.push(lcon_str(c))
    }
    sort_items(items)
    parts.push("C[" + join_comma(items) + "]")
  }
  if s.templates.length() > 0 {
    let items : Array[String] = []
    for kv in s.templates {
      items.push(kv.0 + "=" + tnode_str(kv.1))
    }
    sort_items(items)
    parts.push("T[" + join_comma(items) + "]")
  }
  join_pipe(parts)
}

// â”€â”€ projection: canon Scope â†’ و–­é‌¢ LSec â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
fn prim_name(n : Node) -> String? {
  match n {
    StrArg(x, _) => Some(x)
    NumArg(x, _, _) => Some(x)
    // TInt مپ¯ DR-075 آ§1 مپ§ه€¤ç©؛é–“هˆ¤ه®ڑمپ«هˆ‡و›؟م€پCLI ç›¸مپ§ IntArg çµŒç”±م€‚lower و–­é‌¢مپ§مپ¯ن»–مپ® value primitive
    // مپ¨هگŒه‍‹مپ®ه€¤م‚»مƒ« (n) مپ¨مپ—مپ¦و‰±مپ† (Some(x) م‚’è؟”مپ™)م€‚
    IntArg(x, _, _, _) => Some(x)
    FloatArg(x, _) => Some(x)
    // DR-076 آ§1/آ§4: bool is now a normal value type, same satellite shape as string/number/int/float.
    BoolArg(x, _, _) => Some(x)
    SepArg(x, _, _, _, _, _, _, _) => Some(x)
    FilterArg(x, _) => Some(x)
    ReqArg(x) => Some(x)
    NoDashStr(x) => Some(x)
    _ => None
  }
}

///|
fn proj_seq_sat(xs : Array[Node]) -> GItem {
  match xs {
    [Exact(t), Bind(n, v)] => GSet(t, v, n)
    [Exact(t), Bind(n, v), FailMark(_)] => GSet(t, v, n)
    [Exact(t), Bind(n, v), DeprMark(_)] => GSet(t, v, n)
    [Exact(t), EffMark(n, op)] => GEff(t, n, op)
    [Exact(t), tail] =>
      match prim_name(tail) {
        Some(n) => GSeqSat(t, n)
        None => GExact("?seq:" + t)
      }
    _ => GExact("?seq:?")
  }
}

///|
fn proj_greedy(node : Node, reg : Map[String, Node]) -> GItem {
  match node {
    DdSat(name) => GExact(name)
    // DR-090: no golden lowering fixture exercises this yet (spec fixtures for DR-090 are
    // "query":"parse"è¼ھéƒ­, not lowering shape comparisons) â€” minimal, informative encoding via
    // the existing GMatch shape rather than inventing a new GItem variant for an untested path.
    DdMatchSat(spelling, is_pattern, self_keep, _) =>
      GMatch("dd_match:" + (if self_keep { "keep" } else { "drop" }), [
        (spelling, if is_pattern { "pattern" } else { "exact" }),
      ])
    Exact(s) => GExact(s)
    Rooted(inner, _) => proj_greedy(inner, reg)
    CmdSat(name, child) => GCmd(name, proj_scope(child, reg))
    NativeMatch(EqSplit(prefix~, entries~)) => {
      let es : Array[(String, String)] = []
      for e in entries {
        es.push((prefix + e.key, e.name))
      }
      GMatch("eq_split", es)
    }
    NativeMatch(ShortCombine(prefix=_, entries~, ..)) => {
      let es : Array[(String, String)] = []
      for e in entries {
        es.push(("\{e.ch}", e.name))
      }
      GMatch("short_combine", es)
    }
    Seq(xs) => proj_seq_sat(xs)
    _ => GExact("?greedy")
  }
}

///|
fn proj_pos(node : Node) -> TNode {
  match node {
    Ref(k) => TRefTmpl(canon_tmpl(k), false)
    Seq(xs) => {
      let items : Array[TNode] = []
      for x in xs {
        items.push(proj_tnode(x))
      }
      TSeq(items)
    }
    other =>
      match prim_name(other) {
        Some(n) => TRefEnt(n)
        None => TExact("?pos")
      }
  }
}

///|
fn proj_tnode(node : Node) -> TNode {
  match node {
    Seq(xs) => {
      let items : Array[TNode] = []
      for x in xs {
        items.push(proj_tnode(x))
      }
      TSeq(items)
    }
    Or([inner, Seq([])]) =>
      match inner {
        Ref(k) => TRefTmpl(canon_tmpl(k), true)
        other => proj_tnode(other)
      }
    Ref(k) => TRefTmpl(canon_tmpl(k), false)
    Exact(s) => TExact(s)
    other =>
      match prim_name(other) {
        Some(n) => TRefEnt(n)
        None => TExact("?tnode")
      }
  }
}

///|
fn proj_entity(e : Entity) -> LEnt {
  let typ = if e.is_config_file {
    "config_file"
  } else {
    match e.ty {
      TStr => "string"
      // DR-077 آ§3: `Entity.ty` is already collapsed TCountâ†’TNum by `ensure_entity` for every real
      // count cell â€” folded in defensively (this arm should never actually see TCount).
      TNum | TCount => "number"
      TFloat => "float"
      TInt => "int"
      TFlag | TBool => "bool"
      TNone => "none"
    }
  }
  {
    name: e.name,
    typ,
    // DR-083 آ§1: LEnt is the golden-fixture "5-face" oracle format, which only knows a scalar
    // default (`dec_lent` below decodes `"default"` via a single `json_to_value`, no accum-array
    // shape) â€” project the scalar face of `Entity.default_values` for this cross-check.
    default_: default_scalar(e),
    env: e.env_key,
    inherit_: e.inherit_,
    config_key: e.config_key,
    accum: e.accum,
  }
}

///|
fn collect_reftmpls(
  nodes : Array[Node],
  reg : Map[String, Node],
  out : Array[String],
) -> Unit {
  fn is_tmpl_key(k : String) -> Bool {
    !str_has_prefix(k, "lazy:") && reg.get(k) is Some(_)
  }

  fn walk(n : Node) -> Unit {
    match n {
      Ref(k) =>
        if is_tmpl_key(k) && !conformance_str_in(out, k) {
          out.push(k)
          match reg.get(k) {
            Some(body) => walk(body)
            None => ()
          }
        }
      Seq(xs) =>
        for x in xs {
          walk(x)
        }
      Or(xs) =>
        for x in xs {
          walk(x)
        }
      Many(inner, _) => walk(inner)
      BoundedTail(inner, _, _) => walk(inner)
      Scoped(_, inner) => walk(inner)
      Rooted(inner, _) => walk(inner)
      _ => ()
    }
  }

  for n in nodes {
    walk(n)
  }
}

///|
fn proj_scope(sc : Scope, reg : Map[String, Node]) -> LSec {
  let greedy : Array[GItem] = []
  for g in sc.greedy {
    greedy.push(proj_greedy(g, reg))
  }
  let positionals : Array[TNode] = []
  for p in sc.positional {
    positionals.push(proj_pos(p))
  }
  let entities : Array[LEnt] = []
  for e in sc.entities {
    entities.push(proj_entity(e))
  }
  let constraints : Array[Constraint] = []
  for c in sc.constraints {
    constraints.push(c)
  }
  let ref_ids : Array[String] = []
  collect_reftmpls(sc.positional, reg, ref_ids)
  let templates : Array[(String, TNode)] = []
  for k in ref_ids {
    match reg.get(k) {
      Some(body) => templates.push((canon_tmpl(k), proj_tnode(body)))
      None => ()
    }
  }
  { greedy, positionals, entities, constraints, templates }
}

// â”€â”€ lower runner (canon_of / pick3 / run_lower) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
fn canon_of(def : Definition, order : Array[Installer]) -> String {
  let reg : Map[String, Node] = Map([])
  match parse_definition(def, order, registry=reg) {
    Ok(sc) => lsec_str(proj_scope(sc, reg))
    Err(e) => "ERR:" + deferrs_str(e)
  }
}

///|
fn order_sig(order : Array[Installer]) -> String {
  let buf = StringBuilder::new()
  for x in order {
    buf.write_string(owned_vocab(x))
    buf.write_string(";")
  }
  buf.to_string()
}

///|
fn pick3(order : Array[Installer]) -> Array[Array[Installer]] {
  let ident : Array[Installer] = []
  for x in order {
    ident.push(x)
  }
  let rev : Array[Installer] = []
  let mut i = order.length() - 1
  while i >= 0 {
    rev.push(order[i])
    i = i - 1
  }
  let rot : Array[Installer] = []
  if order.length() > 0 {
    let mut j = 1
    while j < order.length() {
      rot.push(order[j])
      j = j + 1
    }
    rot.push(order[0])
  }
  let out : Array[Array[Installer]] = []
  let sigs : Array[String] = []
  for cand in [ident, rev, rot] {
    let sig = order_sig(cand)
    if !conformance_str_in(sigs, sig) {
      sigs.push(sig)
      out.push(cand)
    }
  }
  out
}

///|
fn run_lower(def : Definition, order : Array[Installer], want : LSec) -> String {
  let got = canon_of(def, order)
  let wantS = lsec_str(want)
  let mut perm_ok = true
  for p in pick3(order) {
    if canon_of(def, p) != got {
      perm_ok = false
    }
  }
  if !perm_ok {
    "PERM-DIVERGE|got=" + got + "|want=" + wantS
  } else if got == wantS {
    "PASS"
  } else {
    "DIVERGE|got=" + got + "|want=" + wantS
  }
}

// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
// SECTION 4 â€” Parse-path projections (mirror slice fixture_runner_wbtest.mbt)
// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ

///|
/// Key-sorted rendering of the built result object (CONFORMANCE آ§3: result is structural, key order
/// non-normative). Arrays keep order.
fn render_rval_sorted(r : RVal) -> String {
  match r {
    RScalar(v) => render_val(v)
    RArr(vs) => {
      let items : Array[String] = []
      for v in vs {
        items.push(render_rval_sorted(v))
      }
      "[" + join_comma(items) + "]"
    }
    RObj(kvs) => {
      let items : Array[String] = []
      for kv in kvs {
        items.push(kv.0 + "=" + render_rval_sorted(kv.1))
      }
      sort_items(items)
      "{" + join_comma(items) + "}"
    }
  }
}

///|
/// آ§2 CLI effects, EXCLUDING config_file infra cells. `set`/`remove` render an operand (DR-080 آ§2:
/// remove's operand is the type-parsed value being removed, same wire shape as set's); every other
/// op (default/unset/empty/update/splice) renders bare â€” `splice` carries no operand (DR-080 آ§2 `@`
/// just points at old, DESIGN's placeholder-value convention).
fn proj_effects_ex(sc : Scope, binds : Array[Binding]) -> String {
  let items : Array[String] = []
  for b in binds {
    if is_sentinel(b.key) {
      continue
    }
    if is_config_file_cell(sc, b.key) {
      continue
    }
    // DR-089 آ§3 (team-lead è£په®ڑ 2026-07-11): none مپ®ç™؛çپ«مپ¯ effects مپ«م‚‚çڈ¾م‚Œمپھمپ„ (è¦³و¸¬مپ¯
    // ParserContext/explains ه±¤مپ®ç®،وژŒم€په€¤ç©؛é–“مپھمپ—مپ® set م‚¨مƒ³مƒˆمƒھم‚’ç™؛وکژمپ—مپھمپ„)م€‚ه†…éƒ¨è،¨çڈ¾مپ¯
    // `flag_bare_true_variant` ه†چهˆ©ç”¨مپ® Set+VBool(true) placeholder مپ®مپ¾مپ¾مپ§è‰¯مپڈ (installer.mbt)م€پ
    // مپ“مپ“ (ه°„ه½±ه±¤) مپ مپ‘مپ§é™¤ه¤–مپ™م‚‹ â€” `is_config_file_cell` مپ¨هگŒمپکم€ŒEntity ه±‍و€§م‚’è¦‹مپ¦ç‰¹ه®ڑ cell م‚’
    // ه°„ه½±مپ‹م‚‰ه¤–مپ™م€چمƒ‘م‚؟مƒ¼مƒ³م€‚
    if is_none_cell(sc, b.key) {
      continue
    }
    // DR-093 آ§2/آ§7: dd ç™؛çپ«مپ® committed è¦³و¸¬ç”¨ binding م‚‚هگŒمپکçگ†ç”± (ه€¤ç©؛é–“مپھمپ—م€پDR-089 آ§3) مپ§
    // effects مپ‹م‚‰é™¤ه¤–مپ™م‚‹ â€” entity م‚’وŒپمپںمپھمپ„مپ®مپ§ `is_none_cell` مپ§مپ¯وچ‰مپˆم‚‰م‚Œمپھمپ„ (`is_dd_cell`
    // هڈ‚ç…§)م€‚
    if is_dd_cell(sc, b.key) {
      continue
    }
    match b.op {
      Set | Remove =>
        items.push(
          "\{b.key}:\{eff_op(b.op)}(\{render_val(b.value)})@\{render_src(b.source)}",
        )
      _ => items.push("\{b.key}:\{eff_op(b.op)}@\{render_src(b.source)}")
    }
  }
  join_comma(items)
}

///|
fn is_config_file_cell(sc : Scope, name : String) -> Bool {
  for e in sc.entities {
    if e.name == name && e.is_config_file {
      return true
    }
  }
  false
}

///|
fn is_none_cell(sc : Scope, name : String) -> Bool {
  for e in sc.entities {
    if e.name == name && e.ty == TNone {
      return true
    }
  }
  false
}

///|
/// DR-093 آ§2/آ§7 و³¢هڈٹ: dd è¦پç´  (`DdSat`/`DdMatchSat`) مپ¯ entity م‚’وŒپمپںمپھمپ„ (DR-030م€Œه®ںن½“=ه€¤م‚»مƒ«م€چ/
/// LOWERING آ§B.4م€پ`ensure_entities` مپ® `not_dd` م‚¬مƒ¼مƒ‰) مپŒم€پDR-093 مپ® committed è¦³و¸¬ç”¨ binding
/// (ç™؛çپ«و™‚مپ® `flag_bare_true_variant` هگŒه‍‹ `Set VBool(true)` placeholder) مپ¯ن»–مپ®ه€¤مپ¨هگŒمپک `binds`
/// é…چهˆ—مپ«ن¹—م‚‹م€‚`is_none_cell` مپ¯ entity èµ°وں»مپھمپ®مپ§ dd è¦پç´ مپ® binding م‚’وچ‰مپˆم‚‰م‚Œمپھمپ„ â€” scope مپ®
/// greedy é‌¢م‚’ç›´وژ¥èµ°وں»مپ—مپ¦ dd è¦پç´ هگچم‚’é›†م‚پم‚‹م€په¯¾مپ«مپھم‚‹هˆ¤ه®ڑم€‚`proj_effects_ex` مپ¯ `binds` م‚’مƒ«مƒ¼مƒˆ
/// scope هں؛و؛–مپ§مƒ•مƒ©مƒƒمƒˆمپ«èˆگم‚پم‚‹ (`b.key` مپ®مپ؟و¯”è¼ƒم€پ`b.scope` ن¸چه•ڈ) مپ®مپ§م€پ`CmdSat` مپ®ه­گ scope م‚‚
/// ه†چه¸°çڑ„مپ«è¦‹م‚‹ (dd/global-sever.json مپ®م‚ˆمپ†مپھه­گم‚³مƒ‍مƒ³مƒ‰م‚¹م‚³مƒ¼مƒ— dd مپ®ه®ںو¸¬مپ§ه؟…é ˆمپ¨هˆ¤وکژ)م€‚
fn is_dd_cell(sc : Scope, name : String) -> Bool {
  fn scan(g : Node) -> Bool {
    match g {
      DdSat(trigger) => trigger == name
      DdMatchSat(_, _, _, elem_name) => elem_name == name
      Or(alts) => {
        for a in alts {
          if scan(a) {
            return true
          }
        }
        false
      }
      Rooted(inner, _) => scan(inner)
      CmdSat(_, child) => is_dd_cell(child, name)
      _ => false
    }
  }

  for g in sc.greedy {
    if scan(g) {
      return true
    }
  }
  false
}

///|
/// A `path` array rendered as a single comparable token (DR-066 آ§4 snoc form, root-first). `>` joins
/// segments â€” element/scope names are installer-derived identifiers (kuu source names), never
/// containing `>` â€” so this stays unambiguous the same way `/` separates the kind/reason fields.
fn render_path(path : Array[String]) -> String {
  let buf = StringBuilder::new()
  let mut first = true
  for s in path {
    if !first {
      buf.write_string(">")
    }
    buf.write_string(s)
    first = false
  }
  buf.to_string()
}

///|
/// آ§2 failure error set. Emits `element@pos/kind` per error; `reason` and `path` (DR-066 آ§4) each
/// ride along independently when the fixture asserted that field on ANY error in the set (per-field
/// opt-in, CONFORMANCE آ§3/آ§5) â€” `/reason` first (kept at its original position for fixtures already
/// asserting only reason), `|path` appended after (a separate delimiter so "no reason, but path
/// asserted" cannot collide with "reason asserted, no path"). sorted as a set.
fn proj_errors(
  errs : Array[ParseError],
  with_reason : Bool,
  with_path : Bool,
) -> String {
  let items : Array[String] = []
  for e in errs {
    let mut item = "\{e.element}@\{e.argv_pos}/\{render_kind(e.kind)}"
    if with_reason {
      item = item + "/\{e.reason}"
    }
    if with_path {
      item = item + "|\{render_path(e.path)}"
    }
    items.push(item)
  }
  sort_items(items)
  "{" + join_comma(items) + "}"
}

///|
fn proj_warnings(o : Outcome) -> String {
  let ws = warnings_of(o)
  sort_items(ws)
  join_comma(ws)
}

///|
/// spec issue conformance-tried-triggers-help-entry-fields (CONFORMANCE آ§2/آ§3): DR-053 آ§4's
/// tried_triggers material as a sorted set (é †ه؛ڈé‌‍è¦ڈç¯„م€پ`proj_errors`مپ¨هگŒمپک `{a,b,c}` è،¨è¨ک â€” ç©؛é›†هگˆ
/// مپ¯ `{}` مپ«مپھم‚ٹم€Œexact trigger 0 ه€‹م€چم‚’وکژç¤؛çڑ„مپ«è،¨çڈ¾مپ™م‚‹م€پç©؛و–‡ه­—هˆ—مپ¨مپ®هڈ–م‚ٹéپ•مپˆم‚’éپ؟مپ‘م‚‹)م€‚
fn proj_tried_triggers(triggers : Array[String]) -> String {
  let items : Array[String] = []
  for t in triggers {
    items.push(t)
  }
  sort_items(items)
  "{" + join_comma(items) + "}"
}

///|
/// Result with the DR-052 result-key axis applied.
fn proj_result_export(
  sc : Scope,
  binds : Array[Binding],
  ekmap : Map[String, ExportKey],
) -> String {
  render_rval_sorted(
    build_result(
      apply_export_keys(binds, ekmap),
      accum_cells(sc, ekmap),
      apply_export_to_defaults(default_cells(sc), ekmap),
      [],
      nones=none_cells(sc),
    ),
  )
}

///|
/// Resolved value-source tags per cell (DR-031). Config_file infra cells are excluded. Flag-preset
/// defaults report `default` when no other seat surfaced (LOWERING آ§A.5). An accum cell's `Unset`
/// binding (issue 2026-07-09-accum-filters-non-set-op-semantics) reports `default` regardless of
/// its own `source` field â€” `Unset` is CLI-fired (`b.source == Cli`) but uncommitted (DR-045
/// "default ه€¤مپ¸وˆ»مپ™... committed=false"), so the value tag must reflect the LADDER OUTCOME
/// ("as if untouched", same as `unset-ladder.json`'s scalar precedent where a scalar cell's fold
/// already re-seats to a lower ladder rung on unset) rather than the firing token's own source. A
/// LATER `Set` after an `Unset` still wins normally (the loop keeps overwriting `src` in order) â€”
/// mirrors `build_result`'s ACCUMULATE fold treating `Unset` as a clear-point, not a terminal state.
fn proj_sources(
  sc : Scope,
  resolved : Array[Binding],
  ek : Map[String, ExportKey],
) -> String {
  let items : Array[String] = []
  for e in sc.entities {
    if e.is_config_file {
      continue
    }
    // DR-089 آ§3: none has no value, so it has no "source" either (çµگو‍œé‌‍وژ²è¼‰مپ¨هگŒمپک posture â€” ç™؛çپ«مپ®
    // è¦³و¸¬مپ¯ explains ه±¤مپ®ç®،وژŒمپ§م€پمپ“مپ®ه°„ه½±مپ®é–¢ه؟ƒمپ§مپ¯مپھمپ„)م€‚
    if e.ty == TNone {
      continue
    }
    // issue accum-export-key-rename-asymmetry مپ®ç¶ڑمپچ (fixture export-key/rename-multiple.json
    // مپ§ه®ںو©ںç¢؛èھچ): sources ه°„ه½±م‚‚ `proj_result_export`/`accum_cells` مپ¨هگŒمپک DR-052 آ§1 è§£و±؛
    // (`exposed_key_of`, resolve.mbt) م‚’çµŒç”±مپ•مپ›م‚‹ â€” مپ“مپ،م‚‰م‚‚ن»ٹمپ¾مپ§ `ek` م‚’ن¸€هˆ‡è¦‹مپ¦مپٹم‚‰مپڑم€پ
    // rename مپ•م‚Œمپں cell مپ® source è،ŒمپŒو—§هگچمپ®مپ¾مپ¾ه‡؛م‚‹مƒگم‚°مپ مپ£مپں (rename.json مپ¯ه…ƒم€… sources م‚’
    // و¤œè¨¼مپ—مپ¦مپ„مپھمپ‹مپ£مپںمپںم‚پé،•هœ¨هŒ–مپ—مپ¦مپ„مپھمپ‹مپ£مپں)م€‚EkNull (é€ڈéپژ) مپ® cell مپ¯ sources مپ«م‚‚ه‡؛مپ•مپھمپ„
    // (result هپ´مپ®é€ڈéپژمپ¨هگŒمپک posture)م€‚
    match exposed_key_of(e.name, ek) {
      None => ()
      Some(exposed) => {
        let mut src : String? = None
        for b in resolved {
          if b.key == e.name && !is_sentinel(b.key) {
            src = match b.op {
              Unset => Some("default")
              _ => Some(render_src(b.source))
            }
          }
        }
        match src {
          Some(s) => items.push(exposed + "=" + s)
          None =>
            // DR-044 uniform array (issue 2026-07-09-env-separator-split-gap's env-separator-
            // split.json, `sources` check): an unfired multiple/repeat cell decays to `[]` (never
            // absent, same guarantee flag/bool's default preset gets below) â€” regardless of type,
            // and regardless of whether the element ALSO declared an explicit `default:` (accum
            // cells usually don't; the empty array IS the implicit default here, unconditionally).
            if e.accum is Some(_) {
              items.push(exposed + "=default")
            } else if (e.ty == TFlag || e.ty == TBool) && e.accum is None {
              match default_scalar(e) {
                Some(_) => items.push(exposed + "=default")
                None => ()
              }
            }
        }
      }
    }
  }
  sort_items(items)
  join_comma(items)
}

///|
fn proj_sources_tree(resolved : Array[Binding]) -> String {
  let items : Array[String] = []
  for b in resolved {
    if is_sentinel(b.key) {
      continue
    }
    let mut key = ""
    for seg in b.scope {
      key = key + seg + "."
    }
    key = key + b.key
    items.push(key + "=" + render_src(b.source))
  }
  sort_items(items)
  join_comma(items)
}

// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
// SECTION 5 â€” JSON conformance runner (mirror slice json_conformance_wbtest.mbt)
// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ

// â”€â”€ skip signal â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
suberror DecodeSkip {
  DecodeSkip(String)
}

// â”€â”€ decoded case & fixture â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
enum CfgInj {
  NoCfg
  CfgObj(ConfigVal)
  CfgFiles(Array[(String, ConfigVal)])
}

///|
struct DCase {
  argv : Array[String]
  id : String
  outcome : String
  exp_effects : String?
  exp_result : String?
  // errors face: (asserted-set-string, whether fixture provided reason/path on any error, DR-066 آ§4/آ§5)
  exp_errors : String?
  exp_errors_with_reason : Bool
  exp_errors_with_path : Bool
  exp_interps : Array[String]?
  exp_warnings : String?
  exp_sources : String?
  fired_cmp : Bool
  fired_exp : String?
  // spec issue conformance-tried-triggers-help-entry-fields (CONFORMANCE آ§2/آ§3): help_entry is
  // opt-in on failure OR ambiguous (structural equality â€” a plain String? compare like fired_action's).
  help_cmp : Bool
  help_exp : String?
  // tried_triggers is opt-in on failure only, set comparison (é †ه؛ڈé‌‍è¦ڈç¯„) â€” held as the SAME
  // sorted `{a,b,c}` projection string `proj_tried_triggers` produces from the live Outcome, so
  // comparison is a plain String `!=` like every other set-compared face (errors/warnings/sources).
  tried_cmp : Bool
  tried_exp : String?
  resolve : Bool
  env : Map[String, String]
  cfg : CfgInj
}

///|
struct DecodedFixture {
  scope : Scope
  registry : Map[String, Node]
  ekmap : Map[String, ExportKey]
  cases : Array[DCase]
}

///|
enum DElem {
  DOpt(ElemDef)
  DAlias(AliasDef)
}

///|
enum DCmd {
  DCommand(CommandDef)
  DCmdAlias(AliasDef)
}

// â”€â”€ JSON helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
fn jf_str(o : Map[String, Json], key : String) -> String? {
  match o.get(key) {
    Some(j) => j.j_str()
    None => None
  }
}

///|
/// DR-067 آ§2 name/id و§‹و–‡هˆ¶ç´„ (codex ç¯€ç›®مƒ¬مƒ“مƒ¥مƒ¼وŒ‡و‘ک1, issue 2026-07-09-ref-template-result-shape):
/// `#` م‚’هگ«م‚€ name/id مپ¯مƒ¦مƒ¼م‚¶ه®ڑç¾©مپ§ç¦پو­¢ â€” repeat lowering مپ®ه†…éƒ¨ template م‚­مƒ¼
/// (`e.name + "#cons"`, installer.mbt `lower_repeat_head`)مƒ»`next_or_branch_id`'s è‡ھه‹•وژ،ç•ھ
/// ("#0"/"#1"/â€¦)مƒ»resolve.mbt مپ® row/fire sentinel ("#row"/"#fire") مپŒه…±وœ‰مپ™م‚‹ن؛ˆç´„هگچه‰چç©؛é–“
/// (DR-046 آ§4)م€‚id وœھوŒ‡ه®ڑمپھم‚‰ name مپŒ id م‚’ه…¼مپ­م‚‹ (DR-046 آ§2) مپںم‚پ name مپ«م‚‚هگŒمپکهˆ¶ç´„مپŒهڈٹمپ¶ â€” مپ“مپ“م‚’
/// enforce مپ—مپھمپ„مپ¨ `{"name": "src#cons"}` مپ®م‚ˆمپ†مپھ wire مپŒمپ‌مپ®ه†…éƒ¨م‚­مƒ¼مپ¨è،‌çھپمپ—مپ†م‚‹م€‚و—¢ه­کمپ® decode
/// error مپ¨هگŒمپکèھ‍ه½™ (`raise DecodeSkip`) مپ§ reject مپ™م‚‹م€‚ه‘¼مپ³ه‡؛مپ—هپ´مپ¯ name/id م‚’èھ­م‚“مپ م€Œمپ‌مپ®ه ´م€چمپ§
/// مپ“م‚Œم‚’é€ڑمپ™ (missing مƒپم‚§مƒƒم‚¯مپ®ç›´ه¾Œم€پن»–مƒ•م‚£مƒ¼مƒ«مƒ‰مپ® decode م‚ˆم‚ٹه‰چ â€” è¨؛و–­مپŒ name/id مپ®ه¦¥ه½“و€§مپ§و—©وœں
/// مپ«و­¢مپ¾م‚‹م‚ˆمپ†مپ«مپ™م‚‹)م€‚
fn check_reserved_name(name : String, what : String) -> Unit raise DecodeSkip {
  if name.contains("#") {
    raise DecodeSkip(
      what +
      " name/id '" +
      name +
      "' contains '#' (DR-067 آ§2: '#' مپ¯مƒ¦مƒ¼م‚¶ه®ڑç¾©مپ§ç¦پو­¢م€په†…éƒ¨ن؛ˆç´„هگچه‰چç©؛é–“)",
    )
  }
}

///|
fn has_key(o : Map[String, Json], k : String) -> Bool {
  match o.get(k) {
    Some(_) => true
    None => false
  }
}

///|
fn allowed_keys(
  o : Map[String, Json],
  allowed : Array[String],
  what : String,
) -> Unit raise DecodeSkip {
  for k, _ in o {
    if !conformance_str_in(allowed, k) {
      raise DecodeSkip(what + " has unsupported key '" + k + "'")
    }
  }
}

///|
fn bool_field(
  o : Map[String, Json],
  k : String,
  dflt : Bool,
) -> Bool raise DecodeSkip {
  match o.get(k) {
    None => dflt
    Some(j) =>
      match j.j_bool() {
        Some(b) => b
        None => raise DecodeSkip(k + " is not a bool")
      }
  }
}

///|
fn num_int(j : Json, ctx : String) -> Int raise DecodeSkip {
  match j.j_num() {
    Some(d) => d.to_int()
    None => raise DecodeSkip(ctx + " is not a number")
  }
}

///|
fn json_to_value(j : Json) -> Value raise DecodeSkip {
  match j.j_bool() {
    Some(b) => return VBool(b)
    None => ()
  }
  match j.j_str() {
    Some(s) => return VStr(s)
    None => ()
  }
  match j.j_num() {
    Some(d) => return VNum(d)
    None => ()
  }
  raise DecodeSkip("non-scalar value in effects/result")
}

///|
/// DR-083 آ§1: a declared `"default"` decodes to the length-1-degenerate array uniformly â€” a bare
/// JSON scalar lifts to a single-piece array (`[v]`), a JSON array decodes elementwise (one Value
/// per already-split piece, DR-083 آ§2). Which shape is STRUCTURALLY legal for a given element
/// (scalar element â‡’ length must end up 1) is a definition-time check, NOT a decode-time gate â€”
/// `collect_scalar_array_default` (installer.mbt) is the one that rejects a >1-length default on a
/// non-accum element; this decoder accepts either JSON shape unconditionally.
fn json_to_default_values(j : Json) -> Array[Value] raise DecodeSkip {
  match j.j_arr() {
    Some(a) => {
      let vs : Array[Value] = []
      for it in a {
        vs.push(json_to_value(it))
      }
      vs
    }
    None => [json_to_value(j)]
  }
}

///|
fn json_to_rval(j : Json) -> RVal raise DecodeSkip {
  match j.j_obj() {
    Some(o) => {
      let kvs : Array[(String, RVal)] = []
      for k, v in o {
        kvs.push((k, json_to_rval(v)))
      }
      return RObj(kvs)
    }
    None => ()
  }
  match j.j_arr() {
    Some(a) => {
      let vs : Array[RVal] = []
      for v in a {
        vs.push(json_to_rval(v))
      }
      return RArr(vs)
    }
    None => ()
  }
  RScalar(json_to_value(j))
}

///|
fn json_to_configval(j : Json) -> ConfigVal {
  match j.j_obj() {
    Some(o) => {
      let kvs : Array[(String, ConfigVal)] = []
      for k, v in o {
        kvs.push((k, json_to_configval(v)))
      }
      return CObj(kvs)
    }
    None => ()
  }
  match j.j_arr() {
    Some(a) => {
      let vs : Array[ConfigVal] = []
      for v in a {
        vs.push(json_to_configval(v))
      }
      return CArr(vs)
    }
    None => ()
  }
  match j.j_bool() {
    Some(b) => return CBool(b)
    None => ()
  }
  match j.j_str() {
    Some(s) => return CStr(s)
    None => ()
  }
  match j.j_num() {
    Some(d) => return CNum(d)
    None => ()
  }
  CNull
}

///|
fn dec_strs(j : Json?) -> Array[String] raise DecodeSkip {
  match j {
    None => []
    Some(x) =>
      match x.j_str() {
        Some(s) => [s]
        None =>
          match x.j_arr() {
            Some(a) => {
              let r : Array[String] = []
              for e in a {
                match e.j_str() {
                  Some(s) => r.push(s)
                  None =>
                    raise DecodeSkip("string-array element is not a string")
                }
              }
              r
            }
            None => raise DecodeSkip("expected a string or string[]")
          }
      }
  }
}

///|
/// Decode a filters-chain field (`piece_filters`/`value_filters`/`cell_filters`, DR-009 آ§DSL و–‡و³•)
/// into `Array[FilterSpelling]` (node.mbt, issue filter-spelling-inband-encoding-retyping): same
/// shape as `dec_strs` (a string, or a string[]), but each array element may ALSO be the DR-085 آ§3
/// / DESIGN آ§8.4 object form `{"name": ..., "args": [...]}` â€” needed when a filter's own arg
/// contains a colon (e.g. `regex_match`'s `^https?://` pattern breaks the colon-shorthand DSL's
/// all-colon-split rule, DR-009). Both forms decode to the SAME `FilterSpelling` struct (colon
/// shorthand â†’ `filters.mbt`'s `parse_filter_shorthand`, object form â†’ `name`/`args` read straight
/// off the JSON object) â€” no in-band string encoding is needed since the result type carries `args`
/// as a real `Array[String]`, replacing the earlier U+E000 PUA-tag single-string encoding that
/// shared `Array[String]` with plain shorthand strings (that scheme had a latent hole: an object-
/// form arg VALUE containing the tag character itself would have mis-split). `dec_strs` itself is
/// intentionally NOT reused here: it's shared by `requires`/`conflicts_with`/`exclusive_group`/
/// `env`/`targets`/`members`, none of which have an object form â€” this is a sibling decoder
/// specific to the 3 filter-chain fields, not a generalized replacement.
fn dec_filter_chain(j : Json?) -> Array[FilterSpelling] raise DecodeSkip {
  match j {
    None => []
    Some(x) =>
      match x.j_str() {
        Some(s) => [parse_filter_shorthand(s)]
        None =>
          match x.j_arr() {
            Some(a) => {
              let r : Array[FilterSpelling] = []
              for e in a {
                match e.j_str() {
                  Some(s) => r.push(parse_filter_shorthand(s))
                  None =>
                    match e.j_obj() {
                      Some(o) => {
                        allowed_keys(
                          o,
                          ["name", "args"],
                          "filter (object form)",
                        )
                        let name = match jf_str(o, "name") {
                          Some(n) => n
                          None =>
                            raise DecodeSkip(
                              "filter object form missing 'name'",
                            )
                        }
                        let args = match o.get("args") {
                          Some(aj) =>
                            match aj.j_arr() {
                              Some(aa) => {
                                let out : Array[String] = []
                                for av in aa {
                                  match av.j_str() {
                                    Some(s) => out.push(s)
                                    None =>
                                      raise DecodeSkip(
                                        "filter object form 'args' element is not a string",
                                      )
                                  }
                                }
                                out
                              }
                              None =>
                                raise DecodeSkip(
                                  "filter object form 'args' is not an array",
                                )
                            }
                          None => []
                        }
                        r.push({ name, args })
                      }
                      None =>
                        raise DecodeSkip(
                          "filter chain element is not a string or object",
                        )
                    }
                }
              }
              r
            }
            None =>
              raise DecodeSkip(
                "expected a string or filter[] (string | object form)",
              )
          }
      }
  }
}

// â”€â”€ expected-string builders â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
fn exp_effects_str(eff : Json) -> String raise DecodeSkip {
  let a = match eff.j_arr() {
    Some(x) => x
    None => raise DecodeSkip("effects is not an array")
  }
  let items : Array[String] = []
  for e in a {
    let eo = match e.j_obj() {
      Some(x) => x
      None => raise DecodeSkip("effect is not an object")
    }
    let entity = match jf_str(eo, "entity") {
      Some(s) => s
      None => raise DecodeSkip("effect missing 'entity'")
    }
    let op = match jf_str(eo, "op") {
      Some(s) => s
      None => raise DecodeSkip("effect missing 'op'")
    }
    let source = match jf_str(eo, "source") {
      Some(s) => s
      None => raise DecodeSkip("effect missing 'source'")
    }
    // DR-077 آ§1: an `update` effect's descriptor carries a `transform` name alongside `op` (mirrors
    // the wire effect descriptor `{op:"update", transform:"increment"}`) â€” folded into the SAME
    // op-string `eff_op`/`lower_eff_op` render for the 0-arg case ("update:increment"), so a fixture
    // needs no separate comparison branch. Absent for every other op (unaffected).
    let op_str = match jf_str(eo, "transform") {
      Some(t) => op + ":" + t
      None => op
    }
    match eo.get("operand") {
      Some(j) =>
        items.push(
          "\{entity}:\{op_str}(\{render_val(json_to_value(j))})@\{source}",
        )
      None => items.push("\{entity}:\{op_str}@\{source}")
    }
  }
  join_comma(items)
}

///|
fn exp_result_str(res : Json) -> String raise DecodeSkip {
  render_rval_sorted(json_to_rval(res))
}

///|
/// Decode a fixture error's `path` array (DR-066 آ§4, root-first) into the same `>`-joined token
/// `render_path` produces on the got side, so string comparison lines up.
fn exp_error_path(eo : Map[String, Json]) -> String raise DecodeSkip {
  match eo.get("path") {
    Some(j) =>
      match j.j_arr() {
        Some(segs) => {
          let parts : Array[String] = []
          for s in segs {
            match s.j_str() {
              Some(str) => parts.push(str)
              None => raise DecodeSkip("error 'path' element is not a string")
            }
          }
          render_path(parts)
        }
        None => raise DecodeSkip("error 'path' is not an array")
      }
    None => "" // absent on a specific error â€” compare against empty ([]) path on got side
  }
}

///|
/// Decode the fixture's errors[] and report the sorted set-string plus whether any error had a
/// `reason` and/or `path` field (DR-066 آ§4/آ§5, each an INDEPENDENT per-fixture-set opt-in):
/// with_reason / with_path drive got-side inclusion so the per-field opt-in comparison stays aligned.
fn exp_errors_decode(errs : Json) -> (String, Bool, Bool) raise DecodeSkip {
  let a = match errs.j_arr() {
    Some(x) => x
    None => raise DecodeSkip("errors is not an array")
  }
  // detect reason/path opt-in first (per fixture set, not per element)
  let mut with_reason = false
  let mut with_path = false
  for e in a {
    match e.j_obj() {
      Some(eo) => {
        if has_key(eo, "reason") {
          with_reason = true
        }
        if has_key(eo, "path") {
          with_path = true
        }
      }
      None => raise DecodeSkip("error is not an object")
    }
  }
  let items : Array[String] = []
  for e in a {
    let eo = e.j_obj().unwrap()
    let element = match jf_str(eo, "element") {
      Some(s) => s
      None => ""
    }
    let pos = match eo.get("argv_pos") {
      Some(j) =>
        match j.j_num() {
          Some(d) => d.to_int().to_string()
          None => raise DecodeSkip("error 'argv_pos' is not a number")
        }
      None => raise DecodeSkip("error missing 'argv_pos'")
    }
    let kind = match jf_str(eo, "kind") {
      Some(s) => s
      None => raise DecodeSkip("error missing 'kind'")
    }
    let mut item = "\{element}@\{pos}/\{kind}"
    if with_reason {
      let reason = match jf_str(eo, "reason") {
        Some(s) => s
        None => "" // absent on a specific error â€” compare against empty reason on got side
      }
      item = item + "/\{reason}"
    }
    if with_path {
      item = item + "|\{exp_error_path(eo)}"
    }
    items.push(item)
  }
  sort_items(items)
  ("{" + join_comma(items) + "}", with_reason, with_path)
}

///|
fn exp_warnings_str(j : Json) -> String raise DecodeSkip {
  let a = match j.j_arr() {
    Some(x) => x
    None => raise DecodeSkip("warnings is not an array")
  }
  let items : Array[String] = []
  for e in a {
    let eo = match e.j_obj() {
      Some(x) => x
      None => raise DecodeSkip("warning is not an object")
    }
    match jf_str(eo, "element") {
      Some(el) => items.push(el)
      None => raise DecodeSkip("warning missing 'element'")
    }
  }
  sort_items(items)
  join_comma(items)
}

///|
fn exp_sources_str(j : Json) -> String raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("sources is not an object")
  }
  let items : Array[String] = []
  for k, v in o {
    let src = match v.j_str() {
      Some(s) => s
      None => raise DecodeSkip("source value is not a string")
    }
    items.push(k + "=" + src)
  }
  sort_items(items)
  join_comma(items)
}

///|
fn exp_claimants_str(j : Json) -> String raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("claimants is not an object")
  }
  let items : Array[String] = []
  for k, v in o {
    let ent = match v.j_str() {
      Some(s) => s
      None =>
        raise DecodeSkip("claimant value (occupying entity) is not a string")
    }
    items.push(k + "=" + ent)
  }
  sort_items(items)
  "{" + join_comma(items) + "}"
}

///|
fn exp_interp_str(e : Json) -> String raise DecodeSkip {
  match e.j_obj() {
    Some(o) =>
      if has_key(o, "claimants") {
        allowed_keys(o, ["result", "claimants"], "interpretation wrapper")
        let view = match o.get("result") {
          Some(r) => render_rval_sorted(json_to_rval(r))
          None => raise DecodeSkip("interpretation wrapper missing 'result'")
        }
        view + "#claimants" + exp_claimants_str(o.get("claimants").unwrap())
      } else {
        render_rval_sorted(json_to_rval(e))
      }
    None => render_rval_sorted(json_to_rval(e))
  }
}

///|
fn dec_interps(j : Json) -> Array[String] raise DecodeSkip {
  let a = match j.j_arr() {
    Some(x) => x
    None => raise DecodeSkip("interpretations is not an array")
  }
  let out : Array[String] = []
  for e in a {
    out.push(exp_interp_str(e))
  }
  sort_items(out)
  out
}

// â”€â”€ definition decoders â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
fn dec_short(o : Map[String, Json]) -> Array[Char] raise DecodeSkip {
  match o.get("short") {
    None => []
    Some(j) =>
      match j.j_str() {
        Some(s) => to_chars(s)
        None =>
          match j.j_arr() {
            Some(a) => {
              let cs : Array[Char] = []
              for e in a {
                match e.j_str() {
                  Some(s) =>
                    for c in to_chars(s) {
                      cs.push(c)
                    }
                  None => raise DecodeSkip("short[] element is not a string")
                }
              }
              cs
            }
            None => raise DecodeSkip("short is a bool/other (stage 2)")
          }
      }
  }
}

///|
/// DR-074 آ§3: `"flag"` is a presence-only trigger (`TFlag`, no `=value` form ever â€” e.g. `--help`);
/// `"bool"` is the value-typed canonical bool (`TBool`, additionally takes `--x=value` unless it
/// carries variant spellings, installer.mbt `inst_long`). The two JSON type strings map to
/// DIFFERENT Ty variants now (they used to collapse to one `TFlag`, which made a value-typed
/// bool's `--enabled=true` eq-split unreachable â€” see fixtures/value-typing/bool-canonical.json).
/// Likewise DR-074 آ§1: `"number"` (`TNum`, rejects inf) and `"float"` (`TFloat`, accepts inf) map to
/// DIFFERENT Ty variants (they used to collapse to one `TNum` â€” see
/// fixtures/value-typing/number-inf-nan.json's `--t`/`--n` type-dependent inf acceptهںں).
fn dec_ty(t : String) -> Ty raise DecodeSkip {
  match t {
    "string" => TStr
    "number" => TNum
    "float" => TFloat
    "int" => TInt
    "flag" => TFlag
    "bool" => TBool
    // DR-077 آ§3: `"count"` is the PRE-normalize marker (mirrors `"flag"` â†’ `TFlag`) â€” installer.mbt
    // collapses it to `TNum` at `ensure_entity`, not here (decode's only job is the wire type
    // string â†’ Ty tag, same as every other arm).
    "count" => TCount
    // DR-089 آ§2: type:"none" مپ¯ç¬¬ن¸€ç´ڑ â€” ه€¤ç©؛é–“مپŒç©؛مپ®ه‍‹ (çœپç•¥مپ®وکژç¤؛ç¶´م‚ٹم€پهگŒمپکم‚؟م‚°مپ«è§£و±؛مپ™م‚‹)م€‚
    "none" => TNone
    other => raise DecodeSkip("value type '" + other + "'")
  }
}

///|
/// DR-061 آ§3 configurable factory مپ® type shadow: user ه®ڑç¾©مپ®ه‍‹هگچم‚’ base Ty + parse ç›¸ config مپ«
/// è§£و±؛مپ™م‚‹م€‚fixture مپ® `definitions.types.<name>` â†’ TypeShadow مپ® map مپ§ن؟‌وŒپمپ—م€پdec_option /
/// dec_positional مپ® `type: "<name>"` è§£و±؛مپ§ consultation مپ™م‚‹م€‚canonical ه‍‹هگچ (string/number/int/...)
/// مپ¯ shadow مپ§ override هڈ¯èƒ½مپ مپŒوœ¬ fixture مپ§مپ¯وœھن½؟ç”¨ (`int_parser`/`number_parser`/`bool_parser`
/// factory مپ®مپ؟و‰±مپ†)م€‚
struct TypeShadow {
  base : Ty
  int_round : RoundMode
  // DR-074 آ§2 `number_allow_base_prefix` (`number_parser` factory config)م€‚canonical default = falseم€‚
  // TypeShadow مپŒو‹…مپ† base هپ´مپ® flag مپ¯ canonical default مپŒ false مپھمپ®مپ§م€پint_round مپ¨ç›´ن؛¤مپھه¹³ه‌¦م‚­مƒ¼م€‚
  allow_base_prefix : Bool
  // DR-074 آ§4 `bool_parser` factory config (`true_values`/`false_values`/`case_insensitive` م‚’ 1
  // struct مپ«و‌ںمپ­مپں carrierم€پElemDef.bool_config مپ¨هگŒه‍‹)م€‚canonical default = `bool_config_canonical()`م€‚
  bool_config : BoolConfig
} derive(Eq, Debug)

///|
/// Decode `definitions.types` (DR-061 آ§3 `{name: <factory>, config: {<key>: <value>, ...}}`) into
/// a shadow map. هگ„ shadow مپ¯ base Ty (factory هگچمپ‹م‚‰ه°ژه‡؛) مپ¨ه¹³ه‌¦ config م‚­مƒ¼مپ§و§‹وˆگمپ•م‚Œم‚‹م€‚
/// çڈ¾çٹ¶م‚µمƒ‌مƒ¼مƒˆ: `int_parser` (base = TIntم€پconfig = `int_round`)م€پ`number_parser` (base = TNumم€پ
/// config = `number_allow_base_prefix`)م€پ`bool_parser` (base = TBoolم€پconfig = `true_values` /
/// `false_values` / `case_insensitive`م€پDR-074 آ§3/آ§4)م€‚ن»–مپ® factory هگچمپ¯ DecodeSkip مپ§وکژç¤؛çڑ„مپ«
/// unsupported و‰±مپ„ (typo و¤œه‡؛م€پDR-061 آ§4 مپ¯ factory è‡ھè؛«مپŒ config ه€¤م‚’و¤œè¨¼مپ™م‚‹è¦ڈه®ڑمپھمپ®مپ§م€پ
/// type/factory èھچè­کمپ®مپ“مپ®ه±¤مپ¯ capability gate مپ¨مپ—مپ¦وŒ¯م‚‹èˆ‍مپ†)م€‚
///
/// DR-094 آ§3/آ§9 و،ˆA: factory هگچمپ¯ `<bare>` (builtin ns مپ®ç³–è،£) / `builtin/<bare>` (ns وکژç¤؛) مپ®
/// 2 ه½¢مپŒهگŒن¸€ه®ںن½“مپ«è§£و±؛مپ•م‚Œم‚‹م€‚و—§ ad-hoc prefix `kuu_<bare>` مپ¯ fixture pin bump (37aa3b3d) ه®Œن؛†مپ«
/// ن¼´مپ„ç§»è،Œوœںé–“م‚’çµ‚مپˆم€پunsupported factory مپ¨مپ—مپ¦وکژç¤؛çڑ„مپ«و‹’هگ¦مپ•م‚Œم‚‹ (unknown-vocab مپ®ن¸€éƒ¨م€پ
/// DR-054)م€‚
fn dec_types(j : Json) -> Map[String, TypeShadow] raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("definitions.types is not an object")
  }
  let out : Map[String, TypeShadow] = Map([])
  for name, tj in o {
    let to = match tj.j_obj() {
      Some(x) => x
      None =>
        raise DecodeSkip(
          "definitions.types[" +
          name +
          "] is not an object (expected {name, config})",
        )
    }
    allowed_keys(to, ["name", "config"], "type shadow")
    let factory = match jf_str(to, "name") {
      Some(s) => s
      None =>
        raise DecodeSkip(
          "definitions.types[" + name + "] missing factory 'name'",
        )
    }
    match factory {
      "int_parser" | "builtin/int_parser" => {
        // DR-075 آ§2 int_round (10 مƒ¢مƒ¼مƒ‰èھ‍ه½™م€پround_mode_of مپ§è§£و±؛) + DR-074 آ§2 مپ® (int مپ«م‚‚و³¢هڈٹمپ™م‚‹)
        // `number_allow_base_prefix`م€‚config وœھوŒ‡ه®ڑمپ¯ canonical default (RError + false)م€‚
        let mut mode = RError
        let mut base_prefix = false
        match to.get("config") {
          Some(cj) => {
            let co = match cj.j_obj() {
              Some(x) => x
              None =>
                raise DecodeSkip(
                  "definitions.types[" + name + "].config is not an object",
                )
            }
            allowed_keys(
              co,
              ["int_round", "number_allow_base_prefix"],
              "int_parser config",
            )
            match co.get("int_round") {
              Some(vj) =>
                match vj.j_str() {
                  Some(s) =>
                    match round_mode_of(s) {
                      Some(m) => mode = m
                      None =>
                        raise DecodeSkip(
                          "definitions.types[" +
                          name +
                          "].config.int_round '" +
                          s +
                          "' is not a canonical RoundMode",
                        )
                    }
                  None =>
                    raise DecodeSkip(
                      "definitions.types[" +
                      name +
                      "].config.int_round is not a string",
                    )
                }
              None => ()
            }
            match co.get("number_allow_base_prefix") {
              Some(vj) =>
                match vj.j_bool() {
                  Some(b) => base_prefix = b
                  None =>
                    raise DecodeSkip(
                      "definitions.types[" +
                      name +
                      "].config.number_allow_base_prefix is not a bool",
                    )
                }
              None => ()
            }
          }
          None => ()
        }
        out.set(name, {
          base: TInt,
          int_round: mode,
          allow_base_prefix: base_prefix,
          bool_config: bool_config_canonical(),
        })
      }
      "number_parser" | "builtin/number_parser" => {
        // DR-074 آ§2 `number_allow_base_prefix` = çµ±هگˆ opt-in مپ§ 0x/0o/0b + hex float ن¸€و‹¬وœ‰هٹ¹هŒ–
        // (هچکن¸€ flagم€پcanonical default false)م€‚ن»– config م‚­مƒ¼ (`number_thousand_sep` /
        // `number_leading_zero`) مپ¯وœ¬ substrate وœھم‚µمƒ‌مƒ¼مƒˆ (fixture مپŒن½؟م‚ڈمپھمپ„مپںم‚پ)م€‚
        let mut base_prefix = false
        match to.get("config") {
          Some(cj) => {
            let co = match cj.j_obj() {
              Some(x) => x
              None =>
                raise DecodeSkip(
                  "definitions.types[" + name + "].config is not an object",
                )
            }
            allowed_keys(
              co,
              ["number_allow_base_prefix"],
              "number_parser config",
            )
            match co.get("number_allow_base_prefix") {
              Some(vj) =>
                match vj.j_bool() {
                  Some(b) => base_prefix = b
                  None =>
                    raise DecodeSkip(
                      "definitions.types[" +
                      name +
                      "].config.number_allow_base_prefix is not a bool",
                    )
                }
              None => ()
            }
          }
          None => ()
        }
        out.set(name, {
          base: TNum,
          int_round: RError,
          allow_base_prefix: base_prefix,
          bool_config: bool_config_canonical(),
        })
      }
      "bool_parser" | "builtin/bool_parser" => {
        // DR-074 آ§3/آ§4 bool_parser factory config: `true_values`/`false_values`/`case_insensitive`
        // مپ® 3 ه¹³ه‌¦ config م‚­مƒ¼م€‚canonical default مپ¯و—¢ه­ک parse_bool مپ¨هگŒه€¤
        // (bool_config_canonical())م€پوœھوŒ‡ه®ڑم‚­مƒ¼مپ¯مپ‌م‚Œمپ‍م‚Œمپ® default م‚’ه€‹هˆ¥مپ«ç¶­وŒپمپ™م‚‹ (3 م‚­مƒ¼ç‹¬ç«‹
        // override â€” 1 م‚­مƒ¼مپ مپ‘ opt-in مپ—مپ¦م‚‚ن»–مپ® 2 م‚­مƒ¼مپ¯ canonical مپ®مپ¾مپ¾م€پDR-061 آ§4 مپ®ه¹³ه‌¦
        // config م‚­مƒ¼هژںه‰‡مپ¨هگŒمپکم€Œم‚­مƒ¼هچکن½چمپ§ç‹¬ç«‹م€چمپ®و‰±مپ„م€پint_parser/number_parser مپ¨هگŒه‍‹)م€‚
        let canon = bool_config_canonical()
        let mut true_values = canon.true_values
        let mut false_values = canon.false_values
        let mut case_insensitive = canon.case_insensitive
        match to.get("config") {
          Some(cj) => {
            let co = match cj.j_obj() {
              Some(x) => x
              None =>
                raise DecodeSkip(
                  "definitions.types[" + name + "].config is not an object",
                )
            }
            allowed_keys(
              co,
              ["true_values", "false_values", "case_insensitive"],
              "bool_parser config",
            )
            match co.get("true_values") {
              Some(vj) => true_values = dec_str_array(vj, name, "true_values")
              None => ()
            }
            match co.get("false_values") {
              Some(vj) => false_values = dec_str_array(vj, name, "false_values")
              None => ()
            }
            match co.get("case_insensitive") {
              Some(vj) =>
                match vj.j_bool() {
                  Some(b) => case_insensitive = b
                  None =>
                    raise DecodeSkip(
                      "definitions.types[" +
                      name +
                      "].config.case_insensitive is not a bool",
                    )
                }
              None => ()
            }
          }
          None => ()
        }
        out.set(name, {
          base: TBool,
          int_round: RError,
          allow_base_prefix: false,
          bool_config: { true_values, false_values, case_insensitive },
        })
      }
      other =>
        raise DecodeSkip(
          "definitions.types[" +
          name +
          "] unsupported factory '" +
          other +
          "' (only int_parser / number_parser / bool_parser are wired in the current substrate)",
        )
    }
  }
  out
}

///|
/// DR-078 آ§1 `definitions.templates`: name â†’ shared consumption-grammar `Node`, decoded straight
/// into the `registry` a `ref` element's head resolves against (`ElemDef.ref_target`/`elem_head`,
/// installer.mbt â€” this decode is the ONLY missing piece, the runtime side was already complete).
/// Mutates `registry` in place (same map `dec_fixture` later threads into `parse_definition`) rather
/// than returning a fresh map â€” `registry` also receives `parse_definition`'s OWN repeat-recursion
/// entries later (`init_sb`), so it has to be the single shared mutable instance throughout, not a
/// value merged in afterward.
fn dec_templates(
  j : Json,
  shadows : Map[String, TypeShadow],
  registry : Map[String, Node],
) -> Unit raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("definitions.templates is not an object")
  }
  for name, tj in o {
    check_reserved_name(name, "definitions.templates")
    registry.set(name, dec_template_body(tj, shadows))
  }
}

///|
/// One `definitions.templates` entry's body (DR-078 آ§1 "ه€¤مپ¯è¦پç´ ه®ڑç¾©مپ¨هگŒمپکو§‹é€ è¨کو³• (or / seq /
/// è£¸و–‡ه­—هˆ—ç­‰م€پLOWERING آ§A ç¾¤مپ®ç³–è،£مپŒمپ‌مپ®مپ¾مپ¾هٹ¹مپڈ)"). Three shapes, mirroring `dec_or_structural`'s
/// own branch-shape handling (آ§1's example is literally an `or` of a `seq` branch + a bare-leaf
/// branch â€” this reuses that SAME decoder + `or_branch_node`, installer.mbt, rather than
/// duplicating the or/seq/leaf grammar a second time):
///   `{"or": [...]}`   â€” structural or (DR-055 value-enum `or` form is rejected: a template's
///                       job is a shared CONSUMPTION grammar, not a constraint-declaration sugar)
///   `{"seq": [...]}`  â€” a bare sequence of leaf cells (no outer `or`)
///   `{"type":..,"name":..}` â€” a single bare leaf cell (no `seq` wrapper, DR-078 آ§1 "è£¸و–‡ه­—هˆ—ç­‰")
fn dec_template_body(
  j : Json,
  shadows : Map[String, TypeShadow],
) -> Node raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("definitions.templates entry is not an object")
  }
  match o.get("or") {
    Some(orj) => {
      allowed_keys(o, ["or"], "template body (or)")
      match dec_or_structural(orj, shadows) {
        Some(branches) => {
          let nodes : Array[Node] = []
          for br in branches {
            nodes.push(or_branch_node(br))
          }
          Or(nodes)
        }
        None =>
          raise DecodeSkip(
            "definitions.templates 'or' has no structural branches (DR-055 value-enum form is option-only, not a shared consumption template)",
          )
      }
    }
    None =>
      match o.get("seq") {
        Some(sj) => {
          allowed_keys(o, ["seq"], "template body (seq)")
          let sa = match sj.j_arr() {
            Some(x) => x
            None => raise DecodeSkip("template body 'seq' is not an array")
          }
          let nodes : Array[Node] = []
          for e in sa {
            nodes.push(elem_head(dec_or_leaf(e, shadows)))
          }
          Seq(nodes)
        }
        None => elem_head(dec_or_leaf(j, shadows)) // bare leaf {"type":..,"name":..}
      }
  }
}

///|
/// wire bool|array long â†’ `LongDecl`, UNCHANGED â€” this is decode's entire responsibility for `long`
/// now (kawaz è£په®ڑ 2026-07-08): the two-form distinction (DR-071 آ§1) is preserved as data instead of
/// being collapsed into an `Array[String]` here, because collapsing it destroys information
/// `resolve_long` (installer.mbt) needs (a bare `long:true` and an explicit `long:[":set"]` decode to
/// the SAME `[":set"]` array, yet DR-076 آ§2 requires DIFFERENT flag sugar for each). Type-dependent
/// sugar expansion, colon-DSL classification, and syntax-error detection all moved to installer.mbt's
/// `resolve_long` / `collect_invalid_long_dsl` â€” decode only mirrors the wire shape.
fn dec_long(j : Json) -> LongDecl raise DecodeSkip {
  match j.j_bool() {
    Some(b) => LBool(b)
    None =>
      match j.j_arr() {
        Some(a) => {
          let strs : Array[String] = []
          for e in a {
            match e.j_str() {
              Some(s) => strs.push(s)
              None => raise DecodeSkip("long[] element is not a string")
            }
          }
          LList(strs)
        }
        None => raise DecodeSkip("long is not a bool/array")
      }
  }
}

///|
fn dec_repeat(j : Json) -> RepeatSpec raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("repeat is not an object")
  }
  allowed_keys(o, ["min", "max", "lazy"], "repeat")
  let min = match o.get("min") {
    Some(m) => num_int(m, "repeat.min")
    None => 0
  }
  let max = match o.get("max") {
    Some(m) => Some(num_int(m, "repeat.max"))
    None => None
  }
  let lazy_ = bool_field(o, "lazy", false)
  { min, max, lazy_ }
}

///|
/// The DR-036 `collector` vocab this decode layer actually wires end-to-end (issue
/// 2026-07-09-dec-multiple-collector-decode). `unwrap_single` has a real runtime (resolve.mbt's
/// `apply_collector`/`unwrap_single`, applied to the accum cell's final array in `build_result`).
/// `to_set`/`from_entries` are DR-036 registry presets but NOT reachable through this simple
/// by-name field: `to_set` has no runtime implementation at all yet, and `from_entries` (DR-044)
/// takes a shape config (`FromEntries`: Entries/KeyValue/KeyPromote) this single-string field can't
/// carry â€” accepting either name here would decode successfully but silently render the plain
/// array at runtime (a decode/runtime capability mismatch), so both are explicitly rejected with a
/// reason instead of falling into the generic "unknown" message.
fn known_collector(name : String) -> Bool {
  name == "unwrap_single"
}

///|
/// DR-036 `multiple`. Returns (fires, separator, collector). The `accumulator` key's accepted
/// vocab stays "append"-only (issue acceptance criterion هˆ¤و–­: DR-036 also lists merge/override/
/// increment/flatten, but `installer.mbt`'s `ensure_entity` hardcodes the accum registry entry
/// from `e.multiple`/`elem_repeat`/`e.separator` alone â€” it never reads the decoded accumulator
/// string. Accepting a wider vocab here would decode successfully while installer.mbt silently
/// keeps treating every multiple cell as plain "append", a decode/runtime mismatch of the same
/// kind `known_collector`'s doc comment describes for `to_set`/`from_entries`. Widening this needs
/// `ensure_entity` to actually consult the accumulator name first).
/// DR-080 آ§1: "merge" م‚’ accumulator èھ‍ه½™مپ«è؟½هٹ  (append مپ®ه…„ه¼ں)م€‚وˆ»م‚ٹه€¤مپ®4ç•ھç›® (accumulator هگچ)
/// مپ¯ None = وœھوŒ‡ه®ڑ (`ensure_entity` مپŒو—¢ه®ڑ "append" مپ«مƒ•م‚©مƒ¼مƒ«مƒگمƒƒم‚¯)م€پSome("merge") مپŒ DR-080 مپ®
/// merge accumulator م‚’éپ¸مپ¶م€‚bool/string ç³–è،£ (`true`/`"append"`) مپ¯ه¸¸مپ« "append" ç›¸ه½“ (accumulator
/// هگچ None = مƒ‡مƒ•م‚©مƒ«مƒˆ) â€” merge مپ¯ object ه½¢مپ® `accumulator` م‚­مƒ¼مپ§مپ®مپ؟éپ¸مپ¹م‚‹ (DR-080 آ§1 مپ®ه®£è¨€ن¾‹)م€‚
/// DR-091 آ§2: "kv_map" م‚’هگŒمپکو‍  (object ه½¢مپ® `accumulator` م‚­مƒ¼é™گه®ڑ) مپ«è؟½هٹ  â€” `installer.mbt`'s
/// `value_prim`/`elem_head`/`inst_long` main entry مپŒ `Some("kv_map")` م‚’è¦‹مپ¦ `KvArg` م‚’ emit مپ—م€پ
/// `resolve.mbt`'s `build_result` مپŒ `AccumCell.accum == "kv_map"` م‚’è¦‹مپ¦ç•³مپ؟çµگو‍œم‚’ RObj مپ«مپ™م‚‹
/// (merge مپ¨هگŒمپکم€Œه®£è¨€م‚’مپ‌مپ®مپ¾مپ¾ Entity.accum مپ¸é€ڑمپ™م€چçµŒè·¯م€پمپ“مپ“مپ¯هڈ—çگ†مپ™م‚‹مپ مپ‘)م€‚
fn dec_multiple(j : Json) -> (Bool, String?, String?, String?) raise DecodeSkip {
  match j.j_bool() {
    Some(b) => return (b, None, None, None)
    None => ()
  }
  match j.j_str() {
    Some("append") => return (true, None, None, None)
    Some(other) => raise DecodeSkip("multiple preset '" + other + "'")
    None => ()
  }
  match j.j_obj() {
    Some(o) => {
      allowed_keys(o, ["accumulator", "separator", "collector"], "multiple")
      let accumulator = match jf_str(o, "accumulator") {
        Some("append") => None // و—¢ه®ڑمپ¨هگŒç¾© â€” Entity.accum مپ¸مپ®ه†™مپ—مپ¯ ensure_entity مپŒ "append" مپ«مƒ•م‚©مƒ¼مƒ«مƒگمƒƒم‚¯
        Some("merge") => Some("merge")
        Some("kv_map") => Some("kv_map")
        Some(a) => raise DecodeSkip("multiple.accumulator '" + a + "'")
        None => None
      }
      let collector = match jf_str(o, "collector") {
        Some(c) =>
          if known_collector(c) {
            Some(c)
          } else {
            raise DecodeSkip(
              "multiple.collector '" + c + "' has no wired runtime yet",
            )
          }
        None => None
      }
      (true, jf_str(o, "separator"), collector, accumulator)
    }
    None => raise DecodeSkip("multiple is not a bool/string/object")
  }
}

///|
fn dec_export(j : Json) -> ExportKey {
  match j.j_str() {
    Some("") => EkNull
    Some(s) => EkKey(s)
    None => EkNull
  }
}

///|
fn dec_alias(o : Map[String, Json]) -> AliasDef raise DecodeSkip {
  allowed_keys(
    o,
    ["alias", "name", "short", "long", "deprecated", "type"],
    "alias",
  )
  let target = match jf_str(o, "alias") {
    Some(t) => t
    None => raise DecodeSkip("alias missing target")
  }
  let name = jf_str(o, "name")
  match name {
    Some(n) => check_reserved_name(n, "alias")
    None => ()
  }
  let short = dec_short(o)
  // DR-076 آ§2 flag ه·®مپ—و›؟مپˆ/è£œه®Œمپ® alias هپ´éپ©ç”¨ (issue 2026-07-08 dec-alias-long-override-flag-
  // sugar-gap): decode مپ¯مپ“مپ“مپ§م‚‚ canonical هپ´مپ® dec_long مپ¨هگŒمپکمپڈ wire مپ® bool|array ن؛Œه½¢م‚’
  // `LongDecl` مپ«مپ‌مپ®مپ¾مپ¾ه†™مپ™مپ مپ‘ â€” ه‍‹ن¾‌ه­کمپ®ç³–è،£è§£é‡ˆمپ¯ installer.mbt مپ® desugar_aliases
  // (resolve_long çµŒç”±) مپŒو‹…مپ†م€‚
  let long_override : LongDecl? = match o.get("long") {
    Some(lj) => Some(dec_long(lj))
    None => None
  }
  let deprecated = bool_field(o, "deprecated", false)
  { target, name, short, long_override, deprecated }
}

///|
/// DR-055 value-enum ه½¢ه¼ڈمپ® or و‍‌م‚’ decode مپ—م€پ(1) enum و¶ˆè²»و§‹é€ ç”¨مپ®ه…¨ exact ه€¤ (requires مپ®وœ‰ç„،م‚’
/// ه•ڈم‚ڈمپھمپ„ â€” issue values-decode-support, BEnum مپ® `dec_option` ه‘¼مپ³ه‡؛مپ—مپŒن½؟مپ†) مپ¨ (2) هˆ¶ç´„ç”¨مپ®
/// value_requires (requires م‚’وŒپمپ¤و‍‌مپ مپ‘) مپ®ن¸،و–¹م‚’1مƒ‘م‚¹مپ§è؟”مپ™م€‚ه¾“و‌¥مپ¯ (2) مپ مپ‘م‚’è؟”مپ—مپ¦مپ„مپںمپŒم€پن»ٹه›‍
/// values/or مپ®و¶ˆè²»و„ڈه‘³è«–م‚’هگˆوµپمپ•مپ›م‚‹مپ«مپ‚مپںم‚ٹهگŒمپکèµ°وں»مپ§ (1) م‚‚ن¸€ç·’مپ«هڈژé›†مپ™م‚‹م‚ˆمپ†و‹،ه¼µمپ—مپں (ن؛Œé‡چ
/// ه®ںè£…م‚’éپ؟مپ‘م‚‹)م€‚
fn dec_or(
  j : Json,
  parent_name : String,
) -> (Array[String], Array[(String, String, Array[String])]) raise DecodeSkip {
  let a = match j.j_arr() {
    Some(x) => x
    None => raise DecodeSkip("or is not an array")
  }
  // MDR-004 آ§2: the capability gate that used to reject "seq"/"type" branches here is GONE â€” the
  // caller (`dec_option`) now shape-detects BEFORE calling `dec_or`, routing structural branches to
  // `dec_or_structural` instead. This function only ever sees the value-enum form now.
  // DR-055 آ§1 + DR-052 آ§ه€¤و‍‌ id ç›´ن؛¤: هگ„و‍‌مپ® tuple = (branch_id, exact_value, targets)م€‚branch_id مپ¯
  // `id` مƒ•م‚£مƒ¼مƒ«مƒ‰ (fixture مپ® `id: "fmt_json"`) م‚’وژ،ç”¨م€پوœھوŒ‡ه®ڑمپھم‚‰ parent_name مپ«مƒ•م‚©مƒ¼مƒ«مƒگمƒƒم‚¯
  // (parent ç›´ه±‍ value_requires مپ¨ç­‰ن¾،وŒ™ه‹•)م€‚
  let exacts : Array[String] = []
  let vrs : Array[(String, String, Array[String])] = []
  for e in a {
    let bo = match e.j_obj() {
      Some(x) => x
      None => raise DecodeSkip("or branch is not an object")
    }
    allowed_keys(bo, ["exact", "id", "requires"], "or branch")
    let exact = match jf_str(bo, "exact") {
      Some(s) => s
      None =>
        raise DecodeSkip(
          "or branch missing 'exact' (only exact valueو‍‌ supported)",
        )
    }
    exacts.push(exact)
    let reqs = dec_strs(bo.get("requires"))
    if reqs.length() > 0 {
      let branch_id = jf_str(bo, "id").unwrap_or(parent_name)
      check_reserved_name(branch_id, "or branch")
      vrs.push((branch_id, exact, reqs))
    }
  }
  (exacts, vrs)
}

///|
/// MDR-004 kawaz è£په®ڑ 2026-07-08: auto `OrBranch.id` numbering for structural branches without an
/// explicit `"id"`. "وژ،ç•ھ seq مپ¯ decode 1 ه›‍مپ®مƒ‘مƒ¼م‚µه…¨ن½“مپ§هچکèھ؟ه¢—هٹ ... ن¸€و„ڈمپھم‚‰ن½•مپ§م‚‚م‚ˆمپ„" â€” a single
/// monotonic counter for the whole decode run satisfies this; the `#` prefix keeps it out of user
/// namespace (fixture ids are plain strings like `"fmt_json"`, never `#`-prefixed).
let or_branch_seq : Array[Int] = [0]

///|
fn next_or_branch_id() -> String {
  let n = or_branch_seq[0]
  or_branch_seq[0] = n + 1
  "#" + n.to_string()
}

///|
/// DESIGN آ§5.3 `values` shorthand: a flat array of exact-match string literals (`["red","green",
/// "blue"]`). The seq-branch form (`"values": [..., [{"name":"r",...},...]]`, DESIGN آ§5.3 ه¾Œهچٹ) is
/// OUT OF SCOPE for this issue (no target fixture exercises it) â€” a non-string element raises
/// DecodeSkip rather than silently degrading, so a future seq-branch fixture surfaces as a decode
/// gap instead of a wrong parse.
fn dec_values(j : Json) -> Array[String] raise DecodeSkip {
  let a = match j.j_arr() {
    Some(x) => x
    None => raise DecodeSkip("values is not an array")
  }
  let out : Array[String] = []
  for e in a {
    match e.j_str() {
      Some(s) => out.push(s)
      None =>
        raise DecodeSkip(
          "values element is not a string (seq-branch values form not supported)",
        )
    }
  }
  out
}

///|
/// Strict `Array[String]` decode for a factory config key that DR-061 آ§4 declares as `{"type":
/// "array", "items": "string"}` (e.g. `bool_parser`'s `true_values`/`false_values`, DR-074 آ§4) â€”
/// unlike `dec_strs`, no bare-string sugar (config schema says array, not `string | string[]`).
/// `type_name`/`field` are only for the DecodeSkip message.
fn dec_str_array(
  j : Json,
  type_name : String,
  field : String,
) -> Array[String] raise DecodeSkip {
  let a = match j.j_arr() {
    Some(x) => x
    None =>
      raise DecodeSkip(
        "definitions.types[" +
        type_name +
        "].config." +
        field +
        " is not an array",
      )
  }
  let out : Array[String] = []
  for e in a {
    match e.j_str() {
      Some(s) => out.push(s)
      None =>
        raise DecodeSkip(
          "definitions.types[" +
          type_name +
          "].config." +
          field +
          " element is not a string",
        )
    }
  }
  out
}

///|
/// MDR-004 آ§2: shape-detect a JSON `"or"` array â€” `None` if it's the DR-055 value-enum form (every
/// branch has `"exact"`, handled by `dec_or` instead), `Some(branches)` if it's the STRUCTURAL
/// consumption-grammar form (any branch has `"seq"`/`"type"` â€” a multi-cell `{"seq":[...]}` branch
/// or a single-cell `{"type":..,"name":..}` branch, used verbatim as the branch object itself).
fn dec_or_structural(
  j : Json,
  shadows : Map[String, TypeShadow],
) -> Array[OrBranch]? raise DecodeSkip {
  let a = match j.j_arr() {
    Some(x) => x
    None => raise DecodeSkip("or is not an array")
  }
  let mut structural = false
  for e in a {
    match e.j_obj() {
      Some(bo) =>
        if has_key(bo, "seq") || has_key(bo, "type") {
          structural = true
        }
      None => ()
    }
  }
  if !structural {
    return None
  }
  let branches : Array[OrBranch] = []
  for e in a {
    let bo = match e.j_obj() {
      Some(x) => x
      None => raise DecodeSkip("or branch is not an object")
    }
    let id = match jf_str(bo, "id") {
      Some(s) => {
        check_reserved_name(s, "or branch")
        s
      }
      None => next_or_branch_id()
    }
    let items : Array[ElemDef] = match bo.get("seq") {
      Some(sj) => {
        let sa = match sj.j_arr() {
          Some(x) => x
          None => raise DecodeSkip("or branch 'seq' is not an array")
        }
        let its : Array[ElemDef] = []
        for ij in sa {
          its.push(dec_or_leaf(ij, shadows))
        }
        its
      }
      // a single-cell branch IS the leaf object itself (no "seq" wrapper, DESIGN آ§1.2 è£¸é…چهˆ— seq ç³–è،£
      // â€” wire form already normalizes bare-seq sugar, so here a missing "seq" key on a branch that
      // has "type"/"name" directly is exactly the 1-item case).
      None => [dec_or_leaf(e, shadows)]
    }
    branches.push({ id, items })
  }
  Some(branches)
}

///|
/// A leaf cell inside a structural `"or"` branch: `{"type":..,"name":..}`. Minimal â€” BCell only, no
/// long/short/env/etc (the shared trigger, if any, lives on the PARENT option's `long`, factored out
/// per the `variable-arity-ambiguous.json` wire form; an anonymous positional or-branch leaf has no
/// trigger at all).
fn dec_or_leaf(
  j : Json,
  shadows : Map[String, TypeShadow],
) -> ElemDef raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("or branch leaf is not an object")
  }
  allowed_keys(o, ["type", "name"], "or branch leaf")
  let name = match jf_str(o, "name") {
    Some(s) => s
    None => raise DecodeSkip("or branch leaf missing 'name'")
  }
  check_reserved_name(name, "or branch leaf")
  // DR-089 آ§2: type çœپç•¥ = none مپ®ç³–è،£ (or branch leaf م‚‚ن»–مپ®è¦پç´ ç¨®مپ¨هگŒمپکè¦ڈç´„)م€‚
  let (ty, int_round_from_shadow) = match jf_str(o, "type") {
    Some(t) =>
      match shadows.get(t) {
        Some(sh) => (sh.base, sh.int_round)
        None => (dec_ty(t), RError)
      }
    None => (TNone, RError)
  }
  pos(name, ty, int_round=int_round_from_shadow)
}

///|
fn dec_option(
  j : Json,
  shadows : Map[String, TypeShadow],
) -> DElem raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("option is not an object")
  }
  if has_key(o, "alias") {
    return DAlias(dec_alias(o))
  }
  allowed_keys(
    o,
    [
      "id", "name", "type", "long", "short", "env", "default", "global", "inherit",
      "inheritable", "multiple", "separator", "requires", "conflicts_with", "exclusive_group",
      "required", "export_key", "config_key", "deprecated", "or", "values", "piece_filters",
      "value_filters", "cell_filters", "ref", "repeat",
      // DR-090 آ§2: dd ه°‚ç”¨مپ®2è»¸و‹،ه¼µم‚­مƒ¼ â€” ن»– type مپ§مپ¯ç„،و„ڈه‘³مپ مپŒم€پdd هˆ†ه²گ (ن¸‹) مپ مپ‘مپŒèھ­م‚€
      // ("option" ه…±é€ڑ allowed_keys مپ«è¶³مپ™مپ®مپ¯ن»– wire ه±‍و€§ (env/config_key ç­‰) مپ¨هگŒمپکو‰±مپ„و–¹)م€‚
       "match", "self",
      // codex ç¯€ç›®مƒ¬مƒ“مƒ¥مƒ¼ Major 1 (DESIGN آ§7.2م€Œه­گè¦پç´ مپ¯è¦ھمپ® config م‚’ç¶™و‰؟م€پن¸ٹو›¸مپچهڈ¯èƒ½م€چ/ DR-049
      // آ§4 è¦پç´ هچکن½چ env_prefix ن¸ٹو›¸مپچ): è¦پç´ هچکن½چمپ® scope config override â€” `dec_option` è‡ھè؛«مپ¯
      // مپ“مپ®ه€¤م‚’و¶ˆè²»مپ—مپھمپ„ (`allowed_keys` م‚’é€ڑمپ™مپںم‚پمپ مپ‘)م€په®ںéڑ›مپ® decode/merge مپ¯ه‘¼مپ³ه‡؛مپ—ه…ƒ
      // `dec_definition` مپŒ `oj` م‚’ه†چèھ­مپ—مپ¦è،Œمپ† (`dec_scope_config` مپ® 2 و®µç›®ه‘¼مپ³ه‡؛مپ—)م€‚
       "config",
    ],
    "option",
  )
  let tystr = match jf_str(o, "type") {
    Some(t) => t
    None =>
      if has_key(o, "or") || has_key(o, "ref") || has_key(o, "values") {
        // DR-078 آ§1: a `ref` element's own consumption is replaced by the referenced template
        // (`elem_head`'s `Ref(r)` head, ty unused there) â€” same "type is moot" reasoning `or`
        // already gets. `values` gets the same default (DR-028 è؟½è¨ک: values م‚’وŒپمپ¤ node مپ¯ type
        // مƒ•م‚£مƒ¼مƒ«مƒ‰مپھمپ—مپ§ enum ه‍‹م‚’ه…¼مپ­م‚‹) â€” DESIGN آ§5.3's `values` shorthand is string-literal-
        // only in this issue's scope (seq-branch values form not implemented), so the enum's own
        // values are always strings regardless of this default.
        "string"
      } else {
        // DR-089 آ§2: type çœپç•¥ = none مپ®ç³–è،£ (or/ref/values مپ„مپڑم‚Œم‚‚ç„،مپ„ه ´هگˆ)م€‚و—§ه®ںè£…مپ¯
        // مپ“مپ“م‚’ DecodeSkip (type ه؟…é ˆ) مپ«مپ—مپ¦مپ„مپںمپŒم€پDR-089 مپ§م€Œç„،مپ„م‚‚مپ®مپ«ه‹‌و‰‹مپ«ه€¤ه‍‹م‚’مپ‚مپ¦م‚‹مپ®مپ¯
        // و‰‹وٹœمپچم€چ(kawaz) مپ¨مپ—مپ¦ default-typing و،ˆمپŒوکژç¤؛çڑ„مپ«ن¸چوژ،ç”¨مپ«مپھمپ£مپںمپ®مپ¨ه¯¾ç§°مپ«م€پو—§
        // DecodeSkip م‚‚م€Œç„،مپ„م‚‚مپ®م‚’م‚¨مƒ©مƒ¼و‰±مپ„مپ™م‚‹م€چèھ¤م‚ٹمپ مپ£مپں â€” ه€¤ç©؛é–“مپŒç„،مپ„مپ“مپ¨è‡ھن½“مپ¯و­£ه½“مپھه®£è¨€م€‚
        "none"
      }
  }
  let name = match jf_str(o, "name") {
    Some(s) => s
    None => raise DecodeSkip("option missing 'name'")
  }
  check_reserved_name(name, "option")
  // MDR-004 آ§2: "or" is shape-detected FIRST â€” the DR-055 value-enum form ({"exact":...} branches,
  // dec_or, parent name = branch-id مƒ•م‚©مƒ¼مƒ«مƒگمƒƒم‚¯ه…ˆ) and the structural consumption-grammar form
  // (BOr, dec_or_structural) share the same JSON key but are otherwise unrelated (آ§5.3 values و­£è¦ڈه½¢
  // vs آ§1 و¶ˆè²»و–‡و³•مپ®و‍‌)م€‚
  let structural_or = match o.get("or") {
    Some(orj) => dec_or_structural(orj, shadows)
    None => None
  }
  // issue values-decode-support (DESIGN آ§5.3 "values مپ¯ or مپ®م‚·مƒ§مƒ¼مƒˆمƒڈمƒ³مƒ‰" + team-lead è£په®ڑ
  // 2026-07-10م€Œvalues مپ¨ or (value-enumه½¢ه¼ڈ) مپ®و¶ˆè²»و„ڈه‘³è«–م‚’هˆ†ه²گمپ•مپ›مپھمپ„م€چ): `values` مپ¯مپ“مپ“مپ§
  // `or` value-enum ç›¸ه½“ (ه…¨ exact ه€¤مپ®مƒھم‚¹مƒˆ) مپ¸و­£è¦ڈهŒ–مپ—م€پن»¥é™چ `value_enum`/`value_requires` مپ®
  // و±؛ه®ڑم‚’م€Œvalues ç”±و‌¥م€چمپ¨م€Œor ç”±و‌¥م€چمپ§ه®Œه…¨مپ«هگŒمپکçµŒè·¯مپ«وµپمپ™ â€” ç³–è،£مپ¨و­£è¦ڈه½¢مپ§è¦³و¸¬وŒ™ه‹•مپŒه‰²م‚Œمپھمپ„
  // م‚ˆمپ†مپ«مپ™م‚‹م€‚`values` مپ¨ `or` مپ®هگŒو™‚وŒ‡ه®ڑمپ¯ه¯¾è±، fixture مپ«ç„،مپڈوœھه®ڑç¾© (values م‚’ه„ھه…ˆم€پç„،è¦–مپ—مپں
  // `or` مپŒمپ‚م‚Œمپ°ن¸‹مپ® `value_requires` هˆ¤ه®ڑمپ«مپ¯çڈ¾م‚Œمپھمپ„ â€” وƒ³ه®ڑه¤–مپ®çµ„هگˆمپ›مپھمپ®مپ§و¤œه‡؛مپ¯مپ—مپھمپ„)م€‚
  let (value_enum, value_requires) : (
    Array[String]?,
    Array[(String, String, Array[String])],
  ) = match structural_or {
    Some(_) => (None, [])
    None =>
      match o.get("values") {
        Some(vj) => (Some(dec_values(vj)), [])
        None =>
          match o.get("or") {
            Some(orj) => {
              let (exacts, vrs) = dec_or(orj, name)
              (Some(exacts), vrs)
            }
            None => (None, [])
          }
      }
  }
  if tystr == "dd" {
    // DR-090 آ§2: `match` (regex مƒˆمƒھم‚¬) / `self` (`"drop"` و—¢ه®ڑ | `"keep"`)م€‚`self` مپ®èھ‍ه½™ه¤–و–‡ه­—هˆ—مپ¯
    // decode و™‚ç‚¹مپ§و‹’هگ¦ (ç¶´م‚ٹمƒںم‚¹م‚’é»™مپ£مپ¦ drop و‰±مپ„مپ«مپ—مپھمپ„م€پDR-054 مپ®م€Œو§‹و–‡مپ®é©ڑمپچمپ¯ v1 Errorم€چç­‹)م€‚
    let match_ = jf_str(o, "match")
    let self_keep = match jf_str(o, "self") {
      Some("drop") | None => false
      Some("keep") => true
      Some(other) =>
        raise DecodeSkip("dd 'self' has unknown value '" + other + "'")
    }
    // DR-093 آ§2/آ§5: dd م‚‚ required م‚’وŒپمپ¦م‚‹ (`{"type":"dd","required":true}`م€پو–°è¦ڈ wire èھ‍ه½™م‚¼مƒ­)م€‚
    let required = bool_field(o, "required", false)
    return DOpt({ ..dd_marker(match_~, self_keep~, required~), name, })
  }
  // DR-061 آ§3: type shadow lookup â€” user ه®ڑç¾©مپ® type هگچمپھم‚‰ base Ty + parse ç›¸ config م‚’وژ،ç”¨م€پ
  // canonical ه‍‹هگچ (string/int/...) مپ«مƒ•م‚©مƒ¼مƒ«مƒگمƒƒم‚¯م€‚help/config_file مپ¯èھ‍ه½™ keyword مپ§ shadow مپ®
  // éپ©ç”¨ه¯¾è±،ه¤– (installer èھ‍ه½™م€پDR-042)م€‚
  let (
    ty,
    fail_action,
    config_file,
    int_round_from_shadow,
    base_prefix_from_shadow,
    bool_config_from_shadow,
  ) = match tystr {
    "help" => (TFlag, true, false, RError, false, bool_config_canonical())
    "config_file" => (TStr, false, true, RError, false, bool_config_canonical())
    _ =>
      match shadows.get(tystr) {
        Some(sh) =>
          (
            sh.base,
            false,
            false,
            sh.int_round,
            sh.allow_base_prefix,
            sh.bool_config,
          )
        None =>
          (dec_ty(tystr), false, false, RError, false, bool_config_canonical())
      }
  }
  // DR-071 آ§1 / kawaz è£په®ڑ 2026-07-08: decode مپ¯ wire مپ® bool|array ن؛Œه½¢م‚’مپ‌مپ®مپ¾مپ¾ `LongDecl` مپ«ه†™مپ™
  // مپ مپ‘ â€” ç³–è،£ه±•é–‹مƒ»colon DSL هˆ†é،‍ (variants مپ®هˆ†é›¢م‚’هگ«م‚€) مپ¯ installer.mbt مپ® `resolve_long` مپŒ
  // `normalize_option` مپ‹م‚‰و‹…مپ† (ن¸‹è¨ک `opt(...)` مپ¯ `variants` م‚’و¸،مپ•مپھمپ„ = ه¸¸مپ« [] مپ®مپ¾مپ¾ه®£è¨€ه±¤مپ¸)م€‚
  let long_decl : LongDecl = match o.get("long") {
    Some(lj) => dec_long(lj)
    None => LList([])
  }
  let short = dec_short(o)
  let env = dec_strs(o.get("env"))
  let default : Array[Value]? = match o.get("default") {
    Some(d) => Some(json_to_default_values(d))
    None => None
  }
  let global = bool_field(o, "global", false)
  let inherit_flag = bool_field(o, "inherit", false)
  let inheritable = bool_field(o, "inheritable", false)
  let (multiple, sep, coll, acc) = match o.get("multiple") {
    Some(m) => dec_multiple(m)
    None => (false, None, None, None)
  }
  let requires = dec_strs(o.get("requires"))
  let conflicts = dec_strs(o.get("conflicts_with"))
  let exclusive = dec_strs(o.get("exclusive_group"))
  let required = bool_field(o, "required", false)
  let export_ = match o.get("export_key") {
    Some(e) => dec_export(e)
    None => EkUnset
  }
  let config_key : Array[String]? = match o.get("config_key") {
    Some(c) => Some(dec_strs(Some(c)))
    None => None
  }
  let deprecated = bool_field(o, "deprecated", false)
  let piece_filters = dec_filter_chain(o.get("piece_filters"))
  let value_filters = dec_filter_chain(o.get("value_filters"))
  let cell_filters = dec_filter_chain(o.get("cell_filters"))
  // DR-091 آ§3 (team-lead è£په®ڑ 2026-07-11 ن؟®و­£): `long_prefix`/`require_equal_separator` are NOT
  // element-level wire keys â€” the canonical source is `dec_definition`'s scope-level read (DESIGN
  // آ§7.2's sibling, "scope config" per DR-091 آ§3), which overrides every `ElemDef` this function
  // returns AFTER decode. An option JSON object carrying either key hits the `allowed_keys` reject
  // above (element-level override would be an un-specced vocabulary invention). `opt(...)` below
  // omits both â€” they keep `opt`'s defaults (`"--"`/`false`) here and get set for real by the
  // caller (`dec_definition`).
  let ref_ = jf_str(o, "ref")
  // DR-078 آ§1 option repeat (issue 2026-07-09-ref-template-result-shape, new capability): `repeat`
  // used to be positional-only (`dec_positional`'s own decode above) â€” mirrored here now that
  // installer.mbt's `inst_long` wires it into an option's satellite (`GreedyRepeat`, eval.mbt).
  let repeat : RepeatSpec? = match o.get("repeat") {
    Some(r) => Some(dec_repeat(r))
    None => None
  }
  DOpt({
    ..opt(
      name,
      ty,
      long=long_decl,
      short~,
      repeat~,
      env~,
      global~,
      inherit_=inherit_flag,
      inheritable~,
      multiple~,
      accumulator=acc,
      fail_action~,
      config_file~,
      config_key~,
      export_~,
      requires~,
      conflicts~,
      exclusive~,
      required~,
      value_requires~,
      default~,
      int_round=int_round_from_shadow,
      allow_base_prefix=base_prefix_from_shadow,
      bool_config=bool_config_from_shadow,
      piece_filters~,
      value_filters~,
      cell_filters~,
      ref_~,
      body=match structural_or {
        Some(branches) => BOr(branches)
        None =>
          match value_enum {
            Some(values) => BEnum(values)
            None => BCell
          }
      },
    ),
    separator: sep,
    collector: coll,
    deprecated,
  })
}

///|
fn dec_positional(
  j : Json,
  shadows : Map[String, TypeShadow],
) -> ElemDef raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("positional is not an object")
  }
  allowed_keys(
    o,
    [
      "id", "name", "type", "repeat", "optional", "multiple", "separator", "export_key",
      "config_key", "default", "positionals", "or", "piece_filters", "value_filters",
      "cell_filters", "ref", "env", "required", "requires",
      // codex ç¯€ç›®مƒ¬مƒ“مƒ¥مƒ¼ Major 1 (dec_option هپ´مپ¨هگŒمپکè¦پç´ هچکن½چ scope config overrideم€پ
      // ه¯¾ç§°مپ® positional ç‰ˆ)م€‚
       "config",
    ],
    "positional",
  )
  // MDR-004 آ§2: "positionals" (named nested group, BGroup) and "or" (anonymous structural or,
  // BOr) are decoded via ElemBody now â€” the gates that used to reject these keys are GONE. A
  // positional's "or" is ALWAYS structural (there is no DR-055 value-enum-or concept for
  // positionals â€” that's an option-only constraint-declaration sugar, آ§5.3).
  match o.get("positionals") {
    Some(pj) => return dec_positional_group(o, pj, shadows)
    None => ()
  }
  match o.get("or") {
    Some(orj) =>
      match dec_or_structural(orj, shadows) {
        Some(branches) => return { ..pos("", TStr), body: BOr(branches) }
        None =>
          raise DecodeSkip(
            "positional 'or' has no structural branches (all-exact value-enum form is option-only, DR-055 آ§1 / آ§5.3)",
          )
      }
    None => ()
  }
  // DR-061 آ§3: positional م‚‚ type shadow م‚’ consultation (dec_option مپ¨هگŒه‍‹)م€‚
  // DR-089 آ§2: type çœپç•¥ = none مپ®ç³–è،£ (و—§ه®ںè£…مپ¯ TStr م‚’ه‹‌و‰‹مپ«مپ‚مپ¦م‚‹ default-typing مپ مپ£مپں â€”
  // DR-089 مپ®م€Œوژ،ç”¨مپ—مپھمپ‹مپ£مپںو،ˆم€چمپŒوکژç¤؛çڑ„مپ«هگ¦ه®ڑمپ™م‚‹مƒ‘م‚؟مƒ¼مƒ³م€‚`ref` ن»کمپچمپ®ه ´هگˆمپ¯مپ‌م‚‚مپ‌م‚‚ ty مپŒ
  // وœھن½؟ç”¨ (elem_head مپ® Ref(r) headم€پن¸‹مپ® `dec_or_structural`/`positionals` هˆ†ه²گهگŒو§ک) مپھمپ®مپ§
  // TNone مپ«ه¤‰مپˆمپ¦م‚‚ç„،ه®³)م€‚
  let (
    ty,
    int_round_from_shadow,
    base_prefix_from_shadow,
    bool_config_from_shadow,
  ) = match jf_str(o, "type") {
    Some(t) =>
      match shadows.get(t) {
        Some(sh) =>
          (sh.base, sh.int_round, sh.allow_base_prefix, sh.bool_config)
        None => (dec_ty(t), RError, false, bool_config_canonical())
      }
    None => (TNone, RError, false, bool_config_canonical())
  }
  let name = match jf_str(o, "name") {
    Some(s) => s
    None => raise DecodeSkip("positional missing 'name'")
  }
  check_reserved_name(name, "positional")
  let repeat : RepeatSpec? = match o.get("repeat") {
    Some(r) => Some(dec_repeat(r))
    None => None
  }
  let optional = bool_field(o, "optional", false)
  let (multiple, sep, coll, acc) = match o.get("multiple") {
    Some(m) => dec_multiple(m)
    None => (false, None, None, None)
  }
  let export_ = match o.get("export_key") {
    Some(e) => dec_export(e)
    None => EkUnset
  }
  let config_key : Array[String]? = match o.get("config_key") {
    Some(c) => Some(dec_strs(Some(c)))
    None => None
  }
  let default : Array[Value]? = match o.get("default") {
    Some(d) => Some(json_to_default_values(d))
    None => None
  }
  let piece_filters = dec_filter_chain(o.get("piece_filters"))
  let value_filters = dec_filter_chain(o.get("value_filters"))
  let cell_filters = dec_filter_chain(o.get("cell_filters"))
  let ref_ = jf_str(o, "ref")
  // DR-088 (issue dr-088-positional-default-verification): positionals can declare `env` too
  // (Entity.env_key applies uniformly across options/positionals, `dec_option`'s same-named
  // field) â€” this was missing from the positional decoder entirely (`allowed_keys` rejected it
  // outright), a genuine decode gap surfaced by `positional-env-presence.json`.
  let env = dec_strs(o.get("env"))
  // DR-093 آ§1/آ§2/آ§5: positional م‚‚ required م‚’وŒپمپ¦م‚‹ (corpus/real-cli مپ®
  // `{"name":"path","type":"string","required":true}` ه®ںن¾‹مپŒç¤؛مپ™é€ڑم‚ٹم€پoption é™گه®ڑمپ§مپ¯مپھمپ„)م€‚
  let required = bool_field(o, "required", false)
  // DR-093 آ§3/آ§5: positional م‚‚ requires (ن»–è¦پç´ مپ¸مپ®ن¾‌ه­ک) م‚’وŒپمپ¦م‚‹ â€” die مپ®éھ¨و ¼
  // (`{"name":"args","requires":["--"]}`) مپ¯ requires مپ®مƒˆمƒھم‚¬هپ´مپŒ positional مپ§مپ‚م‚‹ه®ںن¾‹م€‚
  // option هپ´ (`dec_option`) مپ¯و—¢مپ«ه¯¾ه؟œو¸ˆمپ؟مپ مپ£مپںمپŒ positional هپ´مپ¯ decode gap مپ مپ£مپں
  // (fixtures/constraints-parse/requires-dd-target.json مپŒç™؛è¦‹)م€‚
  let requires = dec_strs(o.get("requires"))
  pos(
    name,
    ty,
    repeat~,
    optional~,
    multiple~,
    accumulator=acc,
    separator=sep,
    collector=coll,
    config_key~,
    export_~,
    ref_~,
    default~,
    int_round=int_round_from_shadow,
    allow_base_prefix=base_prefix_from_shadow,
    bool_config=bool_config_from_shadow,
    piece_filters~,
    value_filters~,
    env~,
    cell_filters~,
    required~,
    requires~,
  )
}

///|
/// MDR-004 آ§1/آ§3: a named group positional (`{"name":"xs","repeat":{...},"positionals":[...]}`) â€”
/// `BGroup(items)`. Inner items are decoded via `dec_positional` itself (recursive â€” an inner leaf
/// like transparent-seq's `k` is just a normal positional decode, `export_key:null` included).
fn dec_positional_group(
  o : Map[String, Json],
  pj : Json,
  shadows : Map[String, TypeShadow],
) -> ElemDef raise DecodeSkip {
  let name = match jf_str(o, "name") {
    Some(s) => s
    None => raise DecodeSkip("positional (named group) missing 'name'")
  }
  check_reserved_name(name, "positional (named group)")
  let repeat : RepeatSpec? = match o.get("repeat") {
    Some(r) => Some(dec_repeat(r))
    None => None
  }
  let inner_arr = match pj.j_arr() {
    Some(x) => x
    None => raise DecodeSkip("positionals is not an array")
  }
  let items : Array[ElemDef] = []
  for ij in inner_arr {
    items.push(dec_positional(ij, shadows))
  }
  { ..pos(name, TStr, repeat~), body: BGroup(items) }
}

///|
/// DR-014 / DESIGN آ§7.2 (issue scope-config-object-gap): the resolved (post-inheritance) value of
/// every scope `config` key, threaded top-down through `dec_definition`/`dec_command`'s recursion â€”
/// this IS the "ه­گè¦پç´ مپ¯è¦ھمپ® config م‚’ç¶™و‰؟م€پن¸ٹو›¸مپچهڈ¯èƒ½" hierarchy (DESIGN آ§7.2), realized as
/// "each scope merges its own `config` object over the value it received from its parent" rather
/// than a stored-on-`Definition` carrier (installer.mbt never reads a `Definition`-level config; the
/// resolved tuple gets baked onto each `ElemDef` the scope owns, same pattern DR-091 آ§3 established
/// for the original 2-field minimal implementation).
struct ScopeConfig {
  long_prefix : String
  short_prefix : String
  env_prefix : String
  auto_env : Bool
  allow_equal_separator : Bool
  short_combine : Bool
  require_equal_separator : Bool
} derive(Eq, Debug)

///|
/// The canonical config, in effect at the root scope when no `config` object is ever written
/// (equivalent to every key's DESIGN آ§7.2 default) â€” matches DR-091 آ§3's pre-issue defaults exactly
/// (`long_prefix:"--"`, `require_equal_separator:false`) for the 2 fields that already existed.
fn default_scope_config() -> ScopeConfig {
  {
    long_prefix: "--",
    short_prefix: "-",
    env_prefix: "",
    auto_env: false,
    allow_equal_separator: true,
    short_combine: true,
    require_equal_separator: false,
  }
}

///|
/// Merges THIS scope's own `config` object (JSON, may be partly or fully absent) over `parent`
/// (the already-resolved config the enclosing scope handed down) â€” a key ABSENT from `co` inherits
/// `parent`'s resolved value; a key PRESENT overrides it. This single merge step, applied once per
/// scope in the top-down recursion, is the entire "éڑژه±¤ç¶™و‰؟هڈ¯èƒ½" mechanism DR-014 specifies â€” no
/// separate reconciliation pass is needed because each scope only ever sees its own JSON object and
/// the one already-merged value from above.
fn dec_scope_config(
  co : Map[String, Json],
  parent : ScopeConfig,
) -> ScopeConfig raise DecodeSkip {
  allowed_keys(
    co,
    [
      "long_prefix", "short_prefix", "env_prefix", "auto_env", "allow_equal_separator",
      "short_combine", "require_equal_separator",
    ],
    "definition.config",
  )
  let long_prefix = match jf_str(co, "long_prefix") {
    Some(s) => s
    None => parent.long_prefix
  }
  let short_prefix = match jf_str(co, "short_prefix") {
    Some(s) => s
    None => parent.short_prefix
  }
  let env_prefix = match jf_str(co, "env_prefix") {
    Some(s) => s
    None => parent.env_prefix
  }
  let auto_env = bool_field(co, "auto_env", parent.auto_env)
  let allow_equal_separator = bool_field(
    co,
    "allow_equal_separator",
    parent.allow_equal_separator,
  )
  let short_combine = bool_field(co, "short_combine", parent.short_combine)
  let require_equal_separator = bool_field(
    co,
    "require_equal_separator",
    parent.require_equal_separator,
  )
  {
    long_prefix,
    short_prefix,
    env_prefix,
    auto_env,
    allow_equal_separator,
    short_combine,
    require_equal_separator,
  }
}

///|
/// DR-091 آ§3 è‡ھç„¶مپھه¸°çµگمƒپم‚§مƒƒم‚¯م‚’ 1 ç®‡و‰€مپ«é›†ç´„ (codex ç¯€ç›®مƒ¬مƒ“مƒ¥مƒ¼ Major 1 ç›£وں»و™‚ç‚¹مپ§ç™؛è¦‹: ه…ƒم€…
/// `dec_definition` مپ® SCOPE مƒ¬مƒ™مƒ«مپ«مپ مپ‘م‚¤مƒ³مƒ©م‚¤مƒ³ه±•é–‹مپ•م‚Œمپ¦مپ„مپں â€” è¦پç´ هچکن½چ config override
/// (DR-049 آ§4م€Œمپ‌مپ®è¦پç´ مپ® config مپ§ env_prefix:"" م‚’ن¸ٹو›¸مپچمپ™م‚‹م€چمپ§وکژç¤؛مپ•م‚Œم‚‹م€پDESIGN آ§7.2م€Œه­گè¦پç´ م€چ
/// مپ¯ command مپ مپ‘مپ§مپھمپڈ option/positional م‚‚هگ«م‚€) م‚’è؟½هٹ مپ™م‚‹ن»¥ن¸ٹم€پهگŒمپکن¸چو•´هگˆمپ¯م‚¹م‚³مƒ¼مƒ—هچکن½چمپ®
/// resolved config مپ مپ‘مپ§مپھمپڈم€پè¦پç´ هچکن½چمپ§ resolved مپ—مپں config مپ§م‚‚èµ·مپ“م‚ٹمپ†م‚‹ (ن¾‹: è¦پç´ مپŒç‹¬è‡ھمپ«
/// `long_prefix:""` م‚’ن¸ٹو›¸مپچمپ—مپ¤مپ¤ `require_equal_separator` م‚’وکژç¤؛مپ—مپھمپ„ه ´هگˆم€پè¦ھمپ‹م‚‰ç¶™و‰؟مپ—مپںه€¤مپŒ
/// false مپ®مپ¾مپ¾مپ مپ¨هگŒمپکم€Œç©؛ prefix مپŒç´  operand مپ¨è،‌çھپمپ™م‚‹م€چه•ڈé،ŒمپŒè¦پç´ هچکن½چمپ§ه†چçڈ¾مپ™م‚‹) â€” checker م‚’
/// é–¢و•°هŒ–مپ—مپ¦ن¸،ه‘¼مپ³ه‡؛مپ—ç‚¹ (م‚¹م‚³مƒ¼مƒ—è§£و±؛ç›´ه¾Œمƒ»è¦پç´ مپ”مپ¨مپ®مƒ‍مƒ¼م‚¸ç›´ه¾Œ) مپ‹م‚‰هگŒن¸€مƒ­م‚¸مƒƒم‚¯مپ§و¤œè¨¼مپ™م‚‹م€‚
///
/// `require_equal_separator: true` أ— `allow_equal_separator: false` مپ®çں›ç›¾مƒپم‚§مƒƒم‚¯مپ¯م€پمپ“مپ“مپ«مپ¯
/// ç„،مپ„ â€” installer ه±¤ `collect_eq_separator_conflict` (installer.mbt) مپ¸ç§»è¨­و¸ˆمپ؟ (DESIGN آ§7.2
/// مپŒ definition-error مپ¨è¦ڈç¯„هŒ–م€پdecode ه±¤مپ® `DecodeSkip` مپ§مپ¯ query:definition_error fixture مپ§
/// element هˆ¥مپ« pin مپ§مپچمپھمپ„مپںم‚پ â€” `collect_eq_separator_conflict` مپ® doc comment هڈ‚ç…§)م€‚
fn validate_scope_config(cfg : ScopeConfig) -> Unit raise DecodeSkip {
  // DR-091 آ§3 "هچکç‹¬مپ®ç©؛ prefix مپ¯وœھه®ڑç¾©ه‹•ن½œمپ®مپ¾مپ¾": `long_prefix: ""` مپ¯
  // `require_equal_separator: true` مپ¨مپ®ن½µç”¨و™‚مپ®مپ؟هگˆو³• â€” ç©؛ prefix هچکç‹¬مپھم‚‰مپ“مپ® scope مپ®
  // SPACE-FORM main entry مپŒ ANY مƒˆمƒ¼م‚¯مƒ³مپ«مƒ‍مƒƒمƒپمپ—مپ¦مپ—مپ¾مپ„م€پç´  operand مپ¨è،‌çھپمپ™م‚‹
  // (`ElemDef.require_equal_separator` مپ® doc comment هڈ‚ç…§)م€‚definition-error مپ¨مپ—مپ¦و±؛ه®ڑçڑ„مپ«
  // reject (`collect_unsupported_accum_update` ç­‰مپ¨هگŒمپکم€Œé‌™çڑ„م€په®ںè،Œو™‚مپ§مپھمپ„م€چه§؟ه‹¢)م€‚
  if cfg.long_prefix == "" && !cfg.require_equal_separator {
    raise DecodeSkip(
      "long_prefix: \"\" requires require_equal_separator: true (DR-091 آ§3)",
    )
  }
}

///|
/// "_" é€£çµگ (DR-049 آ§3 auto_env هگچه°ژه‡؛مپ®é€£çµگم‚»مƒ‘مƒ¬مƒ¼م‚؟)م€‚ç©؛ segment مپ¯ه‘¼مپ³ه‡؛مپ—هپ´مپŒو—¢مپ«é™¤ه¤–مپ—مپ¦مپ„م‚‹
/// ه‰چوڈگ (`auto_env_name` â€” env_prefix وœھè¨­ه®ڑو™‚مپ« prefix segment è‡ھن½“م‚’ç©چمپ¾مپھمپ„م€پDR-049 آ§3
/// م€Œenv_prefix وœھè¨­ه®ڑمپھم‚‰ prefix éƒ¨م‚’çœپمپڈم€چ)م€‚
fn join_us(items : Array[String]) -> String {
  let buf = StringBuilder::new()
  let mut first = true
  for s in items {
    if !first {
      buf.write_string("_")
    }
    buf.write_string(s)
    first = false
  }
  buf.to_string()
}

///|
/// DR-049 آ§3 auto_env هگچه°ژه‡؛: `UPPER(env_prefix) "_" UPPER(scope_path م‚’ "_" é€£çµگ) "_" UPPER(name)`م€‚
/// `env_prefix` وœھè¨­ه®ڑ (`""`) مپھم‚‰ prefix segment م‚’çœپمپڈ (آ§3 وکژè¨ک)م€‚`name` مپ¯ wire format مپ®
/// snake_case (DR-022) مپھمپ®مپ§ه¤‰وڈ›مپ¯ uppercase مپ®مپ؟ (kebab/camel مپ‹م‚‰مپ®ه¤‰وڈ›è¦ڈه‰‡مپ¯ه®ڑç¾©مپ—مپھمپ„م€پآ§3)م€‚
fn auto_env_name(
  env_prefix : String,
  scope_path : Array[String],
  name : String,
) -> String {
  let segs : Array[String] = []
  if env_prefix != "" {
    segs.push(env_prefix.to_upper())
  }
  for s in scope_path {
    segs.push(s.to_upper())
  }
  segs.push(name.to_upper())
  join_us(segs)
}

///|
/// DR-049 آ§3/آ§4: applies THIS scope's resolved `env_prefix`/`auto_env` to one option/positional
/// element. Two independent effects (آ§4م€Œوکژç¤؛ env: مپŒ auto_env مپ«ه„ھه…ˆمپ™م‚‹م€چmeans these are mutually
/// exclusive per element, not layered):
/// - explicit `env:` (آ§4): env_prefix prepends to EVERY declared env key (`UPPER(env_prefix) + "_"
///   + <value>` â€” the value itself is left as the author wrote it, only the prefix segment is
///   uppercased per آ§3's "UPPER(env_prefix)"), UNLESS env_prefix is `""` (آ§3 "وœھè¨­ه®ڑمپھم‚‰ prefix éƒ¨
///   م‚’çœپمپڈ" â€” the element is left byte-for-byte unchanged, preserving every pre-issue fixture that
///   declares `env:` with no scope config at all).
/// - no explicit `env:` + `auto_env: true` (آ§3): derives the full name via `auto_env_name` â€” gated to
///   `BCell` bodies only ("ه€¤م‚»مƒ«وŒپمپ،è¦پç´ ", DESIGN آ§7.2 line 842 â€” a `BOr`/`BGroup`/`BEnum` wrapper
///   has no single value slot for a scalar env lookup to bind to, matcher/leaf-level auto_env is not
///   specified anywhere and would be an invented extension).
fn apply_env_config(
  e : ElemDef,
  env_prefix : String,
  auto_env : Bool,
  scope_path : Array[String],
) -> ElemDef {
  if e.env.length() > 0 {
    if env_prefix == "" {
      e
    } else {
      let prefixed : Array[String] = []
      for v in e.env {
        prefixed.push(env_prefix.to_upper() + "_" + v)
      }
      { ..e, env: prefixed }
    }
  } else if auto_env && e.body is BCell {
    { ..e, env: [auto_env_name(env_prefix, scope_path, e.name)] }
  } else {
    e
  }
}

///|
fn dec_command(
  j : Json,
  shadows : Map[String, TypeShadow],
  parent_config : ScopeConfig,
  scope_path : Array[String],
) -> DCmd raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("command is not an object")
  }
  if has_key(o, "alias") {
    return DCmdAlias(dec_alias(o))
  }
  allowed_keys(
    o,
    [
      "type", "name", "options", "positionals", "commands", "export_key",
      // DR-014 / DESIGN آ§7.2 / DR-091 آ§3: a command's own object IS its Definition's `o`
      // (`dec_definition` is called with THIS SAME map below) â€” so `config` is legal here too.
       "config",
    ],
    "command",
  )
  let name = match jf_str(o, "name") {
    Some(s) => s
    None => raise DecodeSkip("command missing 'name'")
  }
  check_reserved_name(name, "command")
  // ه­گم‚³مƒ‍مƒ³مƒ‰مپ® definition مپ¯è¦ھمپ® shadows م‚’ç¶™و‰؟مپ™م‚‹ (DR-061 مپ¯ scope ç¶™و‰؟م‚’è¦ڈه®ڑمپ—مپ¦مپ„مپھمپ„مپŒم€پ
  // sliceه®ںè£…مپ¯ fixture مپŒه‘½ن»¤çڑ„مپ« flat مپھ type shadow م‚’ه®£è¨€مپ™م‚‹مپ مپ‘مپھمپ®مپ§è¦ھâ†’ه­گمپ¸مپ®هچکç´”ن¼‌وگ¬مپ§è¶³م‚ٹم‚‹)
  //
  // DR-014 éڑژه±¤ç¶™و‰؟ / DR-049 آ§3 scope_path: مپ“مپ® command è‡ھè؛«مپ® name م‚’ scope_path مپ«è¶³مپ—مپ¦ه­گمپ¸
  // و¸،مپ™ â€” auto_env مپ®مƒ•مƒ«ن؟®é£¾هگچه°ژه‡؛ (DR-049 آ§3م€Œم‚¹م‚³مƒ¼مƒ—مƒ‘م‚¹مپ¯مƒ•مƒ«ن؟®é£¾م€چ) مپŒن½؟مپ†م€‚
  let body = dec_definition(
    o,
    shadows~,
    parent_config~,
    scope_path=scope_path + [name],
  )
  let export_ = match o.get("export_key") {
    Some(e) => dec_export(e)
    None => EkUnset
  }
  DCommand({ name, body, export_key: export_ })
}

///|
fn dec_definition(
  o : Map[String, Json],
  shadows? : Map[String, TypeShadow] = Map([]),
  parent_config? : ScopeConfig = default_scope_config(),
  scope_path? : Array[String] = [],
) -> Definition raise DecodeSkip {
  // DR-014 / DESIGN آ§7.2 (issue scope-config-object-gap; supersedes DR-091 آ§3's original 2-field-
  // only, non-inheriting scope config): مپ“مپ®ه‘¼مپ³ه‡؛مپ—مپ® `o` (root definition objectم€پمپ¾مپںمپ¯ 1مپ¤مپ®
  // command مپ® own definition object â€” `dec_command` مپŒè‡ھهˆ†مپ® `o` م‚’مپ‌مپ®مپ¾مپ¾و¸،مپ™) مپŒوŒپمپ¤
  // `config: {long_prefix, short_prefix, env_prefix, auto_env, allow_equal_separator, short_combine,
  // require_equal_separator}` (DESIGN آ§7.2 مپ® wire ه½¢مپ‌مپ®م‚‚مپ®) م‚’ `parent_config` (ه‘¼مپ³ه‡؛مپ—ه…ƒمپ‹م‚‰
  // ç¶™و‰؟مپ—مپںو—¢è§£و±؛ه€¤) مپ®ن¸ٹمپ« `dec_scope_config` مپ§مƒ‍مƒ¼م‚¸مپ™م‚‹ â€” وکژç¤؛مپ—مپںم‚­مƒ¼مپ مپ‘ن¸ٹو›¸مپچم€پçœپç•¥مپ—مپں
  // م‚­مƒ¼مپ¯è¦ھمپ®ه€¤م‚’مپ‌مپ®مپ¾مپ¾ç¶™و‰؟مپ™م‚‹ (DESIGN آ§7.2م€Œه­گè¦پç´ مپ¯è¦ھمپ® config م‚’ç¶™و‰؟م€پن¸ٹو›¸مپچهڈ¯èƒ½م€چ)م€‚
  // `config` è‡ھن½“م‚’çœپç•¥مپ—مپںم‚¹م‚³مƒ¼مƒ—مپ¯ `parent_config` م‚’مپ‌مپ®مپ¾مپ¾ن½؟مپ† (= ن½•م‚‚ن¸ٹو›¸مپچمپ—مپھمپ„م€پç¶™و‰؟مپ®
  // وپ’ç­‰ه°„)م€‚مƒ«مƒ¼مƒˆم‚¹م‚³مƒ¼مƒ—مپ® `parent_config` و—¢ه®ڑمپ¯ `default_scope_config()` (DR-091 آ§3 مپ®
  // pre-issue و—¢ه®ڑمپ¨هگŒن¸€ه€¤)م€‚
  let config = match o.get("config") {
    Some(cj) => {
      let co = match cj.j_obj() {
        Some(x) => x
        None => raise DecodeSkip("config is not an object")
      }
      dec_scope_config(co, parent_config)
    }
    None => parent_config
  }
  validate_scope_config(config)
  let options : Array[ElemDef] = []
  let positionals : Array[ElemDef] = []
  let commands : Array[CommandDef] = []
  let aliases : Array[AliasDef] = []
  match o.get("options") {
    Some(arr) => {
      let a = match arr.j_arr() {
        Some(x) => x
        None => raise DecodeSkip("options is not an array")
      }
      for oj in a {
        match dec_option(oj, shadows) {
          DOpt(e) => {
            // codex ç¯€ç›®مƒ¬مƒ“مƒ¥مƒ¼ Major 1 (DR-049 آ§4م€Œمپ‌مپ®è¦پç´ مپ® config مپ§ env_prefix:"" م‚’ن¸ٹو›¸مپچمپ™م‚‹
            // (DR-014 مپ®éڑژه±¤ç¶™و‰؟مپ§è¦پç´ هچکن½چمپ®ن¸ٹو›¸مپچمپŒهڈ¯èƒ½)م€چ/ DESIGN آ§7.2م€Œه­گè¦پç´ مپ¯è¦ھمپ® config م‚’
            // ç¶™و‰؟م€پن¸ٹو›¸مپچهڈ¯èƒ½م€چمپ®م€ژه­گè¦پç´ م€ڈمپ¯ command scope مپ«é™گم‚‰مپھمپ„): `dec_option` مپ¯è¦پç´ مپ®ç”ں
            // JSON م‚’ `allowed_keys` و¸ˆمپ؟ `Map[String, Json]` مپ¨مپ—مپ¦ن؟‌وŒپمپ—مپھمپ„مپ®مپ§م€پè¦پç´ هچکن½چمپ®
            // `config` مپ¯مپ“مپ“ (ه‘¼مپ³ه‡؛مپ—ه…ƒ) مپ§ `oj` م‚’ç›´وژ¥ه†چèھ­مپ—مپ¦هڈ–م‚ٹه‡؛مپ™ â€” `dec_scope_config` م‚’
            // مپ“مپ®م‚¹م‚³مƒ¼مƒ—مپ® `config` م‚’è¦ھمپ¨مپ—مپ¦è¦پç´ مپ® `config` مپ«éپ©ç”¨مپ™م‚Œمپ°م€پو—¢ه­کمپ®éڑژه±¤مƒ‍مƒ¼م‚¸
            // مƒ­م‚¸مƒƒم‚¯م‚’مپ‌مپ®مپ¾مپ¾è¦پç´ مƒ¬مƒ™مƒ«مپ¸ 1 و®µه»¶é•·مپ§مپچم‚‹ (هˆ¥ه®ںè£…م‚’وŒپمپںمپھمپ„)م€‚
            let elem_config = match oj.j_obj() {
              Some(oo) =>
                match oo.get("config") {
                  Some(ecj) => {
                    let eco = match ecj.j_obj() {
                      Some(x) => x
                      None => raise DecodeSkip("option config is not an object")
                    }
                    let merged = dec_scope_config(eco, config)
                    validate_scope_config(merged)
                    merged
                  }
                  None => config
                }
              None => config // هˆ°éپ”ن¸چèƒ½ (dec_option مپŒو—¢مپ« object مپ§مپ‚م‚‹مپ“مپ¨م‚’و¤œè¨¼و¸ˆمپ؟)
            }
            options.push(
              apply_env_config(
                {
                  ..e,
                  long_prefix: elem_config.long_prefix,
                  short_prefix: elem_config.short_prefix,
                  allow_equal_separator: elem_config.allow_equal_separator,
                  short_combine: elem_config.short_combine,
                  require_equal_separator: elem_config.require_equal_separator,
                },
                elem_config.env_prefix,
                elem_config.auto_env,
                scope_path,
              ),
            )
          }
          DAlias(al) => aliases.push(al)
        }
      }
    }
    None => ()
  }
  match o.get("positionals") {
    Some(arr) => {
      let a = match arr.j_arr() {
        Some(x) => x
        None => raise DecodeSkip("positionals is not an array")
      }
      for pj in a {
        let e = dec_positional(pj, shadows)
        // Major 1 مپ¨هگŒمپکè¦پç´ هچکن½چ overrideم€پpositional ç‰ˆ (DESIGN آ§7.2م€Œه­گè¦پç´ م€چمپ®ه¯¾ç§°ç¯„ه›²)م€‚
        let elem_config = match pj.j_obj() {
          Some(po) =>
            match po.get("config") {
              Some(ecj) => {
                let eco = match ecj.j_obj() {
                  Some(x) => x
                  None => raise DecodeSkip("positional config is not an object")
                }
                let merged = dec_scope_config(eco, config)
                validate_scope_config(merged)
                merged
              }
              None => config
            }
          None => config // هˆ°éپ”ن¸چèƒ½ (dec_positional مپŒو—¢مپ« object مپ§مپ‚م‚‹مپ“مپ¨م‚’و¤œè¨¼و¸ˆمپ؟)
        }
        positionals.push(
          apply_env_config(
            {
              ..e,
              long_prefix: elem_config.long_prefix,
              short_prefix: elem_config.short_prefix,
              allow_equal_separator: elem_config.allow_equal_separator,
              short_combine: elem_config.short_combine,
              require_equal_separator: elem_config.require_equal_separator,
            },
            elem_config.env_prefix,
            elem_config.auto_env,
            scope_path,
          ),
        )
      }
    }
    None => ()
  }
  match o.get("commands") {
    Some(arr) => {
      let a = match arr.j_arr() {
        Some(x) => x
        None => raise DecodeSkip("commands is not an array")
      }
      for cj in a {
        match dec_command(cj, shadows, config, scope_path) {
          DCommand(c) => commands.push(c)
          DCmdAlias(al) => aliases.push(al)
        }
      }
    }
    None => ()
  }
  { options, positionals, commands, aliases }
}

///|
fn dec_argv(cj : Map[String, Json]) -> Array[String] raise DecodeSkip {
  let aj = match cj.get("argv") {
    Some(x) => x
    None => raise DecodeSkip("case missing 'argv'")
  }
  let a = match aj.j_arr() {
    Some(x) => x
    None => raise DecodeSkip("argv is not an array")
  }
  let out : Array[String] = []
  for t in a {
    match t.j_str() {
      Some(s) => out.push(s)
      None => raise DecodeSkip("argv element is not a string")
    }
  }
  out
}

///|
fn dec_case(cj : Json) -> DCase raise DecodeSkip {
  let co = match cj.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("case is not an object")
  }
  allowed_keys(
    co,
    ["id", "argv", "expect", "env", "config", "config_files", "why"],
    "case",
  )
  let argv = dec_argv(co)
  let id = jf_str(co, "id").unwrap_or("")
  let expect = match co.get("expect") {
    Some(e) => e
    None => raise DecodeSkip("case missing 'expect'")
  }
  let eo = match expect.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("expect is not an object")
  }
  let outcome = match jf_str(eo, "outcome") {
    Some(o) =>
      if o == "success" || o == "failure" || o == "ambiguous" {
        o
      } else {
        raise DecodeSkip("outcome '" + o + "'")
      }
    None => raise DecodeSkip("expect missing 'outcome'")
  }
  let env : Map[String, String] = Map([])
  match co.get("env") {
    Some(ej) => {
      let eobj = match ej.j_obj() {
        Some(x) => x
        None => raise DecodeSkip("case env is not an object")
      }
      for k, v in eobj {
        match v.j_str() {
          Some(s) => env.set(k, s)
          None => raise DecodeSkip("case env value is not a string")
        }
      }
    }
    None => ()
  }
  let cfg = match co.get("config") {
    Some(cjj) => CfgObj(json_to_configval(cjj))
    None =>
      match co.get("config_files") {
        Some(fj) =>
          match fj.j_obj() {
            Some(fo) => {
              let files : Array[(String, ConfigVal)] = []
              for k, v in fo {
                files.push((k, json_to_configval(v)))
              }
              CfgFiles(files)
            }
            None => NoCfg
          }
        None => NoCfg
      }
  }
  let has_sources = has_key(eo, "sources")
  let resolve = has_sources ||
    has_key(co, "env") ||
    (match cfg {
      NoCfg => false
      _ => true
    })
  let exp_effects = match eo.get("effects") {
    Some(x) => Some(exp_effects_str(x))
    None => None
  }
  let exp_result = match eo.get("result") {
    Some(x) => Some(exp_result_str(x))
    None => None
  }
  let (exp_errors, exp_errors_with_reason, exp_errors_with_path) = match
    eo.get("errors") {
    Some(x) => {
      let (s, wr, wp) = exp_errors_decode(x)
      (Some(s), wr, wp)
    }
    None => (None, false, false)
  }
  let exp_interps = match eo.get("interpretations") {
    Some(x) => Some(dec_interps(x))
    None => None
  }
  let exp_warnings = match eo.get("warnings") {
    Some(x) => Some(exp_warnings_str(x))
    None => None
  }
  let exp_sources = if has_sources {
    Some(exp_sources_str(eo.get("sources").unwrap()))
  } else {
    None
  }
  let (fired_cmp, fired_exp) = if outcome == "failure" &&
    has_key(eo, "fired_action") {
    (true, jf_str(eo, "fired_action"))
  } else {
    (false, None)
  }
  // spec issue conformance-tried-triggers-help-entry-fields: help_entry is opt-in on failure OR
  // ambiguous (DR-053 آ§4 material â€” both outcomes can carry a selected/discoverable help entry).
  let (help_cmp, help_exp) = if (outcome == "failure" || outcome == "ambiguous") &&
    has_key(eo, "help_entry") {
    (true, jf_str(eo, "help_entry"))
  } else {
    (false, None)
  }
  // tried_triggers is opt-in on failure only (DR-053 آ§4 material tied to the failure position â€”
  // ambiguous has no single failure position to derive it from). Projected to the SAME sorted
  // `{a,b,c}` string the live Outcome comparison uses, at decode time â€” a plain String compare
  // at the comparison site, matching every other set-compared face.
  let (tried_cmp, tried_exp) = if outcome == "failure" &&
    has_key(eo, "tried_triggers") {
    (true, Some(proj_tried_triggers(dec_strs(eo.get("tried_triggers")))))
  } else {
    (false, None)
  }
  {
    argv,
    id,
    outcome,
    exp_effects,
    exp_result,
    exp_errors,
    exp_errors_with_reason,
    exp_errors_with_path,
    exp_interps,
    exp_warnings,
    exp_sources,
    fired_cmp,
    fired_exp,
    help_cmp,
    help_exp,
    tried_cmp,
    tried_exp,
    resolve,
    env,
    cfg,
  }
}

// â”€â”€ definition_error path (DR-082) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
/// DR-082 آ§1: `query: "definition_error"` fixture مپ® 1 case â€” DR-054 آ§4 مپ® `parse_definition()`
/// è؟”ه€¤م‚’مپ‌مپ®مپ¾مپ¾è»¢ç”¨مپ™م‚‹م€‚`argv` مپ¯ç„،مپ„ (ه®ڑç¾©مپ®é‌™çڑ„و¤œوں»مپ§مپ‚م‚ٹه®ںè،Œمپ—مپھمپ„)م€‚و¯”è¼ƒه¯¾è±،مپ¯
/// element+kind مپ®çµ„مپ®é›†هگˆمپ®مپ؟ (message/hint مپ¯مƒ¬مƒ³مƒ€مƒ©ç®،è½„مپھمپ®مپ§و¯”è¼ƒمپ—مپھمپ„م€پDR-082 آ§1 â€” parse
/// fixture مپ® `errors` مپŒ message م‚’و¯”è¼ƒمپ—مپھمپ„مپ®مپ¨هگŒوµپه„€)م€‚`exp_errors` مپ¯ `deferrs_str` مپ¨هگŒمپک
/// م‚½مƒ¼مƒˆو¸ˆمپ؟ "element/kind" é€£çµگè،¨çڈ¾مپھمپ®مپ§م€په®ںè،Œو™‚مپ«مپ‌مپ®مپ¾مپ¾و–‡ه­—هˆ—و¯”è¼ƒمپ§مپچم‚‹م€‚
struct DDefErrorCase {
  id : String
  exp_errors : String
}

///|
struct DDefErrorFixture {
  def : Definition
  registry : Map[String, Node]
  cases : Array[DDefErrorCase]
}

///|
fn dec_def_error_case(cj : Json) -> DDefErrorCase raise DecodeSkip {
  let co = match cj.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("case is not an object")
  }
  allowed_keys(co, ["id", "why", "expect"], "definition_error case")
  let id = match jf_str(co, "id") {
    Some(s) => s
    None => raise DecodeSkip("case missing 'id'")
  }
  let eo = match co.get("expect") {
    Some(x) =>
      match x.j_obj() {
        Some(o) => o
        None => raise DecodeSkip("expect is not an object")
      }
    None => raise DecodeSkip("case missing 'expect'")
  }
  allowed_keys(eo, ["outcome", "errors"], "definition_error case's expect")
  match jf_str(eo, "outcome") {
    Some("definition-error") => ()
    Some(o) =>
      raise DecodeSkip("expect.outcome '" + o + "' is not 'definition-error'")
    None => raise DecodeSkip("expect missing 'outcome'")
  }
  let errsj = match eo.get("errors") {
    Some(x) => x
    None => raise DecodeSkip("expect missing 'errors'")
  }
  let arr = match errsj.j_arr() {
    Some(x) => x
    None => raise DecodeSkip("expect.errors is not an array")
  }
  let items : Array[String] = []
  for ej in arr {
    let ejo = match ej.j_obj() {
      Some(x) => x
      None => raise DecodeSkip("expect.errors entry is not an object")
    }
    allowed_keys(
      ejo,
      ["element", "kind"],
      "definition_error case's expect.errors entry",
    )
    let element = match jf_str(ejo, "element") {
      Some(s) => s
      None => raise DecodeSkip("errors entry missing 'element'")
    }
    let kind = match jf_str(ejo, "kind") {
      Some(s) => s
      None => raise DecodeSkip("errors entry missing 'kind'")
    }
    items.push(element + "/" + kind)
  }
  sort_items(items)
  { id, exp_errors: join_comma(items) }
}

///|
/// `dec_fixture` (query="parse") مپ¨ه¯¾ç…§çڑ„مپ«م€پمپ“مپ“مپ§مپ¯ `parse_definition` م‚’ه‘¼مپ°مپھمپ„ â€” definition_
/// error fixture مپ®ن¸»و—¨مپ¯م€Œparse_definition مپŒ Err م‚’è؟”مپ™مپ“مپ¨م€چè‡ھن½“م‚’و¤œè¨¼مپ™م‚‹مپ“مپ¨مپھمپ®مپ§م€پ
/// `dec_fixture` مپ®م‚ˆمپ†مپ« `Err` م‚’هچ³ `DecodeSkip` مپ—مپ¦مپ—مپ¾مپ†مپ¨وœ¬é،Œم‚’و¤œè¨¼مپ§مپچمپھمپڈمپھم‚‹
/// (`dec_fixture`'s `"definition rejected: ..."` هˆ†ه²گمپ¨ه¯¾ç…§)م€‚`definition`/`definitions` مپ® decode
/// (dec_definition/dec_types/dec_templates) مپ¯ "parse" مپ¨هگŒمپکçµŒè·¯م‚’ه†چهˆ©ç”¨مپ™م‚‹ â€” و¤œè¨¼ه·®هˆ†مپ¯مپ“مپ®ه¾Œمپ®
/// `parse_definition` ه‘¼مپ³ه‡؛مپ—م‚؟م‚¤مƒںمƒ³م‚° (fixture decode و™‚مپ§مپ¯مپھمپڈ case ه®ںè،Œو™‚) مپ مپ‘م€‚
fn dec_definition_error_fixture(j : Json) -> DDefErrorFixture raise DecodeSkip {
  let top = match j.j_obj() {
    Some(o) => o
    None => raise DecodeSkip("fixture is not an object")
  }
  let defj = match top.get("definition") {
    Some(d) => d
    None => raise DecodeSkip("missing 'definition'")
  }
  let defo = match defj.j_obj() {
    Some(o) => o
    None => raise DecodeSkip("definition is not an object")
  }
  allowed_keys(
    defo,
    [
      "options", "positionals", "commands", "definitions",
      // DR-091 آ§3 (scope config, DESIGN آ§7.2 مپ®ه…„ه¼ں): `dec_definition` مپŒèھ­م‚€ nested config objectم€‚
       "config",
    ],
    "definition",
  )
  let registry : Map[String, Node] = Map([])
  let shadows = match defo.get("definitions") {
    Some(dj) => {
      let d = match dj.j_obj() {
        Some(x) => x
        None => raise DecodeSkip("definitions is not an object")
      }
      allowed_keys(d, ["types", "templates"], "definitions")
      let ts = match d.get("types") {
        Some(tj) => dec_types(tj)
        None => Map([])
      }
      match d.get("templates") {
        Some(tmplj) => dec_templates(tmplj, ts, registry)
        None => ()
      }
      ts
    }
    None => Map([])
  }
  let def = dec_definition(defo, shadows~)
  let casesj = match top.get("cases") {
    Some(c) => c
    None => raise DecodeSkip("missing 'cases'")
  }
  let carr = match casesj.j_arr() {
    Some(x) => x
    None => raise DecodeSkip("cases is not an array")
  }
  let cases : Array[DDefErrorCase] = []
  for cj in carr {
    cases.push(dec_def_error_case(cj))
  }
  { def, registry, cases }
}

///|
/// DR-082 آ§1: run `parse_definition` and compare its `Err` (element+kind set) against the fixture's
/// expectation. An unexpected `Ok` (the definition was NOT rejected) is itself a mismatch â€”
/// `render_outcome`-style "EXPECTED-*" convention mirrors the parse-path runner's diagnostics.
fn run_definition_error(fx : DDefErrorFixture, c : DDefErrorCase) -> String {
  match parse_definition(fx.def, full_installers(), registry=fx.registry) {
    Ok(_) => "EXPECTED-DEFINITION-ERROR got=ok"
    Err(errs) => {
      let got = deferrs_str(errs)
      if got == c.exp_errors {
        "PASS"
      } else {
        "errors got=\{got} want=\{c.exp_errors}"
      }
    }
  }
}

///|
fn dec_fixture(j : Json) -> DecodedFixture raise DecodeSkip {
  let top = match j.j_obj() {
    Some(o) => o
    None => raise DecodeSkip("fixture is not an object")
  }
  match jf_str(top, "query") {
    Some("parse") => ()
    Some(q) => raise DecodeSkip("query '" + q + "' (parse/lower only)")
    None => raise DecodeSkip("missing 'query'")
  }
  let defj = match top.get("definition") {
    Some(d) => d
    None => raise DecodeSkip("missing 'definition'")
  }
  let defo = match defj.j_obj() {
    Some(o) => o
    None => raise DecodeSkip("definition is not an object")
  }
  // DR-061 آ§3 configurable factory: `definitions.types` م‚’è¨±ه®¹مپ—م€پمپ‌مپ®ن¸­è؛«م‚’ shadow map مپ« decodeم€‚
  // shadow مپ¯ dec_definition مپ« thread مپ•م‚Œمپ¦ type هگچè§£و±؛مپ§ consultation مپ•م‚Œم‚‹م€‚
  // DR-078 آ§1: `definitions.templates` (ه…±وœ‰و¶ˆè²»و–‡و³•م€پidâ†’Node) م‚‚هگŒمپک `definitions` م‚ھمƒ–م‚¸م‚§م‚¯مƒˆمپ®
  // هŒ؛هˆ†مپ¨مپ—مپ¦è¨±ه®¹مپ—م€پ`registry` (parse_definition مپ® ref è§£و±؛ç©؛é–“) م‚’ن؛‹ه‰چمپ«هں‹م‚پم‚‹ â€” types (shadow
  // map) مپ¨مپ¯هˆ¥مپ®هڈ—مپ‘çڑ؟ (آ§2: templates مپ¯ه¤–éƒ¨ registry م‚’وŒپمپںمپھمپ„ه”¯ن¸€مپ®هŒ؛هˆ†م€پم‚¯مƒ­مƒ¼م‚¸مƒ£مپھمپ—مپ®ç´”و§‹é€ )م€‚
  allowed_keys(
    defo,
    [
      "options", "positionals", "commands", "definitions",
      // DR-091 آ§3 (scope config, DESIGN آ§7.2 مپ®ه…„ه¼ں): `dec_definition` مپŒèھ­م‚€ nested config objectم€‚
       "config",
    ],
    "definition",
  )
  let registry : Map[String, Node] = Map([])
  let shadows = match defo.get("definitions") {
    Some(dj) => {
      let d = match dj.j_obj() {
        Some(x) => x
        None => raise DecodeSkip("definitions is not an object")
      }
      allowed_keys(d, ["types", "templates"], "definitions")
      let ts = match d.get("types") {
        Some(tj) => dec_types(tj)
        None => Map([])
      }
      match d.get("templates") {
        Some(tmplj) => dec_templates(tmplj, ts, registry)
        None => ()
      }
      ts
    }
    None => Map([])
  }
  let def = dec_definition(defo, shadows~)
  let scope = match parse_definition(def, full_installers(), registry~) {
    Ok(sc) => sc
    Err(errs) => raise DecodeSkip("definition rejected: " + deferrs_str(errs))
  }
  let ekmap = build_export_map(def)
  let casesj = match top.get("cases") {
    Some(c) => c
    None => raise DecodeSkip("missing 'cases'")
  }
  let carr = match casesj.j_arr() {
    Some(x) => x
    None => raise DecodeSkip("cases is not an array")
  }
  let cases : Array[DCase] = []
  for cj in carr {
    cases.push(dec_case(cj))
  }
  { scope, registry, ekmap, cases }
}

// â”€â”€ lower path â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
struct DecodedLower {
  def : Definition
  order : Array[Installer]
  want : LSec
}

///|
fn dec_installer(name : String) -> Installer raise DecodeSkip {
  for i in full_installers() {
    if owned_vocab(i) == name {
      return i
    }
  }
  raise DecodeSkip("unknown installer '" + name + "'")
}

///|
fn dec_installers(top : Map[String, Json]) -> Array[Installer] raise DecodeSkip {
  match top.get("installers") {
    None => full_installers()
    Some(j) =>
      match j.j_arr() {
        None => full_installers()
        Some(a) => {
          let out : Array[Installer] = []
          for e in a {
            match e.j_str() {
              Some(s) => out.push(dec_installer(s))
              None => raise DecodeSkip("installers[] element is not a string")
            }
          }
          out
        }
      }
  }
}

///|
fn req_field(o : Map[String, Json], key : String) -> String raise DecodeSkip {
  match jf_str(o, key) {
    Some(s) => s
    None => raise DecodeSkip("golden node missing string field '" + key + "'")
  }
}

///|
fn dec_ref_link(
  o : Map[String, Json],
  what : String,
) -> String raise DecodeSkip {
  allowed_keys(o, ["ref", "link"], what)
  let r = req_field(o, "ref")
  let l = req_field(o, "link")
  if l != r {
    raise DecodeSkip(
      what +
      " has refâ‰ link (unrepresentable in و–­é‌¢: ref=" +
      r +
      " link=" +
      l +
      ")",
    )
  }
  r
}

///|
fn dec_gitem(j : Json) -> GItem raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("greedy item is not an object")
  }
  if has_key(o, "scope") {
    allowed_keys(o, ["exact", "scope"], "golden command subtree")
    let name = req_field(o, "exact")
    let so = match o.get("scope").unwrap().j_obj() {
      Some(x) => x
      None => raise DecodeSkip("command 'scope' is not an object")
    }
    return GCmd(name, dec_lsec(so))
  }
  if has_key(o, "matcher") {
    allowed_keys(o, ["matcher", "entries"], "golden matcher")
    let kind = req_field(o, "matcher")
    let entries : Array[(String, String)] = []
    match o.get("entries") {
      Some(ej) =>
        match ej.j_obj() {
          Some(eo) =>
            for k, v in eo {
              match v.j_str() {
                Some(nm) => entries.push((k, nm))
                None => raise DecodeSkip("matcher entry value is not a string")
              }
            }
          None => raise DecodeSkip("matcher 'entries' is not an object")
        }
      None => raise DecodeSkip("matcher missing 'entries'")
    }
    return GMatch(kind, entries)
  }
  if has_key(o, "seq") {
    allowed_keys(o, ["seq"], "golden seq satellite")
    let sa = match o.get("seq").unwrap().j_arr() {
      Some(x) => x
      None => raise DecodeSkip("greedy seq is not an array")
    }
    if sa.length() != 2 {
      raise DecodeSkip("greedy seq satellite is not [exact, ref]")
    }
    let trig = match sa[0].j_obj() {
      Some(x) => {
        allowed_keys(x, ["exact"], "golden seq trigger")
        req_field(x, "exact")
      }
      None => raise DecodeSkip("greedy seq[0] is not an object")
    }
    let refn = match sa[1].j_obj() {
      Some(x) => dec_ref_link(x, "golden seq value cell")
      None => raise DecodeSkip("greedy seq[1] is not an object")
    }
    return GSeqSat(trig, refn)
  }
  if has_key(o, "value") {
    allowed_keys(o, ["exact", "value", "link"], "golden set descriptor")
    return GSet(
      req_field(o, "exact"),
      json_to_value(o.get("value").unwrap()),
      req_field(o, "link"),
    )
  }
  // DR-045 effect descriptor (`{exact, link, effect: {op, transform?, args?}}`) â€” the non-Set ops
  // (default/unset/empty/update, DR-011/077) that lower to `Seq([Exact, EffMark])` (see the
  // `[Exact(t), EffMark(n, op)] => GEff(t, n, op)` projection below). No `lower fixture` used this
  // shape before DR-077 (every prior lowering fixture only exercised Set), so this decode path is
  // new â€” added for count's `:update:increment` lowering fixtures, but generic over all 4 non-set
  // ops.
  if has_key(o, "effect") {
    allowed_keys(o, ["exact", "link", "effect"], "golden effect descriptor")
    let ex = req_field(o, "exact")
    let link = req_field(o, "link")
    let effo = match o.get("effect").unwrap().j_obj() {
      Some(x) => x
      None => raise DecodeSkip("effect is not an object")
    }
    return GEff(ex, link, dec_eff_op(effo))
  }
  allowed_keys(o, ["exact"], "golden greedy exact")
  GExact(req_field(o, "exact"))
}

///|
/// DR-045 op vocab (`set`/`default`/`unset`/`empty`) + DR-077 آ§1's 5th op (`update`, which additionally
/// carries a `transform` name + optional `args`). `set` is accepted for completeness even though
/// GSet's dedicated `{value, link}` shorthand is the normal spelling for it in a fixture.
fn dec_eff_op(o : Map[String, Json]) -> EffectOp raise DecodeSkip {
  let opstr = match jf_str(o, "op") {
    Some(s) => s
    None => raise DecodeSkip("effect missing 'op'")
  }
  match opstr {
    "set" => Set
    "default" => Default
    "unset" => Unset
    "empty" => Empty
    "update" => {
      let transform = match jf_str(o, "transform") {
        Some(t) => t
        None => raise DecodeSkip("update effect missing 'transform'")
      }
      let args : Array[String] = match o.get("args") {
        Some(aj) =>
          match aj.j_arr() {
            Some(a) => {
              let r : Array[String] = []
              for e in a {
                match e.j_str() {
                  Some(s) => r.push(s)
                  None =>
                    raise DecodeSkip(
                      "update effect args element is not a string",
                    )
                }
              }
              r
            }
            None => raise DecodeSkip("update effect 'args' is not an array")
          }
        None => []
      }
      Update(transform, args)
    }
    other => raise DecodeSkip("unrecognized effect op '" + other + "'")
  }
}

///|
fn dec_pos_tnode(j : Json) -> TNode raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("positional node is not an object")
  }
  if has_key(o, "link") {
    return TRefEnt(dec_ref_link(o, "positional entity ref"))
  }
  match jf_str(o, "ref") {
    Some(k) => {
      allowed_keys(o, ["ref", "optional"], "positional template ref")
      TRefTmpl(canon_tmpl(k), bool_field(o, "optional", false))
    }
    None => raise DecodeSkip("unrecognized positional node")
  }
}

///|
fn dec_tmpl_body(j : Json) -> TNode raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("template body is not an object")
  }
  if has_key(o, "seq") {
    allowed_keys(o, ["seq"], "template seq")
    let sa = match o.get("seq").unwrap().j_arr() {
      Some(x) => x
      None => raise DecodeSkip("template seq is not an array")
    }
    let items : Array[TNode] = []
    for e in sa {
      items.push(dec_tmpl_body(e))
    }
    return TSeq(items)
  }
  if has_key(o, "link") {
    return TRefEnt(dec_ref_link(o, "template entity ref"))
  }
  if has_key(o, "ref") {
    allowed_keys(o, ["ref", "optional"], "template ref")
    return TRefTmpl(
      canon_tmpl(req_field(o, "ref")),
      bool_field(o, "optional", false),
    )
  }
  allowed_keys(o, ["exact"], "template literal")
  TExact(req_field(o, "exact"))
}

///|
fn dec_lent(name : String, j : Json) -> LEnt raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("entity is not an object")
  }
  allowed_keys(
    o,
    ["type", "default", "env", "inherit", "config_key", "accumulator"],
    "golden entity",
  )
  let typ = req_field(o, "type")
  let default_ = match o.get("default") {
    Some(d) => Some(json_to_value(d))
    None => None
  }
  let config_key : Array[String]? = match o.get("config_key") {
    Some(c) => Some(dec_strs(Some(c)))
    None => None
  }
  {
    name,
    typ,
    default_,
    env: jf_str(o, "env"),
    inherit_: bool_field(o, "inherit", false),
    config_key,
    accum: jf_str(o, "accumulator"),
  }
}

///|
fn dec_lcon(j : Json) -> Constraint raise DecodeSkip {
  let o = match j.j_obj() {
    Some(x) => x
    None => raise DecodeSkip("constraint is not an object")
  }
  match req_field(o, "kind") {
    "requires" => {
      allowed_keys(o, ["kind", "element", "targets"], "requires constraint")
      CRequires(req_field(o, "element"), dec_strs(o.get("targets")))
    }
    "conflicts_with" => {
      allowed_keys(
        o,
        ["kind", "element", "targets"],
        "conflicts_with constraint",
      )
      CConflicts(req_field(o, "element"), dec_strs(o.get("targets")))
    }
    "requires_if" => {
      // DR-055 آ§1 + DR-052 آ§ه€¤و‍‌ id ç›´ن؛¤: fixture هپ´مپŒ constraints[] م‚’ç›´ه®£è¨€مپ™م‚‹ه ´é‌¢مپ§مپ® decoderم€‚
      // `entity` (committed هˆ¤ه®ڑه¯¾è±،) مپ¨ `element` (éپ•هڈچو™‚ emit مپ™م‚‹ branch_id) مپ®ن¸،و–¹م‚’هڈ—مپ‘ن»کمپ‘م‚‹م€‚
      // `entity` çœپç•¥و™‚مپ¯ `element` مپ«مƒ•م‚©مƒ¼مƒ«مƒگمƒƒم‚¯ (parent ç›´ه±‍ value_requires ç›¸ه½“مپ®وڑ—é»™ه½¢)م€‚
      allowed_keys(
        o,
        ["kind", "entity", "element", "value", "targets"],
        "requires_if constraint",
      )
      let element = req_field(o, "element")
      let entity = jf_str(o, "entity").unwrap_or(element)
      CRequiresIf(
        entity,
        element,
        req_field(o, "value"),
        dec_strs(o.get("targets")),
      )
    }
    "exclusive_group" => {
      allowed_keys(
        o,
        ["kind", "group", "members"],
        "exclusive_group constraint",
      )
      CExclusive(req_field(o, "group"), dec_strs(o.get("members")))
    }
    other => raise DecodeSkip("unsupported constraint kind '" + other + "'")
  }
}

///|
fn dec_lsec(o : Map[String, Json]) -> LSec raise DecodeSkip {
  allowed_keys(
    o,
    ["greedy", "positionals", "entities", "constraints", "templates"],
    "golden و–­é‌¢",
  )
  let greedy : Array[GItem] = []
  match o.get("greedy") {
    Some(gj) =>
      match gj.j_arr() {
        Some(a) =>
          for e in a {
            greedy.push(dec_gitem(e))
          }
        None => raise DecodeSkip("greedy is not an array")
      }
    None => ()
  }
  let positionals : Array[TNode] = []
  match o.get("positionals") {
    Some(pj) =>
      match pj.j_arr() {
        Some(a) =>
          for e in a {
            positionals.push(dec_pos_tnode(e))
          }
        None => raise DecodeSkip("positionals is not an array")
      }
    None => ()
  }
  let entities : Array[LEnt] = []
  match o.get("entities") {
    Some(en) =>
      match en.j_obj() {
        Some(eo) =>
          for k, v in eo {
            entities.push(dec_lent(k, v))
          }
        None => raise DecodeSkip("entities is not an object")
      }
    None => ()
  }
  let constraints : Array[Constraint] = []
  match o.get("constraints") {
    Some(cj) =>
      match cj.j_arr() {
        Some(a) =>
          for e in a {
            constraints.push(dec_lcon(e))
          }
        None => raise DecodeSkip("constraints is not an array")
      }
    None => ()
  }
  let templates : Array[(String, TNode)] = []
  match o.get("templates") {
    Some(tj) =>
      match tj.j_obj() {
        Some(to) =>
          for k, v in to {
            templates.push((canon_tmpl(k), dec_tmpl_body(v)))
          }
        None => raise DecodeSkip("templates is not an object")
      }
    None => ()
  }
  { greedy, positionals, entities, constraints, templates }
}

///|
fn dec_lower(j : Json) -> DecodedLower raise DecodeSkip {
  let top = match j.j_obj() {
    Some(o) => o
    None => raise DecodeSkip("fixture is not an object")
  }
  let defo = match top.get("definition") {
    Some(d) =>
      match d.j_obj() {
        Some(o) => o
        None => raise DecodeSkip("definition is not an object")
      }
    None => raise DecodeSkip("missing 'definition'")
  }
  // DR-061 آ§3 configurable factory: `definitions.types` م‚’è¨±ه®¹مپ—م€پمپ‌مپ®ن¸­è؛«م‚’ shadow map مپ« decodeم€‚
  // shadow مپ¯ dec_definition مپ« thread مپ•م‚Œمپ¦ type هگچè§£و±؛مپ§ consultation مپ•م‚Œم‚‹م€‚
  allowed_keys(
    defo,
    [
      "options", "positionals", "commands", "definitions",
      // DR-091 آ§3 (scope config, DESIGN آ§7.2 مپ®ه…„ه¼ں): `dec_definition` مپŒèھ­م‚€ nested config objectم€‚
       "config",
    ],
    "definition",
  )
  let shadows = match defo.get("definitions") {
    Some(dj) => {
      let d = match dj.j_obj() {
        Some(x) => x
        None => raise DecodeSkip("definitions is not an object")
      }
      allowed_keys(d, ["types"], "definitions")
      match d.get("types") {
        Some(tj) => dec_types(tj)
        None => Map([])
      }
    }
    None => Map([])
  }
  let def = dec_definition(defo, shadows~)
  let order = dec_installers(top)
  let expo = match top.get("expect") {
    Some(e) =>
      match e.j_obj() {
        Some(o) => o
        None => raise DecodeSkip("expect is not an object")
      }
    None => raise DecodeSkip("missing 'expect'")
  }
  { def, order, want: dec_lsec(expo) }
}

// â”€â”€ fixtures discovery â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
fn is_json_file(name : String) -> Bool {
  let cs = to_chars(name)
  let n = cs.length()
  n >= 5 &&
  cs[n - 5] == '.' &&
  cs[n - 4] == 'j' &&
  cs[n - 3] == 's' &&
  cs[n - 2] == 'o' &&
  cs[n - 1] == 'n'
}

///|
fn fixtures_root() -> String {
  match @env.get_env_var("KUU_FIXTURES") {
    Some(p) => if p != "" && @fs.path_exists(p) { return p }
    None => ()
  }
  for
    cand in [
      "../../../kuu/main/fixtures", "../../kuu/main/fixtures", "../../../../kuu/main/fixtures",
    ] {
    if @fs.path_exists(cand) {
      return cand
    }
  }
  let cwd = match @env.current_dir() {
    Some(d) => d
    None => "?"
  }
  abort(
    "fixtures root not found (set KUU_FIXTURES to kuu/main/fixtures); cwd=" +
    cwd,
  )
}

///|
fn collect_rel(root : String, rel : String, out : Array[String]) -> Unit raise {
  let dir = if rel == "" { root } else { root + "/" + rel }
  for name in @fs.read_dir(dir) {
    let r = if rel == "" { name } else { rel + "/" + name }
    let p = root + "/" + r
    if @fs.is_dir(p) {
      collect_rel(root, r, out)
    } else if is_json_file(name) {
      out.push(r)
    }
  }
}

// â”€â”€ the case runner â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
fn scope_needs_default_ladder(sc : Scope) -> Bool {
  for g in sc.greedy {
    match g {
      CmdSat(_, _) => return false
      _ => ()
    }
  }
  for e in sc.entities {
    if e.ty != TFlag && e.ty != TBool && e.default_values is Some(_) {
      return true
    }
    // DR-009 value_filters/cell_filters (issue 2026-07-09-filters-registry-foundation) are applied by
    // `resolve_entity` (resolve.mbt's `apply_entity_filters`), NOT by the raw CLI `binds` array
    // this function's `false` result routes to. `resolve_entity_raw`'s CLI-seat fold interprets an
    // accum cell's op sequence now (issue 2026-07-09-accum-entity-filters-wiring's raw-preservation
    // groundwork, extended by issue 2026-07-09-accum-fold-update-default-ops's committed tracking +
    // ladder fall-through), so an accum cell with value_filters/cell_filters ALSO needs the resolve
    // path â€” the guard that used to exclude accum (`e.accum is None &&`) is removed. `apply_entity_
    // filters` already skips cell_filters for an accum cell (accumulated-array post is a separate
    // stage, issue accum-post-filters-stage7); routing through resolve here only activates
    // value_filters(each).
    if e.value_filters.length() > 0 || e.cell_filters.length() > 0 {
      return true
    }
    // DR-080 و³¢هڈٹç¯€: a merge-accumulator cell's Set/Remove/Splice PIECE bindings only fold into
    // the cell's final state inside `resolve_merge_accum` (resolve.mbt) â€” the raw-`binds` fold
    // this function's `false` result routes to (`build_result`'s generic ACCUMULATE match) has no
    // concept of "هگŒمپک at_pos مپ® piece هˆ— = 1 ç™؛çپ«" grouping or old-composition, and would push a
    // `Splice`/`Remove` binding's placeholder/operand value straight into the array (wrong on
    // every axis: no overwrite-vs-merge distinction, no @ old-splice, `Remove`'s operand and
    // `Splice`'s `VBool(false)` placeholder both leak into the result). A merge cell ALWAYS needs
    // the resolve path, even with no env/config/default/filters declared.
    if e.accum is Some("merge") {
      return true
    }
  }
  false
}

///|
fn has_commands(sc : Scope) -> Bool {
  for g in sc.greedy {
    match g {
      CmdSat(_, _) => return true
      _ => ()
    }
  }
  false
}

///|
fn cfg_lookup(files : Array[(String, ConfigVal)], p : String) -> ConfigVal? {
  for kv in files {
    if kv.0 == p {
      return Some(kv.1)
    }
  }
  None
}

///|
fn pe_msg(pe : ParseError) -> String {
  pe.message
}

///|
/// The `ParseError`-preserving form (`"failure"`-branch resolve check, DR-009 آ§7 cell_filters etc.
/// surfacing as a resolve-layer Err even when `parse()` itself succeeded â€” see `do_resolve`'s
/// string-message wrapper below, kept for its existing "success"-branch callers).
fn do_resolve_pe(
  sc : Scope,
  cli : Array[Binding],
  dc : DCase,
) -> Result[Array[Binding], ParseError] {
  // `at_pos: dc.argv.length()` â€” a resolve-layer Error (env/config seat parse failure, or a
  // DR-009 آ§7 value_filters/cell_filters reject) is not read at a token position, it surfaces after
  // the argv path completed (`ladder_err`'s doc comment, resolve.mbt). Threading the real final
  // position here (instead of `resolve_scope`/`resolve_scope_config`'s `at_pos? = -1` default)
  // matches `eval_constraints`'s convention for the same conceptual point (DR-053 آ§2).
  let at_pos = dc.argv.length()
  match dc.cfg {
    NoCfg => resolve_scope(sc, cli, dc.env, at_pos~)
    CfgObj(obj) =>
      resolve_scope_config(sc, cli, dc.env, fn(_p) { Some(obj) }, at_pos~)
    CfgFiles(files) =>
      resolve_scope_config(
        sc,
        cli,
        dc.env,
        fn(p) { cfg_lookup(files, p) },
        at_pos~,
      )
  }
}

///|
fn do_resolve(
  sc : Scope,
  cli : Array[Binding],
  dc : DCase,
) -> Result[Array[Binding], String] {
  match do_resolve_pe(sc, cli, dc) {
    Ok(rb) => Ok(rb)
    Err(pe) => Err(pe_msg(pe))
  }
}

///|
/// `dc.cfg` (NoCfg/CfgObj/CfgFiles) â†’ `resolve.mbt`'s `resolve_scope_tree` provider ه¥‘ç´„مپ¸مپ®è–„مپ„
/// م‚¢مƒ€مƒ—م‚؟ (issue resolve-first-constraint-pipeline Phase 1: ه†چه¸°çڑ„مپھوœ¨è§£و±؛مƒ­م‚¸مƒƒم‚¯è‡ھن½“مپ¯
/// `resolve_scope_tree` هپ´مپ«ن¸€وœ¬هŒ–م€پمپ“مپ“مپ§مپ¯ DCase هˆ†ه²گمپ¨ `Result[..., ParseError]` â†’
/// `Result[..., String]` مپ®مƒڈمƒ¼مƒچم‚¹هگ‘مپ‘و•´ه½¢مپ مپ‘م‚’و‹…مپ† â€” `do_resolve_pe`/`run_case` مپ®
/// `bool_requires_provider` مپ¨هگŒه‍‹مپ®هˆ†ه²گ)م€‚
fn resolve_tree(
  sc : Scope,
  binds : Array[Binding],
  dc : DCase,
  path : Array[String],
  inherited : Map[String, Value],
) -> Result[Array[Binding], String] {
  let provider : (String) -> ConfigVal? = match dc.cfg {
    NoCfg => fn(_p) { None }
    CfgObj(obj) => fn(_p) { Some(obj) }
    CfgFiles(files) => fn(p) { cfg_lookup(files, p) }
  }
  // See `do_resolve_pe`'s comment: real final argv position, not the `-1` default.
  let at_pos = dc.argv.length()
  match
    resolve_scope_tree(sc, binds, dc.env, provider, path~, inherited~, at_pos~) {
    Ok(rb) => Ok(rb)
    Err(pe) => Err(pe_msg(pe))
  }
}

///|
fn run_case(df : DecodedFixture, dc : DCase) -> String {
  let sc = df.scope
  let root = ScopeNode(sc)
  // DR-047 آ§5 وکژç¢؛هŒ– (kawaz è£په®ڑ 2026-07-09): bool-target requires/CRequiresIf مپ¯ KTop (CLI é‌¢
  // مپ®مپ؟) مپ§مپ¯ه¸¸مپ«م‚¹م‚­مƒƒمƒ—مپ•م‚Œمپ¦مپ„م‚‹مپ®مپ§م€په€¤و؛گ (env) مپŒè§£مپ‘م‚‹ه¾Œو®µمپ§مپ“مپ“مپ§مƒ•م‚£مƒ«م‚؟مپ™م‚‹
  // (cell_filters مپ¨هگŒمپکهپ´م€پ`resolve.mbt` مپ® `apply_requires_filter` â€” çµŒè·¯و•°مپ«ه؟œمپکمپ¦
  // success/ambiguous/failure م‚’ه†چç¢؛ه®ڑ)م€‚DR-021 â†’ DR-073 مپ® export-key collision وک‡و ¼
  // (`promote_collision_ambiguous`) م‚ˆم‚ٹه…ˆمپ«éپ©ç”¨مپ™م‚‹ â€” è²¬ه‹™مپŒç•°مپھم‚‹2مپ¤مپ®ه¾Œه‡¦çگ† (م€ŒçµŒè·¯مپ®وˆگç«‹
  //è‡ھن½“م€چمپ¨م€Œexport-key è،‌çھپمپ«م‚ˆم‚‹ Successâ†’Ambiguous وک‡و ¼م€چ) م‚’ç´ ç›´مپ«ç›´هˆ—مپ«ن¸¦مپ¹م‚‹م€‚
  // issue resolve-first-constraint-pipeline (Phase 1م€پو—§ bool-requires-config-inherit-gap è£په®ڑ
  // 2026-07-10 (b) م‚’ç½®مپچوڈ›مپˆ): apply_requires_filter مپ¯ه€™è£œمپ”مپ¨مپ« `resolve_scope_tree` م‚’
  // ه®ںéڑ›مپ«ه‘¼مپ¶م‚ˆمپ†مپ«مپھمپ£مپںمپ®مپ§م€پ`resolve_scope_config` مپ¨هگŒمپک `provider: (String) -> ConfigVal?`
  // ه¥‘ç´„م‚’مپ‌مپ®مپ¾مپ¾و¸،مپ›م‚‹ â€” `do_resolve_pe` مپŒ dc.cfg مپ‹م‚‰ن½œم‚‹ provider مپ¨هگŒه‍‹ (CfgFiles م‚‚
  // ه‌‡ن¸€مپ«و‰±م‚ڈم‚Œم€پهچکن¸€ ConfigVal مپ مپ£مپںو—§ه¥‘ç´„مپ®و—¢çں¥مپ®و®‹ه­کم‚®مƒ£مƒƒمƒ—مپŒè§£و¶ˆ)م€‚
  let bool_requires_provider : (String) -> ConfigVal? = match dc.cfg {
    NoCfg => fn(_p) { None }
    CfgObj(obj) => fn(_p) { Some(obj) }
    CfgFiles(files) => fn(p) { cfg_lookup(files, p) }
  }
  let outcome = promote_collision_ambiguous(
    apply_requires_filter(
      parse(root, dc.argv, defs=df.registry),
      root,
      df.registry,
      dc.env,
      dc.argv.length(),
      provider=bool_requires_provider,
    ),
    df.ekmap,
  )
  let problems : Array[String] = []
  let use_resolve = dc.resolve || scope_needs_default_ladder(sc)
  match dc.outcome {
    "success" =>
      match outcome {
        Success(binds) => {
          match dc.exp_effects {
            Some(ee) => {
              let ae = proj_effects_ex(sc, binds)
              if ae != ee {
                problems.push("effects got=\{ae} want=\{ee}")
              }
            }
            None => ()
          }
          if dc.resolve && has_commands(sc) {
            match resolve_tree(sc, binds, dc, [], Map([])) {
              Ok(rb) => {
                match dc.exp_result {
                  Some(er) => {
                    let ar = proj_result_export(sc, rb, df.ekmap)
                    if ar != er {
                      problems.push("result got=\{ar} want=\{er}")
                    }
                  }
                  None => ()
                }
                match dc.exp_sources {
                  Some(es) => {
                    let asr = proj_sources_tree(rb)
                    if asr != es {
                      problems.push("sources got=\{asr} want=\{es}")
                    }
                  }
                  None => ()
                }
              }
              Err(msg) => problems.push("resolve error: " + msg)
            }
          } else if use_resolve {
            match do_resolve(sc, binds, dc) {
              Ok(rb) => {
                match dc.exp_result {
                  Some(er) => {
                    let ar = proj_result_export(sc, rb, df.ekmap)
                    if ar != er {
                      problems.push("result got=\{ar} want=\{er}")
                    }
                  }
                  None => ()
                }
                match dc.exp_sources {
                  Some(es) => {
                    let asr = proj_sources(sc, rb, df.ekmap)
                    if asr != es {
                      problems.push("sources got=\{asr} want=\{es}")
                    }
                  }
                  None => ()
                }
              }
              Err(msg) => problems.push("resolve error: " + msg)
            }
          } else {
            match dc.exp_result {
              Some(er) => {
                let ar = proj_result_export(sc, binds, df.ekmap)
                if ar != er {
                  problems.push("result got=\{ar} want=\{er}")
                }
              }
              None => ()
            }
          }
          match dc.exp_warnings {
            Some(ew) => {
              let aw = proj_warnings(outcome)
              if aw != ew {
                problems.push("warnings got=\{aw} want=\{ew}")
              }
            }
            None => ()
          }
        }
        other => problems.push("EXPECTED-SUCCESS got=" + render_outcome(other))
      }
    "failure" =>
      match outcome {
        Failure(d) => {
          match dc.exp_errors {
            Some(ex) => {
              let ae = proj_errors(
                d.errors,
                dc.exp_errors_with_reason,
                dc.exp_errors_with_path,
              )
              if ae != ex {
                problems.push("errors got=\{ae} want=\{ex}")
              }
            }
            None => ()
          }
          if dc.fired_cmp {
            let got = match d.fired_action {
              Some(s) => s
              None => "(none)"
            }
            let want = match dc.fired_exp {
              Some(s) => s
              None => "(none)"
            }
            if got != want {
              problems.push("fired_action got=\{got} want=\{want}")
            }
          }
          if dc.help_cmp {
            let got = match d.help_entry {
              Some(s) => s
              None => "(none)"
            }
            let want = match dc.help_exp {
              Some(s) => s
              None => "(none)"
            }
            if got != want {
              problems.push("help_entry got=\{got} want=\{want}")
            }
          }
          if dc.tried_cmp {
            let got = proj_tried_triggers(d.tried_triggers)
            let want = match dc.tried_exp {
              Some(s) => s
              None => "{}"
            }
            if got != want {
              problems.push("tried_triggers got=\{got} want=\{want}")
            }
          }
        }
        // DR-009 آ§7 cell_filters (and any other resolve-layer check, e.g. a future
        // constraint that only resolve sees): `parse()` itself can succeed while the VALUE
        // resolution layer (env/config/inherit/default ladder fill + filter chains,
        // resolve.mbt) still rejects â€” a "failure" fixture case exercising THAT path needs
        // the resolve check run here too, mirroring the "success" branch's
        // `use_resolve`-gated `do_resolve` call. Without this, a resolve-layer Err was
        // invisible to `"failure"` fixtures entirely (this function's `match outcome` never
        // called resolve at all before) â€” `Success` fell straight to the `other` catch-all
        // below and got mis-reported as EXPECTED-FAILURE got=ok{...}.
        Success(binds) if use_resolve =>
          match do_resolve_pe(sc, binds, dc) {
            Err(pe) =>
              match dc.exp_errors {
                Some(ex) => {
                  let ae = proj_errors(
                    [pe],
                    dc.exp_errors_with_reason,
                    dc.exp_errors_with_path,
                  )
                  if ae != ex {
                    problems.push("errors got=\{ae} want=\{ex}")
                  }
                }
                None => ()
              }
            Ok(_) =>
              problems.push("EXPECTED-FAILURE got=ok (resolve also succeeded)")
          }
        other => problems.push("EXPECTED-FAILURE got=" + render_outcome(other))
      }
    _ =>
      match outcome {
        Ambiguous(d) => {
          match dc.exp_interps {
            Some(ei) => {
              let got : Array[String] = []
              for interp in d.interpretations {
                // Result-object view is always rendered (DR-053 آ§3 éھ¨و ¼و¸©ه­ک)
                let view = render_rval_sorted(
                  build_result(
                    apply_export_keys(interp.binds, df.ekmap),
                    accum_cells(sc, df.ekmap),
                    [],
                    [],
                    nones=none_cells(sc),
                  ),
                )
                // DR-073 آ§1: append `#claimants{...}` suffix only when the interpretation carries
                // a non-empty claimantsé‌¢ (matches exp_interp_str's `view + "#claimants" + ...`
                // encoding at line 1500). Non-collision interpretations render as bare view â€” the
                // renderer must not synthesize an empty `#claimants{}` for those (would fail the
                // structural or-position/repeat/prefix-guard ambiguous fixtures whose expected
                // form is view-only, not `view#claimants{}`).
                if interp.claimants.length() == 0 {
                  got.push(view)
                } else {
                  let items : Array[String] = []
                  for kv in interp.claimants {
                    items.push(kv.0 + "=" + kv.1)
                  }
                  sort_items(items)
                  got.push(view + "#claimants{" + join_comma(items) + "}")
                }
              }
              sort_items(got)
              let ag = join_comma(got)
              let ew = join_comma(ei)
              if ag != ew {
                problems.push("interpretations got=[\{ag}] want=[\{ew}]")
              }
            }
            None => ()
          }
          if dc.help_cmp {
            let got = match d.help_entry {
              Some(s) => s
              None => "(none)"
            }
            let want = match dc.help_exp {
              Some(s) => s
              None => "(none)"
            }
            if got != want {
              problems.push("help_entry got=\{got} want=\{want}")
            }
          }
        }
        other =>
          problems.push("EXPECTED-AMBIGUOUS got=" + render_outcome(other))
      }
  }
  if problems.length() == 0 {
    "PASS"
  } else {
    let sb = StringBuilder::new()
    let mut first = true
    for p in problems {
      if !first {
        sb.write_string(" | ")
      }
      sb.write_string(p)
      first = false
    }
    sb.to_string()
  }
}

// â”€â”€ ledgers (MDR-001 آ§6: start empty, populate as fixtures classify) â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
/// The FROZEN divergence ledger (fixture = و­£وœ¬, main src/core = è¢«و¤œن½“).
///
/// Each entry is the FULL `rel::slug :: verdict` string of a comparison that currently diverges â€”
/// a KNOWN gap either INHERITED from slice/poc (وœھه®ںè£…مپŒو­£وœ¬ن»•و§کمپ«è؟½ه¾“مپ—مپ¦مپ„مپھمپ„) or a suspected
/// fixture-authoring issue frozen for later resolution. The runner asserts the observed divergence
/// SET equals this ledger: UNEXPECTED and VANISHED entries both fail (verdict-granularity freeze,
/// MDR-001 آ§6). Empty = full conformance (no known gaps against the fixture corpus).
fn known_divergences() -> Array[String] {
  []
}

///|
/// The FROZEN skip ledger â€” decode-time twin of `known_divergences`. Each entry is `(rel, reason)`:
/// a fixture the decoder cannot losslessly represent, so it raises DecodeSkip before any case runs.
/// UNEXPECTED / VANISHED / CHANGED SKIP REASON all fail the run (like divergences, MDR-001 آ§6).
///
/// MDR-004 (ElemBody body grammar) resolved the 4 structural-or / nested-group skips inherited from
/// slice (BOr option/positional lowering + BGroup+IdxRepeat lowering), and the parallel
/// number_allow_base_prefix work (hex/oct/bin integer + hex float lexer) resolved the remaining
/// `definitions.types[number]` factory-config gap â€” all previously-frozen skip entries are removed
/// since every fixture now decodes and runs losslessly (full conformance, no known skip gaps).
fn expected_skips() -> Array[(String, String)] {
  []
}

///|
fn case_key(rel : String, id : String) -> String {
  rel + "::" + id
}

///|
fn is_kebab(s : String) -> Bool {
  if s == "" {
    return false
  }
  let mut prev_dash = true
  for c in s {
    if c == '-' {
      if prev_dash {
        return false
      }
      prev_dash = true
    } else if (c >= 'a' && c <= 'z') || (c >= '0' && c <= '9') {
      prev_dash = false
    } else {
      return false
    }
  }
  !prev_dash
}

///|
fn raw_case_ids(j : Json) -> Array[String]? {
  let top = match j.j_obj() {
    Some(o) => o
    None => return None
  }
  let casesj = match top.get("cases") {
    Some(c) => c
    None => return None
  }
  let carr = match casesj.j_arr() {
    Some(x) => x
    None => return None
  }
  let ids : Array[String] = []
  for cj in carr {
    ids.push(
      match cj.j_obj() {
        Some(co) => jf_str(co, "id").unwrap_or("")
        None => ""
      },
    )
  }
  Some(ids)
}

///|
fn check_ids(rel : String, ids : Array[String]) -> Array[String] {
  let bad : Array[String] = []
  let seen : Map[String, Int] = Map([])
  let mut ci = 0
  for id in ids {
    ci = ci + 1
    if id == "" {
      bad.push(
        rel +
        "::case#" +
        ci.to_string() +
        " â€” id و¬ èگ½مپ¾مپںمپ¯é‌‍و–‡ه­—هˆ— (DR-072: هگ„ case مپ¯ required مپ® kebab-case id م‚’وŒپمپ¤)",
      )
    } else if !is_kebab(id) {
      bad.push(
        rel +
        "::case#" +
        ci.to_string() +
        " â€” id '" +
        id +
        "' مپŒ kebab-case ([a-z0-9-]) مپ§مپھمپ„",
      )
    } else {
      match seen.get(id) {
        Some(first) =>
          bad.push(
            rel +
            "::case#" +
            ci.to_string() +
            " â€” id '" +
            id +
            "' مپŒ fixture ه†…مپ§é‡چè¤‡ (هˆ‌ه‡؛ case#" +
            first.to_string() +
            ")",
          )
        None => seen.set(id, ci)
      }
    }
  }
  bad
}

///|
fn load_json(path : String) -> Json raise {
  @json.parse(@fs.read_file_to_string(path))
}

///|
test "conformance: fixtures م‚’ JSON ç›´èھ­مپ؟مپ§ه®ںé£ں (parse èھ‍ه½™ç¶²ç¾… + lower 5 é‌¢و–­é‌¢)" {
  let root = fixtures_root()
  let rels : Array[String] = []
  collect_rel(root, "", rels) catch {
    _ => abort("fixtures walk failed under " + root)
  }
  sort_items(rels)
  let decoded : Array[String] = []
  let skips : Array[(String, String)] = []
  let mismatches : Array[String] = []
  let malformed : Array[String] = []
  let mut ran_cases = 0
  for rel in rels {
    let full = root + "/" + rel
    let j = load_json(full) catch {
      _ => {
        skips.push((rel, "load/parse error"))
        continue
      }
    }
    let id_bad : Array[String] = match raw_case_ids(j) {
      Some(ids) => check_ids(rel, ids)
      None => []
    }
    for b in id_bad {
      malformed.push(b)
    }
    let q = match j.j_obj() {
      Some(o) => jf_str(o, "query").unwrap_or("")
      None => ""
    }
    if q == "lower" {
      let dl = dec_lower(j) catch {
        DecodeSkip(reason) => {
          skips.push((rel, reason))
          continue
        }
      }
      decoded.push(rel)
      ran_cases = ran_cases + 1
      let verdict = run_lower(dl.def, dl.order, dl.want)
      if verdict != "PASS" {
        mismatches.push(rel + "::lower :: " + verdict)
      }
      continue
    }
    if q == "definition_error" {
      let fx = dec_definition_error_fixture(j) catch {
        DecodeSkip(reason) => {
          skips.push((rel, reason))
          continue
        }
      }
      decoded.push(rel)
      for c in fx.cases {
        ran_cases = ran_cases + 1
        let verdict = run_definition_error(fx, c)
        if verdict != "PASS" {
          mismatches.push(case_key(rel, c.id) + " :: " + verdict)
        }
      }
      continue
    }
    let df = dec_fixture(j) catch {
      DecodeSkip(reason) => {
        skips.push((rel, reason))
        continue
      }
    }
    decoded.push(rel)
    if id_bad.length() > 0 {
      continue
    }
    for c in df.cases {
      ran_cases = ran_cases + 1
      let verdict = run_case(df, c)
      if verdict != "PASS" {
        mismatches.push(case_key(rel, c.id) + " :: " + verdict)
      }
    }
  }
  println(
    "[json-conformance] decoded=\{decoded.length()} ran_cases=\{ran_cases} skipped=\{skips.length()} mismatches=\{mismatches.length()}",
  )
  println("[json-conformance] decoded: " + join_comma(decoded))
  let hist : Map[String, Int] = Map([])
  for pair in skips {
    let r = pair.1
    hist.set(
      r,
      (match hist.get(r) {
        Some(n) => n
        None => 0
      }) +
      1,
    )
  }
  let hitems : Array[String] = []
  for r, n in hist {
    hitems.push("\{n}أ— \{r}")
  }
  sort_items(hitems)
  for h in hitems {
    println("[json-conformance]   skip " + h)
  }
  for m in mismatches {
    println("[json-conformance]   diverge " + m)
  }
  for m in malformed {
    println("[json-conformance]   malformed " + m)
  }
  // Assert malformed-id list is empty.
  if malformed.length() > 0 {
    let sb = StringBuilder::new()
    sb.write_string("fixture case-id well-formedness violation (DR-072):\n")
    for m in malformed {
      sb.write_string("  " + m + "\n")
    }
    println(sb.to_string())
    abort(sb.to_string())
  }
  // Skip ledger assertion (empty ledger; any observed skip is UNEXPECTED for now).
  let sk_ledger = expected_skips()
  let unexpected_skips : Array[String] = []
  let changed_skips : Array[String] = []
  for pair in skips {
    let rel = pair.0
    let reason = pair.1
    let mut found_reason : String? = None
    for e in sk_ledger {
      if e.0 == rel {
        found_reason = Some(e.1)
        break
      }
    }
    match found_reason {
      None => unexpected_skips.push(rel + " :: " + reason)
      Some(want) =>
        if want != reason {
          changed_skips.push(rel + " :: got=" + reason + " want=" + want)
        }
    }
  }
  let vanished_skips : Array[String] = []
  for e in sk_ledger {
    let mut still_skipped = false
    for pair in skips {
      if pair.0 == e.0 {
        still_skipped = true
        break
      }
    }
    if !still_skipped {
      vanished_skips.push(e.0)
    }
  }
  if unexpected_skips.length() > 0 ||
    vanished_skips.length() > 0 ||
    changed_skips.length() > 0 {
    let sb = StringBuilder::new()
    sb.write_string("skip ledger mismatch:\n")
    if unexpected_skips.length() > 0 {
      sb.write_string("  UNEXPECTED SKIP:\n")
      for s in unexpected_skips {
        sb.write_string("    " + s + "\n")
      }
    }
    if vanished_skips.length() > 0 {
      sb.write_string("  VANISHED SKIP:\n")
      for s in vanished_skips {
        sb.write_string("    " + s + "\n")
      }
    }
    if changed_skips.length() > 0 {
      sb.write_string("  CHANGED SKIP REASON:\n")
      for s in changed_skips {
        sb.write_string("    " + s + "\n")
      }
    }
    println(sb.to_string())
    abort(sb.to_string())
  }
  // Divergence ledger assertion (empty ledger; any observed divergence is UNEXPECTED).
  let known = known_divergences()
  let unexpected : Array[String] = []
  for m in mismatches {
    if !conformance_str_in(known, m) {
      unexpected.push(m)
    }
  }
  let vanished : Array[String] = []
  for k in known {
    if !conformance_str_in(mismatches, k) {
      vanished.push(k)
    }
  }
  if unexpected.length() > 0 || vanished.length() > 0 {
    let sb = StringBuilder::new()
    sb.write_string("divergence ledger mismatch:\n")
    if unexpected.length() > 0 {
      sb.write_string("  UNEXPECTED:\n")
      for m in unexpected {
        sb.write_string("    " + m + "\n")
      }
    }
    if vanished.length() > 0 {
      sb.write_string("  VANISHED:\n")
      for k in vanished {
        sb.write_string("    " + k + "\n")
      }
    }
    println(sb.to_string())
    abort(sb.to_string())
  }
}

///|
/// MDR-004 آ§4 / ه®ںè£…é † 5: OrBranch.id (ç„،وŒ‡ه®ڑمپھم‚‰è‡ھه‹•وژ،ç•ھ `#{seq}`) مپ¯ه†…éƒ¨ç…§هگˆه°‚ç”¨مپ§م€پè¦³و¸¬é‌¢
/// (held Error / ambiguous interpretations / success result) مپ®مپ©مپ“مپ«م‚‚و¼ڈم‚Œمپ¦مپ¯مپ„مپ‘مپھمپ„م€‚ه¯¾è±،
/// 4 fixture مپ¯مپ©م‚Œم‚‚ "id" م‚­مƒ¼ç„،وŒ‡ه®ڑ (= è‡ھه‹•وژ،ç•ھمپ®مپ؟) مپھمپ®مپ§م€پو—¢مپ«مپ‌م‚Œè‡ھن½“مپŒé‌‍و¼ڈه‡؛مپ®çٹ¶و³پè¨¼و‹ مپ§
/// مپ¯مپ‚م‚‹ â€” مپŒم€پfixture ن»»مپ›مپ مپ¨م€Œه°†و‌¥èھ°مپ‹مپŒ .id م‚’è،¨ç¤؛çµŒè·¯مپ«é…چç·ڑمپ—مپ¦مپ—مپ¾مپ†م€چé€€è،Œم‚’و¤œه‡؛مپ§مپچمپھمپ„
/// (codex REVIEW-M5)م€‚مپ“مپ“مپ§مپ¯هگŒمپکه®ڑç¾©ه½¢ (ه¯¾ç§° or مپ® 2 و‍‌م€پheld-errors-same-depth.json مپ¨هگŒه‍‹) م‚’
/// inline JSON مپ§çµ„مپ؟م€پfailure (0 وœ¬وˆگç«‹) / ambiguous (2 وœ¬وˆگç«‹) / success (1 وœ¬مپ®مپ؟ç”ںه­ک) مپ® 3 outcome
/// مپ™مپ¹مپ¦مپ§م€پrendered text مپ«è‡ھه‹• id مƒ‘م‚؟مƒ¼مƒ³ ("#0" / "#1") مپŒن¸€هˆ‡çڈ¾م‚Œمپھمپ„مپ“مپ¨م€پمپ‹مپ¤وœ¬و‌¥مپ® leaf هگچ
/// (a/b) مپ¯çڈ¾م‚Œم‚‹مپ“مپ¨م‚’هگŒو™‚مپ«ه›؛ه®ڑمپ™م‚‹م€‚
test "conformance: OrBranch auto id (#{seq}) مپ¯ held-error / ambiguous / success مپ®مپ©مپ“مپ«م‚‚و¼ڈم‚Œمپھمپ„ (MDR-004 آ§4)" {
  let src =
    #|{
    #|  "query": "parse",
    #|  "definition": {
    #|    "positionals": [
    #|      {"or": [{"type": "number", "name": "a"}, {"type": "number", "name": "b"}]}
    #|    ]
    #|  },
    #|  "cases": []
    #|}
  let j = @json.parse(src)
  let df = dec_fixture(j)
  let no_leak = fn(s : String) -> Unit {
    if s.contains("#0") || s.contains("#1") {
      abort("auto branch id leaked into observable text: \{s}")
    }
  }
  // failure (0 وœ¬وˆگç«‹): é‌‍و•°ه€¤ 1 token مپ¯ن¸،و‍‌مپ¨م‚‚هگŒن½چç½®مپ§ dead-end (same-depth هگŒه‍‹)م€‚
  let fail_outcome = parse(ScopeNode(df.scope), ["x"], defs=df.registry)
  match fail_outcome {
    Failure(d) => {
      let texts : Array[String] = []
      for e in d.errors {
        texts.push(e.element + ":" + e.message)
      }
      let joined = join_comma(texts)
      no_leak(joined)
      if !joined.contains("a:") || !joined.contains("b:") {
        abort("expected both leaf names (a/b) in failure text, got: \{joined}")
      }
    }
    other => abort("expected Failure, got " + render_outcome(other))
  }
  // ambiguous (2 وœ¬وˆگç«‹): و•°ه€¤ 1 token مپ¯ن¸،و‍‌مپŒهگŒن½چç½®مپ§وˆگç«‹ â†’ 2 ه®Œه…¨çµŒè·¯م€‚
  let amb_outcome = parse(ScopeNode(df.scope), ["5"], defs=df.registry)
  match amb_outcome {
    Ambiguous(d) => {
      let views : Array[String] = []
      for interp in d.interpretations {
        views.push(
          render_rval_sorted(
            build_result(
              apply_export_keys(interp.binds, df.ekmap),
              accum_cells(df.scope, df.ekmap),
              [],
              [],
            ),
          ),
        )
      }
      let joined = join_comma(views)
      no_leak(joined)
      if !joined.contains("a=5") || !joined.contains("b=5") {
        abort(
          "expected both interpretations (a=5/b=5) in ambiguous text, got: \{joined}",
        )
      }
    }
    other => abort("expected Ambiguous, got " + render_outcome(other))
  }
  // success (1 وœ¬مپ®مپ؟ç”ںه­ک) مپ¯ه¯¾ç§° 2 و‍‌ (a/b ه…±مپ« number) مپ§مپ¯ن½œم‚Œمپھمپ„ â€” ن¸،و‍‌مپ¯ه¸¸مپ«ه¯¾ç§°مپ«وˆگç«‹/
  // ن¸چوˆگç«‹مپ™م‚‹مپںم‚پم€پهچکن¸€مƒˆمƒ¼م‚¯مƒ³ argv مپ§مپ¯ه؟…مپڑ failure مپ‹ ambiguous مپ«مپھم‚‹م€‚success é‌¢مپ®é‌‍و¼ڈه‡؛مپ¯
  // path-search/variable-arity-ambiguous.json::non-number-collapses-to-name (و—¢ه­ک conformanceم€پ
  // é‌‍ه¯¾ç§° 2 و‍‌مپ§و•°ه€¤و‍‌مپ®مپ؟و­»مپ¬م‚±مƒ¼م‚¹) مپŒهˆ¥é€”ه›؛ه®ڑو¸ˆمپ؟مپھمپ®مپ§م€پوœ¬ wbtest مپ¯ failure/ambiguous مپ®
  // 2 outcome م‚’م‚¹م‚³مƒ¼مƒ—مپ¨مپ™م‚‹م€‚
}

// â”€â”€ DR-078: definitions.templates + ref (è’¸ç•™ 1:1 audit و¼ڈم‚Œ #1/#2, slice phase4:114/phase10:64) â”€â”€

///|
/// ن؟‌è¨¼ (è’¸ç•™ 1:1 audit و¼ڈم‚Œ #1م€پslice `poc/phase4_wbtest.mbt:125-152` ç›¸ه½“م€پDR-078 آ§1 مپ® decode
/// é…چç·ڑç–ژé€ڑ): `hlcolors := color+` (positional مپŒ `ref:"color"` + `repeat:{min:1}`م€پ`color` مپ¯
/// `definitions.templates` مپ« `or [ [r,g,b] مپھ 3 و•°ه€¤ seq | و–‡ه­—هˆ— colorname ]` (DR-078 آ§1 مپ®ن¾‹
/// مپ‌مپ®م‚‚مپ®) مپ¨مپ—مپ¦ه®£è¨€مپ•م‚Œمپںه…±وœ‰ template) مپŒو­£مپ—مپڈ decode â†’ lowering â†’ parse مپ•م‚Œم‚‹م€‚
/// و–‡ه­—هˆ—هگچمپ®ç¹°م‚ٹè؟”مپ— (`red blue`) مپ¯هگ„ç™؛çپ«مپŒ colorname و‍‌م‚’è¾؟م‚‹مپ مپ‘مپ®ن¸€ç¾©çڑ„مپھ parseم€‚
/// `255 0 0` مپ¯م€Œ1 ه›‍ç™؛çپ«مƒ»rgb و‍‌ (3 مƒˆمƒ¼م‚¯مƒ³و¶ˆè²»)م€چمپ¨م€Œ3 ه›‍ç™؛çپ«مƒ»colorname و‍‌ (1 مƒˆمƒ¼م‚¯مƒ³مپڑمپ¤)م€چمپ®
/// و§‹é€ çڑ„مپ«ç•°مپھم‚‹ه®Œه…¨çµŒè·¯مپŒن¸،ç«‹مپ—م€پambiguous:2 مپ«مپھم‚‹ (or و‍‌مپ®éپ•مپ„مپ¯ DR-043 مپ®هڈ–م‚ٹهˆ†éپ¸ه¥½مپ®ه¯¾è±،ه¤– â€”
/// éپ¸ه¥½مپ¯م€ŒهگŒمپک closure مپ®هˆ†مپ‘و–¹م€چمپ®ن¸­مپ§مپ—مپ‹هٹ¹مپ‹مپھمپ„م€پو¬،مپ® wbtest مپ§ه¯¾مپ§ه›؛ه®ڑ)م€‚
test "DR-078: definitions.templates + ref â€” repeat over a shared or-template (hlcolors := color+)" {
  let src =
    #|{
    #|  "query": "parse",
    #|  "definition": {
    #|    "definitions": {"templates": {"color": {"or": [
    #|      {"seq": [{"type": "number", "name": "r"}, {"type": "number", "name": "g"}, {"type": "number", "name": "b"}]},
    #|      {"type": "string", "name": "colorname"}
    #|    ]}}},
    #|    "positionals": [
    #|      {"name": "hlcolors", "ref": "color", "repeat": {"min": 1}}
    #|    ]
    #|  },
    #|  "cases": []
    #|}
  let df = dec_fixture(@json.parse(src))
  // ç´”و–‡ه­—هˆ—مپ®ç¹°م‚ٹè؟”مپ—: colorname و‍‌مپ®مپ؟مپŒوˆگç«‹مپ™م‚‹ن¸€ç¾©çڑ„مپھ parse (rgb و‍‌مپ¯و•°ه€¤مپ§مپھمپ„مƒˆمƒ¼م‚¯مƒ³مپ§ dead-end)م€‚
  // render_outcome مپ¯ binding م‚’ flat key=value (sort و¸ˆمپ؟) مپ§وڈڈç”»مپ™م‚‹ (slice مپ® ok{name=blue,name=red}
  // مپ¨هگŒمپکه½¢م€پè‰²مƒ†مƒ³مƒ—مƒ¬مپ® leaf هگچمپ¯ "colorname")م€‚
  assert_eq(
    render_outcome(
      parse(ScopeNode(df.scope), ["red", "blue"], defs=df.registry),
    ),
    "ok{colorname=blue,colorname=red}",
  )
  // rgb و‍‌ (1 ه›‍ç™؛çپ«, 3 مƒˆمƒ¼م‚¯مƒ³) vs colorname و‍‌ (3 ه›‍ç™؛çپ«, 1 مƒˆمƒ¼م‚¯مƒ³مپڑمپ¤) â€” و§‹é€ çڑ„مپ«ç•°مپھم‚‹ه®Œه…¨çµŒè·¯
  // مپŒن¸،ç«‹مپ— ambiguous:2 (DR-038)م€‚
  assert_eq(
    render_outcome(
      parse(ScopeNode(df.scope), ["255", "0", "0"], defs=df.registry),
    ),
    "ambiguous:2",
  )
}

///|
/// ن؟‌è¨¼ (è’¸ç•™ 1:1 audit و¼ڈم‚Œ #2م€پslice `poc/phase10_wbtest.mbt:90-108` ç›¸ه½“): repeat مپ®هڈ–م‚ٹهˆ†éپ¸ه¥½
/// (preferenceم€پDR-043) مپ¯م€ŒهگŒمپک closure مپ®هˆ†مپ‘و–¹م€چو¬،ه…ƒمپ«مپ®مپ؟هٹ¹مپچم€پor و‍‌مپ®éپ•مپ„ (و§‹é€ çڑ„مپ«ç•°مپھم‚‹ه®Œه…¨
/// çµŒè·¯) م‚’ن¾µé£ںمپ—مپ¦مپ‹مپچو¶ˆمپ•مپھمپ„م€‚`255 0 0` مپ¯ه‰چ wbtest مپ¨هگŒمپکمپڈ ambiguous:2 مپ®مپ¾مپ¾ â€” éپ¸ه¥½مپ¯م€ŒهگŒç‚¹مپ®
/// share مپ مپ‘çµ‍م‚‹م€چم‚‚مپ®مپ§مپ‚مپ£مپ¦م€Œor و‍‌مپ®ه·®م‚’و½°مپ™م€چم‚‚مپ®مپ§مپ¯مپھمپ„مپ“مپ¨م‚’ه›؛ه®ڑمپ™م‚‹م€‚ç´”و–‡ه­—هˆ— argv مپ«مپ¯
/// rgb èھ­مپ؟مپŒç„،مپ„مپ®مپ§ (مپ™مپ¹مپ¦é‌‍و•°ه€¤) split مپ¯ن¸€و„ڈ â€” éپ¸ه¥½مپ®وœ‰ç„،مپ«é–¢م‚ڈم‚‰مپڑوˆگç«‹مپ™م‚‹م‚±مƒ¼م‚¹مپ¨مپ—مپ¦ه¯¾و¯”مپ™م‚‹م€‚
test "DR-078: preference does not erode or-branch ambiguity (share-dimension only, DR-043)" {
  let src =
    #|{
    #|  "query": "parse",
    #|  "definition": {
    #|    "definitions": {"templates": {"color": {"or": [
    #|      {"seq": [{"type": "number", "name": "r"}, {"type": "number", "name": "g"}, {"type": "number", "name": "b"}]},
    #|      {"type": "string", "name": "colorname"}
    #|    ]}}},
    #|    "positionals": [
    #|      {"name": "hlcolors", "ref": "color", "repeat": {"min": 1}}
    #|    ]
    #|  },
    #|  "cases": []
    #|}
  let df = dec_fixture(@json.parse(src))
  assert_eq(
    render_outcome(
      parse(ScopeNode(df.scope), ["255", "0", "0"], defs=df.registry),
    ),
    "ambiguous:2",
  )
  assert_eq(
    render_outcome(
      parse(ScopeNode(df.scope), ["red", "green", "blue"], defs=df.registry),
    ),
    "ok{colorname=blue,colorname=green,colorname=red}",
  )
}

///|
/// ن؟‌è¨¼ (codex ç¯€ç›®مƒ¬مƒ“مƒ¥مƒ¼وŒ‡و‘ک1م€پissue 2026-07-09-ref-template-result-shape): wire schema مپ® name/id
/// هˆ¶ç´„ `^[^#]+$` (DR-067 آ§2م€Œ`#` م‚’هگ«م‚€ name/id مپ¯مƒ¦مƒ¼م‚¶ه®ڑç¾©مپ§ç¦پو­¢م€چم€په†…éƒ¨ن؛ˆç´„هگچه‰چç©؛é–“ = repeat
/// lowering مپ® `<name>#cons` / `next_or_branch_id` مپ® `#0`/`#1`/â€¦ / resolve.mbt مپ® row/fire sentinel
/// "#row"/"#fire") م‚’ decode ه±¤مپŒ enforce مپ™م‚‹مپ“مپ¨م‚’م€پ`#` مپ®ه‡؛çڈ¾مپ—مپ†م‚‹ç®‡و‰€مپ”مپ¨مپ«مƒ‍مƒˆمƒھم‚¯م‚¹مپ§ه›؛ه®ڑمپ™م‚‹
/// â€” 1 ç®‡و‰€مپ مپ‘ç¢؛èھچمپ™م‚‹مپ¨م€Œمپںمپ¾مپںمپ¾é€ڑمپ£مپ¦مپںم€چم‚’è¦‹é€ƒمپ™ (empirical-verification مپ®م‚µمƒ³مƒ—مƒ«و•°هژںه‰‡)م€‚
/// positional مپ® name / option مپ® name / definitions.templates مپ® template key مپ® 3 م‚«مƒ†م‚´مƒھمپ§
/// decode مپŒ `DecodeSkip` (definition مپ® decode errorم€پو—¢ه­کèھ‍ه½™مپ®مپ¾مپ¾) م‚’وٹ•مپ’م‚‹مپ“مپ¨م‚’ç¢؛èھچمپ™م‚‹م€‚
test "decode: a `#` in name/id is rejected at every user-facing name surface (codex review #1)" {
  // (1) positional مپ® nameم€‚`@json.parse` (raise ParseError) م‚’ try مپ®ه¤–مپ§ه…ˆمپ«è©•ن¾،مپ—مپ¦مپٹمپڈ â€”
  // `dec_fixture` è‡ھè؛«مپ® `raise DecodeSkip` مپ مپ‘م‚’ catch مپ§و±²م‚€م€‚
