    #|        "effects": [],
    #|        "result": {}
    #|      }
    #|    }
    #|  ]
    #|}
  let df = dec_fixture(@json.parse(src))
  assert_eq(df.cases.length(), 1)
  let verdict = run_case(df, df.cases[0])
  if verdict != "PASS" {
    abort("expected PASS, got: " + verdict)
  }
}

