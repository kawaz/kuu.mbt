// â”€â”€ DR-092: inf / é‌‍و•´و•° float مپ® JSON serialize è¦ڈç´„ (end-to-end via dec_fixture/run_case) â”€â”€

///|
/// ن؟‌è¨¼ (DR-092 آ§1/آ§2م€Œinf مپ¯ JSON string sentinel "Infinity"/"-Infinity" مپ§è،¨مپ™م€چم€په®ںè£…èھ؟وں»
/// 2026-07-11 مپ®ه®ںو©ںç¢؛èھچçµگو‍œ): fixture مپ® `result` ن½چç½®مپ« JSON و–‡ه­—هˆ— `"Infinity"` م‚’و›¸مپ„مپںوœںه¾…ه€¤
/// (DR-092 آ§1 مپ® wire è،¨çڈ¾مپ‌مپ®م‚‚مپ®) مپŒم€په®ںéڑ›مپ® `--t inf` (float ه‍‹) ه®ںè،Œçµگو‍œمپ¨ن¸€è‡´مپ™م‚‹ â€” هڈŒو–¹مپ¨م‚‚
/// `render_val` م‚’çµŒç”±مپ—م€پGOT هپ´مپ¯ `VNum(inf)` â†’ MoonBit Ryu ه®ںè£…مپ® "Infinity" ç‰¹و®ٹه½¢م€پEXPECT هپ´مپ¯
/// JSON string decode (`json_to_value` مپ¯و–‡ه­—هˆ—م‚’مپ‌مپ®مپ¾مپ¾ `VStr` مپ«ه†™مپ™) â†’ `render_val(VStr(s)) =
/// s` مپ®ç´ é€ڑمپ—م€پمپ§هگŒمپکو–‡ه­—هˆ— "Infinity" مپ«هڈژو‌ںمپ™م‚‹م€‚**production م‚³مƒ¼مƒ‰ه¤‰و›´مپھمپ—مپ§ DR-092 مپ® wire
/// è،¨çڈ¾è¦ڈç´„مپŒ conformance harness ن¸ٹمپ§و—¢مپ«وˆگç«‹مپ™م‚‹**مپ“مپ¨م‚’ end-to-end مپ§ه›؛ه®ڑمپ™م‚‹
/// (fixtures/value-typing/number-inf-nan.json مپ¸مپ®ه®ں pin مپ¯ main مپŒهˆ¥و®µمپ§è،Œمپ†ن؛ˆه®ڑم€پوœ¬مƒ†م‚¹مƒˆمپ¯
/// spec fixture م‚’ن¸€هˆ‡ه¤‰و›´مپ›مپڑم‚¤مƒ³مƒ©م‚¤مƒ³ JSON مپ§هگŒمپکè¼ھéƒ­م‚’ه…ˆمپ«ه›؛ه®ڑمپ™م‚‹م‚‚مپ®)م€‚
test "DR-092 end-to-end: --t inf round-trips through result as the JSON string sentinel \"Infinity\"" {
  let src =
    #|{
    #|  "query": "parse",
    #|  "definition": {
    #|    "options": [
    #|      {"name": "t", "type": "float", "long": true}
    #|    ]
    #|  },
    #|  "cases": [
    #|    {
    #|      "id": "inf-result-serializes-as-json-string-sentinel",
    #|      "argv": ["--t", "inf"],
    #|      "expect": {
    #|        "outcome": "success",
    #|        "effects": [{"entity": "t", "op": "set", "operand": "Infinity", "source": "cli"}],
    #|        "result": {"t": "Infinity"}
    #|      }
    #|    },
    #|    {
    #|      "id": "neg-inf-result-serializes-as-json-string-sentinel",
    #|      "argv": ["--t", "-Infinity"],
    #|      "expect": {
    #|        "outcome": "success",
