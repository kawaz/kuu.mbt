// â”€â”€ codex ç¯€ç›®مƒ¬مƒ“مƒ¥مƒ¼ Major 1: è¦پç´ هچکن½چ scope config override â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
/// ن؟‌è¨¼ (codex وŒ‡و‘ک Major 1, DR-049 آ§4م€Œprefix م‚’ن»کمپ‘مپںمپڈمپھمپ„ه®Œه…¨وŒ‡ه®ڑ (ن¾‹: HOME م‚’èھ­م‚€) مپ¯م€پمپ‌مپ®
/// è¦پç´ مپ® config مپ§ env_prefix:"" م‚’ن¸ٹو›¸مپچمپ™م‚‹ (DR-014 مپ®éڑژه±¤ç¶™و‰؟مپ§è¦پç´ هچکن½چمپ®ن¸ٹو›¸مپچمپŒهڈ¯èƒ½)م€چمپ®
/// motivating case مپ‌مپ®م‚‚مپ®): scope مپŒ `env_prefix: "MYAPP"` م‚’وŒپمپ¤ن¸­مپ§م€پ1مپ¤مپ®è¦پç´ مپ مپ‘è‡ھهˆ†مپ®
/// `config: {"env_prefix": ""}` م‚’وŒپمپ¤مپ¨م€پمپ‌مپ®è¦پç´ مپ®وکژç¤؛ `env: "HOME"` مپ¯é€£çµگمپ•م‚Œمپڑمپ‌مپ®مپ¾مپ¾و®‹م‚‹
/// (DR-049 آ§3م€Œenv_prefix وœھè¨­ه®ڑمپھم‚‰ prefix éƒ¨م‚’çœپمپڈم€چمپŒè¦پç´ هچکن½چمپ® resolved config مپ«م‚‚هگŒمپکè¦ڈه‰‡مپ§
/// هٹ¹مپڈ)م€‚هگŒمپکم‚¹م‚³مƒ¼مƒ—مپ®ن»–è¦پç´ مپ¯ scope هپ´مپ® env_prefix é€£çµگم‚’مپ‌مپ®مپ¾مپ¾هڈ—مپ‘م‚‹ â€” è¦پç´ هچکن½چ override مپŒ
/// ه…„ه¼ںè¦پç´ مپ«و³¢هڈٹمپ—مپھمپ„مپ“مپ¨م‚‚هگŒو™‚مپ«ه›؛ه®ڑمپ™م‚‹م€‚
test "dec_definition: an element's own config env_prefix:\"\" opts that element out of the scope's env_prefix (DR-049 آ§4 HOME motivating case)" {
  let src =
    #|{
    #|  "options": [
    #|    {"name": "port", "type": "number", "env": "PORT"},
    #|    {"name": "home", "type": "string", "env": "HOME", "config": {"env_prefix": ""}}
    #|  ],
    #|  "config": {"env_prefix": "MYAPP"}
    #|}
  let o = match @json.parse(src).j_obj() {
    Some(x) => x
    None => abort("test src is not an object")
  }
  let def = dec_definition(o) catch {
    DecodeSkip(r) => abort("expected successful decode, got DecodeSkip: " + r)
  }
  assert_eq(def.options[0].env, ["MYAPP_PORT"]) // ه…„ه¼ںè¦پç´ مپ¯ scope مپ®é€£çµگم‚’مپ‌مپ®مپ¾مپ¾هڈ—مپ‘م‚‹
  assert_eq(def.options[1].env, ["HOME"]) // opt-out è¦پç´ مپ¯é€£çµگمپ•م‚Œمپھمپ„
}

///|
/// ن؟‌è¨¼ (هگŒن¸ٹم€پlong_prefix/short_combine è»¸): scope و—¢ه®ڑ (`long_prefix:"--"`) مپ®ن¸­مپ§ 1 è¦پç´ مپ مپ‘
/// `config: {"long_prefix":"+"}` م‚’وŒپمپ¤مپ¨م€پمپ‌مپ®è¦پç´ مپ مپ‘ `+` ç¶´م‚ٹمپ«مپھم‚ٹم€په…„ه¼ںè¦پç´ مپ¯ `--` مپ®مپ¾مپ¾ â€”
/// مƒ‍مƒ¼م‚¸مپ¯è¦پç´ هچکن½چمپ§ `dec_scope_config` م‚’ه†چéپ©ç”¨مپ™م‚‹مپ مپ‘ (هˆ¥مƒ­م‚¸مƒƒم‚¯م‚’وŒپمپںمپھمپ„) مپ“مپ¨مپ®ç›´وژ¥ç¢؛èھچم€‚
test "dec_definition: an element's own config long_prefix overrides ONLY that element, siblings keep the scope default" {
  let src =
    #|{
    #|  "options": [
    #|    {"name": "a", "type": "string", "long": true},
    #|    {"name": "b", "type": "string", "long": true, "config": {"long_prefix": "+"}}
    #|  ]
    #|}
  let o = match @json.parse(src).j_obj() {
    Some(x) => x
    None => abort("test src is not an object")
  }
  let def = dec_definition(o) catch {
    DecodeSkip(r) => abort("expected successful decode, got DecodeSkip: " + r)
  }
  assert_eq(def.options[0].long_prefix, "--")
  assert_eq(def.options[1].long_prefix, "+")
}

///|
/// ن؟‌è¨¼ (هگŒن¸ٹم€پpositional ه¯¾ç§°و€§ â€” DESIGN آ§7.2م€Œه­گè¦پç´ م€چمپ¯ option/positional هڈŒو–¹م‚’هگ«م‚€):
/// positional م‚‚è¦پç´ هچکن½چ `config` م‚’هڈ—çگ†مپ—م€پenv_prefix override مپŒهگŒمپکè¦ڈه‰‡مپ§هٹ¹مپڈم€‚
test "dec_definition: a positional's own config env_prefix override works the same as an option's" {
  let src =
    #|{
    #|  "positionals": [
    #|    {"name": "target", "type": "string"},
    #|    {"name": "home", "type": "string", "env": "HOME", "config": {"env_prefix": ""}}
    #|  ],
    #|  "config": {"env_prefix": "MYAPP", "auto_env": true}
    #|}
  let o = match @json.parse(src).j_obj() {
    Some(x) => x
    None => abort("test src is not an object")
  }
  let def = dec_definition(o) catch {
    DecodeSkip(r) => abort("expected successful decode, got DecodeSkip: " + r)
  }
  assert_eq(def.positionals[0].env, ["MYAPP_TARGET"]) // auto_env çµŒç”±م€پscope env_prefix é€£çµگ
  assert_eq(def.positionals[1].env, ["HOME"]) // opt-outم€پوکژç¤؛ env: مپ‌مپ®مپ¾مپ¾
}

///|
/// ن؟‌è¨¼ (è¦پç´ هچکن½چ override مپ§م‚‚ DR-091 آ§3 مپ®é‌™çڑ„و¤œوں»مپŒهƒچمپڈ â€” `validate_scope_config` م‚’è¦پç´ مƒ‍مƒ¼م‚¸
/// ç›´ه¾Œمپ«م‚‚ه‘¼مپ¶مپ“مپ¨مپ®ç›´وژ¥ç¢؛èھچ): è¦پç´ مپŒ `config: {"long_prefix": ""}` مپ مپ‘م‚’ن¸ٹو›¸مپچمپ—
/// `require_equal_separator` م‚’وکژç¤؛مپ—مپھمپ„ه ´هگˆم€پscope و—¢ه®ڑمپ® `require_equal_separator: false` م‚’
/// ç¶™و‰؟مپ—مپںمپ¾مپ¾مپ«مپھم‚‹مپںم‚پم€پم‚¹م‚³مƒ¼مƒ—مƒ¬مƒ™مƒ«مپ¨هگŒمپکم€Œç©؛ prefix مپŒç´  operand مپ¨è،‌çھپمپ™م‚‹م€چن¸چو•´هگˆمپŒ
/// è¦پç´ هچکن½چمپ§م‚‚ه†چçڈ¾مپ— decode-time reject مپ•م‚Œم‚‹م€‚
test "dec_definition: an element's own config can ALSO trigger the long_prefix:\"\" + !require_equal_separator reject" {
  let src =
    #|{"options":[{"name":"if","type":"string","long":true,"config":{"long_prefix":""}}]}
  let o = match @json.parse(src).j_obj() {
    Some(x) => x
    None => abort("test src is not an object")
  }
  let _ = dec_definition(o) catch { DecodeSkip(_) => return }
  fail(
    "expected DecodeSkip (element-level long_prefix:\"\" without require_equal_separator:true)",
  )
}

///|
/// ن؟‌è¨¼ (è¦پç´ هچکن½چ config مپ® allowed_keys ç¶²ç¾…و€§): option مپ® `config` object ه†…م‚‚ scope config مپ¨
/// هگŒمپک 7 م‚­مƒ¼مپ®مپ؟هڈ—çگ† â€” وœھçں¥م‚­مƒ¼مپ¯ decode-time reject (DR-014 مپ®èھ‍ه½™م‚’è¦پç´ هچکن½چمپ§م‚‚ç™؛وکژمپ—مپھمپ„)م€‚
test "dec_definition: an option's own config rejects an unknown key just like scope config does" {
