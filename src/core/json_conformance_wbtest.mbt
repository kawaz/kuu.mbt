///|
/// DR-066 آ§4 harness smoke test: `errors[].path` opt-in actually drives `run_case`'s comparison,
/// not just decodes without effect. A `--n` (number) value slot inside a `sub` command scope fails
/// to parse ("abc" is not a number) one command deep. The CORRECT-path case (`path: ["sub"]`) must
/// PASS; the WRONG-path case (`path: ["not-sub"]`, everything else identical) must FAIL â€” proving
/// `proj_errors`/`exp_errors_decode` round-trip the path into the comparison, mirroring how the
/// existing `reason` opt-in is exercised end-to-end by the real fixture corpus.
test "conformance harness: errors[].path opt-in is compared, not merely decoded (DR-066 آ§4)" {
  let src =
    #|{
    #|  "why": "DR-066 آ§4 harness smoke test for errors[].path opt-in",
    #|  "query": "parse",
    #|  "definition": {
    #|    "commands": [
    #|      {
    #|        "type": "command",
    #|        "name": "sub",
    #|        "options": [
    #|          {"name": "n", "type": "number", "long": true}
    #|        ]
    #|      }
    #|    ]
    #|  },
    #|  "cases": [
    #|    {
    #|      "id": "correct-path",
    #|      "why": "path: [\"sub\"] matches the actual ancestor (n fails inside the sub command scope)",
    #|      "argv": ["sub", "--n", "abc"],
    #|      "expect": {
    #|        "outcome": "failure",
    #|        "errors": [
    #|          {"element": "n", "argv_pos": 2, "kind": "parse", "reason": "not_a_number", "path": ["sub"]}
    #|        ]
    #|      }
    #|    },
    #|    {
    #|      "id": "wrong-path",
    #|      "why": "path: [\"not-sub\"] is deliberately wrong â€” must be caught as a mismatch",
    #|      "argv": ["sub", "--n", "abc"],
    #|      "expect": {
    #|        "outcome": "failure",
    #|        "errors": [
    #|          {"element": "n", "argv_pos": 2, "kind": "parse", "reason": "not_a_number", "path": ["not-sub"]}
    #|        ]
    #|      }
    #|    }
    #|  ]
    #|}
  let j = @json.parse(src)
  let df = dec_fixture(j)
  assert_eq(df.cases.length(), 2)
  for c in df.cases {
    let verdict = run_case(df, c)
    if c.id == "correct-path" {
      if verdict != "PASS" {
        abort("expected PASS for correct-path, got: \{verdict}")
      }
    } else if verdict == "PASS" {
      abort("expected a path mismatch for wrong-path, got PASS")
    }
  }
}

///|
/// ن؟‌è¨¼ (issue 2026-07-09-constraint-path-filtering-gap مپ®ه…ƒ exact reproم€پDR-047 آ§5 وکژç¢؛هŒ–
/// kawaz è£په®ڑ 2026-07-09 ه¾Œمپ® end-to-end ç¢؛èھچ): alias مپ§هگŒن¸€مƒˆمƒھم‚¬ `--v` م‚’وŒپمپ¤ 2 çµŒè·¯ (a مپ«
/// `requires:["c"]`م€پc مپ¯مƒ•مƒ©م‚°) مپ«ه¯¾مپ—م€پ`run_case` (= `apply_requires_filter` â†’
/// `promote_collision_ambiguous` مپ®ç›´هˆ—éپ©ç”¨è¾¼مپ؟مپ® harness وœ¬çµŒè·¯) مپŒ3م‚±مƒ¼م‚¹مپ¨م‚‚و­£مپ—مپ„ outcome م‚’
/// è؟”مپ™مپ“مپ¨م‚’ه›؛ه®ڑمپ™م‚‹م€‚`c` مپ«مپ¯ `env:["C"]` م‚’è؟½هٹ مپ—مپ¦مپ„م‚‹ (ه…ƒ exact repro مپ«مپ¯ç„،مپ‹مپ£مپںمپŒم€پenv
/// و•‘و¸ˆم‚±مƒ¼م‚¹مپ®و¤œè¨¼مپ«ه؟…è¦پ â€” DR-047 آ§5 وکژç¢؛هŒ–م€Œه€¤و؛گن¸چه•ڈم€چمپ® env é‌¢م‚«مƒگمƒ¼)م€‚
test "DR-047 آ§5 end-to-end: exact issue repro (alias same trigger, requires) via run_case" {
  let src =
    #|{
    #|  "query": "parse",
    #|  "definition": {
    #|    "options": [
    #|      {"name": "a", "type": "flag", "requires": ["c"]},
    #|      {"alias": "a", "name": "v", "long": [":set:true"]},
    #|      {"name": "b", "type": "flag"},
    #|      {"alias": "b", "name": "v", "long": [":set:true"]},
    #|      {"name": "c", "type": "flag", "long": true, "env": ["C"]}
    #|    ]
    #|  },
    #|  "cases": [
    #|    {
    #|      "id": "c-unset-a-excluded",
    #|      "argv": ["--v"],
    #|      "expect": {"outcome": "success", "effects": [
    #|        {"entity": "b", "op": "set", "operand": true, "source": "cli"}
    #|      ]}
    #|    },
    #|    {
    #|      "id": "c-cli-both-survive",
    #|      "argv": ["--v", "--c"],
    #|      "expect": {"outcome": "ambiguous"}
    #|    },
    #|    {
    #|      "id": "c-env-both-survive",
    #|      "argv": ["--v"],
    #|      "env": {"C": "true"},
    #|      "expect": {"outcome": "ambiguous"}
    #|    }
    #|  ]
    #|}
  let df = dec_fixture(@json.parse(src))
  assert_eq(df.cases.length(), 3)
  for c in df.cases {
    let verdict = run_case(df, c)
    if verdict != "PASS" {
      abort("case '" + c.id + "' expected PASS, got: " + verdict)
    }
  }
}

