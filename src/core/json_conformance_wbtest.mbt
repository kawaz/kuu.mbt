// json_conformance_wbtest.mbt â€” JSON-DIRECT conformance runner (query: "parse" + "lower").
//
// PORTED FROM: kawaz/kuu.mbt slice/poc/{json_conformance_wbtest,lower_runner_wbtest,helpers_wbtest,
// fixture_runner_wbtest}.mbt â€” verbatim structure with API adaptations for main src/core:
//   - ParseError is a 6-tuple (element/argv_pos/kind/reason/message/path, DR-066 آ§3/آ§4): proj_errors
//     and exp_errors_decode include `reason` when the fixture asserts it on ANY error in the set, and
//     `path` likewise on its own independent opt-in (per-field, per-fixture-set â€” DR-066 آ§4/آ§5:
//     message is never compared, reason/path are each optional and asserted independently).
//   - resolve_scope / resolve_scope_config return `Result[Array[Binding], ParseError]` in main
//     (slice returned Result[..., String] for the config variant and Array[Binding] for the flat
//     variant). Both sites in resolve_tree/do_resolve wrap the ParseError message.
//   - env_value in main takes (element, ty, s, at_pos)->Result; the variant-DSL operand still needs
//     the naive slice-form coercion â†’ local `dsl_variant_value` helper.
//
// The two-ledger contract (expected_skips / known_divergences) starts EMPTY per MDR-001 آ§6: fixtures
// are re-fed against the new implementation, and every observed skip / divergence is reported by the
// test so we can classify them off-line. Empty ledger + failing test = the fixture-first mode.

// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
// SECTION 1 â€” Local helpers (mirror slice/poc/helpers_wbtest.mbt)
// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ

// â”€â”€ deprecated-free Json accessors (moon nightly: as_* ç³»مپ¯ deprecated) â”€â”€â”€â”€â”€â”€â”€

///|
fn Json::j_obj(self : Json) -> Map[String, Json]? {
  if self is Object(m) {
    Some(m)
  } else {
    None
  }
}

///|
fn Json::j_arr(self : Json) -> Array[Json]? {
  if self is Array(a) {
    Some(a)
  } else {
    None
  }
}

///|
fn Json::j_str(self : Json) -> String? {
  if self is String(x) {
    Some(x)
  } else {
    None
  }
}

///|
fn Json::j_bool(self : Json) -> Bool? {
  if self is True {
    Some(true)
  } else if self is False {
    Some(false)
  } else {
    None
  }
}

///|
fn Json::j_num(self : Json) -> Double? {
  if self is Number(n, ..) {
    Some(n)
  } else {
    None
  }
}

///|
/// Deterministic codepoint ordering (MoonBit's builtin sorts by length first).
fn str_less(a : String, b : String) -> Bool {
  let ca = to_chars(a)
  let cb = to_chars(b)
  let n = if ca.length() < cb.length() { ca.length() } else { cb.length() }
  let mut i = 0
  while i < n {
    let x = ca[i].to_int()
    let y = cb[i].to_int()
    if x < y {
      return true
    }
    if x > y {
      return false
    }
    i = i + 1
  }
  ca.length() < cb.length()
}

///|
fn sort_items(arr : Array[String]) -> Unit {
  let mut i = 1
  while i < arr.length() {
    let key = arr[i]
    let mut j = i - 1
    while j >= 0 && str_less(key, arr[j]) {
      arr[j + 1] = arr[j]
      j = j - 1
    }
    arr[j + 1] = key
    i = i + 1
  }
}

///|
fn join_comma(items : Array[String]) -> String {
  let buf = StringBuilder::new()
  let mut first = true
  for s in items {
    if !first {
      buf.write_string(",")
    }
    buf.write_string(s)
    first = false
  }
  buf.to_string()
}

///|
fn join_pipe(items : Array[String]) -> String {
  let buf = StringBuilder::new()
  let mut first = true
  for s in items {
    if !first {
      buf.write_string("|")
    }
    buf.write_string(s)
    first = false
  }
  buf.to_string()
}

///|
fn str_has_prefix(s : String, pre : String) -> Bool {
  let cs = to_chars(s)
  let cp = to_chars(pre)
  if cp.length() > cs.length() {
    return false
  }
  let mut i = 0
  while i < cp.length() {
    if cs[i] != cp[i] {
      return false
    }
    i = i + 1
  }
  true
}

// â”€â”€ render helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
fn render_val(v : Value) -> String {
  match v {
    VStr(s) => s
    VBool(b) => if b { "true" } else { "false" }
    VNum(d) => {
      let i = d.to_int()
      if i.to_double() == d {
        i.to_string()
      } else {
        d.to_string()
      }
    }
  }
}

///|
fn render_src(s : Source) -> String {
  match s {
    Cli => "cli"
    Env => "env"
    Config => "config"
    Inherit => "inherit"
    Default => "default"
  }
}

///|
fn render_kind(k : ErrKind) -> String {
  match k {
    KParse => "parse"
    KFilter => "filter"
    KConstraint => "constraint"
  }
}

///|
fn render_def_kind(k : DefErrKind) -> String {
  match k {
    DVocabIntersection => "vocab-intersection"
    DUnknownVocab => "unknown-vocab"
    DInvalidRange => "invalid-range"
    DAbsentRef => "absent-ref"
    DCircularRef => "circular-ref"
    DZeroProgress => "zero-progress"
    DConfigCycle => "config-cycle"
    DInvalidArgument => "invalid-argument"
  }
}

///|
fn deferrs_str(errs : Array[DefError]) -> String {
  let items : Array[String] = []
  for e in errs {
    items.push("\{e.element}/\{render_def_kind(e.kind)}")
  }
  sort_items(items)
  join_comma(items)
}

///|
/// Compact one-line rendering of an Outcome for the runner's "EXPECTED-* got=" diagnostics.
fn render_outcome(o : Outcome) -> String {
  match o {
    Success(binds) => "ok{" + render_binds_result(binds) + "}"
    Failure(d) =>
      match d.fired_action {
        Some(n) => "action:" + n
        None =>
          if d.errors.length() > 0 {
            "fail:" + primary_message(d.errors)
          } else {
            "fail:no complete parse"
          }
      }
    Ambiguous(d) => "ambiguous:" + d.interpretations.length().to_string()
  }
}

///|
fn primary_message(errors : Array[ParseError]) -> String {
  let mut best = errors[0]
  for e in errors {
    if e.argv_pos > best.argv_pos {
      best = e
    }
  }
  best.message
}

///|
/// Result-side binding renderer for render_outcome ("ok{k=v,â€¦}"). Skips markers.
fn render_binds_result(binds : Array[Binding]) -> String {
  let items : Array[String] = []
  for b in binds {
    if !is_sentinel(b.key) {
      items.push("\{b.key}=\{render_val(b.value)}")
    }
  }
  sort_items(items)
  join_comma(items)
}

// â”€â”€ generic set-membership helper for arrays of strings â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
fn conformance_str_in(xs : Array[String], v : String) -> Bool {
  for x in xs {
    if x == v {
      return true
    }
  }
  false
}

// â”€â”€ EffectOp / ExportKey helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
fn eff_op(op : EffectOp) -> String {
  match op {
    Set => "set"
    Default => "default"
    Unset => "unset"
    Empty => "empty"
    // DR-077 آ§1 (5th op): the transform name rides along so two DIFFERENT update transforms (e.g.
    // "increment" vs a future "add") render distinctly. Args are appended ONLY when non-empty
    // (mirrors DR-077 آ§2's colon-DSL nesting, `:update:add:5`) so the 0-arg `increment` case reads
    // as plain "update:increment", not "update:increment:" with a dangling separator.
    Update(transform, args) =>
      if args.length() == 0 {
        "update:" + transform
      } else {
        "update:" + transform + ":" + join_comma(args)
      }
    // DR-080 آ§2 merge accumulator piece markers â€” fixture (merge-basic.json ç­‰) مپ® effects oracle
    // مپŒ pin مپ™م‚‹ op هگچمپ‌مپ®م‚‚مپ® ("set" مپ¯و—¢ه­کمپ® add piece è،¨ç¤؛مپ¨هگŒمپکم€پremove/splice مپŒمپ“مپ®2ه€¤)م€‚
    Remove => "remove"
    Splice => "splice"
  }
}

