///|
/// ن؟‌è¨¼ (issue filter-spelling-inband-encoding-retyping â€” in-band ç©´مپ®é–‰éژ–مپ® pin): DESIGN آ§8.4 /
/// DR-085 آ§3 مپ®م‚ھمƒ–م‚¸م‚§م‚¯مƒˆه½¢ه¼ڈ filter spelling (`{"name":..,"args":[...]}`) مپ¯م€پargs مپ®ه€¤مپ‌مپ®م‚‚مپ®مپ«
/// U+E000 (و—§ه®ںè£…مپŒ colon è،‌çھپه›‍éپ؟مپ®م‚؟م‚°مپ«ن½؟مپ£مپ¦مپ„مپں Private Use Area و–‡ه­—) مپŒهگ«مپ¾م‚Œمپ¦مپ„مپ¦م‚‚م€پ
/// `FilterSpelling.args` (node.mbt) مپ®هگ„è¦پç´ مپ¨مپ—مپ¦ن¸€هˆ‡هˆ†ه‰²مپ•م‚Œمپڑ literal مپ®مپ¾مپ¾ن؟‌وŒپمپ•م‚Œم‚‹م€‚و—§ه®ںè£…
/// (U+E000 م‚؟م‚°ن»کمپچهچکن¸€و–‡ه­—هˆ—مپ¸مپ® in-band encode/decode) مپ¯مپ“مپ®ه…¥هٹ›مپ§èھ¤مپ£مپ¦هˆ†ه‰²مƒ»ç ´ه£ٹمپ—مپ¦مپ„مپں â€”
/// م‚؟م‚°و–‡ه­—م‚’هگ«م‚€ه€¤مپ‌مپ®م‚‚مپ®مپŒ decode م‚’ه£ٹمپ™و½œهœ¨ç©´مپ مپ£مپںمپںم‚پم€پمپ‌م‚Œم‚’هں‹م‚پمپںهپ´مپ® pinم€‚`args` مپ« U+E000
/// م‚’è¤‡و•°ه€‹ (è¦پç´ مپ®ه†…éƒ¨مپ¨è¦پç´ ه¢ƒç•Œç´›مپ„مپ®ن½چç½®مپ®ن¸،و–¹) هں‹م‚پè¾¼مپ؟م€پو§‹é€ هŒ–مƒ•م‚£مƒ¼مƒ«مƒ‰مپŒمپ©مپ“مپ«م‚‚ colon/tag
/// هˆ†ه‰²مƒ­م‚¸مƒƒم‚¯م‚’çµŒç”±مپ—مپھمپ„مپ“مپ¨م‚’ه›؛ه®ڑمپ™م‚‹م€‚
test "dec_filter_chain: an object-form arg value containing U+E000 (retired in-band PUA tag) survives as a literal, unsplit" {
  let tag = "\u{E000}"
  let raw_arg = "a" + tag + "b" + tag + tag + "c"
  let src = "[{\"name\":\"regex_match\",\"args\":[\"" +
    raw_arg +
    "\"]},{\"name\":\"trim\"}]"
  let j = @json.parse(src)
  let result = dec_filter_chain(Some(j)) catch {
    DecodeSkip(r) => abort("expected successful decode, got DecodeSkip: " + r)
  }
  assert_eq(result.length(), 2)
  assert_eq(result[0].name, "regex_match")
  assert_eq(result[0].args.length(), 1)
  assert_eq(result[0].args[0], raw_arg)
  assert_eq(result[1].name, "trim")
  assert_eq(result[1].args.length(), 0)
}

// â”€â”€ DR-091 آ§3: long_prefix / require_equal_separator decode (scope-level, team-lead è£په®ڑ
// 2026-07-11: و­£وœ¬مپ¯ definition/scope مپ® wire م‚­مƒ¼ â€” è¦پç´ هچکن½چمپ¯وœھè¦ڈه®ڑèھ‍ه½™مپ®مپںم‚پن¸چهڈ—çگ†) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

///|
/// ن؟‌è¨¼ (DR-091 آ§3 "هچکç‹¬مپ®ç©؛ prefix مپ¯وœھه®ڑç¾©ه‹•ن½œمپ®مپ¾مپ¾" â†’ decode-time definition-error): a
/// DEFINITION (scope) declaring `long_prefix: ""` WITHOUT `require_equal_separator: true` is
/// rejected at decode (`DecodeSkip`) â€” this is the exact ambiguity آ§3 exists to close (an
/// empty-prefix space-form trigger would match ANY bare token in that scope), so it must never
/// reach `parse_definition`/`inst_long` at all.
test "dec_definition: long_prefix:\"\" without require_equal_separator:true is a decode-time reject (DR-091 آ§3)" {
  let src =
    #|{"options":[{"name":"if","type":"string","long":true}],"config":{"long_prefix":""}}
  let o = match @json.parse(src).j_obj() {
    Some(x) => x
    None => abort("test src is not an object")
  }
  let _ = dec_definition(o) catch { DecodeSkip(_) => return }
  fail("expected DecodeSkip, but dec_definition succeeded")
}

///|
/// ه¯¾و¥µ: `long_prefix: ""` PAIRED with `require_equal_separator: true` decodes successfully AND
/// propagates to every option in that scope's `options` array â€” the eq gate is what makes the
/// empty prefix safe (`ElemDef.require_equal_separator`'s doc comment), and `dec_definition`
/// (not `dec_option`) is the single place that writes these 2 fields onto each `ElemDef`.
test "dec_definition: long_prefix:\"\" WITH require_equal_separator:true decodes successfully and propagates to options (ه¯¾و¥µ)" {
  let src =
    #|{"options":[{"name":"if","type":"string","long":true},{"name":"of","type":"string","long":true}],"config":{"long_prefix":"","require_equal_separator":true}}
  let o = match @json.parse(src).j_obj() {
    Some(x) => x
    None => abort("test src is not an object")
  }
  let def = dec_definition(o) catch {
    DecodeSkip(r) => abort("expected successful decode, got DecodeSkip: " + r)
  }
  assert_eq(def.options.length(), 2)
  for e in def.options {
    assert_eq(e.long_prefix, "")
    assert_eq(e.require_equal_separator, true)
  }
}

///|
/// ن؟‌è¨¼ (è¦پç´ هچکن½چمپ®ن¸ٹو›¸مپچمپ¯وœھè¦ڈه®ڑèھ‍ه½™): an OPTION carrying `long_prefix` or
/// `require_equal_separator` directly (not on the enclosing definition/scope) is rejected by
/// `dec_option`'s `allowed_keys` as an unknown key â€” these 2 fields are scope-only wire vocabulary,
/// never element-level (team-lead è£په®ڑ 2026-07-11, the ه¯¾و¥µ half of the previous 2 tests: this
/// pins that dec_option does NOT accept them, closing the door the earlier element-level design
/// had left open).
test "dec_option: long_prefix at the OPTION level is an unknown-key decode reject (scope-only vocabulary)" {
  let src =
    #|{"name":"if","type":"string","long":true,"long_prefix":""}
  let j = @json.parse(src)
  let _ = dec_option(j, Map([])) catch { DecodeSkip(_) => return }
  fail("expected DecodeSkip (long_prefix is not a valid option-level key)")
}

// â”€â”€ issue scope-config-object-gap: DR-014 full 7-key config object + éڑژه±¤ç¶™و‰؟ â”€â”€â”€â”€â”€

///|
/// ن؟‌è¨¼ (DESIGN آ§7.2م€Œه­گè¦پç´ مپ¯è¦ھمپ® config م‚’ç¶™و‰؟م€پن¸ٹو›¸مپچهڈ¯èƒ½م€چ): a root scope declares
/// `long_prefix: "+"`; a nested `commands[0]` declares NO `config` at all â€” its options must still
/// resolve `long_prefix` to the INHERITED `"+"` (not the pre-issue root default `"--"`), proving
/// the parentâ†’child propagation `dec_command`/`dec_definition` now carry.
test "dec_definition: a child command with no own config inherits every key from the parent scope" {
  let src =
    #|{
    #|  "options": [{"name": "root_opt", "type": "string", "long": true}],
    #|  "config": {"long_prefix": "+"},
    #|  "commands": [
    #|    {"name": "sub", "options": [{"name": "sub_opt", "type": "string", "long": true}]}
    #|  ]
    #|}
  let o = match @json.parse(src).j_obj() {
    Some(x) => x
    None => abort("test src is not an object")
  }
  let def = dec_definition(o) catch {
    DecodeSkip(r) => abort("expected successful decode, got DecodeSkip: " + r)
  }
  assert_eq(def.options[0].long_prefix, "+")
  assert_eq(def.commands.length(), 1)
  assert_eq(def.commands[0].body.options[0].long_prefix, "+")
}

///|
/// ن؟‌è¨¼ (هگŒن¸ٹم€پن¸ٹو›¸مپچهپ´): a child command declaring its OWN `config` with only `short_prefix`
/// overrides ONLY that key â€” `long_prefix` still resolves to the parent's `"+"` (merge is
/// per-key, not whole-object replacement, `dec_scope_config`'s doc comment).
test "dec_definition: a child command's own config overrides ONLY the keys it declares, inherits the rest" {
  let src =
    #|{
    #|  "options": [],
    #|  "config": {"long_prefix": "+"},
    #|  "commands": [
    #|    {
    #|      "name": "sub",
    #|      "options": [{"name": "sub_opt", "type": "string", "long": true, "short": "s"}],
    #|      "config": {"short_prefix": "="}
    #|    }
    #|  ]
    #|}
  let o = match @json.parse(src).j_obj() {
    Some(x) => x
    None => abort("test src is not an object")
  }
  let def = dec_definition(o) catch {
    DecodeSkip(r) => abort("expected successful decode, got DecodeSkip: " + r)
  }
  let sub_opt = def.commands[0].body.options[0]
  assert_eq(sub_opt.short_prefix, "=") // ه­گمپŒوکژç¤؛مپ—مپںن¸ٹو›¸مپچ
  assert_eq(sub_opt.long_prefix, "+") // è¦ھمپ‹م‚‰ç¶™و‰؟ (ه­گمپ¯ long_prefix م‚’و›¸مپ„مپ¦مپ„مپھمپ„)
}

///|
/// ن؟‌è¨¼ (ه­«م‚¹م‚³مƒ¼مƒ—مپ¾مپ§مپ®ه¤ڑو®µç¶™و‰؟): a grandchild command (root â†’ mid â†’ leaf, neither `mid` nor
/// `leaf` declaring their own `config`) still resolves the root's `long_prefix` â€” hierarchical
/// merge threads through every recursion level, not just 1 hop.
test "dec_definition: config inheritance threads through MULTIPLE nesting levels (grandchild)" {
  let src =
    #|{
    #|  "options": [],
    #|  "config": {"long_prefix": "+"},
    #|  "commands": [
    #|    {
    #|      "name": "mid",
    #|      "options": [],
    #|      "commands": [
    #|        {"name": "leaf", "options": [{"name": "v", "type": "string", "long": true}]}
    #|      ]
    #|    }
    #|  ]
    #|}
  let o = match @json.parse(src).j_obj() {
    Some(x) => x
    None => abort("test src is not an object")
  }
  let def = dec_definition(o) catch {
    DecodeSkip(r) => abort("expected successful decode, got DecodeSkip: " + r)
  }
  let leaf = def.commands[0].body.commands[0].body
  assert_eq(leaf.options[0].long_prefix, "+")
}

