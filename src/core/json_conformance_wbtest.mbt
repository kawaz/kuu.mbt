    #|        "result": {"t": "-Infinity"}
    #|      }
    #|    }
    #|  ]
    #|}
  let df = dec_fixture(@json.parse(src))
  assert_eq(df.cases.length(), 2)
  for c in df.cases {
    let verdict = run_case(df, c)
    if verdict != "PASS" {
      abort("expected PASS for case '" + c.id + "', got: " + verdict)
    }
