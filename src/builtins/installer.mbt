// installer.mbt вАФ builtin parse_definition as a chain of installers (DR-042).
//
// UsefulAST (@engine.ElementDef / @engine.Definition / вА¶) вЖТ AtomicAST (@engine.Scope / @engine.Node / @engine.Entity / вА¶) гВТзµДгБњзЂЛгБ¶гВЛ lowering е±§гАВ
// еРД installer гБѓ special vocab (long / short / env / dd / ...) гВТжЙАжЬЙгБЧгАБapply жЩВгБЂ (1) гБЭгБЃ vocab гВТ
// READ (еЙКйЩ§гБЧгБ™гБД вАФ еЃ£и®Ае±§гБѓ read-only, invariant вС†'), (2) greedy и°ЫжШЯ / matcher / re-scoping гВТ
// add-if-absent гБІ implant гБЩгВЛ, (3) еЃЯдљУ (@engine.Entity) гБЃ seat (env / inherit) гВТеЃ£и®АгБЩгВЛгАВ5 invariants гБЂгВИгВК
// chain гБЃй†ЖеЇПгБЂдЊЭе≠ШгБЫгБЪгАБidempotentгАВеЃМеЕ®жАІгБѓгАМchain гБЃгБ©гБЃ installer гБЂгВВжЙАжЬЙгБХгВМгБ™гБД special vocabгАНгБЃж§ЬжЯїгАВ
//
// MDR-002 ¬І3 жЇЦжЛ†: installer гБѓ node / value / matcher / resolve гБЂдЊЭе≠ШгБЧгАБи©ХдЊ°еЩ® (eval) гБЂгБѓдЊЭе≠ШгБЧгБ™гБДгАВ
// MDR-002 ињљи®ШгАМCPS гБЃе∞Дз®ЛгАНгБЃ installer и¶ПзіД: repeat гБѓгВєгГСгВ§гГ≥ељҐ (positional гБЃ Ref / @engine.BoundedTail /
// @engine.ScopeNode) гБЂгБЃгБњж≠£и¶ПеМЦгБЧгАБ@engine.Or / @engine.Seq / @engine.Rooted еЖЕйГ®гБЄгБЃеЯЛгВБиЊЉгБњгБѓзФЯжИРгБЧгБ™гБД (еПЦгВКеИЖйБЄе•љгБЃе±АжЙАеМЦгВТйБњгБСгВЛгБЯгВБ)гАВ
// MDR-003 еСљеРНи¶ПзіД: bare дЇИзіДи™ЮгБѓжЬЂе∞Њ `_` еМЦ вАФ @engine.RepeatSpec гБЃ bare `lazy` гБѓ `is_lazy` гБЂ renameгАВ
// @engine.Entity еБігБЃ `is_inherit` гБѓ node.mbt гБМ rename жЄИгБњгАВ

///|
/// One `long` DSL string (DR-011/071/076), classified. `":set"` (bare sentinel) is `Main`; any
/// OTHER colon form is `Variant` (an empty prefix, e.g. `":set:true"`, is the element's own
/// bare-degenerate main entry вАФ DR-076 ¬І4 вАФ a NON-empty prefix, e.g. `"no:set:false"`, is a
/// separately-triggered named variant вАФ DR-011). DR-011 жШОзҐЇеМЦ (kawaz и£БеЃЪ 2026-07-08): a colon-less
/// string (e.g. `"verbose"`) and a colon-having string whose effect word is outside the vocabulary
/// (`set`/`default`/`unset`/`empty`) are BOTH a variant DSL syntax error, not a literal spelling
/// fallback вАФ `Invalid` carries the offending string for the caller to surface as a DR-054
/// definition-error `unknown-vocab`. An explicit-spelling entry point belongs to DR-057's alias
/// element, not to `long`'s DSL (there is no "colon-less = literal" escape hatch here anymore).
pub(all) enum LongSpelling {
  Main(String) // resolved main-entry spelling (`own_name`, verbatim вАФ see `classify_long_spelling`)
  Variant(@engine.Variant) // a fully-built variant (trigger/op/operand already resolved against own_name)
  Invalid(String, @engine.DefErrorKind) // definition-time classification and the original spelling
} derive(Eq, Debug)

///|
/// Naive scalar coercion for a colon-DSL operand string (`no:set:false`'s `"false"`, `:set:true`'s
/// `"true"`, etc.) into the element's `@engine.Value` per its type вАФ mirrors `@engine.config_to_value`'s per-type
/// parsers (DR-074/075/076 canonical lexicons) but with a permissive `@engine.String` fallback instead of an
/// Error: a DSL operand is a literal the DEFINITION author wrote (not untrusted CLI input), so an
/// unparseable operand degrading to a string is a defensive fallback, not a silent-coercion concern.
fn dsl_operand_value(ty : &@engine.TypeExt, s : String) -> @engine.Value {
  match ty.parse_token(s) {
    Ok(value) => value
    Err(_) =>
      if ty.name() == "flag" || ty.name() == "bool" {
        @engine.Bool(s == "true" || s == "1")
      } else {
        @engine.String(s)
      }
  }
}

///|
/// Classify one `long`/`long_override` DSL string against `own_name` (the caller decides WHICH name
/// applies вАФ a canonical element's own kebab name for `resolve_long`/`normalize_option`, or an
/// alias's re-derived name for `@engine.AliasDef.long_override` desugaring, DR-057 ¬І3) and the element's
/// type (for `Variant`'s operand parsing, DR-074/075/076). This is the SOLE interpreter of the
/// colon DSL (DR-011/071/076 wire vocab) вАФ both `resolve_long` (main `long` attribute) and
/// `desugar_aliases` (alias override desugaring) call this so the two paths can never drift apart
/// (issue 2026-07-08 alias `long_override` gap: aliases used to skip DSL classification entirely,
/// silently misinterpreting `":set:true"` as a literal `"--:set:true"` spelling).
fn invocation_form_text(form : @engine.FnInvocationForm) -> String {
  match form {
    @engine.ColonString(spelling) => spelling
    @engine.ArrayParts(parts) => {
      let out = StringBuilder::new()
      out.write_char('[')
      let mut index = 0
      while index < parts.length() {
        if index > 0 {
          out.write_char(',')
        }
        out.write_string(parts[index])
        index = index + 1
      }
      out.write_char(']')
      out.to_string()
    }
  }
}

///|
fn classify_long_form(
  form : @engine.FnInvocationForm,
  own_name : String,
  ty : &@engine.TypeExt,
  extensions : @engine.Registry,
) -> LongSpelling {
  let original = invocation_form_text(form)
  let parts = match @engine.decode_fn_invocation_parts(form) {
    Ok(parts) => parts
    Err(_) => return Invalid(original, @engine.InvalidArgument)
  }
  if parts.length() < 2 {
    return Invalid(original, @engine.UnknownVocab)
  }
  let prefix = parts[0]
  let trigger = if prefix == "" { own_name } else { prefix + "-" + own_name }
  let args : Array[String] = []
  let mut index = 2
  while index < parts.length() {
    args.push(parts[index])
    index = index + 1
  }
  let invocation : @engine.FnInvocation = { name: parts[1], args }
  // The no-arg bare set spelling prepares the ordinary value slot; it is a lowering sugar rather
  // than a call to the one-or-more-argument set resident.
  if invocation.name == "set" && invocation.args.length() == 0 && prefix == "" {
    return Main(own_name)
  }
  let descriptor = match extensions.lookup_cell_fn(invocation.name) {
    None => return Invalid(original, @engine.UnknownVocab)
    Some(descriptor) => descriptor
  }
  match descriptor.validate_invocation(invocation) {
    Err(_) => return Invalid(original, @engine.InvalidArgument)
    Ok(_) => ()
  }
  match invocation.name {
    "set" =>
      match invocation.args {
        [] =>
          if prefix == "" {
            Main(own_name)
          } else {
            Variant({ trigger, op: @engine.Set, operand: None })
          }
        [value] =>
          Variant({
            trigger,
            op: @engine.Set,
            operand: Some(dsl_operand_value(ty, value)),
          })
        _ =>
          // A scalar target cannot map multiple logical values. Structured seq/repeat aggregation
          // requires a structured Value carrier and is kept as an explicit unimplemented boundary.
          Invalid(original, @engine.InvalidArgument)
      }
    "default" => Variant({ trigger, op: @engine.Default, operand: None })
    "unset" => Variant({ trigger, op: @engine.Unset, operand: None })
    "empty" => Variant({ trigger, op: @engine.Empty, operand: None })
    _ => Variant({ trigger, op: @engine.Invoke(invocation), operand: None })
  }
}

///|
pub fn classify_long_spelling(
  s : String,
  own_name : String,
  ty : &@engine.TypeExt,
  extensions : @engine.Registry,
) -> LongSpelling {
  classify_long_form(@engine.ColonString(s), own_name, ty, extensions)
}

///|
/// DR-076 ¬І2: the `:set:true` variant (bare-trigger fire вЖТ literal `true`) a flag's longе±ХйЦЛ
/// composes in вАФ `classify_long_spelling(":set:true", kebab(name), flag_type())` would build the SAME
/// value (colon-DSL round-trip), this just skips the string-splitting for the one fixed shape.
fn flag_bare_true_variant(name : String) -> @engine.Variant {
  { trigger: kebab(name), op: @engine.Set, operand: Some(@engine.Bool(true)) }
}

///|
/// DR-077 ¬І3: the `:update:increment` variant (bare-trigger fire вЖТ apply the `increment` transform
/// to the linked cell's old value) a count's longе±ХйЦЛ composes in вАФ mirrors `flag_bare_true_variant`
/// exactly, just with `@engine.Update("increment", [])` in place of `@engine.Set`/`true` (count has no operand to
/// carry; the fired value depends on the cell's running state, computed by resolve.mbt's fold).
fn count_increment_variant(name : String) -> @engine.Variant {
  {
    trigger: kebab(name),
    op: @engine.Invoke({ name: "incr", args: [] }),
    operand: None,
  }
}

///|
/// `@engine.LongDeclaration` (wire дЇМељҐ) вЖТ (main-entry spellings вАФ kebab е±ХйЦЛжЄИгБњ, variants)гАВDR-071 ¬І1's
/// type-independent `long: true` вЖТ `[":set"]` sugar is what every OTHER type gets; DR-076 ¬І2 gives
/// `type:"flag"` a DIFFERENT sugar (и¶ПеЙЗ1: еЈЃгБЧжЫњгБИ) and an explicit non-empty list gets `:set:true`
/// COMPOSED IN alongside whatever the author wrote (и¶ПеЙЗ2: и£ЬеЃМгАБidempotent). DR-077 ¬І3 gives
/// `type:"count"` the SAME two-rule treatment with `:update:increment` in place of `:set:true` вАФ
/// count is the 2nd instance of this exact з≥Ци°£еЈЃгБЧжЫњгБИ+и£ЬеЃМ machinery (not a parallel mechanism).
/// This is the ONLY place that needs the bool/array distinction `@engine.LongDeclaration` preserves вАФ once
/// collapsed to `Array[String]` (the old design), `long:true` and `long:[":set"]` become
/// indistinguishable, yet DR-076/077 require different flag/count sugar for each (kawaz и£БеЃЪ
/// 2026-07-08, spec DR-071 ¬І1 "wire гБЂгБѓдЇМељҐгБ®гВВиЉЙгВЛгАБе±ХйЦЛгБѓ long installer гБЃиІ£йЗИ"). `Invalid`
/// spellings (DR-011 жШОзҐЇеМЦ: colon-less / и™ЮељЩе§Ц effect, DR-077 ¬І2 unknown transform) are silently
/// skipped here вАФ the caller (`normalize_option`) only reaches this AFTER
/// `collect_invalid_long_dsl` has already surfaced them as definition-errors and `parse_definition`
/// has returned early on any error, so none should be live at this point in practice.
fn resolve_long(
  decl : @engine.LongDeclaration,
  name : String,
  ty : &@engine.TypeExt,
  extensions : @engine.Registry,
) -> (Array[String], Array[@engine.Variant]) {
  match decl {
    Bool(false) => ([], [])
    Bool(true) =>
      if ty.name() == "flag" {
        ([], [flag_bare_true_variant(name)])
      } else if ty.name() == "count" {
        ([], [count_increment_variant(name)])
      } else if ty.name() == "none" {
        // DR-089 ¬І2 гБЃгАМжґИи≤ї 0 гБЃзіФгГИгГ™гВђгАНcanonical дЊЛ (`{"name": "sep", "long": true}`) вАФ
        // flag_type()/count_type() гБ®еРМгБШгАМmain entry гВТжМБгБЯгБЪ bare-true variant гБ†гБСгАНгБЃ 3 дЊЛзЫЃгАВnone гБЂгБѓ
        // йБЛгБґеА§гБМзД°гБДгБЃгБІ `flag_bare_true_variant` гБЃгГЧгГђгГЉгВєгГЫгГЂгГА (`@engine.Set @engine.Bool(true)`) гВТгБЭгБЃгБЊгБЊ
        // еЖНеИ©зФ®гБЧгБ¶гВИгБД вАФ гБУгБЃ @engine.Binding гБѓ `build_result` еБігБІ `@engine.NoneCell` гБЂгВИгВКзµРжЮЬгБЛгВЙйЩ§е§ЦгБХгВМгВЛ
        // (`resolve.mbt` еПВзЕІ)гАБcommitted еПВеК† (conflicts/exclusive/requires гГИгГ™гВђеБі) гБ†гБСгБМзФЯгБНгВЛгАВ
        ([], [flag_bare_true_variant(name)])
      } else {
        ([kebab(name)], [])
      }
    List(strs) => {
      let longs : Array[String] = []
      let vars : Array[@engine.Variant] = []
      for l in strs {
        match classify_long_spelling(l, kebab(name), ty, extensions) {
          Main(n) => longs.push(n)
          Variant(v) => vars.push(v)
          Invalid(_, _) => ()
        }
      }
      if ty.name() == "flag" && (longs.length() > 0 || vars.length() > 0) {
        let bare_true = flag_bare_true_variant(name)
        let mut already = false
        for v in vars {
          if v == bare_true {
            already = true
          }
        }
        if !already {
          vars.push(bare_true)
        }
      }
      (longs, vars)
    }
    Forms(forms) => {
      let longs : Array[String] = []
      let vars : Array[@engine.Variant] = []
      for form in forms {
        match classify_long_form(form, kebab(name), ty, extensions) {
          Main(n) => longs.push(n)
          Variant(v) => vars.push(v)
          Invalid(_, _) => ()
        }
      }
      if ty.name() == "flag" && (longs.length() > 0 || vars.length() > 0) {
        let bare_true = flag_bare_true_variant(name)
        let mut already = false
        for v in vars {
          if v == bare_true {
            already = true
          }
        }
        if !already {
          vars.push(bare_true)
        }
      }
      // DR-114 ¬І6.2: count explicit lists are interpreted exactly as written. Only long:true
      // replaces the type-independent :set sugar with :incr; there is no list completion.
      (longs, vars)
    }
  }
}

///|
pub fn owned_vocab(installer : &@engine.InstallerExt) -> String {
  match installer.vocab() {
    [first, ..] => first
    [] => ""
  }
}

///|
/// еА§гГЧгГ™гГЯгГЖгВ£гГЦгБЃеФѓдЄАгБЃжІЛзѓЙзВє (positional / long / short гБДгБЪгВМгБЃ value slot гВВгБУгБУгВТйАЪгВЛ,
/// issue 2026-07-09-separator-non-string-type-parse-gap жЃµ1: дї•еЙНгБѓ `element_head` гБ†гБСгБМ
/// `separator` гВТи¶ЛгБ¶ `separated resident` гБЂеИЖе≤РгБЧгАБlong/short main entry гБѓгБУгБЃйЦҐжХ∞гВТ `separator` жКЬгБНгБІ
/// зЫіжО•еСЉгВУгБІгБДгБЯгБЯгВБгАБlong/short option гБІ `multiple + separator` гВТеЃ£и®АгБЧгБ¶гВВеИЖеЙ≤гБМдЄАеИЗеКєгБЛгБ™гБД
/// жЧҐе≠ШгГРгВ∞гБМгБВгБ£гБЯ вАФ `separator` гВТгБУгБЃйЦҐжХ∞иЗ™иЇЂгБЃеИЖе≤РгБЂж†ЉдЄКгБТгБЧгАБеСЉгБ≥еЗЇгБЧеЕГ (positional гБЃ
/// `element_head` / long гБЃ `inst_long` main entry) гБМеРМгБШеИ§жЦ≠гВТеЕ±жЬЙгБЩгВЛгВИгБЖдЄАеЕГеМЦгБЧгБЯгАВ`separator`
/// гБМ `Some` гБ™гВЙ `separated resident` гВТжІЛзѓЙгБЧгАБеЮЛжГЕе†± (ty/int_round/allow_base_prefix) гВТгБЭгБЃгБЊгБЊйБЛжРђгБЩгВЛ
/// (жЃµ2: separated resident иЗ™иЇЂгБМ piece гБФгБ®гБЂеЮЛ parse гВТи°МгБЖгАБ`sep_binds` еПВзЕІ) вАФ жЃµ1 (еИЖеЙ≤иЗ™дљУгВТйЕНзЈЪ) гБ®
/// жЃµ2 (еИЖеЙ≤еЊМгБЃеЮЛ parse) гБѓеРМдЄАгВµгВ§гВѓгГЂгБІе∞ОеЕ•ењЕй†И (issue ињљи®Ш2: жЃµ1 еНШзЛђгБІгБѓжИРеКЯз≥їгБМ regress гБЩгВЛ
/// еЃЯжЄђзҐЇи™НжЄИгБњ)гАВ
/// `merge` (DR-080 ж≥ҐеПКзѓА): `@engine.ElementDef.accumulator == Some("merge")` гБЃзі†йАЪгБЧгАВдЄ°еСЉгБ≥еЗЇгБЧеЕГ
/// (`element_head` / `inst_long` main entry) гБМеРМгБШеИ§жЦ≠ (`e.accumulator` гВТи¶ЛгВЛ) гВТеЕ±жЬЙгБЩгВЛгАВ
///
/// codex Medium ињљеЊУ (2026-07-10, issue merge-no-separator-marker-gap): зµМиЈѓйБЄжКЮгБѓ
/// `separator is Some(_)` **еНШзЛђ**гБІгБѓгБ™гБП `separator is Some(_) || merge` вАФ merge еЃ£и®Аи¶Бзі†гБѓ
/// `separator` жЬ™еЃ£и®АгБІгВВ `separated resident` (piece еЗ¶зРЖ) еБігБЄйА≤гВАгАВ`separator` гБѓ `separated resident` гБЄгБЭгБЃгБЊгБЊ
/// `String?` гБІйБЛгБ≥ (`sep_binds` гБМ `None` гВТгАМ1 piece = еЕ®дљУгАНгБ®гБЧгБ¶жЙ±гБЖгАБDR-034 ¬І6.3 гБЃзЄЃйАА)гАБ
/// гГЮгГЉгВЂгГЉи™Ни≠Ш (`@engine.classify_merge_piece`) гБѓ piece жХ∞гБЂйЦҐгВПгВЙгБЪеРМгБШ pipeline гБІеКєгБП вАФ `--fields -a`
/// (separator зД°гБЧгАБгВ≥гГ≥гГЮгБІеЙ≤гВЛдљЩеЬ∞гБМзД°гБД) гБІгВВ `-a` гБМ remove гГЮгГЉгВЂгГЉгБ®гБЧгБ¶иІ£йЗИгБХгВМгВЛгАВ
/// merge гБІгБ™гБДи¶Бзі†гБѓеЊУжЭ•йАЪгВК `separator is Some(_)` гБЃгБњгБМ gate (гБУгБЃеИЖе≤РгБѓдЄНе§Й)гАВ
///
/// `kv_map` (DR-091 ¬І2): `@engine.ElementDef.accumulator == Some("kv_map")` гБѓ `merge`/`separator` гБЃ separated resident
/// зµМиЈѓгБ®гБѓеИ•жЮЭ вАФ kv_map гБѓгАМ1 token = 1 pieceгАНгБІ separator еИЖеЙ≤гВТењЕи¶БгБ®гБЧгБ™гБД (`k=v` гБЃ `=` еИЖеЙ≤гБѓ
/// гБУгБЃ node гБЃдїХдЇЛгБІгБѓгБ™гБП `resolve.mbt`'s `build_result` гБМзХ≥гБњжЩВгБЂи°МгБЖгАБnode.mbt гБЃ `kv resident` doc
/// commentеПВзЕІ)гАВ`merge` гВИгВКеЕИгБЂеИ§еЃЪгБЩгВЛгБЃгБѓдЄ§иАЕгБМеРМжЩВгБЂзЬЯгБЂгБ™гВЛгБУгБ®гБѓзД°гБД (decode е±§ `dec_multiple`
/// гБМ `accumulator` гВТеНШдЄА `String?` гБ®гБЧгБ¶гБЧгБЛйБЛгБ∞гБ™гБДгАБDR-080/DR-091 гБЃгБ©гБ°гВЙгБЛдЄАжЦєгБЃи™ЮељЩ) гБЯгВБ
/// й†ЖеЇПгБЂжДПеС≥гБѓзД°гБДгБМгАБkv resident гБМ separated resident гБЃеИЖе≤РгБЂеЈїгБНиЊЉгБЊгВМгБ™гБДгВИгБЖжЬАеИЭгБЂеИЗгВКеЗЇгБЩгАВ
fn value_prim(
  ty : &@engine.TypeExt,
  name : String,
  int_round : @engine.RoundMode,
  allow_base_prefix : Bool,
  bool_config : @engine.BoolConfig,
  piece_filters : Array[@engine.FnInvocation],
  separator? : String? = None,
  merge? : Bool = false,
  kv_map? : Bool = false,
) -> @engine.Node {
  let configured = configured_type(
    ty,
    int_round,
    bool_config,
    allow_base_prefix~,
  )
  if kv_map {
    kv_arg(name, piece_filters)
  } else if separator is Some(_) || merge {
    separated_arg(
      name,
      separator,
      configured,
      int_round,
      bool_config,
      piece_filters,
      allow_base_prefix~,
      merge~,
    )
  } else {
    match ty.name() {
      "number" => number_arg(name, piece_filters, allow_base_prefix~)
      "int" => int_arg(name, int_round, piece_filters, allow_base_prefix~)
      "float" => float_arg(name, piece_filters)
      "bool" => bool_arg(name, bool_config, piece_filters)
      "string" => string_arg(name, piece_filters)
      _ =>
        // A value-less resident still consumes its positional token structurally; the
        // placeholder binding is removed through the element's NoneCell metadata.
        if configured.has_value_slot() {
          typed_arg(name, configured, piece_filters)
        } else {
          string_arg(name, piece_filters)
        }
    }
  }
}

///|
fn copy_strs(a : Array[String]) -> Array[String] {
  let r : Array[String] = []
  for x in a {
    r.push(x)
  }
  r
}

///|
/// Deep-copy an `Array[@engine.FnInvocation]` вАФ mirrors `copy_strs`'s discipline (global/alias desugaring
/// pushes COPIES into descendant scopes, `clone_elem`'s doc comment) but also copies each entry's
/// own `args : Array[String]` (a mutable nested array `copy_strs`-style aliasing would otherwise
/// share across scope copies).
fn copy_filter_spellings(
  a : Array[@engine.FnInvocation],
) -> Array[@engine.FnInvocation] {
  let r : Array[@engine.FnInvocation] = []
  for fs in a {
    r.push({ name: fs.name, args: copy_strs(fs.args) })
  }
  r
}

///|
/// жЬЙеКє long зґігВКдЄАи¶І (post-normalize; `:set` гБѓжЧҐгБЂ kebab(name) гБЂе±ХйЦЛжЄИгБњгАБ`normalize_option` гБМ
/// `@engine.LongDeclaration` гВТ `List([<kebab main entries>])` гБЂзҐЇеЃЪгБХгБЫгБЯеЊМгБЃељҐ)гАВ[] = main-entry гБ™гБЧ (DR-071)гАВ
/// pre-normalize гБ™ `Bool` гБѓгБУгБУгБЂжЭ•гБ™гБДеЙНжПР (еСЉгБ≥еЗЇгБЧгБѓеЕ®гБ¶ normalize еЊМ)гАВ
fn long_of(e : @engine.ElementDef) -> Array[String] {
  match e.long {
    List(strs) => strs
    Forms(_) | Bool(_) => []
  }
}

///|
fn copy_long(l : @engine.LongDeclaration) -> @engine.LongDeclaration {
  match l {
    Bool(b) => Bool(b)
    List(strs) => List(copy_strs(strs))
    Forms(forms) => {
      let copied : Array[@engine.FnInvocationForm] = []
      for form in forms {
        copied.push(
          match form {
            @engine.ColonString(spelling) => @engine.ColonString(spelling)
            @engine.ArrayParts(parts) => @engine.ArrayParts(copy_strs(parts))
          },
        )
      }
      Forms(copied)
    }
  }
}

///|
fn copy_chars(a : Array[Char]) -> Array[Char] {
  let r : Array[Char] = []
  for x in a {
    r.push(x)
  }
  r
}

///|
fn copy_variants(a : Array[@engine.Variant]) -> Array[@engine.Variant] {
  let r : Array[@engine.Variant] = []
  for x in a {
    r.push(x)
  }
  r
}

///|
fn clone_elem(e : @engine.ElementDef) -> @engine.ElementDef {
  {
    name: e.name,
    ty: e.ty,
    long: copy_long(e.long),
    variants: copy_variants(e.variants),
    short: copy_chars(e.short),
    env: copy_strs(e.env),
    help_meta: e.help_meta,
    is_tty: e.is_tty,
    tty_stream: e.tty_stream,
    tty_cygwin: e.tty_cygwin,
    is_dd: e.is_dd,
    is_exact: e.is_exact,
    dd_match: e.dd_match,
    dd_self_keep: e.dd_self_keep,
    is_global: e.is_global,
    is_inherit: e.is_inherit,
    is_inheritable: e.is_inheritable,
    link_depth: e.link_depth,
    ref_target: e.ref_target,
    repeat: e.repeat,
    optional: e.optional,
    multiple: e.multiple,
    accumulator: e.accumulator,
    flatten: e.flatten,
    separator: e.separator,
    collector: e.collector,
    fail_action: e.fail_action,
    is_config_file: e.is_config_file,
    config_key: e.config_key,
    export_key: e.export_key,
    requires: e.requires,
    conflicts_with: e.conflicts_with,
    exclusive_group: e.exclusive_group,
    required_group: e.required_group,
    required: e.required,
    value_requires: e.value_requires,
    deprecated: e.deprecated,
    is_alias: e.is_alias,
    hidden: e.hidden,
    completer: e.completer,
    default_values: e.default_values,
    default_fn: e.default_fn,
    default_declared: e.default_declared,
    int_round: e.int_round,
    allow_base_prefix: e.allow_base_prefix,
    bool_config: e.bool_config,
    piece_filters: copy_filter_spellings(e.piece_filters),
    value_filters: copy_filter_spellings(e.value_filters),
    final_filters: copy_filter_spellings(e.final_filters),
    accum_filters: copy_filter_spellings(e.accum_filters),
    long_prefix: e.long_prefix,
    short_prefix: e.short_prefix,
    env_prefix: e.env_prefix,
    auto_env: e.auto_env,
    long_eq_sep: e.long_eq_sep,
    short_combine: e.short_combine,
    short_attached_value: e.short_attached_value,
    body: clone_body(e.body),
  }
}

///|
/// MDR-004: deep-clone `@engine.ElementBody`'s nested `@engine.ElementDef`s (mirrors the Array-field deep-copy discipline
/// `clone_elem` already applies to `long`/`variants`/`short`/`env` вАФ global/alias desugaring pushes
/// COPIES into descendant scopes, so aliasing the same mutable nested arrays across scopes would be
/// a bug).
fn clone_body(b : @engine.ElementBody) -> @engine.ElementBody {
  match b {
    Cell => Cell
    Or(branches) => {
      let out : Array[@engine.OrBranch] = []
      for br in branches {
        let items : Array[@engine.ElementDef] = []
        for it in br.items {
          items.push(clone_elem(it))
        }
        out.push({ id: br.id, items })
      }
      Or(out)
    }
    Group(items) => {
      let out : Array[@engine.ElementDef] = []
      for it in items {
        out.push(clone_elem(it))
      }
      Group(out)
    }
    Enum(values) => Enum(copy_strs(values))
  }
}

///|
/// snake_case вЖТ kebab-case (DR-022): AST key гБѓ snake, CLI long гБѓ kebabгАВASCII гБЃгБњжГ≥еЃЪгАВ
fn kebab(name : String) -> String {
  let buf = StringBuilder::new()
  for c in name {
    if c == '_' {
      buf.write_char('-')
    } else {
      buf.write_char(c)
    }
  }
  buf.to_string()
}

///|
/// зіФжІЛжЦЗ pre-pass (LOWERING ¬ІA / ¬ІC.4)гАВstatic check гБ® installer fixpoint гБЃеЙНгБЂиµ∞гВЛ:
///   Fix 2 (¬ІB.1 / DR-071 / DR-076 ¬І2, kawaz и£БеЃЪ 2026-07-08): `resolve_long` гБМ `@engine.LongDeclaration` (wire дЇМељҐ)
///   гВТиІ£йЗИгБЧгАБmain entry (kebab е±ХйЦЛжЄИгБњ) гБ® variants гБЂзҐЇеЃЪгБХгБЫгВЛгАВз≥Ци°£е±ХйЦЛгГїflag еЈЃгБЧжЫњгБИ/и£ЬеЃМгГї
///   colon DSL еИЖй°ЮгБѓгБУгБУгБЂйЫЖзіД вАФ decode е±§ (dec_long) гБѓгВВгБЖ wire гБЃељҐгВТеЖЩгБЩгБ†гБС (дЇМељҐгБЃеМЇеИ•гБѓ decode
///   еЊМгБЂжљ∞гБХгБ™гБДгАБ`resolve_long` гБЃгВ≥гГ°гГ≥гГИеПВзЕІ)гАВ
///   Fix 3 (DR-064 ¬І5): dd и¶Бзі†гБІ name жЬ™жМЗеЃЪгБ™гВЙ trigger зґігВКгВТ "--" гБЂжЧҐеЃЪ
///   Fix 4 (LOWERING ¬ІA.5 / DR-076 ¬І2): flag_type() гБЃеА§гВїгГЂгВТ bool_type() гБЄеЈЃгБЧжЫњгБИ (flag = bool + default:false +
///   long зґігВКеРИжИР)гАВгБУгВМгБЂгВИгВК inst_long / eq_entries гБѓ flag_type() гВТзЙєжЃКжЙ±гБДгБЩгВЛењЕи¶БгБМгБ™гБПгБ™гВКгАБbool гБ®
///   еЃМеЕ®еРМдЄАгБЃ lowering зµМиЈѓгБЂиЗ™зДґгБЂдєЧгВЛ (flag еЫЇжЬЙгБЃ lowering еИЖе≤РгВТгАМеЮЛеЈЃгБЧжЫњгБИ + resolve_longгАНгБЃ
///   2 зВєгБ†гБСгБЂзЄЃйААгБХгБЫгВЛгАБDR-076 ¬І2 и¶ПеЙЗ4)гАВ
fn normalize_surface(
  def : @engine.Definition,
  extensions : @engine.Registry,
) -> Unit {
  let mut i = 0
  while i < def.options.length() {
    def.options[i] = normalize_option(def.options[i], extensions)
    i = i + 1
  }
  i = 0
  while i < def.positionals.length() {
    def.positionals[i] = normalize_dd_name(def.positionals[i])
    i = i + 1
  }
  for c in def.commands {
    normalize_surface(c.body, extensions)
  }
}

///|
/// DR-076 ¬І2: flag гБЃе±ХйЦЛеЊМгБЃеА§гВїгГЂгБѓ bool (LOWERING ¬ІA.5) вАФ resolve_long гБѓеЕГгБЃеЮЛ (e.ty, гБЊгБ† flag_type())
/// гБІеИ§еЃЪгБЩгВЛењЕи¶БгБМгБВгВЛгБЃгБІгАБеЮЛеЈЃгБЧжЫњгБИгВИгВКеЕИгБЂеСЉгБґгАВ`flag_type() вЖТ bool_type()` гБѓгБУгБУгБІзҐЇеЃЪгБЧгБ¶гВИгБД вАФ `bool_type()`
/// еЮЛгБЃ short/eq-split жМЩеЛХгБѓ "bool_type() еЕ®иИђгБЂзФїдЄАзЪДгБ™гГЂгГЉгГЂ" (йЭЮжґИи≤їгГїеЫЇеЃЪ true) гБІйЦЙгБШгВЛгБЃгБІгАБе§ЙжПЫеЊМгВВ
/// гАМеЕГ flag гБ†гБ£гБЯгБЛгАНгВТи¶ЪгБИгБ¶гБКгБПењЕи¶БгБМзД°гБД (builtins/matcher_residents.mbt гБЃ `flag_type() | bool_type()` гВҐгГЉгГ†гБМдЄ°жЦє flag еЮЛгБ®
/// гБЧгБ¶жЙ±гБЖгБЃгБѓгБУгБЃзФїдЄАжАІгБЃгБКгБЛгБТ)гАВ
///
/// DR-077 ¬І3 (`count_type()`) гБѓеѓЊзІ∞зЪДгБ™з≥Ци°£гБЂи¶ЛгБИгБ¶ **гБУгБУгБІгБѓ number_type() гБЂе§ЙжПЫгБЧгБ™гБД** вАФ count зФ±жЭ•гБЃ short/
/// eq-split жМЩеЛХ (йЭЮжґИи≤їгГїеЫЇеЃЪ increment) гБѓгАМnumber_type() еЕ®иИђгАНгБЂгБѓйБ©зФ®гБІгБНгБ™гБД (ordinary number гБЃ short
/// гБѓеА§гВТжґИи≤їгБЩгВЛгБЃгБМж≠£гБЧгБДжМЩеЛХгАБ`-n5` з≠Й) гБЃгБІгАБflag гБ®йБХгБ£гБ¶гАМеЮЛе§ЙжПЫеЊМгВВеЕГ count гБ†гБ£гБЯгБЛгАНгВТи¶ЪгБИгБ¶
/// гБКгБПењЕи¶БгБМгБВгВЛгАВ@engine.ElementDef гБЂе∞ВзФ®гГЮгГЉгВЂгГЉгВТжЦ∞и®≠гБЩгВЛдї£гВПгВКгБЂгАБ**count_type() гБ®гБДгБЖгВњгВ∞иЗ™дљУгВТ installer chain
/// гБЃйЦУгБЪгБ£гБ®дњЭжМБгБЧгАБеА§гВїгГЂгБЃеЃЯдљУеЮЛ (@engine.Entity.ty = number_type()) гБЄгБЃеПОжЭЯгВТ `ensure_entity` гБЊгБІйБЕеїґгБХгБЫгВЛ**
/// (`ensure_entity` гБЃгВ≥гГ°гГ≥гГИеПВзЕІ) вАФ жЧҐе≠ШгБЃеЮЛгБЭгБЃгВВгБЃгБМжГЕе†±гВТйБЛгБґи®≠и®ИгБѓеі©гБХгБЪгАБcollapse гБЃгВњгВ§гГЯгГ≥гВ∞гБ†гБС
/// еЊМгВНгБЂгБЪгВЙгБЩгАВshort/eq-split matcher (builtins/matcher_residents.mbt) гБѓ `count_type()` гВТ `flag_type() | bool_type()` гБ®дЄ¶гБґзђђ 3 гБЃ
/// йЭЮжґИи≤їжМЩеЛХгБ®гБЧгБ¶жЙ±гБЖгАВ
fn normalize_option(
  e : @engine.ElementDef,
  extensions : @engine.Registry,
) -> @engine.ElementDef {
  if e.is_dd {
    normalize_dd_name(e)
  } else {
    let (longs, vars) = resolve_long(e.long, e.name, e.ty, extensions)
    // flag_type() гБѓ bool_type() гБЄжЫЄгБНжПЫгВПгВК `ensure_entity` еИ∞йБФжЩВгБЂгБѓеЕГ flag_type() гБ†гБ£гБЯгБЛгВТеИ§еИ•гБІгБНгБ™гБПгБ™гВЛ
    // гБЯгВБгАБflag preset гБЃ default:false (LOWERING ¬ІA.5) гБѓгБУгБЃеЮЛеЈЃгБЧжЫњгБИгБ®еРМгБШе†іжЙАгБІзҐЇеЃЪгБХгБЫгВЛ
    // (issue group-inner-bool-default-false-duplicate-top-level: plain bool_type() гБѓжЪЧйїЩ default гВТ
    // жМБгБЯгБ™гБДгБЃгБІ `ensure_entity` еБігБЃж≥®еЕ•еѓЊи±°гВТзµЮгВЛдЄАжЦєгАБflag зФ±жЭ•гБЃ bool_type() гБѓ preset гВТзґ≠жМБгБЩгВЛ
    // ењЕи¶БгБМгБВгВЛ вАФ жШОз§Ї default гБМгБВгВМгБ∞гБЭгБ°гВЙгБМеЛЭгБ§гБЃгБѓе§ЙгВПгВЙгБ™гБД)гАВ
    let default_values2 = if e.ty.name() == "flag" && e.default_values is None {
      match e.ty.default_seat_resolver(@engine.SeatCtx::new(None)) {
        Some(value) => Some([value])
        None => None
      }
    } else {
      e.default_values
    }
    let default_fn2 = match e.default_fn {
      Some(call) => Some(call)
      None =>
        match default_values2 {
          Some(values) if !e.multiple &&
            e.repeat is None &&
            e.separator is None &&
            !e.is_tty =>
            Some(@engine.Typed(@engine.FnCall::typed("set", values)))
          _ => None
        }
    }
    let ty2 = if e.ty.name() == "flag" { bool_type() } else { e.ty }
    {
      ..e,
      ty: ty2,
      default_values: default_values2,
      default_fn: default_fn2,
      long: List(longs),
      variants: vars,
    }
  }
}

///|
fn normalize_dd_name(e : @engine.ElementDef) -> @engine.ElementDef {
  if e.is_dd && e.name == "" {
    { ..e, name: "--" } // DR-064 ¬І5
  } else {
    e
  }
}

///|
fn clone_def(d : @engine.Definition) -> @engine.Definition {
  let os : Array[@engine.ElementDef] = []
  for e in d.options {
    os.push(clone_elem(e))
  }
  let ps : Array[@engine.ElementDef] = []
  for e in d.positionals {
    ps.push(clone_elem(e))
  }
  let cs : Array[@engine.CommandDef] = []
  for c in d.commands {
    cs.push({ name: c.name, body: clone_def(c.body), export_key: c.export_key })
  }
  let als : Array[@engine.AliasDef] = []
  for a in d.aliases {
    als.push(a) // @engine.AliasDef гБѓ immutable value data (nested mutable array гВТжМБгБЯгБ™гБД)
  }
  {
    scope: d.scope,
    options: os,
    positionals: ps,
    commands: cs,
    aliases: als,
    help_types: d.help_types,
  }
}

///|
/// зµРжЮЬгВ≠гГЉ map гБЃжІЛзѓЙ (DR-052)гАВи¶Бзі†/гВ≥гГЮгГ≥гГЙеРН вЖТ export_keyгАВpost-parse гБЃзµРжЮЬ remap зФ®гАВalias
/// гВТ desugar жЄИгБњгБЃ clone гБЂеѓЊгБЧгБ¶еПОйЫЖгБЩгВЛ вАФ command alias гБЃ export_key = @engine.Key(canonical) гБМ
/// еїЇгБ£гБЯ @engine.Scope гБЃ keying гБ®дЄАиЗігБЩгВЛгВИгБЖгБЂгАВ
pub fn build_export_map(
  def : @engine.Definition,
  extensions : @engine.Registry,
) -> Map[String, @engine.ExportKey] {
  let d = clone_def(def)
  // `d` гБѓ normalize_surface гВТзµМгБ¶гБДгБ™гБДзФЯгБЃ (= pre-normalize) и§Зи£љгБ™гБЃгБІгАБ`orig` еЉХжХ∞гБЂгВВ
  // еРМгБШ `d` гВТжЄ°гБЧгБ¶гВИгБД (flag_type() з≠ЙгБЃеЕГгБЃеЮЛгБѓгБЊгБ†жЫЄгБНжПЫгВПгБ£гБ¶гБДгБ™гБД)гАВ
  desugar_aliases(d, d, extensions)
  let m : Map[String, @engine.ExportKey] = Map([], capacity=0)
  collect_export(d, m)
  m
}

///|
fn collect_export(
  def : @engine.Definition,
  m : Map[String, @engine.ExportKey],
) -> Unit {
  for e in def.options {
    collect_export_body(e, m)
  }
  for e in def.positionals {
    collect_export_body(e, m)
  }
  for c in def.commands {
    m.set(c.name, c.export_key)
    collect_export(c.body, m)
  }
}

///|
/// MDR-004 ¬І3b: `collect_export` needs to recurse into `@engine.ElementBody` вАФ a `Group`/`Or` element's
/// nested leaves (e.g. transparent-seq's `k`, export_key:null) each have their OWN export_key that
/// must reach the map, or their `export_key:null` и£ЄеА§еМЦ (DR-052 ¬І2) never gets applied downstream
/// (resolve's export-key remap only consults this map). `Group` registers BOTH the wrapper (the
/// array cell itself) and its inner leaves; `Or`'s wrapper has no export_key of its own concern
/// (structural dispatcher, no scalar/array value) вАФ only its branch leaves register.
fn collect_export_body(
  e : @engine.ElementDef,
  m : Map[String, @engine.ExportKey],
) -> Unit {
  match e.body {
    Cell => m.set(e.name, e.export_key)
    Or(branches) =>
      for br in branches {
        for it in br.items {
          collect_export_body(it, m)
        }
      }
    Group(items) => {
      m.set(e.name, e.export_key)
      for it in items {
        collect_export_body(it, m)
      }
    }
    // Enum (issue values-decode-support): same standing as Cell вАФ a single named cell whose
    // consumption structure happens to be an exact-value enum (no nested leaves to recurse into).
    Enum(_) => m.set(e.name, e.export_key)
  }
}

///|
/// и¶Бзі†гБЃ lowered head: еА§гГЧгГ™гГЯгГЖгВ£гГЦ / Ref (ref_target) / separated resident (separator, `value_prim` еБігБЂйЫЖзіД
/// жЄИгБњ вАФ гБУгБЃгГШгГЂгГСгГЉиЗ™иЇЂгБЃељєзЫЃгБѓ ref_target гБЃеИЖе≤РгБЃгБњ)гАВissue
/// 2026-07-15-audit-node-nodashstr-deprmark-variants еЙѓжђ°зЩЇи¶ЛгБЃз©іеЯЛгВБ: `is_exact` (positional-face
/// nameless exact-match leaf, `@engine.ElementDef.is_exact` doc comment) гБѓ ref_target еИЖе≤РгВИгВКеЕИгБЂеИ§еЃЪгБЩгВЛ вАФ
/// value_prim/Ref гБ©гБ°гВЙгБЃзµМиЈѓгВВйАЪгВЙгБЪ `@engine.Exact(name)` гБЄзЫіжО• lower гБЩгВЛгАБbare `@engine.Exact` node гБѓгАМliteral
/// token match; binds nothing, consumes 1гАН(node.mbt) гБМгБЭгБЃгБЊгБЊжђ≤гБЧгБДжМЩеЛХгБЭгБЃгВВгБЃгАВгБУгБЃзµМиЈѓгБѓ
/// `Or`/`Group` гБЃеЖЕеБігГ™гГЉгГХ (`or_branch_node`/`lower_positional` гБЃ Group еИЖе≤РгБМ `element_head` гВТ
/// еЕ±жЬЙгБЩгВЛ) гБЂгВВиЗ™еЛХзЪДгБЂеПКгБґ вАФ DR-063 A.1 гБЃи£ЄжЦЗе≠ЧеИЧж≠£и¶ПеМЦгБМ or жЮЭеЖЕгБІгВВжИРзЂЛгБЩгВЛељҐгБ®еѓЊзІ∞гАВ
pub fn element_head(e : @engine.ElementDef) -> @engine.Node {
  if e.is_exact {
    return @engine.Exact(e.name)
  }
  match e.ref_target {
    Some(r) => Ref(r)
    None =>
      value_prim(
        e.ty,
        e.name,
        e.int_round,
        e.allow_base_prefix,
        e.bool_config,
        e.piece_filters,
        separator=e.separator,
        merge=e.accumulator == Some("merge"),
        kv_map=e.accumulator == Some("kv_map"),
      )
  }
}

///|
/// DESIGN ¬І5.3 (values гБѓ or гБЃгВЈгГІгГЉгГИгГПгГ≥гГЙ) / DR-028 ињљи®Ш (values гВТжМБгБ§ node гБѓ type гГХгВ£гГЉгГЂгГЙ
/// гБ™гБЧгБІ enum еЮЛгВТеЕЉгБ≠гВЛ): the consumption structure for a `Enum` cell вАФ ONE token that must
/// match one of the exact values, or the whole read doesn't exist (DR-028 ¬І3.1 "enum зЪДгГЖгГ≥гГЧгГђгБЄгБЃ
/// жЬ™еЃЪзЊ©еА§гБѓ or еЕ®жЮЭгБЃзґігВКдЄНдЄАиЗі (Reject)" вАФ no held error, same posture bare `@engine.Exact` already has:
/// a non-matching token means every branch of the `@engine.Or` below fails to @engine.Accept, so the read simply
/// isn't there вАФ no separate "reject" signal needed). Each matching branch's @engine.Bind value goes
/// through `dsl_operand_value` (the SAME type coercion `classify_long_spelling`'s DSL operand
/// parsing already uses for variant operands) so a non-string-typed enum would get a correctly-
/// typed value вАФ moot for today's only callers (string-only `values`, this issue's scope) since
/// `dsl_operand_value(string_type(), s) = @engine.String(s)`.
pub fn enum_value_node(
  name : String,
  ty : &@engine.TypeExt,
  values : Array[String],
) -> @engine.Node {
  let branches : Array[@engine.Node] = []
  for v in values {
    branches.push(
      @engine.Seq([
        @engine.Exact(v),
        @engine.Bind(name, dsl_operand_value(ty, v)),
      ]),
    )
  }
  @engine.Or(branches)
}

///|
/// DR-078 ¬І1 result еЖЩеГП (issue 2026-07-09-ref-template-result-shape): wrap ONE repeat rep's
/// `head` (a ref element's consumption unit) so its bindings land nested under `name` (the
/// result scope, DESIGN ¬І2.3/¬І2.4) with a leading "#row" sentinel marking the row boundary
/// (`resolve.mbt`'s `build_result` ROW-GROUP branch groups same-scope bindings into one array
/// element per "#row"). `@engine.Bind`'s 0-token binding rides IN FRONT of `head`'s own bindings within
/// the SAME `@engine.Scoped` wrap, so both land at scope=[name] together in args order вАФ this is safe to
/// apply per-rep (rather than wrapping the whole repeat spine once) because it changes only the
/// CONTENT of one head-consumption, never the spine shape that drives еПЦгВКеИЖйБЄе•љ/еЕИй£ЯгБД
/// (`lower_repeat_head` / `ref_choice` / `bounded_tail_step` remain untouched).
fn ref_row_head(name : String, head : @engine.Node) -> @engine.Node {
  @engine.Scoped(
    name,
    @engine.Seq([@engine.Bind("#row", @engine.Bool(false)), head]),
  )
}

///|
/// MDR-004 ¬І3: one `@engine.OrBranch`'s consumption grammar node вАФ a single node for a 1-item branch, a
/// `@engine.Seq` of value primitives (consumed in order) for a multi-item branch. Each item's own `name`
/// carries through `element_head` unchanged, so held-Error / binding attribution lands on the LEAF
/// (e.g. `a`/`s`/`b`/`r`/`g`/`b`/`name`) with no extra provenance wiring needed (¬І4).
pub fn or_branch_node(br : @engine.OrBranch) -> @engine.Node {
  if br.items.length() == 1 {
    element_head(br.items[0])
  } else {
    let nodes : Array[@engine.Node] = []
    for it in br.items {
      nodes.push(element_head(it))
    }
    @engine.Seq(nodes)
  }
}

///|
/// жЬЙеКє repeat spec (DR-043)гАВ`optional:true` гБѓ `{min:0,max:1}` гБЃз≥Ци°£ (зЛђзЂЛж¶ВењµгБІгБѓгБ™гБД)гАВ
fn elem_repeat(e : @engine.ElementDef) -> @engine.RepeatSpec? {
  match e.repeat {
    Some(s) => Some(s)
    None =>
      if e.optional {
        Some({ min: 0, max: Some(1), is_lazy: false })
      } else {
        None
      }
  }
}

///|
/// `Opt(X)` = `@engine.Or([X, @engine.Seq([])])`гАВз©Ї @engine.Seq гБМ 0 гГИгГЉгВѓгГ≥дЄАиЗігАВ
fn opt_node(x : @engine.Node) -> @engine.Node {
  @engine.Or([x, @engine.Seq([])])
}

///|
/// DR-088 ¬І1: гАМеЃ£и®АгБХгВМгБЯеА§жЇРгБѓгГЗгГХгВ©гГЂгГИгБЃе≠ШеЬ®гАНвАФ `default_values` (жШОз§Ї default) гБ†гБСгБІгБ™гБП
/// `env`/`config_key`/`inherit` гБЃеЃ£и®АгВВгАМйБЕеїґиІ£ж±ЇгБЩгВЛ default_fn гБМи®≠еЃЪгБХгВМгБ¶гБДгВЛгБЃгБ®еРМеЮЛгАНгАВ
/// `eval.mbt`'s `value_declared` (resolve-first-constraint-pipeline / value-present-ladder-gap гБЃ
/// йЭЩзЪДеЃ£и®Аињ∞и™Ю) гБ®еРМгБШ4и¶Бзі†еИ§еЃЪгВТгАБinstaller е±§ (lowering жЩВзВєгАБ@engine.ElementDef гГЩгГЉгВє) гБІи°МгБЖзЙИгАВ
fn has_declared_value_source(e : @engine.ElementDef) -> Bool {
  e.default_values is Some(_) ||
  e.env.length() > 0 ||
  e.config_key is Some(_) ||
  e.is_inherit
}

///|
/// positional face гБЃ loweringгАВrepeat и¶Бзі† (DR-043) гБѓ Ref еЖНеЄ∞: template
/// `name = @engine.Seq([head, Opt(Ref(name))])` гВТ registry гБЂзЩїйМ≤гБЧгАБspine гБЂгБѓ `min-1` mandatory + Ref
/// (min >= 1 гБЃгБњ вАФ `Ref` иЗ™дљУгБѓењЕгБЪ >= 1 head гВТжґИи≤їгБЩгВЛжІЛйА†гБІгАМ0 гБІгВВгВИгБДгАНгВТи°®зПЊгБІгБНгБ™гБДгАБ
/// `consume_head` гБЂгАМ0 гБ™гВЙ silent stopгАНгБЃеИЖе≤РгБМзД°гБДгБЯгВБ)гАВ`min:0` гБЃ UNBOUNDED гБѓдї£гВПгВКгБЂ
/// `@engine.Many(head)` гВТзЫіжО•з©НгВА (дЄЛи®Ши©≥зі∞)гАВbounded (max жЬЙйЩР) гБѓ Ref еЖНеЄ∞гБ™гБЧгБІ @engine.BoundedTail гБЂиРљгБ°гВЛ
/// (LOWERING ¬ІB.8гАБmin:0 гБѓ budget=max гБЃ @engine.BoundedTail гБМжЬАеИЭгБЛгВЙж≠£гБЧгБПжЙ±гБЖ)гАВdd и¶Бзі†гБѓ spine гБЂ
/// иЉЙгБЫгБ™гБДгАВ
///
/// MDR-002 ¬ІCPS и¶ПзіД: repeat гБѓгБУгБУгБІгВєгГСгВ§гГ≥ељҐ (positional гБЃ Ref / @engine.BoundedTail / @engine.ScopeNode /
/// **@engine.Many**) гБЂгБЃгБњж≠£и¶ПеМЦгБЧгАБ@engine.Or/@engine.Seq/@engine.Rooted еЖЕйГ®гБЄгБЃеЯЛгВБиЊЉгБњгБѓзФЯжИРгБЧгБ™гБД (еПЦгВКеИЖйБЄе•љгБЃе±АжЙАеМЦгВТйБњгБС
/// гВЛгБЯгВБ)гАВ`@engine.Many` гБѓ `Ref`/`@engine.BoundedTail` гБ®еѓЊзІ∞гБ™еПЦгВКеИЖйБЄе•љ (жЧҐеЃЪ greedy = йХЈгБДжЦєгБЛгВЙи©¶гБЩгАБ
/// `lazy:true` гБІеПНиїҐ = зЯ≠гБДжЦєгБЛгВЙи©¶гБЩгАБ`has_full_k` гБІ pruning) гВТ scope_consume еБігБЂжМБгБ§ spine ељҐ
/// (eval.mbt гБЃ `@engine.Many(inner, is_lazy) =>` гВҐгГЉгГ†гАБ"parity with Ref/@engine.BoundedTail еПЦгВКеИЖйБЄе•љ spec
/// DR-043")гАВиЉ™йГ≠гБѓ fixtures/path-search/ambiguous-receptacles.json гБМеЫЇеЃЪгБЩгВЛгАВ

///|
/// DR-043 repeat lowering for a single positional `head` node, shared by `Cell` (head =
/// `element_head(e)`) and `Or` (head = `@engine.Or(branch_node...)`, issue
/// 2026-07-09-positional-or-repeat-lowering-gap: Or used to push `@engine.Or(nodes)` directly and
/// silently ignore `elem_repeat(e)` entirely вАФ a structural-or head is JUST a head like any other
/// for repeat's purposes, DR-043 ¬ІгАМrepeat гБЃеѓЊи±°и¶Бзі†гБѓељҐгВТеХПгВПгБ™гБДгАНalready says this for `ref`
/// heads, it applies identically to an `@engine.Or` head). When `elem_repeat(e)` is `None` the bare `head`
/// is pushed unchanged вАФ the branches inside an `@engine.Or` head still each read one head via `@engine.Or`'s
/// existing multi-branch semantics (DR-038); `elem_repeat` only ever governs REPETITION count,
/// never branch structure.
fn lower_repeat_head(
  e : @engine.ElementDef,
  head : @engine.Node,
  registry : Map[String, @engine.Node],
  out : Array[@engine.Node],
) -> Unit {
  match elem_repeat(e) {
    None => out.push(head)
    Some(spec) =>
      match spec.max {
        None =>
          if spec.min == 0 {
            // UNBOUNDED min:0 (DR-043): a bare `Ref(e.name)` cannot express "0 is fine" (its
            // arm in scope_consume has no fallback for `consume_head` failing to progress), and
            // wrapping it in a plain `@engine.Or([Ref(name), @engine.Seq([])])` would lose the еПЦгВКеИЖйБЄе•љ (plain
            // `eval()`'s `@engine.Or` arm has no preference вАФ both branches survive whenever they BOTH
            // reach a full parse, producing @engine.Ambiguous instead of the greedy-left-longest single
            // reading DR-043 requires вАФ exactly this fixture's 3 divergences). `@engine.Many(head)` is
            // the existing spine form with the IDENTICAL preference algorithm already wired in
            // scope_consume, so no registry/self-ref is needed at all (each further rep re-enters
            // the SAME `@engine.Many` node at the same `pidx`, not a named template). `spec.is_lazy` rides
            // straight into `@engine.Many`'s 2nd field (issue 2026-07-08 min0-lazy-repeat-gap resolved:
            // @engine.BoundedTail's 3rd field is the same seat for the bounded sibling, DR-043 lazy is
            // declarative preference regardless of min/max shape).
            out.push(@engine.Many(head, spec.is_lazy))
          } else {
            // UNBOUNDED min>=1 (DR-043): `name#cons = @engine.Seq([head, Opt(Ref(name#cons))])` гБЃ porous
            // иЗ™еПВзЕІгАВ`#cons` гВµгГХгВ£гГГгВѓгВє (DR-046 ¬І4 гБЃиЗ™еЛХ id з©ЇйЦУгАБ`#` гБѓ user ns е§ЦгБЃжЧҐи£БеЃЪ) гБІ
            // mangle гБЩгВЛ вАФ DR-078 гБІ `definitions.templates` гБМгБУгБЃеРМгБШ `registry` гВТеЕ±жЬЙгБЩгВЛгВИгБЖгБЂ
            // гБ™гБ£гБЯгБЯгВБгАБгГЧгГђгГЉгГ≥ `e.name` гВ≠гГЉгБѓгАМrepeat и¶Бзі†гБ®еРМеРНгБЃгГ¶гГЉгВґ templateгАНгБІи°Эз™БгБЧгБЖгВЛ
            // (spec `fixtures/lowering/repeat/basic.json` гБЃ golden гВВеЕГгАЕгБУгБЃ mangled ељҐ
            // `"src#cons"` гВТжЬЯеЊЕгБЧгБ¶гБКгВКгАБ`canon_tmpl` гБЃзЈ©жѓФиЉГ (еЕИй†≠ `#` еМЇеИЗгВКгБІж≠£и¶ПеМЦ) гБМгБУгВМгБЊгБІ
            // еЃЯи£ЕеБігБЃгГЧгГђгГЉгГ≥еРНгБ®гБЃеЈЃгВТеРЄеПОгБЧгБ¶йЪ†гБЧгБ¶гБДгБЯгБ†гБС вАФ жЬђ mangle гБІ golden гБ®еЃЯдљУгБМдЄАиЗігБЩгВЛ)гАВ
            let cons = e.name + "#cons"
            registry.set(cons, @engine.Seq([head, opt_node(Ref(cons))]))
            if spec.is_lazy {
              // lazy marker (evaluator гБМ split йБЄе•љгВТеЉХгБПгБЯгВБгБЃ mangled key)
              registry.set("lazy:" + cons, @engine.Exact("lazy"))
            }
            let m = spec.min
            let mut k = 0
            while k < m - 1 {
              out.push(head) // mandatory unrolled heads (DR-043 min)
              k = k + 1
            }
            out.push(Ref(cons)) // >= 1 porous recursive tail
          }
        Some(mx) => {
          // BOUNDED (LOWERING ¬ІB.8): min mandatory heads + @engine.BoundedTail(head, max-min)
          let m = if spec.min < 0 { 0 } else { spec.min }
          let mut k = 0
          while k < m {
            out.push(head)
            k = k + 1
          }
          let budget = if mx - m < 0 { 0 } else { mx - m }
          out.push(@engine.BoundedTail(head, budget, spec.is_lazy))
        }
      }
  }
}

///|
fn lower_positional(
  def : @engine.Definition,
  registry : Map[String, @engine.Node],
) -> Array[@engine.Node] {
  let out : Array[@engine.Node] = []
  for e in def.positionals {
    if not_dd(e) {
      match e.body {
        Or(branches) => {
          // MDR-004 ¬І3 "Or (positional, еМњеРН)": spine гБЂ @engine.Or([branch_node...]) гВТзЫіжО•з©НгВАгАВи©ХдЊ°еЩ®гБЃ
          // жЧҐе≠Ш @engine.Or жДПеС≥иЂЦ (еЕ®жЮЭи©ХдЊ° + @engine.Held еЕ®дњЭжМБгАБDR-053 ¬І2 / еЃМеЕ®зµМиЈѓ 2 жЬђдї•дЄКгБІ ambiguous дњЭе≠ШгАБ
          // DR-038) гБМгБЭгБЃгБЊгБЊиЉ™йГ≠гВТжЇАгБЯгБЩгАВDR-043 repeat гБ®гБЃзµДеРИгБЫ (issue
          // 2026-07-09-positional-or-repeat-lowering-gap гБІж†єж≤ї): `@engine.Or(nodes)` гВТ head гБ®гБЧгБ¶
          // `lower_repeat_head` гБЂжЄ°гБЩ вАФ repeat гБЃгГђгГ≥гВЇгБЂгБѓгАМжІЛйА† or гБЃ 1 зЩЇзБЂгАНгВВдїЦгБЃ head гБ®
          // еРМгБШ 1 unit гБІгАБRef/@engine.Many/@engine.BoundedTail гБЃгБ©гВМгБЂгБ™гВЛгБЛгБѓ head гБЃељҐ (@engine.Or гБЛ string resident гБЛ) гБЂ
          // дЊЭе≠ШгБЧгБ™гБДгАВ
          let nodes : Array[@engine.Node] = []
          for br in branches {
            nodes.push(or_branch_node(br))
          }
          lower_repeat_head(e, @engine.Or(nodes), registry, out)
        }
        Group(items) => {
          // MDR-004 ¬І3 "Group + repeat": @engine.IndexedRepeat(label=name, head=@engine.Seq(inner cells), min,
          // budget) гБЂ lowerгАВbudget (issue
          // 2026-07-13-positional-group-trailing-missing-operand) = `max - min` (bounded гБЃ
          // гБ®гБН) / `None` (max:null гБЃ UNBOUNDEDгАБгБЊгБЯгБѓ repeat е±ЮжАІиЗ™дљУгБМзД°гБДе†іеРИ вАФ
          // гБ©гБ°гВЙгВВеЊУжЭ•гБ©гБКгВК greedy-max-forever)гАВдї•еЙНгБѓ `elem_repeat(e).max` гВТдЄЄгБФгБ®зД°и¶Ц
          // гБЧгБ¶гБКгВКгАБ`repeat:{min:1,max:1}` гБЃгВИгБЖгБ™ bounded named-group гБІгВВеЄЄгБЂ unbounded
          // гБ®гБЧгБ¶и©ХдЊ°гБХгВМгБ¶гГИгГЉгВѓгГ≥гВТ over-consume гБЧгБ¶гБДгБЯ (`fixtures/repeat-parse/group-
          // trailing-positional.json` гБМ pin гБЩгВЛ вАФ group гБЃзЫіеЊМгБЂеИ• positional гБМзґЪгБПељҐгБ†гБС
          // гБІй°ХеЬ®еМЦгБЩгВЛ)гАВ
          //
          // bounded-head еЙНжПР (issue 2026-07-08 greedy-once-and-idxrepeat-premises ¬І2, kawaz и£БеЃЪ
          // еЊЕгБ° вАФ installer и¶ПзіДгБ®гБЧгБ¶гБЃжШОжЦЗеМЦгВТйБЄжКЮгАБeval еБігБЄгБЃ backtrack ињљеК†гБѓи¶ЛйАБгВК): `idx_repeat_eval`
          // (eval.mbt) гБѓеЃ£и®АдЄК deterministic гБ™ greedy-max гБІгАБдЄЛжµБе§±жХЧжЩВгБЃеЊМйАА (regex backtracking,
          // DR-043 гБЃйАЪеЄЄ repeat гБМ `ref_choice` гБІжМБгБ§ж©ЯжІЛ) гВТжМБгБЯгБ™гБДгАВhead гБМ permissive (bare string
          // primitive з≠ЙгАБзД°еИґйЩРгБЂгБ©гВУгБ™гГИгГЉгВѓгГ≥гБІгВВжґИи≤їгБІгБНгВЛ) гБ†гБ®гАБbudget гБМ None (UNBOUNDED) гБЃ
          // гБ®гБНгБѓеЊМзґЪгБЃењЕй†И positional гБЃгБґгВУгБЊгБІ greedy-max гБЂй£ЯгВПгВМгБ¶ starve гБЧгБЖгВЛ (backtrack гБМ
          // зД°гБДгБЃгБІеЫЮеЊ©гБЧгБ™гБД) вАФ йАЪеЄЄ repeat гБЃ backtrack.json fixture гБМеЫЇеЃЪгБЩгВЛгАМзЄЃе∞ПеЖНеИЖеЙ≤гАНгБЃ
          // дњЭи®ЉгБѓ @engine.IndexedRepeat гБЂгБѓеПКгБ∞гБ™гБДгАВbudget гБМ Some (bounded) гБЃгБ®гБНгБѓ over-consume иЗ™дљУгБМ
          // иµЈгБНгБ™гБДгБЯгВБгБУгБЃ GAP гВТиЄПгБЊгБ™гБДгАВUNBOUNDED гБЃгБЊгБЊжЬЂе∞ЊгБЂењЕй†И positional гВТзґЪгБСгВЛи®≠и®ИгВТ
          // жЫЄгБПйЪЫгБѓ head гБЃеЕИй†≠гБЂжШОз§ЇзЪДгБ™ trigger (@engine.Exact з≠Й) гВТжМБгБЯгБЫгВЛгБУгБ®гАВ
          let head = if items.length() == 1 {
            element_head(items[0])
          } else {
            let nodes : Array[@engine.Node] = []
            for it in items {
              nodes.push(element_head(it))
            }
            @engine.Seq(nodes)
          }
          let (min, budget) = match elem_repeat(e) {
            Some(spec) =>
              (
                spec.min,
                match spec.max {
                  Some(mx) =>
                    Some(if mx - spec.min < 0 { 0 } else { mx - spec.min })
                  None => None
                },
              )
            None => (0, None)
          }
          out.push(@engine.IndexedRepeat(e.name, head, min, budget))
        }
        Cell =>
          match e.ref_target {
            // DR-078 ¬І1 result еЖЩеГП (issue 2026-07-09-ref-template-result-shape): a `ref`
            // element's own `name` must create a result scope (DESIGN ¬І2.3/¬І2.4) вАФ `element_head`
            // returns the bare `Ref(target)`, discarding `e.name` entirely, so without this the
            // referenced template's OWN leaf names (colorname/r/g/b) surface at the TOP level
            // instead of nested under `e.name`.
            Some(_) =>
              match elem_repeat(e) {
                // no repeat: single occurrence, degenerate row (DESIGN ¬І6.1 гБЃйАЖ вАФ repeat гБМ
                // гАМйЕНеИЧгБЂеМЕгВАгАНжУНдљЬгВТжЛЕгБЖгАБе§ЦгБЩгБ® row гБМгБЭгБЃгБЊгБЊеА§гБЂгБ™гВЛ) вАФ no "#row" marker
                // needed, `sub_under(binds, e.name)` already yields the row's flat leaves.
                None => out.push(@engine.Scoped(e.name, element_head(e)))
                Some(_) =>
                  lower_repeat_head(
                    e,
                    ref_row_head(e.name, element_head(e)),
                    registry,
                    out,
                  )
              }
            None =>
              // DR-088 ¬І2 (issue dr-088-positional-default-verification): a plain (no
              // repeat/optional) positional that declares a value source (default/env/
              // config_key/inherit) is structurally COMPLETE with 0 tokens too вАФ the declared
              // source is "a default_fn scheduled to resolve later" (DR-088 ¬І1), so the path
              // must not starve into `missing_operand` just because no token showed up here.
              // `opt_node` (`@engine.Or([head, @engine.Seq([])])`, already used by `elem_repeat`'s min:0 paths)
              // makes the ONE occurrence optional at the structural level WITHOUT touching
              // `elem_repeat`/`lower_repeat_head`'s array-producing repeat machinery вАФ the
              // entity stays a genuine SCALAR cell (no `accum`), and an unconsumed occurrence
              // leaves it uncommitted, so `resolve.mbt`'s existing default-seat ladder
              // (`resolve_ladder_below_cli`) fills it in exactly as it already does for options.
              // Declared-but-unresolved-at-runtime (e.g. env var absent) still falls through to
              // the scalar's OWN default_values / lower ladder rungs as usual вАФ this only fixes
              // the STRUCTURAL completeness gate, not the value resolution itself.
              if elem_repeat(e) is None && has_declared_value_source(e) {
                lower_repeat_head(e, opt_node(element_head(e)), registry, out)
              } else {
                lower_repeat_head(e, element_head(e), registry, out)
              }
          }
        // Enum (issue values-decode-support): `dec_positional` never produces this shape today
        // (positionals only decode structural "or"/"positionals" вАФ DESIGN ¬І5.3's value-enum
        // shorthand is option-only, `dec_positional`'s own comment). Wired anyway (not aborted) so
        // a future positional-values fixture works without another round-trip here вАФ same
        // `enum_value_node` consumption structure the option side (`inst_long`) uses.
        Enum(values) =>
          lower_repeat_head(
            e,
            enum_value_node(e.name, e.ty, values),
            registry,
            out,
          )
      }
    }
  }
  out
}

///|
/// (cloned) @engine.Definition tree гБЛгВЙ scope-builder tree гВТзµДгВАгАВpositional гБѓ 1 еЇ¶гБ†гБС lower (дї•еЊМгБѓжИРйХЈ
/// гБЧгБ™гБД вАФ global copy гБѓ greedy еБігБЂеЕ•гВЛ)гАВentities / greedy гБѓ fixpoint pass гБІеЯЛгВБгВЛгАВ
fn init_sb(
  def : @engine.Definition,
  templates : Map[String, @engine.Node],
  extensions : @engine.Registry,
) -> @engine.InstallBuilder {
  let positional = lower_positional(def, templates)
  let children : Array[@engine.InstallChild] = []
  for c in def.commands {
    children.push(
      @engine.InstallChild::new(c.name, init_sb(c.body, templates, extensions)),
    )
  }
  @engine.InstallBuilder::new(
    def,
    @engine.InstallOutput::new(positional),
    children,
    templates,
    extensions,
  )
}

///|
/// Core lowering (installer гБІгБѓгБ™гБД вАФ ж±ЇеЃЪзЪДгАБй†ЖеЇПзД°дЊЭе≠Ш): option/positional гБФгБ®гБЂ entity 1 еАЛгВТ
/// name еЙ≤ељУгБІ ensure (add-if-absent)гАВжѓО pass иµ∞гВЛ (global-copied option гВВ entity гВТеЊЧгВЛгБЯгВБ)гАВ
///
/// dd и¶Бзі†гБѓ entity гВТжМБгБЯгБ™гБД (LOWERING ¬ІB.4гАМеА§гБ™гБЧгАН/ DR-064 ¬І1)гАВlink_depth == 0 гБЃгБњ ensure
/// (global link COPY гБѓ declaring cell гБЄ link еРМжЬЯгБЩгВЛгБЯгВБе≠Р scope еБі entity гБѓдЄНи¶Б вАФ DR-070 ¬І1b gap 5)гАВ
fn is_help_group_declaration(e : @engine.ElementDef) -> Bool {
  e.name == "" && e.help_meta.help_group_name is Some(_)
}

///|
fn ensure_entities(sb : @engine.InstallBuilder, has_cf : Bool) -> Unit {
  for e in sb.definition().options {
    if not_dd(e) && !is_help_group_declaration(e) && e.link_depth == 0 {
      ensure_entity_body(sb.output(), e, has_cf, sb.extensions())
    }
  }
  for e in sb.definition().positionals {
    if not_dd(e) {
      ensure_entity_body(sb.output(), e, has_cf, sb.extensions())
    }
  }
}

///|
/// MDR-004 ¬І3b: register `e` (and any `@engine.ElementBody`-nested leaves) as top-level entities вАФ the
/// evaluator's `@engine.Or`/`@engine.Seq`/`@engine.IndexedRepeat` nodes don't know about entities at all, so this recursive
/// walk is the ONLY registration point. `Or`'s wrapper is a structural dispatcher with no
/// scalar/array value of its own (e.g. "color" never itself holds a value вАФ only its branch leaves
/// r/g/b/name do), so ONLY the branch leaves register. `Group`'s wrapper DOES need its own entity
/// (the array cell вАФ `elem_repeat` on it still drives the existing "flatten" accumulator path,
/// unaffected by `body`) in ADDITION to its inner leaves (e.g. transparent-seq's `k`, its own cell
/// with `entity=k` effects).
///
/// codex гГђгГУгГ•гГЉ Major 4 (issue 2026-07-15-audit-node-nodashstr-deprmark-variants еЙѓжђ°зЩЇи¶Л): the
/// `is_exact` guard used to live ONLY at `ensure_entities`' top-level positionals loop (removed
/// above) вАФ a `Or`/`Group` RECURSIVE call into this same function (branch leaves / group inner
/// items, both below) bypassed it entirely, so an `is_exact` leaf nested inside a structural or /
/// named group would fall into the `Cell`/`ref_target is None` arm and get a phantom
/// `@engine.Entity{name: spelling, ty: none_type()}` вАФ occupying the namespace and blocking a real same-named
/// entity's `ensure_entity` (add-if-absent already returns early once ANY entity with that name
/// exists). Guarding HERE (single entry point every recursive path funnels through) closes both the
/// top-level and the nested cases with one check, and any future `@engine.ElementBody` arm added to this match
/// inherits the guard automatically (installer.mbt's `@engine.ElementDef.is_exact` doc comment: "value_prim/
/// entity зµМиЈѓгВТдЄАеИЗйАЪгВЙгБ™гБД" is the invariant this enforces).
fn ensure_entity_body(
  build : @engine.InstallOutput,
  e : @engine.ElementDef,
  has_cf : Bool,
  extensions : @engine.Registry,
) -> Unit {
  if e.is_exact {
    return
  }
  match e.body {
    Cell =>
      // DR-078 ¬І1 result еЖЩеГП (issue 2026-07-09-ref-template-result-shape): a `ref` element is
      // ALSO a structural dispatcher with no scalar/array value of its own вАФ its "value" is a
      // name-scoped projection of the REFERENCED template's own leaves (installer.mbt's
      // `ref_row_head` / `lower_positional`/`inst_long`'s `@engine.Scoped` wrap), never a flat binding on
      // `e.name` itself. Registering an entity here is (a) dead for the value-source-ladder side
      // (nothing ever binds flatly to `e.name`, so `resolve_entity` always seats `Ok([])` and
      // contributes no binding) вАФ harmless, not "spurious".
      //
      // issue 2026-07-09-accum-fold-update-default-ops ињљи®Ш (2026-07-10, codex гГђгГУгГ•гГЉзФ±жЭ•гБЃ
      // ref-repeat-sibling-trigger.json mismatch): a repeat-bearing ref element (`elem_repeat(e)
      // is Some(_)`) DOES need the entity now, specifically for its `accum: Some("flatten")` вАФ
      // DR-051 ¬І2bгАМеПНеЊ©з≥їгБѓ 0 еЫЮзЩЇзБЂгБІгВВ `[]`гАНгБѓ ref+repeat гВїгГЂгБЂгВВеПКгБґгБМгАБ0 еЫЮзЩЇзБЂгБІгБѓ "#row"
      // (`ref_row_head`) гБМдЄАеИЗзФЯгБЊгВМгБЪгАБbuild_result гБЃ ROW-GROUP еИЖе≤Р (`has_direct_key(binds,
      // "#row")`) гБМзі†йАЪгВКгБЧгБ¶и™§гБ£гБ¶ `{}` (OBJECT зµМиЈѓ) гБЂиРљгБ°гБ¶гБДгБЯ (repro:
      // `{"ref":"color","repeat":{"min":0}}` + зЫіеЊМгБЂ sibling trigger гБІ 0 еПНеЊ©)гАВ`accum_cells`
      // (resolve.mbt) гБМ `sc.entities` гБ†гБСгВТи¶ЛгВЛеЙНжПРгВТдњЭгБ£гБЯгБЊгБЊгАБгБУгБЃ entity зЩїйМ≤гБІгБЭгБЃиµ∞жЯїгБЂ
      // ref+repeat гВїгГЂгВТдєЧгБЫгАБbuild_result гБЃ UNIFORM ARRAY ж≥®еЕ• (DR-044 ¬І1) гБІ `[]` гВТеЗЇгБЩгАВ
      // 1 еЫЮдї•дЄКзЩЇзБЂгБЧгБЯе†іеРИгБЃгАМdouble-rendersгАНжЗЄењµ ("#row" зµМзФ±гБЃи°МйЕНеИЧгБ® UNIFORM ARRAY ж≥®еЕ•гБЃ
      // дЇМйЗНжППзФї) гБѓгАБbuild_result еБігБЃгВђгГЉгГЙгВТ `named` гБ†гБСгБІгБ™гБП `segs` (nested scope дЄАи¶І) гВВ
      // и¶ЛгВЛгВИгБЖжЛ°еЉµгБЧгБ¶йЦЙгБШгБ¶гБДгВЛ (resolve.mbt гБЃгВ≥гГ°гГ≥гГИеПВзЕІ) вАФ ROW-GROUP гБМеЕИгБЂињФгБЧгБЯ path гБѓ
      // `segs` зµМзФ±гБІ obj гБЂиЉЙгВЛгБЃгБІгАБUNIFORM ARRAY еБігБѓ `segs` гГБгВІгГГгВѓгБІйЗНи§Зж≥®еЕ•гВТгВєгВ≠гГГгГЧгБЩгВЛгАВ
      // repeat зД°гБЧгБЃеНШзЩЇ ref (`elem_repeat(e) is None`) гБѓеЕГгБЃгВ≥гГ°гГ≥гГИгБЃжЗЄењµгБМгБЭгБЃгБЊгБЊжЬЙеКє
      // (accum гБМзЂЛгБЯгБ™гБДгБЃгБІж≠їгВУгБ† entity гВТеҐЧгВДгБЩгБ†гБС) гБ™гБЃгБІгАБеѓЊи±°гВТ repeat дїШгБНгБЂйЩРеЃЪгБЩгВЛ вАФ
      // гБЯгБ†гБЧ DR-084 ¬І1 (issue multiple-ref-accum-gap): `multiple` дїШгБНгБЃ repeat зД°гБЧ ref гБѓ
      // "dead" гБІгБѓгБ™гБДгАВгБУгБЃе†іеРИгБЃ accum гБѓ "append" (ensure_entity гБЃгГЗгГХгВ©гГЂгГИеЖЩеГП) гБЂгБ™гВКгАБ
      // `inst_long`/`lower_positional` еБі (гБУгБЃгГХгВ°гВ§гГЂгАБ`ref_row_head` еИЖе≤РгБЃжЭ°дїґ) гБМзЩЇзБЂгБФгБ®гБЂ
      // "#row" гВТжЙУгБ§гВИгБЖйА£еЛХгБЧгБ¶е§ЙгВПгВЛ вАФ дЄ°иАЕгБѓеРМгБШ `e.multiple` гВђгГЉгГЙгБІжПГгБИгВЛењЕи¶БгБМгБВгВЛгАВ
      if e.ref_target is None {
        ensure_entity(build, e, has_cf, extensions)
      } else if elem_repeat(e) is Some(_) || e.multiple {
        ensure_entity(build, e, has_cf, extensions)
      }
    Or(branches) =>
      for br in branches {
        for it in br.items {
          ensure_entity_body(build, it, has_cf, extensions)
        }
      }
    Group(items) =>
      // The wrapper (e.g. "xs") lowers to @engine.IndexedRepeat (MDR-004 ¬І3): its array is built entirely by
      // eval.mbt's array_marker/nest_index scope mechanism, never via the accum-entity ladder. If
      // registered here, ensure_entity would set accum:flatten (elem_repeat(e) is Some for a
      // repeat group), making accum_cells double-count "xs" and inject a spurious extra `[]`
      // alongside the nested-scope array resolve.mbt already builds from the @engine.IndexedRepeat bindings.
      // Only the inner leaf cells (value-source-ladder participants) need entities.
      for it in items {
        ensure_entity_body(build, it, has_cf, extensions)
      }
    // Enum (issue values-decode-support): a single named cell like Cell (the enum's exact-value
    // branches all bind the SAME `e.name`, unlike Or's per-branch leaves) вАФ never has a
    // `ref_target` (values/or on a `ref` element is not a decodable shape today), so this always
    // registers unconditionally, simpler than Cell's ref_target-gated arm above.
    Enum(_) => ensure_entity(build, e, has_cf, extensions)
  }
}

///|
fn ensure_entity(
  build : @engine.InstallOutput,
  e : @engine.ElementDef,
  has_cf : Bool,
  extensions : @engine.Registry,
) -> Unit {
  for ent in build.entities() {
    if ent.name == e.name {
      return
    }
  }
  // repeat / multiple / separator гБѓеА§ LIST вАФ еРНеЙНдїШгБН accumulator registry гБЂиРљгБ®гБЩ (DR-036)гАВ
  //   repeat (multiple зД°гБЧ) вЖТ "append" + flatten:true (DR-105 ¬І3: жЧІзЛђзЂЛ "flatten" accumulator гБЃ
  //     еїГж≠ҐгАБrepeat installer гБЃ cons unfold [T,[T,вА¶]] вЖТ T[] гБѓ append accumulator гБЃ flatten
  //     гГАгВ§гГ§гГЂгБІи°®зПЊгБЩгВЛ)
  //   multiple / separator вЖТ "append" (DR-034)гАБгБВгВЛгБДгБѓ `e.accumulator` гБМжШОз§ЇжМЗеЃЪгБЧгБ¶гБДгВМгБ∞
  //     гБЭгВМ (DR-080 ¬І1: `multiple: {accumulator: "merge", ...}` вАФ жЧІгАМmultiple гБ™гВЙеЄЄгБЂ appendгАН
  //     еЫЇеЃЪеЖЩеГПгВТгАБеЃ£и®АгБХгВМгБЯ accumulator еРНгБЃдЄАиИђеЖЩеГПгБЂзљЃгБНжПЫгБИгВЛ)гАВгБУгБЃжЩВзВєгБІ `e.accumulator` гБѓ
  //     definition-error gate (`collect_unknown_accumulator`) гВТйАЪйБОжЄИгБњгБ™гБЃгБІ "merge"/"kv_map" гБЃ
  //     гБДгБЪгВМгБЛгБЃгБњ (M-17)гАВ
  // дЄ°жЦєзЂЛгБ£гБЯе†іеРИгБѓ multiple гБЃ (accumulator жМЗеЃЪ or) append гБМеЛЭгБ§ (еА§ fold гБМжФѓйЕН)гАВ
  // DR-044 ¬І1 (kawaz и£БеЃЪ): repeat / multiple / separator гБѓ cardinality дЄНеХПгБІеЄЄгБЂйЕНеИЧ
  //   (`repeat:{min:0,max:1}` = optional з≥Ци°£гВВ [] / [x] вАФ scalar жШЗж†ЉгБѓ collector еБігБЃи≤ђеЛЩ)гАВ
  // is_multiple_decl (DR-084 ¬І2, DR-105 ж≥ҐеПК): `e.multiple` гВТгБЭгБЃгБЊгБЊ carry гБЩгВЛ вАФ resolve.mbt гБЃ
  // SEGS-loop еИ§еЃЪ (ref+repeat cons cell гБЃ discard-earlier-firings гБ® ref+repeat+multiple гБЃ
  // firing-preserving гВТеМЇеИ•гБЩгВЛ) гБМгАБaccum еРНгБМдЄ°иАЕгБ®гВВ "append" гБЂжПГгБ£гБЯеЊМгВВгБУгБЃиїЄгБІеИ§еИ•гБЩгВЛгАВ
  let (accum_name, flatten, is_multiple_decl) : (String?, Bool, Bool) = if e.multiple {
    let acc_name = match e.accumulator {
      Some(a) => a
      None => "append"
    }
    let flat = match e.flatten {
      Some(b) => b
      None => false
    }
    (Some(acc_name), flat, true)
  } else {
    match elem_repeat(e) {
      Some(_) => (Some("append"), true, false)
      None =>
        if e.separator is Some(_) {
          (Some("append"), false, false)
        } else {
          (None, false, false)
        }
    }
  }
  let accum : &@engine.AccumulatorExt? = match accum_name {
    Some(name) =>
      match extensions.lookup_accumulator(name) {
        Some(resident) => Some(resident)
        None =>
          abort("registered accumulator disappeared during lowering: " + name)
      }
    None => None
  }
  let collector : &@engine.CollectorExt? = if accum is Some(_) {
    match e.collector {
      Some(declaration) =>
        match declaration.args {
          None =>
            match extensions.lookup_collector(declaration.name) {
              Some(resident) => Some(resident)
              None =>
                abort(
                  "registered collector disappeared during lowering: " +
                  declaration.name,
                )
            }
          Some(args) =>
            if declaration.name == "from_entries" {
              match from_entries_spec_of(args) {
                Some(spec) => Some(from_entries_collector(spec))
                None =>
                  abort("validated from_entries collector args disappeared")
              }
            } else {
              abort(
                "configured collector disappeared during lowering: " +
                declaration.name,
              )
            }
        }
      None => None
    }
  } else {
    None
  }
  // еРМеЮЛ config seat (DR-050 ¬І3): config_file и¶Бзі†гБМе≠ШеЬ®гБЩгВМгБ∞еЕ® value cell гБЂ config seat гВТеЃ£и®А
  // (иЗ™иЇЂгБМ config_file гБЃи¶Бзі†гБѓеЊ™зТ∞з¶Бж≠ҐгБІйЩ§гБП)гАВconfig_key гБѓ path override; None = еРМеЮЛгАВ
  let config_seat = has_cf && !e.is_config_file
  // Preset defaults are resident-owned. tty remains a distinct resident on Entity so its
  // provider-backed default-seat resolver can run at ladder time; count supplies 0 before
  // its value cell converges to the ordinary number resident.
  let seat_ty = if e.is_tty {
    tty_type(e.tty_stream, cygwin=e.tty_cygwin)
  } else {
    e.ty
  }
  let default_values : Array[@engine.Value]? = match e.default_values {
    Some(vs) => Some(vs)
    None =>
      match seat_ty.default_seat_resolver(@engine.SeatCtx::new(None)) {
        Some(value) => Some([value])
        None => None
      }
  }
  let default_fn = match e.default_fn {
    Some(call) => Some(call)
    None =>
      match default_values {
        Some(values) if accum is None &&
          seat_ty.default_seat_observation_key() is None =>
          Some(@engine.Typed(@engine.FnCall::typed("set", values)))
        _ => None
      }
  }
  let ty2 = match seat_ty.name() {
    "count" => number_type()
    "completion_script" => string_type()
    _ => seat_ty
  }
  build
  .entities()
  .push({
    name: e.name,
    link: if seat_ty.name() == "completion_script" {
      Some("#completion_script")
    } else {
      None
    },
    ty: ty2,
    env_key: None,
    config_seat,
    config_key: e.config_key,
    is_config_file: e.is_config_file,
    is_inherit: false, // MDR-003: node.mbt еБі @engine.Entity.is_inherit
    accum,
    // DR-105 ¬І1/¬І3: flatten (append-only dial) and is_multiple_decl (DR-084 ¬І2 origin marker) вАФ
    // both already false-by-construction whenever `accum` is None (the tuple above only ever
    // produces a non-false pair alongside `Some(_)`), mirroring `collector`'s "dead attribute never
    // rides a scalar cell" posture without a redundant guard here.
    flatten,
    is_multiple_decl,
    // DR-036: collector only means anything alongside an accum cell; the registered resident
    // is resolved during lowering so runtime dispatch never branches on a collector name.
    collector,
    default_values,
    default_fn,
    separator: e.separator,
    piece_filters: e.piece_filters,
    value_filters: e.value_filters,
    // DR-102 ¬І1: final_filters (TвЖТT) only means anything for a scalar (non-accum) cell, accum_filters
    // (AccвЖТAcc) only for an accum cell вАФ same "drop the attribute that doesn't apply to this cell's
    // shape" posture `collector` above already uses. `collect_invalid_filter_attribute_mismatch`
    // (definition-error, kind=invalid-range) already rejects the OTHER combination at parse_definition
    // time, so in practice at most one side is ever non-empty here; this split is defense-in-depth.
    final_filters: if accum is Some(_) {
      []
    } else {
      e.final_filters
    },
    accum_filters: if accum is Some(_) {
      e.accum_filters
    } else {
      []
    },
    extension: entity_ext(hidden=e.hidden, completer=e.completer),
  })
}

///|
fn not_dd(e : @engine.ElementDef) -> Bool {
  !e.is_dd
}

// вФАвФА еРД installer вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА

///|
/// DR-091 ¬І3: `eq_split` bundles every eq-split entry it carries under ONE `prefix` (`node.mbt`'s
/// `eq_split(prefix~, entries~)` вАФ a single matcher instance, single prefix). Before this DR every
/// element shared the hardcoded `"--"`, so one `eq_split` per `@engine.Definition` was correct; now an
/// element MAY declare its own `long_prefix` (`if=`/`of=`'s `long_prefix: ""`), so `inst_long`
/// groups eq entries by their declaring element's `long_prefix` and emits one `eq_split` per
/// distinct value actually present вАФ `prefixes`/`groups` are parallel arrays (insertion order),
/// mirroring this file's existing dedup-by-linear-scan style (`resolve.mbt`'s `named`/`segs`
/// arrays) rather than a `Map` (whose iteration order this codebase doesn't otherwise rely on).
fn eq_group(
  prefixes : Array[String],
  groups : Array[Array[EqEntry]],
  prefix : String,
) -> Array[EqEntry] {
  let mut i = 0
  while i < prefixes.length() {
    if prefixes[i] == prefix {
      return groups[i]
    }
    i = i + 1
  }
  let g : Array[EqEntry] = []
  prefixes.push(prefix)
  groups.push(g)
  g
}

///|
/// codex гГђгГУгГ•гГЉ Major 2 (issue 2026-07-15-audit-node-nodashstr-deprmark-variants еЙѓжђ°зЩЇи¶Л) / DR-058
/// ¬І2: append a trailing deprecation resident to a main-entry satellite's node array when `e.deprecated`
/// вАФ shared by EVERY `inst_long` main-entry arm (Or / Enum / ref¬±repeat / Cell, all below) so a
/// deprecated element warns regardless of its value structure (DR-058 ¬І2's contract is еА§жІЛйА†йЭЮдЊЭе≠Ш;
/// the previous fix only wired the Cell arm, missing the other 4). Centralizing the append here (one
/// call site per arm, right before `@engine.Seq(...)`) means a FUTURE `e.body`/`ref_target` arm added to
/// `inst_long` inherits the warning automatically as long as it routes its satellite nodes through
/// this helper вАФ the same "single funnel, no per-arm opt-in to forget" shape `ensure_entity_body`'s
/// `is_exact` guard (Major 4 fix) uses.
fn with_depr(
  e : @engine.ElementDef,
  nodes : Array[@engine.Node],
) -> Array[@engine.Node] {
  if e.deprecated {
    nodes.push(deprecation_mark(e.name))
  }
  nodes
}

///|
/// long: `long` гВТ READгАБname гБВгБЯгВК greedy exact и°ЫжШЯ (space form) гБ®гАБvalue з≥їгБ™гВЙ eq-split matcher
/// гВТ add-if-absent гБІињљеК†гАВи°ЫжШЯгБѓ name гБІ entity гБЂ link (DR-042 ¬Іе±ХйЦЛгБЃж®ЩжЇЦгГСгВњгГЉгГ≥)гАВ
fn inst_long(
  def : @engine.Definition,
  build : @engine.InstallOutput,
  registry : Map[String, @engine.Node],
) -> Unit {
  let eq_prefixes : Array[String] = []
  let eq_groups : Array[Array[EqEntry]] = []
  for e in def.options {
    for l in long_of(e) {
      // DR-091 ¬І3: `e.long_prefix` replaces the old hardcoded `"--"` (жЧҐеЃЪеА§гБѓ `"--"` гБЭгБЃгВВгБЃгБ™гБЃгБІ
      // this element's own trigger is unchanged unless it explicitly overrides).
      let trigger = e.long_prefix + l
      match e.body {
        // MDR-004 ¬І3: Or option (variable-arity) вАФ greedy satellite
        // @engine.Seq([@engine.Exact(trigger), @engine.Or([branch_node...])]). `e.ty` is unused (a Or wrapper carries no
        // value of its own); each branch's own leaf name(s) flow through unchanged via
        // or_branch_node/element_head, so held-Error / binding attribution lands on the leaf with no
        // extra provenance wiring (¬І4).
        Or(branches) => {
          let branch_nodes : Array[@engine.Node] = []
          for br in branches {
            branch_nodes.push(or_branch_node(br))
          }
          add_greedy(
            build,
            maybe_root(
              e.link_depth,
              @engine.Seq(
                with_depr(e, [@engine.Exact(trigger), @engine.Or(branch_nodes)]),
              ),
            ),
          )
        }
        // Enum (issue values-decode-support, DESIGN ¬І5.3 / DR-028 ињљи®Ш): main entry гБЃеА§гВєгГ≠гГГгГИ
        // жґИи≤їжІЛйА†гБМ `enum_value_node` (exact еА§гБЃ or е±ХйЦЛ) гБЂгБ™гВЛ вАФ Cell гБЃ `value_prim` гБЂзЫЄељУгБЩгВЛ
        // еЈЃгБЧжЫњгБИгАВDR-086 ¬І1 гБЃ cut (еРМдЄА trigger гБЃ 0еЉХжХ∞ @engine.Set variant гБ®гБЃзЂґеРИиІ£ж±Ї) гБѓ lowering
        // жІЛйА† (гБУгБУгБІз©НгВА greedy и°ЫжШЯгБЃеАЛжХ∞гГїељҐ) гВТе§ЙгБИгБЪ eval.mbt еБігБІжЙ±гБЖ (lowering query fixture
        // гБЄгБЃељ±йЯњеЫЮйБњгАБteam-lead и£БеЃЪ 2026-07-10) вАФ гБУгБУгБІгБѓйАЪеЄЄгБЃ main entry гБ®еРМгБШељҐгБІеНШзЛђзЩїйМ≤
        // гБЩгВЛгБ†гБСгБІгВИгБДгАВ
        Enum(values) =>
          add_greedy(
            build,
            maybe_root(
              e.link_depth,
              @engine.Seq(
                with_depr(e, [
                  @engine.Exact(trigger),
                  enum_value_node(e.name, e.ty, values),
                ]),
              ),
            ),
          )
        _ =>
          match e.ref_target {
            // DR-078 ¬І1 option repeat (issue 2026-07-09-ref-template-result-shape, new
            // capability): mirrors `lower_positional`'s Cell/ref_target arm вАФ a `ref` element's
            // own `name` creates a result scope, and (when repeated) each rep's row groups under
            // a "#row" sentinel (`ref_row_head`, `resolve.mbt`'s ROW-GROUP branch).
            Some(_) =>
              match elem_repeat(e) {
                None =>
                  add_greedy(
                    build,
                    maybe_root(
                      e.link_depth,
                      @engine.Seq(
                        with_depr(e, [
                          @engine.Exact(trigger),
                          // DR-084 ¬І1 (issue multiple-ref-accum-gap): a `multiple` repeat-less ref
                          // element's row is the ACCUMULATOR's fold unit (one fire = one row) вАФ
                          // tag it with "#row" (`ref_row_head`, same sentinel repeat-bearing ref
                          // uses) so `resolve.mbt`'s ROW-GROUP branch splits each firing into its
                          // own row-group instead of merging every firing's leaves flat into one
                          // object (the pre-DR-084 bug: 2 fires of an or-branch ref would land BOTH
                          // branches' leaves under the same bare `@engine.Scoped(e.name, ...)`, e.g.
                          // `{colorname:"red", r:0, g:128, b:255}` instead of 2 separate rows). No
                          // `multiple` (the `ref-template-no-repeat-degenerate.json` baseline) keeps
                          // the bare `@engine.Scoped` wrap вАФ a single scalar row, never array-wrapped.
                          if e.multiple {
                            ref_row_head(e.name, element_head(e))
                          } else {
                            @engine.Scoped(e.name, element_head(e))
                          },
                        ]),
                      ),
                    ),
                  )
                Some(_) => {
                  // The repeat spine (mandatory heads + Ref/@engine.BoundedTail/@engine.Many tail) collapses to
                  // ONE node for `min <= 1` (no mandatory-head unrolling) вАФ the only shape any
                  // fixture exercises today (`last-wins-repeat-rows.json`'s `{"min":1}`). A
                  // `min > 1` option repeat would need `@engine.GreedyRepeat` to carry multiple
                  // `sc'.positional` slots (eval.mbt's `step_greedy_repeat`), not yet wired.
                  let spine : Array[@engine.Node] = []
                  lower_repeat_head(
                    e,
                    ref_row_head(e.name, element_head(e)),
                    registry,
                    spine,
                  )
                  let tail = if spine.length() == 1 {
                    spine[0]
                  } else {
                    @engine.Seq(spine)
                  }
                  add_greedy(
                    build,
                    maybe_root(
                      e.link_depth,
                      @engine.Seq(
                        with_depr(e, [
                          @engine.Exact(trigger),
                          // DR-034 last-wins-whole-cell (multiple зД°гБЧгБЃеЖНзЩЇзБЂгБѓгВїгГЂдЄЄгБФгБ®дЄКжЫЄгБН):
                          // "#fire" marks this firing's start so `resolve.mbt`'s ROW-GROUP branch
                          // can discard every EARLIER firing's rows wholesale rather than merging
                          // leaf-by-leaf (which would wrongly keep a superseded rep whose position
                          // the later, shorter firing never touched).
                          @engine.Scoped(
                            e.name,
                            @engine.Bind("#fire", @engine.Bool(false)),
                          ),
                          @engine.GreedyRepeat(tail),
                        ]),
                      ),
                    ),
                  )
                }
              }
            None =>
              // DR-076 ¬І1/¬І2/¬І4: every value-typed main entry (bool included, flag ALREADY
              // normalized to bool_type() by `normalize_option`, DR-076 ¬І2) is a NORMAL value satellite
              // вАФ `:set` always takes a value (space form here; eq form via eq_entries below). A
              // bare `--x` fire (the classic flag shape) needs the explicit `:set:true` variant
              // (decoded as a @engine.Set-op @engine.Variant with operand @engine.Bool(true), lowered by the "@engine.Variant
              // entries" loop below, which also carries the fail_action failure resident вАФ flag's
              // presence-only lowering has fully collapsed into that generic variant path; this
              // arm no longer special-cases flag_type()/bool_type() bare-true at all).
              //
              // DESIGN ¬І7.2 / DR-096 ¬І1: `long_eq_sep == @engine.Require` withholds THIS space-form main
              // entry вАФ the only entry point left is the eq-split form registered below (`eq_group`
              // push). Paired with `long_prefix: ""` (DR-096 ¬І3.3, node.mbt's `@engine.ElementDef.long_prefix`
              // doc comment), this is the mechanism an app can opt into to definitionally eliminate
              // the bare-operand collision: with no space-form trigger, `trigger` (== `l` when
              // `long_prefix` is `""`) never matches a bare token вАФ only `eq_split`, which fires
              // exclusively on tokens containing `=`, can reach this element. Neither `long_prefix`
              // nor `long_eq_sep` requires this pairing вАФ an unpaired empty prefix is legal and any
              // resulting collision surfaces as @engine.Ambiguous instead.
              if e.long_eq_sep != @engine.Require {
                // DR-058 ¬І2: a deprecated element's space-form main entry carries a `deprecation resident`
                // warning marker after its value slot (node.mbt's `deprecation resident` doc shape), mirroring
                // `inst_short`'s `depr: e.deprecated` on the SAME element (`e.deprecated` covers
                // both a directly-deprecated canonical entry and a deprecated alias entry-copy,
                // DR-057 ¬І3 `alias_entry` вАФ both fold into this ONE `@engine.ElementDef.deprecated` bool by
                // the time lowering runs, so no alias-specific branch is needed here). Routed
                // through `with_depr` (codex гГђгГУгГ•гГЉ Major 2) so this arm shares the SAME funnel
                // as Or/Enum/ref¬±repeat above.
                add_greedy(
                  build,
                  maybe_root(
                    e.link_depth,
                    @engine.Seq(
                      with_depr(e, [
                        @engine.Exact(trigger),
                        value_prim(
                          e.ty,
                          e.name,
                          e.int_round,
                          e.allow_base_prefix,
                          e.bool_config,
                          e.piece_filters,
                          separator=e.separator,
                          merge=e.accumulator == Some("merge"),
                          kv_map=e.accumulator == Some("kv_map"),
                        ),
                      ]),
                    ),
                  ),
                )
              }
          }
      }
      // eq-split value form (`--key=value`): every value-typed main entry gets this (bool included,
      // DR-076 ¬І1) вАФ a flag's default sugar carries NO main entry at all (`e.long` stays [], DR-076
      // ¬І2), so this loop never runs for a bare classic flag; an explicit `long:[":set"]` flag DOES
      // register its value-slot form here, coexisting with the bare `:set:true` variant (DR-076 ¬І2
      // "valueељҐ+и£ЄгБЃеРМе±Е"). DR-076 ¬І3: bool_type()'s variant-guard exclusion (eq-split withheld when the
      // element ALSO carries `--x`/`--no-x` variant spellings) is REPEALED вАФ bool's eq-split and
      // variant triggers coexist (fixtures/lowering/long/variant.json's ssl: `--ssl=false` fires
      // alongside `--ssl`/`--no-ssl`).
      // DR-075 ¬І2: int_type() гБЃ eq-split (`--v=2.5`) гБМ factory config int_round гВТеПНжШ†гБЩгВЛгВИгБЖгАБ
      // @engine.ElementDef.int_round гВТ EqEntry гБЂжМБгБ°иЊЉгВА (int_type() дї•е§ЦгБѓ entry еБігБІеПВзЕІгБХгВМгБ™гБД)гАВ
      // MDR-004 ¬І3: a Or element's eq-split registers only for a single-value-cell branch (using
      // that leaf's own name/ty/int_round/allow_base_prefix, never the wrapper's) вАФ a multi-cell
      // branch's `=` form is undefined (`--color=v` cannot supply 3 leaves).
      // DR-091 ¬І2: a `kv_map`-accumulator leaf does NOT register an eq-split entry (unlike merge,
      // which shares the same `sep_binds` pipeline as the space form) вАФ `run_eq_split` (builtins/matcher_residents.mbt)
      // builds its binding through `sep_binds`, which has no "the piece must contain `=`" gate (that
      // gate lives in the `kv resident` node, `value_prim`'s dedicated kv_map branch, which `EqEntry`
      // never routes through). Registering here would let `--define=NOEQUALSIGN` silently produce
      // `{NOEQUALSIGN: ""}` instead of DR-091 ¬І2's required Reject вАФ same deliberate-absence posture
      // as `Enum`'s "OUT OF SCOPE" comment below, not an oversight.
      //
      // DR-014гАМ--name=value гБЃи®±еПѓгАН/ DESIGN ¬І7.2 / DR-096 ¬І1: `e.long_eq_sep` (scope config,
      // decode-time baked вАФ always the WRAPPING option's resolved value, never a Or leaf's unbaked
      // default, same reasoning `eq_group(..., e.long_prefix)` already applies below) gates every
      // arm вАФ `@engine.Deny` withholds the eq-split entry entirely, leaving only the space form registered
      // above.
      match e.body {
        Or(branches) =>
          for br in branches {
            if br.items.length() == 1 {
              let leaf = br.items[0]
              if e.long_eq_sep != @engine.Deny &&
                leaf.accumulator != Some("kv_map") {
                eq_group(eq_prefixes, eq_groups, e.long_prefix).push(
                  eq_entry(
                    l,
                    leaf.name,
                    configured_type(
                      leaf.ty,
                      leaf.int_round,
                      leaf.bool_config,
                      allow_base_prefix=leaf.allow_base_prefix,
                    ),
                    leaf.piece_filters,
                    leaf.separator,
                    merge=leaf.accumulator == Some("merge"),
                    deprecated=leaf.deprecated,
                  ),
                )
              }
            }
          }
        Group(_) => () // positional-only shape (MDR-004 ¬І3 scope) вАФ no long spelling applies
        Cell =>
          // DR-076 ¬І2: no `e.ty.name() != "flag"` guard needed here anymore вАФ a classic flag never reaches
          // this loop body at all (its `e.long` is empty, `long_of(e)` yields no `l` to iterate), so
          // the guard was always vacuous for it; an explicit `long:[":set"]` flag (now bool_type()) SHOULD
          // register its eq-split form, which this unconditional push now does correctly (the guard
          // used to wrongly suppress it while `e.ty` still read flag_type() pre-normalize_option).
          if e.long_eq_sep != @engine.Deny && e.accumulator != Some("kv_map") {
            eq_group(eq_prefixes, eq_groups, e.long_prefix).push(
              eq_entry(
                l,
                e.name,
                configured_type(
                  e.ty,
                  e.int_round,
                  e.bool_config,
                  allow_base_prefix=e.allow_base_prefix,
                ),
                e.piece_filters,
                e.separator,
                merge=e.accumulator == Some("merge"),
                deprecated=e.deprecated,
              ),
            )
          }
        // Enum (issue values-decode-support): eq-split (`--color=always`) for an enum-constrained
        // cell is OUT OF SCOPE for this issue (no target fixture exercises `--key=value` against a
        // `values`/`or` value-enum element) вАФ the EqEntry type resident has no
        // enum-value set. Registering nothing avoids accepting an unvalidated value.
        Enum(_) => ()
      }
    }
  }
  // DR-091 ¬І3: emit one `eq_split` matcher PER DISTINCT `long_prefix` seen (was: a single
  // `eq_split(prefix="--", ...)` for the whole @engine.Definition вАФ `eq_group`'s doc comment).
  let mut gi = 0
  while gi < eq_prefixes.length() {
    if eq_groups[gi].length() > 0 {
      add_greedy(
        build,
        @engine.NativeMatch(eq_split(eq_prefixes[gi], eq_groups[gi])),
      )
    }
    gi = gi + 1
  }
  // @engine.Variant entries (DR-011 / DR-045): `{exact, link (by name), effect}` гБЂ loweringгАВ
  // `set` variant гБѓ @engine.Bind (SET degenerate); default/unset/empty гБѓ effect resident (0-token effect)гАВ
  // DR-076 ¬І2/¬І4: a flag's classic bare-fire trigger IS a @engine.Set variant now (`:set:true`, composed in
  // by dec_long) вАФ it rides through here, not through the old flag_type()-only branch above. A fail_action
  // element (DR-048, e.g. help) additionally emits a failure resident alongside its @engine.Set variant's @engine.Bind, so
  // this loop must carry the SAME fail_action attachment the collapsed flag_type() branch used to (a
  // fail_action flag firing here вАФ its ONLY main-entry shape post-DR-076 ¬І2 вАФ must still be able to
  // select as a failed-parse action).
  for e in def.options {
    for v in e.variants {
      // issue scope-config-object-gap codex жМЗжСШ Major 2: main entry (inst_long еЖТй†≠) гБ® eq-split
      // (eq_group) гБѓжЧҐгБЂ e.long_prefix гВТдљњгБЖ вАФ variant гБ†гБС "--" еЫЇеЃЪгБ†гБ®еРМдЄА option family гБЃ
      // зґігВКгБМ long_prefix йЭЮжЧҐеЃЪжЩВгБЂеИЖи£ВгБЩгВЛ (DR-091 ¬І3 гБЃдЄАи≤ЂжАІгВТ variant гБЂгВВеПКгБЉгБЩ)гАВжЧҐеЃЪ
      // "--" гБ™гБЃгБІжЧҐе≠ШжМЩеЛХ (main entry гБ®жПГгБ£гБЯ "--" зґігВК) гБѓдЄНе§ЙгАВ
      let trigger = e.long_prefix + v.trigger
      // DR-058 ¬І2: a deprecated element's variant satellite (@engine.Set's @engine.Bind OR a non-@engine.Set effect resident) also
      // carries a trailing `deprecation resident` вАФ every long entry point this element owns fires the SAME
      // warning, symmetric with `inst_short`'s per-char `depr: e.deprecated` (a short cluster char
      // has no variant/main-entry split, so ONE application point covers it; long's split into
      // main-entry (above) + variant (here) needs both covered for parity).
      let nodes : Array[@engine.Node] = match v.op {
        @engine.Set => {
          let operand = match v.operand {
            Some(val) => val
            None => @engine.Bool(true)
          }
          if e.fail_action {
            [
              @engine.Exact(trigger),
              @engine.Bind(e.name, operand),
              failure_mark(e.name),
            ]
          } else {
            [@engine.Exact(trigger), @engine.Bind(e.name, operand)]
          }
        }
        _ => [@engine.Exact(trigger), effect_mark(e.name, v.op)]
      }
      add_greedy(
        build,
        maybe_root(e.link_depth, @engine.Seq(with_depr(e, nodes))),
      )
    }
  }
}

///|
/// global link COPY (link_depth > 0) гВТ `@engine.Rooted(node, depth)` гБІеМЕгВА вАФ bindings гБМ declaring scope гБЃ
/// entity гБЂ landing гБЩгВЛгВИгБЖ escape гБЩгВЛ (DR-042 link-sync)гАВlink_depth == 0 гБѓиЗ™еЃ£и®АгБІ wrap гБЧгБ™гБДгАВ
fn maybe_root(link_depth : Int, node : @engine.Node) -> @engine.Node {
  if link_depth > 0 {
    @engine.Rooted(node, link_depth)
  } else {
    node
  }
}

///|
/// DESIGN ¬І7.2 / LOWERING ¬ІB.2: mirrors `eq_group` (long installer, DR-091 ¬І3) вАФ bundles every
/// short-cluster entry under ONE `(short_prefix, short_combine)` PAIR per `short_combine` matcher
/// instance. Keying on the pair (not `short_prefix` alone) matters because a `@engine.Definition`'s
/// `def.options` can mix elements from 2 sources with different defaults: elements decoded in THIS
/// scope (uniform `short_prefix`/`short_combine`, both baked from the SAME resolved `ScopeConfig`
/// by `dec_definition`) and elements COPIED in from elsewhere (`add_inheritable_copy`/`alias_entry`,
/// which hardcode the canonical defaults `"-"`/`true` regardless of the current scope's config,
/// mirroring `long_prefix`'s existing "--" hardcode at those same call sites). If 2 elements
/// disagreed on `short_combine` while sharing `short_prefix`, merging them into ONE matcher would
/// require inventing a tie-break policy (spec is silent) вАФ keying on the pair instead routes each
/// distinct combination to its own matcher, so no policy is ever needed.
fn short_group(
  prefixes : Array[String],
  combines : Array[Bool],
  groups : Array[Array[ShortEntry]],
  prefix : String,
  combine : Bool,
) -> Array[ShortEntry] {
  let mut i = 0
  while i < prefixes.length() {
    if prefixes[i] == prefix && combines[i] == combine {
      return groups[i]
    }
    i = i + 1
  }
  let g : Array[ShortEntry] = []
  prefixes.push(prefix)
  combines.push(combine)
  groups.push(g)
  g
}

///|
/// short: `short` гВТ READгАБcluster/value-attach matcher гВТ 1 жЬђ add-if-absentгАВPoC гБІгБѓ single-char
/// (`-v`, `-p 8080`) гВВ matcher гБЂйЫЖзіДгБЩгВЛгБЯгВБгАБshort гБѓзЛђзЂЛ exact и°ЫжШЯгВТзЩЇгБЧгБ™гБД (matcher-seat)гАВ
/// DESIGN ¬І7.2: `e.short_prefix` replaces the old hardcoded `"-"` вАФ one `short_combine` matcher PER
/// DISTINCT `(short_prefix, short_combine)` pair actually present (was: a single
/// `short_combine(prefix="-", ...)` for the whole `@engine.Definition`), same generalization DR-091 ¬І3
/// already applied to `inst_long`/`eq_split`. `e.short_combine` (issue scope-config-object-gap
/// иІ£йЗИA, team-lead и£БеЃЪ 2026-07-11) rides straight through to the matcher's `combine` param вАФ
/// `run_short`/`walk_short` (builtins/matcher_residents.mbt) are the sole consumers of the flag's actual meaning.
fn inst_short(def : @engine.Definition, build : @engine.InstallOutput) -> Unit {
  let sh_prefixes : Array[String] = []
  let sh_combines : Array[Bool] = []
  let sh_groups : Array[Array[ShortEntry]] = []
  for e in def.options {
    for c in e.short {
      // DR-058: deprecated alias entry-copy гБѓ cluster entry гБІгВВи≠¶еСКгБЩгВЛ
      // DR-075 ¬І2: short cluster / space-tail зµМиЈѓгБЃ int_type() (`-n1.5` / `-n 1.5`) гВВ factory config гВТеПНжШ†
      short_group(
        sh_prefixes,
        sh_combines,
        sh_groups,
        e.short_prefix,
        e.short_combine,
      ).push(
        short_entry(
          c,
          e.name,
          configured_short_type(
            e.ty,
            e.int_round,
            e.allow_base_prefix,
            e.bool_config,
          ),
          e.piece_filters,
          e.separator,
          deprecated=e.deprecated,
          merge=e.accumulator == Some("merge"),
          short_attached_value=e.short_attached_value,
          is_alias=e.is_alias,
        ),
      )
    }
  }
  let mut gi = 0
  while gi < sh_prefixes.length() {
    if sh_groups[gi].length() > 0 {
      add_greedy(
        build,
        @engine.NativeMatch(
          short_combine(sh_prefixes[gi], sh_groups[gi], combine=sh_combines[gi]),
        ),
      )
    }
    gi = gi + 1
  }
}

///|
/// env: `env` гВТ READгАБentity гБЃ env seat гБЂзЩїйМ≤ (invariant вС£)гАВladder й†ЖеЇПгБѓ engine жЙАжЬЙ (DR-031)гАБ
/// default_fn гВТ wrap гБЧгБ™гБДгАВеРМ seat еЖНеЃ£и®АгБѓ no-op (idempotent in-place set)гАВ
fn inst_env(def : @engine.Definition, build : @engine.InstallOutput) -> Unit {
  for e in def.options {
    if e.env.length() > 0 {
      seat_env(build, e.name, e.env[0])
    }
  }
  for e in def.positionals {
    if e.env.length() > 0 {
      seat_env(build, e.name, e.env[0])
    }
  }
}

///|
fn seat_env(build : @engine.InstallOutput, name : String, key : String) -> Unit {
  for ent in build.entities() {
    if ent.name == name {
      ent.env_key = Some(key)
    }
  }
}

///|
/// dd: `type:"dd"` гВТ READгАБgreedy exact и°ЫжШЯ (@engine.DdSatisfied) гВТ add-if-absent (DR-041 rev)гАВfire жЩВгБЂ spine
/// walk гБМгАМseveredгАНгГҐгГЉгГЙгБЂеИЗгВКжЫњгВПгВКдї•йЩН greedy off вАФ greedy internal consumption дЄАдљУеМЦгГЂгГЉгГЂгАВ
///
/// DR-064 ¬І2 йЕНзљЃдЄНеХПеЫЮеПО: dd гБѓ canonical гБЂгБѓ options[] гБ†гБМ positionals[] гБЂзљЃгБДгБ¶гВВеЫЮеПОгБЩгВЛ
/// (env / inherit гБ®еРМгБШгБПдЄ° face гВТ walk гБЩгВЛеѓЊзІ∞ељҐ)гАВadd-if-absent (add_greedy) гБМйЗНи§ЗеЃ£и®АгВТ collapseгАВ
fn inst_dd(def : @engine.Definition, build : @engine.InstallOutput) -> Unit {
  // DR-064 ¬І5: dd гБЃ name гБѓ trigger зґігВКгБЂеКєгБП (normalize_surface гБМжЧҐеЃЪ "--" гВТдЊЫзµ¶гАБжШОз§ЇгБѓдЄКжЫЄгБН)гАВ
  // DR-090 ¬І2: `dd_match` гБМ None гБЛгБ§ `dd_self_keep` гБМ false (дЄ°иїЄгБ®гВВжЧҐеЃЪ) гБЃи¶Бзі†гБ†гБСгАБжЧҐе≠Ш
  // `@engine.DdSatisfied` (exact/drop е∞ВзФ®гГОгГЉгГЙ) гВТгБЭгБЃгБЊгБЊдљњгБЖ вАФ еЃМеЕ®гБ™еЊМжЦєдЇТжПЫ (жЧҐе≠Ш wbtest гБЃ `@engine.DdSatisfied("--")`
  // жЙЛзµДгБњгБ®жІЛйА†дЄАиЗігБЧзґЪгБСгВЛ)гАВгБ©гБ°гВЙгБЛгБЃиїЄгБМжЧҐеЃЪгБЛгВЙе§ЦгВМгБЯгВЙдЄАиИђеМЦгГОгГЉгГЙ `@engine.DdMatchSatisfied` гВТз©НгВА
  // (`match` гБМ Some гБЃгБ®гБН name гБѓгГИгГ™гВђзґігВКгБЂдљњгВПгВМгБ™гБДгАБ¬І2 гБЃи¶ПеЃЪйАЪгВК `e.name` гБЃдї£гВПгВКгБЂ
  // `dd_match` гБЃ pattern гВТ spelling гБЂдљњгБЖ)гАВ
  fn dd_node(e : @engine.ElementDef) -> @engine.Node {
    if e.dd_match is None && !e.dd_self_keep {
      @engine.DdSatisfied(e.name)
    } else {
      match e.dd_match {
        Some(pattern) =>
          @engine.DdMatchSatisfied(pattern, true, e.dd_self_keep, e.name)
        None => @engine.DdMatchSatisfied(e.name, false, e.dd_self_keep, e.name)
      }
    }
  }

  for e in def.options {
    if e.is_dd {
      add_greedy(build, dd_node(e))
    }
  }
  for e in def.positionals {
    if e.is_dd {
      add_greedy(build, dd_node(e))
    }
  }
}

///|
/// add-if-absent (invariant вС†' йЭЮеЙКйЩ§): жІЛйА†з≠ЙдЊ°гБ™жЧҐе≠ШгБМгБВгВМгБ∞ињљеК†гБЧгБ™гБДгАВеЖНйБ©зФ®гВТ no-op гБЂгАБfixpoint
/// гВТеПОжЭЯгБХгБЫгВЛгАВ
fn add_greedy(build : @engine.InstallOutput, g : @engine.Node) -> Unit {
  for existing in build.greedy() {
    if existing == g {
      return
    }
  }
  build.greedy().push(g)
}

///|
/// inherit: `inherit` гВТ READгАБentity гБЂ inherit seat гВТеЃ£и®А (invariant вС£, DR-031 cli>env>inherit>default)гАВ
/// seat гБЃеЃЯ lookup гАМжЬАињСз•ЦеЕИгБЃеРМеРН entity еА§гАНгБѓ runtime (resolve_scope) гБІиІ£гБПгАВenv гБ®еѓЊзІ∞гБЃ seat еЃ£и®АеЮЛгАВ
fn inst_inherit(
  def : @engine.Definition,
  build : @engine.InstallOutput,
) -> Unit {
  for e in def.options {
    if e.is_inherit {
      seat_inherit(build, e.name)
    }
  }
  for e in def.positionals {
    if e.is_inherit {
      seat_inherit(build, e.name)
    }
  }
}

///|
fn seat_inherit(build : @engine.InstallOutput, name : String) -> Unit {
  for ent in build.entities() {
    if ent.name == name {
      ent.is_inherit = true // MDR-003
    }
  }
}

///|
/// global: `global` гВТ READгАБoption еЃ£и®АгВТе≠Ре≠Ђ command scope гБЃеЃ£и®Ае±§гБЂгВ≥гГФгГЉ (invariant вС°)гАВ
/// long/short гБѓжђ° pass дї•йЩНгБІе≠РгБІе±ХйЦЛгБЩгВЛгАВshadowing (DR-032/033, жЬАе∞П scope): е≠РгБМеРМгГИгГ™гВђгВТжЧҐгБЂ
/// еЃ£и®АгБЧгБ¶гБДгВМгБ∞ copy гБЧгБ™гБД (иЗ™еЙНгБМеЛЭгБ§)гАВcopy гБѓ `is_global` гВТдњЭжМБгБЧгАБfixpoint гБІжЫігБЂдЄЛдљНгБЄеЖНдЉЭжТ≠гАВ
fn inst_global(sb : @engine.InstallBuilder) -> Unit {
  for opt in sb.definition().options {
    if opt.is_global {
      for child in sb.children() {
        copy_global_into(child.body(), opt)
      }
    }
  }
}

///|
fn copy_global_into(
  child : @engine.InstallBuilder,
  opt : @engine.ElementDef,
) -> Unit {
  for existing in child.definition().options {
    if triggers_overlap(existing, opt) {
      return // shadow гБЊгБЯгБѓжЧҐгБЂ copy жЄИ (idempotent, гГИгГ™гВђеЯЇжЇЦ)
    }
    // DR-057 alias дљµзФ®гГСгВњгГЉгГ≥ (canonical еБігБѓ global гБ†гБМгГИгГ™гВђгВТжМБгБЯгБ™гБД = long/short/variants
    // еЕ®гБ¶з©ЇгБІгАБalias еБігБ†гБСгБМеЃЯйЪЫгБЃгГИгГ™гВђгВТеИ•и¶Бзі†гБ®гБЧгБ¶жМБгБ§) гБІзЩЇи¶Л: `triggers_overlap` гБѓдЄ°иАЕгБ®гВВ
    // гГИгГ™гВђйЫЖеРИгБМз©ЇгБ†гБ®еЄЄгБЂ false гВТињФгБЩгБЯгВБгАБдЄКгБЃгГБгВІгГГгВѓгБ†гБСгБІгБѓгАМжЧҐгБЂгВ≥гГФгГЉжЄИгБњгБЃ trigger-less
    // canonicalгАНгВТж§ЬеЗЇгБІгБНгБЪгАБfixpoint гБЃгБЯгБ≥гБЂеРМгБШи¶Бзі†гВТеЖНгВ≥гГФгГЉгБЧзґЪгБСгБ¶еПОжЭЯгБЧгБ™гБД
    // (installer chain did not converge)гАВеРМеРН + link_depth>0 (= гВ≥гГФгГЉзФ±жЭ•) гБЃжЧҐе≠Ши¶Бзі†гБМгБВгВМгБ∞гАБ
    // idempotent гБ®гБњгБ™гБЩ вАФ гБЯгБ†гБЧеИ§еЃЪгБѓгГИгГ™гВђйЫЖеРИгВВдЄАиЗігБЩгВЛе†іеРИгБЂйЩРгВЛ (codex жМЗжСШгАБеЃЯж©ЯзҐЇи™НжЄИгБњ
    // regression: еРМеРНгБ†гБМ**еИ•гГИгГ™гВђ**гБЃ 2 гБ§гБЃ global гБМз•ЦеЕИгГБгВІгГЉгГ≥гБЃзХ∞гБ™гВЛжЃµгБІгБЭгВМгБЮгВМзЛђзЂЛгБЂеЃ£и®А
    // гБХгВМгБ¶гБДгВЛе†іеРИгАБ`name` гБ†гБСгБІеИ§еЃЪгБЩгВЛгБ®еЕИгБЂгВ≥гГФгГЉгБХгВМгБЯжЦєгБМеЊМзґЪгБЃеИ•гГИгГ™гВђ copy гВТи™§гБ£гБ¶
    // жКСж≠ҐгБЧгАБе≠ЂгВєгВ≥гГЉгГЧгБЄдЄАжЦєгБЃгГИгГ™гВђгБМдЉЭжТ≠гБЧгБ™гБПгБ™гВЛ вАФ conformance гБЃ parse() зµМзФ±гГЖгВєгГИгБІгБѓ
    // DR-041 ¬І4 жЧ©йЦЙгБШ+porous гБМи¶≥жЄђзµРжЮЬгВТеБґзДґдњЭе≠ШгБЧгБ¶гБЧгБЊгБДж§ЬеЗЇгБІгБНгБ™гБЛгБ£гБЯгБЯгВБгАБ`materialize` еЊМ
    // гБЃ @engine.Scope жІЛйА† (@engine.Rooted и°ЫжШЯгБЃжЬђжХ∞) гВТзЫіжО•ж§ЬжЯїгБЩгВЛ wbtest гБІзҐЇи™НгБЧгБЯ)гАВгГИгГ™гВђйЫЖеРИгБМдЄ°жЦєгБ®гВВ
    // з©ЇйЫЖеРИгБЃе†іеРИгБѓгАМйЫЖеРИдЄАиЗігАНгВВиЗ™жШОгБЂжИРзЂЛгБЩгВЛгБЃгБІгАБеЕГгБЃ trigger-less canonical гГРгВ∞гБЃдњЃж≠£гБѓ
    // гБУгБЃгБЊгБЊзґ≠жМБгБХгВМгВЛгАВ
    if existing.name == opt.name &&
      existing.link_depth > 0 &&
      trigger_sets_equal(existing, opt) {
      return
    }
  }
  // copy гБѓ link и°ЫжШЯ (DR-042): declaring scope гБЃ entity гВТ bind (е≠РгБѓиЗ™ cell гВТжМБгБЯгБ™гБД)гАВ
  // link_depth = declaring scope гБЛгВЙгБЃжЃµжХ∞ (+1 per re-propagation)гАВlong/short гБМ @engine.Rooted(node, depth)
  // гБІ wrap гБЩгВЛгАВ
  //
  // INVARIANT (install-time count вЖФ eval-time decrement, зПЊеИґзіД): гБУгБЃ +1 гБѓ SCOPE (name/command) copy
  // level гБЃгБњжХ∞гБИгВЛ (copy_global_into 1 жЃµгБЂгБ§гБН 1)гАВeval еБігБЃ @engine.Rooted `link` counter гБѓ 2 з®ЃгБЃ nesting
  // (nest = scope жЃµ / nest_index = rep #k жЃµ) гБІжЄЫзЃЧгБХгВМгВЛгАВгБЧгБЯгБМгБ£гБ¶гАМlink_depth == и°ЫжШЯгБ® declaring
  // scope гБЃйЦУгБЃ eval nesting жЃµжХ∞гАНгБЃдЄНе§ЙжЭ°дїґгБѓгАМ@engine.Rooted и°ЫжШЯгБМ @engine.IndexedRepeat гБЃдЄЛгБЂзљЃгБЛгВМгБ™гБДгАНжЭ°дїґдЄЛгБІгБЃгБњ
  // жИРзЂЛгБЩгВЛ вАФ зПЊи°М lowering гБѓ @engine.Rooted гВТ scope spine гБІ wrap гБЧгАБrepeat head еЖЕгБЂгБѓеЕ•гВМгБ™гБДгБЃгБІжЇАгБЯгБЩгАВ
  // е∞ЖжЭ• nested-group гБМ scope/global гВТ repeat зЊ§гБЂи®±еЃєгБЩгВЛгБ™гВЙгАБгБУгБЃ +1 гБЂ rep-nesting depth гВВеК†зЃЧгБЩгВЛгАВ
  let copy = clone_elem(opt)
  child.definition().options.push({
    name: copy.name,
    ty: copy.ty,
    long: copy.long,
    variants: copy.variants,
    short: copy.short,
    env: copy.env,
    help_meta: copy.help_meta,
    is_tty: copy.is_tty,
    tty_stream: copy.tty_stream,
    tty_cygwin: copy.tty_cygwin,
    is_dd: copy.is_dd,
    is_exact: copy.is_exact,
    dd_match: copy.dd_match,
    dd_self_keep: copy.dd_self_keep,
    is_global: copy.is_global,
    is_inherit: copy.is_inherit,
    is_inheritable: copy.is_inheritable,
    link_depth: copy.link_depth + 1,
    ref_target: copy.ref_target,
    repeat: copy.repeat,
    optional: copy.optional,
    multiple: copy.multiple,
    accumulator: copy.accumulator,
    flatten: copy.flatten,
    separator: copy.separator,
    collector: copy.collector,
    fail_action: copy.fail_action,
    is_config_file: copy.is_config_file,
    config_key: copy.config_key,
    export_key: copy.export_key,
    requires: copy.requires,
    conflicts_with: copy.conflicts_with,
    exclusive_group: copy.exclusive_group,
    required_group: copy.required_group,
    required: copy.required,
    value_requires: copy.value_requires,
    deprecated: copy.deprecated,
    is_alias: copy.is_alias,
    hidden: copy.hidden,
    completer: copy.completer,
    default_values: copy.default_values,
    default_fn: copy.default_fn,
    default_declared: copy.default_declared,
    int_round: copy.int_round,
    allow_base_prefix: copy.allow_base_prefix,
    bool_config: copy.bool_config,
    piece_filters: copy.piece_filters,
    value_filters: copy.value_filters,
    final_filters: copy.final_filters,
    accum_filters: copy.accum_filters,
    long_prefix: copy.long_prefix,
    short_prefix: copy.short_prefix,
    env_prefix: copy.env_prefix,
    auto_env: copy.auto_env,
    long_eq_sep: copy.long_eq_sep,
    short_combine: copy.short_combine,
    short_attached_value: copy.short_attached_value,
    body: copy.body,
  })
}

///|
/// An element's every long CLI trigger spelling (kebab, sans `--` prefix) вАФ `long_of` (the resolved
/// `:set` main entry, post `resolve_long`) AND `variants` (each colon-DSL variant's own trigger,
/// DR-011/076) combined. The two arrays are just WHERE a spelling landed post-`resolve_long`
/// (main-entry sentinel vs. colon-DSL variant); the actual `--xxx` wire spelling they produce is the
/// same kind of string either way, so any trigger-identity comparison (`triggers_overlap`) must look
/// at both together вАФ otherwise the SAME spelling can hide in `long` on one element and `variants` on
/// the other (e.g. a flag's `:set:true` composed bare-fire trigger lands in `variants`, DR-076 ¬І2,
/// while a plain `:set` main entry lands in `long`) and a real collision goes undetected.
fn all_long_triggers(e : @engine.ElementDef) -> Array[String] {
  let out : Array[String] = []
  for l in long_of(e) {
    out.push(l)
  }
  for v in e.variants {
    out.push(v.trigger)
  }
  out
}

///|
/// 2 и¶Бзі†гБЃгГИгГ™гВђйЫЖеРИгБМеЃМеЕ®дЄАиЗігБЩгВЛгБЛ (й†ЖеЇПзД°и¶ЦгАБ`all_long_triggers` гБЃйЫЖеРИгБ®гБЧгБ¶жѓФиЉГ)гАВ
/// `copy_global_into` гБЃ idempotent еИ§еЃЪ (еРМеРН + гВ≥гГФгГЉзФ±жЭ• + гГИгГ™гВђйЫЖеРИдЄАиЗі) е∞ВзФ® вАФ гГИгГ™гВђйЫЖеРИгБМ
/// дЄ°жЦєгБ®гВВз©ЇгБ™гВЙиЗ™жШОгБЂдЄАиЗігБЩгВЛ (trigger-less canonical гБЃ idempotent еИ§еЃЪгВТдњЭгБ§)гАВ
fn trigger_sets_equal(a : @engine.ElementDef, b : @engine.ElementDef) -> Bool {
  let ta = all_long_triggers(a)
  let tb = all_long_triggers(b)
  if ta.length() != tb.length() {
    return false
  }
  for t in ta {
    if !str_in(tb, t) {
      return false
    }
  }
  true
}

///|
/// гГИгГ™гВђи°Эз™Б: 2 option гБМ long / short / long variant гБДгБЪгВМгБЛгВТеЕ±жЬЙгБЩгВМгБ∞и°Эз™Б (shadow гБѓгГИгГ™гВђеЯЇжЇЦ =
/// еРМеРНгГИгГ™гВђ)гАВlong гБЃ main entry гБ® variant гБѓж†ЉзіНе†іжЙАгБМйБХгБЖгБ†гБСгБІеРМгБШ trigger и™ЮељЩ (`all_long_triggers`
/// еПВзЕІ) гБ™гБЃгБІгАБжѓФиЉГгБѓдЄ°иАЕгВТеРИгВПгБЫгБЯйЫЖеРИеРМе£ЂгБІи°МгБЖгАВ
fn triggers_overlap(a : @engine.ElementDef, b : @engine.ElementDef) -> Bool {
  for ta in all_long_triggers(a) {
    for tb in all_long_triggers(b) {
      if ta == tb {
        return true
      }
    }
  }
  for ca in a.short {
    for cb in b.short {
      if ca == cb {
        return true
      }
    }
  }
  false
}

// вФАвФА driver + completeness вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА

///|
/// inheritable installer (DR-059): global гБЃ REVERSE жЦєеРСгАВе≠Ре≠ЂгБЃ inheritable и¶Бзі†гВТеЕ®з•ЦеЕИ scope гБЂ
/// `<еЃЪзЊ©гВєгВ≥гГЉгГЧеРН>-<name>` зґігВКгБІгВ≥гГФгГЉ (¬І1)гАВз•ЦеЕИгБЃ `--socket-ttl` гБМз•ЦеЕИ `ttl` cell гБЂ bindгАВ
/// еЕ® `ttl` cell (еЃЪзЊ© + з•ЦеЕИгВ≥гГФгГЉ) гБЂ inherit seat гБМзЂЛгБ§гБЃгБІгАБдїїжДПе±§гБЃеА§гБМе≠Ре≠ЂгБЃ default гБ®гБЧгБ¶жµБгВМдЄЛгВЛ
/// (¬І3 еА§жДПеС≥иЂЦ вАФ inherit seat гБЃеѓЊ DR-031)гАВз•ЦеЕИгБМеРМгГИгГ™гВђгВТиЗ™еЃ£и®АгБ™гВЙ shadow гБІ copy гБЧгБ™гБД (global еѓЊзІ∞)гАВ
fn inst_inheritable(sb : @engine.InstallBuilder) -> Unit {
  // (1) е≠Ре≠ЂгБЃ inheritable вЖТ THIS (з•ЦеЕИ) scope гБЃеЃ£и®Ае±§гБЂ prefixed write-entry гВТињљеК†
  let entries : Array[(String, @engine.ElementDef)] = []
  gather_inheritable(sb.children(), entries)
  for de in entries {
    let defining_name = de.0
    let e = de.1
    let trigger = defining_name + "-" + e.name // еЕ®з•ЦеЕИеРМзґігВК (¬І1)
    add_inheritable_copy(sb, e, trigger)
  }
  // (2) subtree гБЃ inheritable еѓЊи±°еРН (иЗ™еЃ£и®А + з•ЦеЕИгВ≥гГФгГЉ) еЕ®гБ¶гБЂ inherit seat гВТжЙУгБ§ (¬І3)
  let names : Array[String] = []
  for e in sb.definition().options {
    if e.is_inheritable && !str_in(names, e.name) {
      names.push(e.name)
    }
  }
  for de in entries {
    if !str_in(names, de.1.name) {
      names.push(de.1.name)
    }
  }
  for name in names {
    seat_inherit(sb.output(), name)
  }
}

///|
/// е≠Ре≠Ђ scope гБЃ inheritable и¶Бзі†гВТеЕ®гБ¶еЫЮеПО (еЃЪзЊ©гВєгВ≥гГЉгГЧеРНгБІ tag вАФ ¬І1 гБЃ prefix)гАВеЕ® subtree гВТеЖНеЄ∞гАВ
fn gather_inheritable(
  children : Array[@engine.InstallChild],
  out : Array[(String, @engine.ElementDef)],
) -> Unit {
  for ch in children {
    for e in ch.body().definition().options {
      if e.is_inheritable {
        out.push((ch.name(), e))
      }
    }
    gather_inheritable(ch.body().children(), out)
  }
}

///|
/// з•ЦеЕИ scope гБЃеЃ£и®Ае±§гБЂ prefixed write-entry гВТињљеК† (add-if-absent, shadow-aware)гАВз•ЦеЕИгБМеРМгГИгГ™гВђгВТ
/// жЧҐгБЂеЃ£и®А (¬І3 global еѓЊзІ∞ shadow) гБ™гВЙ copy гБЧгБ™гБДгАВDR-076 еЊМгБѓи£ЄзЩЇзБЂгГИгГ™гВђгБМ `variants` еБігБЂеЕ•гВЛ
/// (дЊЛ: alias `[":set:true"]` зФ±жЭ•) гБЯгВБгАБ`long_of` (main long гБЃгБњ) гБІгБѓгБ™гБП `all_long_triggers`
/// (long + variants ж®™жЦ≠) гБІеИ§еЃЪгБЩгВЛењЕи¶БгБМгБВгВЛ вАФ codex жМЗжСШгАБеЃЯж©ЯзҐЇи™НжЄИгБњ regression: alias гБМ
/// variants еБігБІжПРдЊЫгБЩгВЛгГИгГ™гВђгВТ `long_of` гБ†гБСгБІгБѓи¶ЛиРљгБ®гБЧгАБеРМгБШзґігВКгБЃ inheritable гВ≥гГФгГЉгВТйЗНи§З
/// ињљеК†гБЧгБ¶гБЧгБЊгБЖ (materialize еЊМгБЃ @engine.Scope гБЂеРМдЄАгГИгГ™гВђгБЃ greedy и°ЫжШЯгБМ 2 жЬђзЂЛгБ§)гАВ
fn add_inheritable_copy(
  sb : @engine.InstallBuilder,
  e : @engine.ElementDef,
  trigger : String,
) -> Unit {
  for existing in sb.definition().options {
    if str_in(all_long_triggers(existing), trigger) {
      return // иЗ™еЙНеД™еЕИ (shadow) / жЧҐ copy (idempotent)
    }
  }
  sb.definition().options.push({
      name: e.name, // з•ЦеЕИ write-target cell гБѓи¶Бзі†еРНеЕ±жЬЙ (inherit-by-name)
      ty: e.ty,
      long: List([trigger]), // prefixed inheritable trigger (post-normalize зЫЄељУгБЃзҐЇеЃЪељҐгАБresolve_long гВТзµМзФ±гБЧгБ™гБД)
      variants: [],
      short: [],
      env: [],
      help_meta: e.help_meta,
      is_tty: false, // write-target copy гБѓ tty preset гВТжМБгБЯгБ™гБД (env_prefix гБ®еРМгБШгАМcanonical default зЫЄељУгАН)
      tty_stream: None,
      tty_cygwin: true,
      is_dd: false,
      is_exact: false,
      dd_match: None,
      dd_self_keep: false,
      is_global: false,
      is_inherit: false, // inherit seat гБѓ inst_inheritable step(2) гБМзЂЛгБ¶гВЛ
      is_inheritable: false, // copy иЗ™дљУгБѓ plain entry (еЖНдЉЭжТ≠гБЧгБ™гБД)
      link_depth: 0,
      ref_target: None,
      repeat: None,
      optional: false,
      multiple: false,
      accumulator: None,
      flatten: None,
      separator: None,
      collector: None,
      fail_action: false,
      is_config_file: false,
      config_key: None,
      export_key: @engine.ExportKey::unset(),
      requires: [],
      conflicts_with: [],
      exclusive_group: [],
      required_group: [],
      required: false, // write-target copy гБѓ required еИґзіДгВТжМБгБЯгБ™гБД (requires/exclusive_group гБ®еРМгБШзРЖзФ±)
      value_requires: [],
      deprecated: false,
      is_alias: false, // write-target copy гБѓ alias/hidden еЃ£и®АзµМиЈѓгВТжМБгБЯгБ™гБД (canonical default зЫЄељУ)
      hidden: false,
      completer: None, // write-target copy гБѓ completer еЃ£и®АзµМиЈѓгВТжМБгБЯгБ™гБД (hidden гБ®еРМгБШзРЖзФ±)
      default_values: None,
      default_fn: None,
      default_declared: false, // write-target гБЂ default гВТзљЃгБЛгБ™гБД (¬І3): еЃЯжЫЄгБНиЊЉгБњгБЃгБњгБМдЉЭжТ≠гБЩгВЛ
      int_round: @engine.Error,
      allow_base_prefix: false, // canonical default (DR-075 ¬І2): write-target гБѓ int_round гВТжМБгБЯгБ™гБД
      // canonical default (DR-074 ¬І2): write-target гБѓ base prefix opt-in гВТжМБгБЯгБ™гБД
      bool_config: bool_config_canonical(), // canonical default (DR-074 ¬І4): write-target гБѓ bool_parser opt-in гВТжМБгБЯгБ™гБД
      piece_filters: [], // write-target гБѓ filter chain гВТжМБгБЯгБ™гБД (жЇР e гБЃ value_filters гБѓ source еБігБІжЧҐгБЂйБ©зФ®жЄИгБњ)
      value_filters: [],
      final_filters: [],
      accum_filters: [],
      long_prefix: "--", // йАЪеЄЄгБЃ long зґігВК (kebab, жЬ™ prefix) вАФ inst_long гБМжЧҐеЃЪ "--" гВТеЙНзљЃгБЩгВЛ
      short_prefix: "-", // write-target copy гБѓ short spelling гВТжМБгБЯгБ™гБД (canonical default зЫЄељУ)
      env_prefix: "", // write-target copy гБѓ env еЄ≠гВТжМБгБЯгБ™гБД (canonical default зЫЄељУ)
      auto_env: false,
      long_eq_sep: @engine.Allow,
      short_combine: true,
      short_attached_value: @engine.Allow,
      body: Cell,
    }, // canonical default (¬І3 гБ®еРМгБШгАМйАЪеЄЄжМЩеЛХгАН)
    // canonical default
    // canonical default
  )
}

///|
/// `node` гБМеА§гВТжЭЯзЄЫгБЩгВЛеЕ®гБ¶гБЃ leaf name гВТеЖНеЄ∞зЪДгБЂйЫЖгВБгВЛ (DR-093 гБЃ or/ref и¶™еЕЕиґ≥еИ§еЃЪгБЃеЃЯдљУиІ£ж±Ї вАФ
/// `required_candidates` гБЃ `ref_target` еИЖе≤РгБМдљњгБЖ)гАВopen value resident гБ® `@engine.RequiredArgument` гБЃ name гБМ
/// еѓЊи±°гАВ`@engine.Or`/`@engine.Seq`/`@engine.Many`/`@engine.BoundedTail`/`@engine.Rooted`/`@engine.Scoped`/`@engine.GreedyRepeat`/`@engine.IndexedRepeat` гБѓеА§
/// гГРгВ§гГ≥гГЗгВ£гГ≥гВ∞гВТжМБгБЯгБ™гБДжІЛйА†гГ©гГГгГСгГЉгБ™гБЃгБІеЖЕйГ®гВТеЖНеЄ∞зЪДгБЂиЊњгВЛгАВ`Ref` гБѓ registry гВТиЊњгБ£гБ¶еПВзЕІеЕИ
/// гГЖгГ≥гГЧгГђгГЉгГИгБЂеЖНеЄ∞гБЩгВЛ (`visiting` гБѓ `head_cycles` гБ®еРМгБШгАМи®™еХПжЄИгБњ template еРНгАНйШ≤еЊ° вАФ еЊ™зТ∞
/// ref гБѓ `collect_circular_ref` гБМеИ•йАФ definition-error гБІеЉЊгБПеЙНжПРгБ†гБМгАБйШ≤еЊ°зЪДгБЂзД°йЩРеЖНеЄ∞гВТйБњгБСгВЛ)гАВ
fn collect_value_names(
  node : @engine.Node,
  registry : Map[String, @engine.Node],
  visiting : Array[String],
  out : Array[String],
) -> Unit {
  match node {
    Ext(_) =>
      match node_resident_name(node) {
        Some(name) => out.push(name)
        None => ()
      }
    @engine.RequiredArgument(name) => out.push(name)
    @engine.Or(alts) =>
      for a in alts {
        collect_value_names(a, registry, visiting, out)
      }
    @engine.Seq(items) =>
      for it in items {
        collect_value_names(it, registry, visiting, out)
      }
    @engine.Many(inner, _) =>
      collect_value_names(inner, registry, visiting, out)
    @engine.BoundedTail(inner, _, _) =>
      collect_value_names(inner, registry, visiting, out)
    @engine.Rooted(inner, _) =>
      collect_value_names(inner, registry, visiting, out)
    @engine.Scoped(_, inner) =>
      collect_value_names(inner, registry, visiting, out)
    @engine.GreedyRepeat(inner) =>
      collect_value_names(inner, registry, visiting, out)
    @engine.IndexedRepeat(_, inner, _, _) =>
      collect_value_names(inner, registry, visiting, out)
    Ref(r) =>
      if !str_in(visiting, r) {
        match registry.get(r) {
          Some(tpl) => {
            visiting.push(r)
            collect_value_names(tpl, registry, visiting, out)
            let _ = visiting.pop()
          }
          None => ()
        }
      }
    _ => ()
  }
}

///|
/// DR-093 ¬І1/¬І2 гБЃеЮЛеІФи≠≤еИ§еЃЪгБМгАМеА§гБМеЃЯйЪЫгБЂзЭАеЬ∞гБЩгВЛ cellгАНгВТи¶ЛгВЛгБЯгВБгБЃеАЩи£ЬгВїгГЂиІ£ж±Ї (codex гГђгГУгГ•гГЉ
/// M-2 дњЃж≠£): еЃ£и®Аи¶Бзі† `e` гБЭгБЃгВВгБЃгБМеА§гВТжМБгБ§гБ®гБѓйЩРгВЙгБ™гБДгАВ
///
/// `e.ref_target` гБМ `Some(_)` (ref и¶Бзі†) гБЃгБ®гБНгАБ`e.body` гБѓеЄЄгБЂ `Cell` гБЃгБЊгБЊ (ref е±ХйЦЛгБѓ
/// registry дЄКгБЃ `@engine.Node` гБ®гБЧгБ¶е≠ШеЬ®гБЧгАБ`@engine.ElementDef.body` гБЂгБѓеПНжШ†гБХгВМгБ™гБД вАФ
/// `ensure_entity_body`/`element_head` гБЃ doc comment еПВзЕІ)гАВеПВзЕІеЕИгГЖгГ≥гГЧгГђгГЉгГИгБМ structural or гБЃ
/// гВИгБЖгБ™и§ЗеРИжІЛйА†гВТжМБгБ§е†іеРИгАБ`e.name` гБ®гБДгБЖгВїгГЂгБѓзµРжЮЬгБЂе≠ШеЬ®гБЫгБЪ (DR-025 гБЃйЬ≤еЗЇи¶ПеЙЗ)гАБеА§гБѓе±ХйЦЛеЊМгБЃ
/// жЮЭгБЃ leaf entity гБЂзЭАеЬ∞гБЩгВЛ вАФ `collect_value_names` гБІ registry дЄКгБЃеЃЯдљУгВТиЊњгБ£гБ¶еАЩи£ЬйЫЖеРИгВТеЊЧгВЛ
/// (DR-007гАМref гБѓжІЛйА†еЃЪзЊ©еЕ®гБ¶гВТеЉХгБНзґЩгБРгАНгБЃеЮЛеІФи≠≤еИ§еЃЪгБЄгБЃеПНжШ†)гАВ
///
/// `e.ref_target` гБМ `None` гБЛгБ§ `e.body` гБМ `Or` (зЫіжЫЄгБН structural orгАБеЮЛдїШгБНжЮЭ) гБЃгБ®гБНгБѓгАБOr
/// wrapper иЗ™иЇЂ (`e.name`) гБѓеА§гВТжМБгБЯгБ™гБДжІЛйА†гГЗгВ£гВєгГСгГГгГБгГ£гБІ (ensure_entity_body гБЃ Or гВ≥гГ°гГ≥гГИ
/// еПВзЕІ)гАБеА§гБѓйБЄгБ∞гВМгБЯжЮЭгБЃ leaf entity гБЂгБЃгБњ commit гБХгВМгВЛгАВеАЩи£ЬйЫЖеРИгВТеРДжЮЭгБЃ leaf name гБЂе±ХйЦЛгБЧгАБ
/// гАМгБ©гБЃжЮЭгБІгБВгВМзЩЇзБЂгБЧгБ¶еА§гБМзҐЇеЃЪгБЧгБ¶гБДгВМгБ∞еЕЕиґ≥гАН(DR-093 гБЃ or и¶™еЕЕиґ≥гБЃеЮЛеІФи≠≤еОЯзРЖ) гВТеСЉгБ≥еЗЇгБЧеБі
/// (`Required`/`RequiredGroup`) гБЃеИ§еЃЪгБЂжМБгБ°иЊЉгВАгАВEnum (value-enum ељҐ) гБѓеЕ®жЮЭгБМ SAME name/cell
/// (`e.name`) гБЂзЭАеЬ∞гБЩгВЛгБЯгВБгБУгБЃе±ХйЦЛгБѓдЄНи¶Б (`[e.name]` гБЃгБЊгБЊгБІеЕГгАЕж≠£гБЧгБД вАФ еѓЊзЕІ fixture
/// `required-value-enum-or-branch.json` гБМжЧҐгБЂ green гБ™гБЃгБѓгБУгБЃгБЯгВБ)гАВ
///
/// `Required` (required еНШй†Е) гБ® `RequiredGroup` (required_group, DR-103) гБЃдЄ°жЦєгБМгБУгБЃгГШгГЂгГСгГЉгВТ
/// еЕ±жЬЙгБЩгВЛгБУгБ®гБІгАБгАМrequired еНШй†ЕгБ® required_group гБІеАЩи£ЬгВїгГЂиІ£ж±ЇгБМй£ЯгБДйБХгБЖгАНжІЛйА†зЪДгБ™дљЩеЬ∞гВТзД°гБПгБЩ
/// (M-2 гБЃеЖНзЩЇйШ≤ж≠ҐгАБissue codex-review-dr102-dr103-postland)гАВ
///
/// жИїгВКеА§гБѓ `@engine.RequiredCandidate` (name + wrapper) вАФ ref зµМзФ±гБЃе†іеРИгАБеА§гБѓеЃ£и®АеЕГ `e` иЗ™иЇЂгБЃ @engine.Scoped
/// йГ®еИЖжЬ® (`@engine.Scoped(e.name, ...)`гАБ`inst_long`/`lower_positional` гБЃ ref еИЖе≤РгБМдљЬгВЛ) гБЂзЭАеЬ∞гБЩгВЛгБЯгВБгАБ
/// `wrapper: Some(e.name)` гВТдїШгБСгБ¶еИ§еЃЪеБі (`eval.mbt`/`resolve.mbt`) гБМгАМеЃ£и®АеЕГи¶Бзі†иЗ™иЇЂгБЃйГ®еИЖжЬ®еЖЕгАН
/// гБ†гБСгВТжОҐгБЩгВИгБЖгБЂгБЩгВЛ (DESIGN ¬І2.4/2.5 гБЃйЬ≤еЗЇи¶ПеЙЗгАБзД°еИґйЩРйАПйБОгБІгБѓгБ™гБПи¶Бзі†иЗ™иЇЂгБЃйГ®еИЖжЬ®гБЂйЩРеЃЪ вАФ
/// `@engine.RequiredCandidate` гБЃ doc comment еПВзЕІ)гАВзЫіжЫЄгБН Or гБЃе†іеРИгАБеА§гБѓи¶™ scope гБЂзЫіжО• bind гБХгВМгВЛгБЯгВБ
/// `wrapper: None`гАВ
fn required_candidates(
  e : @engine.ElementDef,
  registry : Map[String, @engine.Node],
) -> Array[@engine.RequiredCandidate] {
  match e.ref_target {
    Some(r) => {
      let names : Array[String] = []
      collect_value_names(Ref(r), registry, [], names)
      if names.length() > 0 {
        let out : Array[@engine.RequiredCandidate] = []
        for n in names {
          out.push({ name: n, wrapper: Some(e.name) })
        }
        out
      } else {
        [{ name: e.name, wrapper: None }]
      }
    }
    None =>
      match e.body {
        Or(branches) => {
          let out : Array[@engine.RequiredCandidate] = []
          for br in branches {
            for it in br.items {
              out.push({ name: it.name, wrapper: None })
            }
          }
          out
        }
        _ => [{ name: e.name, wrapper: None }]
      }
  }
}

///|
/// constraint installer (DR-055 / DR-042 еЄ≠еЃ£и®АеЮЛ): requires / conflicts_with / exclusive_group /
/// required / required_group (DR-103) / value_requires гВТ scope гБЃйБЕеїґињ∞и™ЮгБ®гБЧгБ¶зЩїйМ≤гАВжІЛйА†и°ЫжШЯгБѓ
/// зД°гБЧ (DR-047 еЃМеЕ® path гБЃжЬАзµВзКґжЕЛгБІи©ХдЊ°)гАВ
fn inst_constraint(
  def : @engine.Definition,
  build : @engine.InstallOutput,
  registry : Map[String, @engine.Node],
) -> Unit {
  let all : Array[@engine.ElementDef] = []
  for e in def.options {
    all.push(e)
  }
  for e in def.positionals {
    all.push(e)
  }
  for e in all {
    if e.requires.length() > 0 {
      add_constraint(build, Requires(e.name, copy_strs(e.requires)))
    }
    if e.conflicts_with.length() > 0 {
      add_constraint(build, Conflicts(e.name, copy_strs(e.conflicts_with)))
    }
    if e.required {
      // DR-093 ¬І1/¬І2: required:true гБЃи¶Бзі†иЗ™иЇЂгВТеѓЊи±°гБЂгБЧгБЯ Required гВТ 1 еАЛзЩїйМ≤гАВеАЩи£ЬгВїгГЂиІ£ж±ЇгБѓ
      // `required_candidates` (RequiredGroup гБ®еЕ±жЬЙ)гАВ
      add_constraint(build, Required(e.name, required_candidates(e, registry)))
    }
    for vr in e.value_requires {
      // DR-055 ¬І1 / DR-052 ¬ІеА§жЮЭ id зЫідЇ§: 4-tuple = (entity, branch_id, value, targets)гАВentity гБѓ
      // committed еИ§еЃЪ / еА§зЕІеРИгБЃеѓЊи±° (и¶™ name)гАБbranch_id гБѓйБХеПНжЩВгБЃ error.element (жЮЭгБЃ id)гАВ
      add_constraint(build, RequiresIf(e.name, vr.0, vr.1, copy_strs(vr.2)))
    }
  }
  // exclusive_group: label per scope гБІгГ°гГ≥гГРгВТйЫЖзіД вЖТ 1 Exclusive per label
  let groups : Array[String] = []
  for e in all {
    for g in e.exclusive_group {
      if !str_in(groups, g) {
        groups.push(g)
      }
    }
  }
  for g in groups {
    let members : Array[String] = []
    for e in all {
      if str_in(e.exclusive_group, g) {
        members.push(e.name)
      }
    }
    add_constraint(build, Exclusive(g, members))
  }
  // required_group (DR-103 ¬І1/¬І3/¬І7 дњЃж≠£гАБcodex M-2): exclusive_group гБ®еРМгБШйЫЖзіДгГСгВњгГЉгГ≥гАБзЛђзЂЛ
  // гБЧгБЯеРНеЙНз©ЇйЦУ (еИ•гБЃ groups йЕНеИЧ)гАВmember гБѓеЃ£и®Аи¶Бзі†еРНгБІгБ™гБП `required_candidates` гБЃеАЩи£ЬгВїгГЂ
  // (structural or гБ™гВЙеРДжЮЭгБЃ leaf name) гВТгБЭгБЃгБЊгБЊйЫЖгВБгВЛ вАФ гВ∞гГЂгГЉгГЧеЕЕиґ≥гБѓгАМгБДгБЪгВМгБЛгБЃ member гБЃ
  // гБДгБЪгВМгБЛгБЃеАЩи£ЬгВїгГЂгБМеЮЛеІФи≠≤еЕЕиґ≥гБЧгБ¶гБДгВМгБ∞ OKгАНгБ®гБДгБЖиЂЦзРЖеТМгБІгАБеАЩи£ЬгВїгГЂгВТгГХгГ©гГГгГИгБЂйЫЖзіДгБЧгБ¶гВВ
  // жХ∞е≠¶зЪДгБЂз≠ЙдЊ° (OR(member1_candidates) OR OR(member2_candidates) OR ... = OR(еЕ® candidates))гАВ
  // 1 RequiredGroup per labelгАВ
  let rg_groups : Array[String] = []
  for e in all {
    for g in e.required_group {
      if !str_in(rg_groups, g) {
        rg_groups.push(g)
      }
    }
  }
  for g in rg_groups {
    let members : Array[@engine.RequiredCandidate] = []
    for e in all {
      if str_in(e.required_group, g) {
        for c in required_candidates(e, registry) {
          members.push(c)
        }
      }
    }
    add_constraint(build, RequiredGroup(g, members))
  }
}

///|
fn str_in(xs : Array[String], v : String) -> Bool {
  for x in xs {
    if x == v {
      return true
    }
  }
  false
}

// вФАвФА alias desugaring (DR-057) вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА

///|
/// `s` гБЂйГ®еИЖжЦЗе≠ЧеИЧ `sub` гВТеРЂгВАгБЛ (name-derived variant еИ§еЃЪ: variant.trigger гБМ canonical.name гВТ
/// йГ®еИЖжЦЗе≠ЧеИЧгБЂеРЂгВАгБ™гВЙ name-derived вАФ DR-057 ¬І3)гАВ
fn str_has_sub(s : String, sub : String) -> Bool {
  if sub.length() == 0 {
    return true
  }
  let cs = s.to_array()
  let cu = sub.to_array()
  if cu.length() > cs.length() {
    return false
  }
  let mut i = 0
  while i + cu.length() <= cs.length() {
    let mut k = 0
    let mut ok = true
    while k < cu.length() {
      if cs[i + k] != cu[k] {
        ok = false
        break
      }
      k = k + 1
    }
    if ok {
      return true
    }
    i = i + 1
  }
  false
}

///|
/// `s` гБЃжЬАеИЭгБЃ `from` еЗЇзПЊгВТ `to` гБЂзљЃжПЫ (name-derived variant гВТ alias еРНгБІеЖНе∞ОеЗЇ: DR-057 ¬І3
/// "--no-ssl" (canonical ssl) вЖТ alias tls гБІ "--no-tls")гАВ
fn str_replace_first(s : String, from : String, to : String) -> String {
  let cs = s.to_array()
  let cf = from.to_array()
  if cf.length() == 0 || cf.length() > cs.length() {
    return s
  }
  let mut i = 0
  while i + cf.length() <= cs.length() {
    let mut k = 0
    let mut ok = true
    while k < cf.length() {
      if cs[i + k] != cf[k] {
        ok = false
        break
      }
      k = k + 1
    }
    if ok {
      let buf = StringBuilder::new()
      buf.write_string(chars_to_str(cs, 0, i))
      buf.write_string(to)
      buf.write_string(chars_to_str(cs, i + cf.length(), cs.length()))
      return buf.to_string()
    }
    i = i + 1
  }
  s
}

///|
/// canonical option / positional и¶Бзі†гВТ name гБІж§ЬзіҐгАВ
fn find_elem(def : @engine.Definition, name : String) -> @engine.ElementDef? {
  for e in def.options {
    if e.name == name {
      return Some(e)
    }
  }
  for e in def.positionals {
    if e.name == name {
      return Some(e)
    }
  }
  None
}

///|
fn find_command(def : @engine.Definition, name : String) -> @engine.CommandDef? {
  for c in def.commands {
    if c.name == name {
      return Some(c)
    }
  }
  None
}

///|
/// alias entry-copy гБЃз©Ї body: entry зґігВК + canonical name гБЃгБњжРЇи°МгАБеА§жЇР / зµРжЮЬгВ≠гГЉ / еИґзіДгБѓеЃЯдљУеБігБЃ
/// гБЊгБЊ (DR-057 ¬І3)гАБгБЭгВМгВЙ field гБѓ set гБЧгБ™гБДгАВ
fn alias_entry(
  canonical_name : String,
  ty : &@engine.TypeExt,
  long : Array[String],
  variants : Array[@engine.Variant],
  short : Array[Char],
  deprecated : Bool,
  help_meta : @engine.HelpMetaDeclaration,
) -> @engine.ElementDef {
  {
    name: canonical_name, // effect / entity / result key гБѓеЕ®гБ¶ canonical name гБІ keying (link еРМеЮЛ)
    ty,
    // жЧҐгБЂе∞ОеЗЇжЄИгБњ explicit зґігВКеИЧ (`:set` гБѓеРЂгБЊгБ™гБД вАФ normalize/resolve_long гБЃеѓЊи±°е§ЦгАБpost-normalize
    // зЫЄељУгБЃзҐЇеЃЪељҐгБ®гБЧгБ¶зЫіжО• List гБІжМБгБ§)гАВalias entry-copies гБѓ fixpoint installer (inst_long з≠Й) гБМ
    // гБЭгБЃгБЊгБЊеЗ¶зРЖгБЩгВЛеѓЊи±°гБІгАБдЇМеЇ¶зЫЃгБЃ resolve_long гБѓиµЈгБНгБ™гБДгАВ
    long: List(long),
    variants,
    short,
    env: [],
    help_meta,
    is_tty: false, // alias entry-copy гВВеА§жЇРгБѓеЃЯдљУеБігБЃгБЊгБЊ (¬І3 гБ®еРМгБШзРЖзФ±гАБenv гБ®еѓЊзІ∞)
    tty_stream: None,
    tty_cygwin: true,
    is_dd: false,
    is_exact: false,
    dd_match: None,
    dd_self_keep: false,
    is_global: false,
    is_inherit: false,
    is_inheritable: false,
    link_depth: 0,
    ref_target: None,
    repeat: None,
    optional: false,
    multiple: false,
    accumulator: None,
    flatten: None,
    separator: None,
    collector: None,
    fail_action: false,
    is_config_file: false,
    config_key: None,
    export_key: @engine.ExportKey::unset(),
    requires: [],
    conflicts_with: [],
    exclusive_group: [],
    required_group: [],
    required: false, // alias entry гБѓ @engine.AliasDef иЗ™дљУгБЂ required еЃ£и®АзµМиЈѓгВТжМБгБЯгБ™гБД (requires/exclusive_group гБ®еРМгБШзРЖзФ±)
    value_requires: [],
    deprecated,
    // DR-104 ¬І2/¬І3: alias entry-copy гБѓеЄЄгБЂ is_alias:true (гБУгБЃйЦҐжХ∞иЗ™дљУгБМ alias еЃ£и®АзФ±жЭ• entry-copy
    // е∞ВзФ®гБЃгВ≥гГ≥гВєгГИгГ©гВѓгВњ)гАВhidden гБѓ @engine.AliasDef гБЂзЛђзЂЛеЃ£и®АзµМиЈѓгВТжМБгБЯгБ™гБД (deprecated гБ®йБХгБДгАБзПЊи°М
    // fixture гБЂ alias еБігБЃзЛђзЂЛ hidden гВТи¶Бж±ВгБЩгВЛгВВгБЃгБМзД°гБД) гБЃгБІ canonical гБ®еРМгБШ false жЧҐеЃЪгАВ
    is_alias: true,
    hidden: false,
    completer: None,
    default_values: None,
    default_fn: None,
    default_declared: false,
    int_round: @engine.Error,
    allow_base_prefix: false,
    bool_config: bool_config_canonical(),
    piece_filters: [],
    value_filters: [],
    final_filters: [],
    accum_filters: [],
    long_prefix: "--",
    short_prefix: "-",
    env_prefix: "",
    auto_env: false,
    long_eq_sep: @engine.Allow,
    short_combine: true,
    short_attached_value: @engine.Allow,
    body: Cell,
  }
}

///|
/// alias еЃ£и®А (DR-057) гВТ option entry-copies / command defs гБЂ desugarгАВеЃМеЕ®жАІж§ЬжЯїгБМ the alias installer resident гБЃ
/// "alias" жЙАжЬЙгВТзҐЇи™НгБЧгБЯеЊМгАБinit_sb еЙНгБЂ 1 еЇ¶гБ†гБСиµ∞гВЛж±ЇеЃЪзЪД pre-passгАВеРД entry-copy гБѓ canonical name
/// гБІ keying (satellites гБМ canonical cell гВТ bindгАБзµРжЮЬгВ≠гГЉгВВ canonical)гАБеЖНе∞ОеЗЇзґігВКгВТжРЇи°МгБЧгАБfixpoint
/// гБЃ long/short/command installer гБМе±ХйЦЛгБЩгВЛ (DR-057 ¬І4)гАВcommand subtree гБЂгВВеЖНеЄ∞гАВ
///
/// `orig` гБѓ normalize_surface йБ©зФ®еЙНгБЃи§Зи£љ (issue 2026-07-08 dec-alias-long-override-flag-sugar-
/// gap): `def` еБігБЃ canonical и¶Бзі†гБѓжЧҐгБЂ flag_type()вЖТbool_type() е§ЙжПЫжЄИгБњгБ™гБЃгБІгАБDR-076 ¬І2 и¶ПеЙЗ1 (flag гБЃ
/// `long:true` з≥Ци°£гБѓ `:set:true` гБЄеЈЃгБЧжЫњгБИ) гВТеИ§еЃЪгБЩгВЛжЭРжЦЩ (еЕГгБЃеЮЛ flag_type()) гБМе§±гВПгВМгБ¶гБДгВЛгАВ`orig`
/// гБЛгВЙеРМгБШ target и¶Бзі†гБЃе§ЙжПЫеЙНгБЃ `ty`/`long` гВТеЉХгБНгАБ`resolve_long` гВТ canonical еБігБ®еРМгБШељҐгБІ
/// йАЪгБЩгБУгБ®гБІгАБalias еБігБЂгВВеРМгБШи¶ПеЙЗ1/2 гВТйБ©зФ®гБЩгВЛгАВ
fn desugar_aliases(
  def : @engine.Definition,
  orig : @engine.Definition,
  extensions : @engine.Registry,
) -> Unit {
  for a in def.aliases {
    let alias_name = match a.name {
      Some(n) => n
      None => a.target // жШОз§Ї name зД°гБЧ вЖТ canonical еРНгВТжµБзФ® (e.g. short-only alias)
    }
    match find_elem(def, a.target) {
      Some(canon) => {
        let (orig_ty, orig_long) = match find_elem(orig, a.target) {
          Some(oc) => (oc.ty, oc.long)
          None => (canon.ty, canon.long) // зРЖиЂЦдЄКиµЈгБНгБ™гБДйШ≤еЊ°зЪДгГХгВ©гГЉгГЂгГРгГГгВѓ
        }
        // canonical иЗ™иЇЂгБЃ (pre-normalize) long гВТ canonical еРНгГїеЕГгБЃеЮЛгБІиІ£ж±ЇгБЩгВЛ вАФ еЯЇеЇХ long зґігВК
        // (name-derived дЄїеЕ•еП£гБЃжЬЙзД°) гБ®гАБзґЩжЙњгБЩгБєгБН NAME-DERIVED variants гБЃдЄ°жЦєгВТгБУгБУгБЛгВЙе∞ОгБПгАВ
        // resolve_long гВТйАЪгБЩгБУгБ®гБІгАБcanonical гБМ flag гБ™гВЙи¶ПеЙЗ1/2 (:set:true еЈЃгБЧжЫњгБИ/и£ЬеЃМ) гВТ
        // еПНжШ†гБЧгБЯељҐгБІ `canon_vars` гБМжЙЛгБЂеЕ•гВЛгАВ
        let (canon_longs, canon_vars) = resolve_long(
          orig_long,
          canon.name,
          orig_ty,
          extensions,
        )
        let long : Array[String] = []
        if str_in(canon_longs, kebab(canon.name)) {
          long.push(alias_name)
        }
        // жШОз§Ї `long` override (DR-007 еЈЃеИЖдЄКжЫЄгБН) гБѓиЗ™зґігВКгВТ addгАБзґЩжЙњ variants гВТ cutгАВalias иЗ™иЇЂгБЃ
        // long гВВ canonical гБ®еРМгБШ `resolve_long` (colon DSL еИЖй°Ю + flag и¶ПеЙЗ1/2) гВТ alias еРНгГї
        // canonical гБЃеЕГгБЃеЮЛгБІйАЪгБЩ вАФ еЮЛдЊЭе≠ШгБЃз≥Ци°£еЈЃгБЧжЫњгБИгБМ alias еБігБІгВВ canonical гБ®жПГгБЖ
        // (issue 2026-07-08 dec-alias-long-override-flag-sugar-gap гБЃж†єж≤ї)гАВ
        let variants : Array[@engine.Variant] = []
        match a.long_override {
          Some(decl) => {
            let (longs, vars) = resolve_long(
              decl, alias_name, orig_ty, extensions,
            )
            for n in longs {
              if !str_in(long, n) {
                long.push(n)
              }
            }
            for v in vars {
              variants.push(v)
            }
          }
          None =>
            // canonical гБЃ NAME-DERIVED variants (дЄКгБІ resolve_long жЄИгБњ) гВТ alias еРНгБІеЖНе∞ОеЗЇгАВ
            // variant.trigger гБМ canonical.name гВТйГ®еИЖжЦЗе≠ЧеИЧгБЂеРЂгВБгБ∞ name-derived (DR-057 ¬І3);
            // жШОз§Ї trigger (e.g. compress гБЃ "gzip") гБѓйЭЮзґЩжЙњ (жШОз§ЇзґігВКйЭЮзґЩжЙњ)гАВ
            for v in canon_vars {
              if str_has_sub(v.trigger, canon.name) {
                variants.push({
                  trigger: str_replace_first(v.trigger, canon.name, alias_name),
                  op: v.op,
                  operand: v.operand,
                })
              }
            }
        }
        def.options.push(
          alias_entry(
            canon.name,
            canon.ty,
            long,
            variants,
            copy_chars(a.short),
            a.deprecated,
            a.help_meta,
          ),
        )
      }
      None =>
        // command alias: co вЖТ checkout йГ®еИЖжЬ®, зµРжЮЬгВ≠гГЉгБѓ checkout гБЂеѓДгБЫгВЛ (DR-057 ¬І2)
        match find_command(def, a.target) {
          Some(cmd) =>
            def.commands.push({
              name: alias_name,
              body: clone_def(cmd.body),
              export_key: @engine.ExportKey::key(a.target),
            })
          None => () // dangling alias target вАФ е∞ЖжЭ•гБЃ absent-ref check зФ®гБЂжЃЛзљЃ
        }
    }
  }
  for c in def.commands {
    let orig_body = match find_command(orig, c.name) {
      Some(oc) => oc.body
      None => c.body // зРЖиЂЦдЄКиµЈгБНгБ™гБДйШ≤еЊ°зЪДгГХгВ©гГЉгГЂгГРгГГгВѓ (orig еБігБЃеѓЊењЬ command гБМи¶ЛгБ§гБЛгВЙгБ™гБД)
    }
    desugar_aliases(c.body, orig_body, extensions)
  }
}

///|
fn add_constraint(
  build : @engine.InstallOutput,
  c : @engine.Constraint,
) -> Unit {
  for existing in build.constraints() {
    if existing == c {
      return
    }
  }
  build.constraints().push(c)
}

///|
fn def_err(
  element : String,
  kind : @engine.DefErrorKind,
  message : String,
  hint : String,
) -> @engine.DefError {
  { element, kind, message, hint }
}

///|
fn default_fn_edges(
  element : @engine.ElementDef,
  extensions : @engine.Registry,
) -> Array[String] {
  let edges : Array[String] = []
  match element.default_fn {
    Some(@engine.Wire(invocation)) =>
      match extensions.lookup_cell_fn(invocation.name) {
        Some(descriptor) =>
          match descriptor.concrete_observes(invocation) {
            Ok(observes) =>
              for edge in observes {
                if edge.has_prefix("option:") {
                  edges.push(edge[7:].to_owned())
                }
              }
            Err(_) => ()
          }
        None => ()
      }
    _ => ()
  }
  edges
}

///|
fn default_fn_cycle_from(
  start : String,
  current : String,
  graph : Map[String, Array[String]],
  visiting : Array[String],
) -> Bool {
  if current == start && visiting.length() > 0 {
    return true
  }
  if str_in(visiting, current) {
    return false
  }
  let next_visiting = copy_strs(visiting)
  next_visiting.push(current)
  match graph.get(current) {
    Some(edges) =>
      for edge in edges {
        if default_fn_cycle_from(start, edge, graph, next_visiting) {
          return true
        }
      }
    None => ()
  }
  false
}

///|
fn collect_default_fn_errors(
  def : @engine.Definition,
  out : Array[@engine.DefError],
  extensions : @engine.Registry,
) -> Unit {
  let elements : Array[@engine.ElementDef] = []
  for element in def.options {
    elements.push(element)
  }
  for element in def.positionals {
    elements.push(element)
  }
  let graph : Map[String, Array[String]] = Map([])
  for element in elements {
    match element.default_fn {
      Some(call) => {
        if element.default_declared && call is @engine.Wire(_) {
          out.push(
            def_err(
              element.name,
              @engine.InvalidRange,
              "default and default_fn both declare the default seat",
              "declare exactly one default-seat supplier",
            ),
          )
        }
        let fn_call = call.to_call()
        match extensions.lookup_cell_fn(fn_call.name) {
          None =>
            out.push(
              def_err(
                element.name,
                @engine.UnknownVocab,
                "default_fn '" + fn_call.name + "' is not registered",
                "register the cell fn or use a registered name",
              ),
            )
          Some(descriptor) => {
            match descriptor.validate_call(fn_call) {
              Err({ reason: _, message }) =>
                out.push(
                  def_err(
                    element.name,
                    @engine.InvalidArgument,
                    message,
                    "match the cell fn descriptor's argument contract",
                  ),
                )
              Ok(_) => ()
            }
            if descriptor.output() is @engine.Sentinel(_) {
              out.push(
                def_err(
                  element.name,
                  @engine.InvalidRange,
                  "default_fn '" +
                  fn_call.name +
                  "' returns a cell-operation sentinel",
                  "use a cell fn whose descriptor returns Value",
                ),
              )
            }
          }
        }
      }
      None => ()
    }
    graph.set(element.name, default_fn_edges(element, extensions))
  }
  for element in elements {
    if default_fn_cycle_from(element.name, element.name, graph, []) {
      out.push(
        def_err(
          element.name,
          @engine.CircularRef,
          "default_fn observes cycle includes '" + element.name + "'",
          "remove one option dependency edge from the cycle",
        ),
      )
    }
  }
  for command in def.commands {
    collect_default_fn_errors(command.body, out, extensions)
  }
}

///|
/// DR-011 жШОзҐЇеМЦ (kawaz и£БеЃЪ 2026-07-08): `long` гБЃ array ељҐгБЃеРДи¶Бзі†гБѓ `classify_long_spelling` гБМ
/// `Main`/`Variant` гБЂеИЖй°ЮгБІгБНгВЛељҐгБІгБ™гБСгВМгБ∞гБ™гВЙгБ™гБД вАФ colon-less гБ™жЦЗе≠ЧеИЧгАБгБЊгБЯгБѓи™ЮељЩе§Ц effect
/// word гВТжМБгБ§жЦЗе≠ЧеИЧ (`Invalid`) гБѓжЦЗж≥ХгВ®гГ©гГЉгБІ `unknown-vocab` (DR-054) гБЂиРљгБ®гБЩгАВ`normalize_option`
/// (`resolve_long` зµМзФ±) гБЃ**еЙН**гБЂж§ЬжЯїгБЩгВЛењЕи¶БгБМгБВгВЛ вАФ `resolve_long` гБѓ `Invalid` гВТйїЩгБ£гБ¶жН®гБ¶гВЛ
/// (еСЉгБ≥еЗЇгБЧеЙНжПРгБМгАМзД°еКєжЦЗе≠ЧеИЧгБѓжЧҐгБЂ definition-error гБ®гБЧгБ¶ж§ЬеЗЇжЄИгБњгАНгБ™гБЃгБІ) гБЯгВБгАБnormalize еЊМгБЃ
/// `e.long` гБЂгБѓзД°еКєгБ™зФЯжЦЗе≠ЧеИЧгБМгВВгБЖжЃЛгБ£гБ¶гБДгБ™гБДгАВ
fn collect_invalid_long_dsl(
  def : @engine.Definition,
  out : Array[@engine.DefError],
  extensions : @engine.Registry,
) -> Unit {
  for e in def.options {
    push_invalid_long(e, out, extensions)
  }
  for e in def.positionals {
    push_invalid_long(e, out, extensions)
  }
  for c in def.commands {
    collect_invalid_long_dsl(c.body, out, extensions)
  }
}

///|
fn push_invalid_long(
  e : @engine.ElementDef,
  out : Array[@engine.DefError],
  extensions : @engine.Registry,
) -> Unit {
  match e.long {
    Bool(_) => () // bool з≥Ци°£гБѓеЄЄгБЂе¶•ељУ (DR-071 ¬І1 / DR-076 ¬І2)
    List(strs) =>
      for l in strs {
        match classify_long_spelling(l, kebab(e.name), e.ty, extensions) {
          Invalid(s, kind) =>
            out.push(
              def_err(
                e.name,
                kind,
                "long spelling '\{s}' is not a valid cell-fn invocation",
                "use a registered cell_fns name with arguments matching its descriptor",
              ),
            )
          Main(_) | Variant(_) => ()
        }
      }
    Forms(forms) =>
      for form in forms {
        match classify_long_form(form, kebab(e.name), e.ty, extensions) {
          Invalid(s, kind) =>
            out.push(
              def_err(
                e.name,
                kind,
                "long spelling '\{s}' is not a valid cell-fn invocation",
                "use a registered cell_fns name with arguments matching its descriptor",
              ),
            )
          Main(_) | Variant(_) => ()
        }
      }
  }
}

///|
/// DR-011 жШОзҐЇеМЦ (kawaz и£БеЃЪ 2026-07-08): alias `long_override` (DR-057 ¬І3 еЈЃеИЖдЄКжЫЄгБН) гБѓ canonical
/// еБігБЃ `long` гБ®еРМгБШ colon DSL гВТеЕ±зФ®гБЩгВЛ (`classify_long_spelling`гАБinstaller.mbt:1497 гБЃгВ≥гГ°гГ≥гГИ
/// гАМдЇМзµМиЈѓгБМ drift гБЧгБ™гБДгВИгБЖеИЖй°ЮеЩ®гВТеЕ±зФ®гАНеПВзЕІ) вАФ жШОзҐЇеМЦгБѓгБУгБЃ DSL гБМзПЊгВМгВЛ**еЕ®гБ¶гБЃе†іжЙА**гБЂдЄАжІШгБЂеКєгБП
/// и¶ПеЙЗгБ™гБЃгБІгАБcolon-less / и™ЮељЩе§Ц effect гБѓ canonical еБі (`push_invalid_long`) гБ®еРМгБШгБП `unknown-vocab`
/// (DR-054) гБЂиРљгБ®гБЩгАВcanonical еБігБ®еИ•йЦҐжХ∞гБЂгБЧгБ¶гБДгВЛгБЃгБѓгАБtarget canonical и¶Бзі†гБЃ `ty` гВТ
/// `find_elem` гБІеЉХгБПењЕи¶БгБМгБВгВК (`classify_long_spelling` гБЃ operand иІ£йЗИгБЂдљњгБЖ)гАБ`push_invalid_long`
/// гБЃгАМиЗ™еИЖгБЃ @engine.ElementDef гВТж§ЬжЯїгБЩгВЛгАНељҐгБ®еЕ•еКЫгБЃељҐгБМйБХгБЖгБЯгВБ вАФ dangling alias target (и¶ЛгБ§гБЛгВЙгБ™гБДе†іеРИ)
/// гБѓ absent-ref check гБМеИ•йАФжЛЊгБЖгБЃгБІгБУгБУгБІгБѓйЭЩгБЛгБЂгВєгВ≠гГГгГЧгБЩгВЛгАВdesugar_aliases (Invalid гВТ
/// rename-only гБІйАЪгБЩзµМиЈѓ) гВИгВКеЙНгАБstatic check гГХгВІгГЉгВЇгБІж§ЬеЗЇгБЩгВЛгАВ
fn collect_invalid_alias_long_override(
  def : @engine.Definition,
  out : Array[@engine.DefError],
  extensions : @engine.Registry,
) -> Unit {
  for a in def.aliases {
    match a.long_override {
      Some(decl) => {
        let alias_name = match a.name {
          Some(n) => n
          None => a.target
        }
        match find_elem(def, a.target) {
          Some(canon) =>
            match decl {
              Bool(_) => () // bool з≥Ци°£гБѓеЄЄгБЂе¶•ељУ (DR-071 ¬І1 / DR-076 ¬І2)
              List(strs) =>
                for l in strs {
                  match
                    classify_long_spelling(l, alias_name, canon.ty, extensions) {
                    Invalid(s, kind) =>
                      out.push(
                        def_err(
                          alias_name,
                          kind,
                          "alias long_override spelling '\{s}' is not a valid cell-fn invocation",
                          "use a registered cell_fns name with arguments matching its descriptor",
                        ),
                      )
                    Main(_) | Variant(_) => ()
                  }
                }
              Forms(forms) =>
                for form in forms {
                  match
                    classify_long_form(form, alias_name, canon.ty, extensions) {
                    Invalid(s, kind) =>
                      out.push(
                        def_err(
                          alias_name,
                          kind,
                          "alias long_override spelling '\{s}' is not a valid cell-fn invocation",
                          "use a registered cell_fns name with arguments matching its descriptor",
                        ),
                      )
                    Main(_) | Variant(_) => ()
                  }
                }
            }
          None => () // dangling alias target вАФ absent-ref check гБМеИ•йАФжЛЊгБЖ
        }
      }
      None => ()
    }
  }
  for c in def.commands {
    collect_invalid_alias_long_override(c.body, out, extensions)
  }
}

///|
/// DR-099 ¬І3/¬І7: `builtin/tty` preset гБЃењЕй†И config `tty_stream` гБМжЬ™жМЗеЃЪгБ™и¶Бзі†гБѓ definition-error
/// (kind=invalid-range)гАВbare `type:"tty"` / `type:"builtin/tty"` (config гВТдЊЫзµ¶гБЩгВЛзµМиЈѓиЗ™дљУгБМзД°гБД вАФ
/// зЫіжО•еПВзЕІгБѓеЄЄгБЂгБУгБЃељҐгАБdecode е±§гБМ `is_tty=true, tty_stream=None` гБІйАЪгБЩ) гБ®гАБdefinitions.types
/// зµМзФ±гБІ `tty_stream` гВТжЫЄгБНењШгВМгБЯ shadow гБЃдЄ°жЦєгВТгБУгБЃдЄАжЬђгБІжЛЊгБЖгАВ
///
/// DR-098 ¬І4 гБМењЕи¶БгБ®гБЧгБ¶гБДгБЯ 3 еИЖй°Ю (йЭЮ bool еЮЛгГїеА§гБ™гБЧи¶Бзі†гГїflag/count гГЧгГ™гВїгГГгГИгБЄгБЃ `tty:`
/// дїШдЄО) гБѓгАБ`type:` гБМеНШдЄАйБЄжКЮгБЃгГХгВ£гГЉгГЂгГЙгБІгБВгВЛдї•дЄКгАБpreset еЮЛгБЄгБЃиїҐжПЫгБІжІЛжЦЗзЪДгБЂзЩЇзФЯгБЧгБ™гБПгБ™гБ£гБЯ
/// (DR-099 ¬І1гАМжО°зФ®гБЧгБ™гБЛгБ£гБЯж°ИгАН) вАФ жЃЛгВЛеФѓдЄАгБЃ definition-error гБѓгБУгБЃ factory иЗ™иЇЂгБЃ config ж§Ьи®Љ
/// гБ†гБС (DR-061 ¬І4гАМconfig еА§гБЃж§Ьи®ЉгБѓ factory иЗ™иЇЂгБЃи≤ђеЛЩгАН)гАВis_tty/tty_stream гБѓ `type:` иІ£ж±ЇгБЃ
/// decode жЩВзВєгБІзҐЇеЃЪгБЧ normalize_surface гБЃељ±йЯњгВТеПЧгБСгБ™гБДгБЯгВБ (flag_type()вЖТbool_type() е§ЙжПЫгБЃгВИгБЖгБ™ pre/post
/// еМЇеИ•гБѓдЄНи¶Б)гАБдїЦгБЃ post-normalize гБ™ collect_* зЊ§гБ®еРМгБШдЄ¶гБ≥гБІеСЉгВУгБІгВИгБДгАВ
fn collect_tty_stream_missing(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn check(e : @engine.ElementDef) -> Unit {
    if e.is_tty && e.tty_stream is None {
      out.push(
        def_err(
          e.name,
          @engine.InvalidRange,
          "'\{e.name}' selects the builtin/tty preset but its factory config is missing 'tty_stream' вАФ bare type:\"tty\"/\"builtin/tty\" has no channel to supply it (DR-099 ¬І3)",
          "declare a definitions.types entry with config.tty_stream set to \"stdin\"|\"stdout\"|\"stderr\", and reference that name from 'type'",
        ),
      )
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_tty_stream_missing(c.body, out)
  }
}

///|
/// zero-progress йЭЩзЪД guard (DR-043): repeat head гБѓ >= 1 token жґИи≤їгБМењЕи¶Б (еЖНеЄ∞ unfold гБЃ loop гВТйШ≤ж≠Ґ)гАВ
/// ref head гБѓгАМtarget гБМ >= 1 жґИи≤їгАНгБЂйВДеЕГ (жґИи≤ї node гБЃгБ™гБД ref cycle гВВжНХжНЙ)гАВ
fn head_progresses(
  node : @engine.Node,
  registry : Map[String, @engine.Node],
  visiting : Array[String],
) -> Bool {
  match node {
    @engine.RequiredArgument(_)
    | @engine.Exact(_)
    | @engine.NativeMatch(_)
    | @engine.DdSatisfied(_)
    | @engine.CommandSatisfied(_, _) => true
    // DR-090: progress depends on `self_keep` вАФ `drop` (false) consumes 1 token like `@engine.DdSatisfied`,
    // `keep` (true) is a 0-token @engine.Accept (same standing as `@engine.Bind`/`effect resident` below).
    @engine.DdMatchSatisfied(_, _, self_keep, _) => !self_keep
    Ext(extension) => !extension.consumes_zero_tokens()
    @engine.IndexedRepeat(_, _, _, _) => true // еРНеЙНдїШгБН indexed repeat гБѓ head гВТжґИи≤ї
    @engine.BoundedTail(_, budget, _) => budget >= 1 // >= 1 head еПЦгВМгВЛжЩВгБЃгБњжґИи≤ї
    @engine.Rooted(inner, _) => head_progresses(inner, registry, visiting)
    @engine.Bind(_, _) => false // 0-token
    Ref(r) => {
      for v in visiting {
        if v == r {
          return false // жґИи≤ї node гБ™гБЧгБЃ cycle вЖТ зД° progress
        }
      }
      match registry.get(r) {
        Some(tpl) => {
          visiting.push(r)
          let ok = head_progresses(tpl, registry, visiting)
          let _ = visiting.pop()
          ok
        }
        None => false // unresolved ref
      }
    }
    @engine.Or(alts) => {
      for a in alts {
        if !head_progresses(a, registry, visiting) {
          return false
        }
      }
      alts.length() > 0
    }
    @engine.Seq(items) =>
      if items.length() >= 1 {
        head_progresses(items[0], registry, visiting)
      } else {
        false
      }
    @engine.Many(_) | @engine.Scoped(_, _) | @engine.ScopeNode(_) => true
    @engine.GreedyRepeat(inner) => head_progresses(inner, registry, visiting)
  }
}

///|
/// HEAD position гБЃ ref (жЬАеИЭгБЂжґИи≤їгБХгВМгВЛи¶Бзі†гБЃ ref), зД°гБСгВМгБ∞ NoneгАВжґИи≤ї head гБЃеЊМгБЃ ref (repeat гБЃ
/// cons tail `@engine.Seq([head, Opt(Ref(self))])` з≠Й) гБѓ head дљНзљЃгБІгБѓгБ™гБДгБЃгБІгАБж≠£ељУгБ™ repeat иЗ™еПВзЕІгБѓ None гВТињФгБЩгАВ
fn head_ref_of(node : @engine.Node) -> String? {
  match node {
    Ref(r) => Some(r)
    @engine.Seq(items) =>
      if items.length() >= 1 {
        head_ref_of(items[0])
      } else {
        None
      }
    @engine.Or(alts) => {
      for a in alts {
        match head_ref_of(a) {
          Some(r) => return Some(r)
          None => ()
        }
      }
      None
    }
    @engine.Rooted(inner, _) => head_ref_of(inner)
    _ => None
  }
}

///|
/// `name` гБЛгВЙ head-position ref гВТиЊњгВЛгБ® loop гБЩгВЛгБЛ (зД°йЩРжІЛйА†е±ХйЦЛгБЃ circular ref, DR-054)гАВrepeat
/// иЗ™еПВзЕІ (head гБМжґИи≤ї node) гБѓгБУгБУгБІ loop гБЧгБ™гБДгАВ
fn head_cycles(
  name : String,
  registry : Map[String, @engine.Node],
  visiting : Array[String],
) -> Bool {
  for v in visiting {
    if v == name {
      return true
    }
  }
  match registry.get(name) {
    Some(tpl) =>
      match head_ref_of(tpl) {
        Some(next) => {
          visiting.push(name)
          let r = head_cycles(next, registry, visiting)
          let _ = visiting.pop()
          r
        }
        None => false
      }
    None => false
  }
}

///|
/// node гБЃ head-position ref гБМ cycle гБЂеИ∞йБФгБЩгВЛгБЛ (circular ref гБМеРМжЩВгБЂ zero-progress гБ®гБЧгБ¶ 2 йЗН
/// е†±еСКгБХгВМгБ™гБДгВИгБЖеМЇеИ•гБЩгВЛзФ®йАФ)гАВ
fn head_node_cycles(
  node : @engine.Node,
  registry : Map[String, @engine.Node],
) -> Bool {
  match head_ref_of(node) {
    Some(r) => head_cycles(r, registry, [])
    None => false
  }
}

///|
/// zero-progress guard (DR-043 / DR-054): repeat head гБѓ >= 1 жґИи≤їгБМењЕи¶БгАВеЕ®дїґеПОйЫЖ вАФ гБЯгБ†гБЧ ref
/// cycle гБЂгВИгВЛ йЭЮ progress гБѓ circular ref (collect_circular_ref) еБігБІе†±еСКгБЩгВЛгБЃгБІгАБгБУгБУгБІгБѓйЩ§е§ЦгБЩгВЛ
/// (kind гВТ distinct гБЂдњЭгБ§)гАВ
fn collect_zero_progress(
  def : @engine.Definition,
  registry : Map[String, @engine.Node],
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.positionals {
    match elem_repeat(e) {
      Some(_) => {
        let head = element_head(e)
        if !head_progresses(head, registry, []) &&
          !head_node_cycles(head, registry) {
          out.push(
            def_err(
              e.name,
              @engine.ZeroProgress,
              "repeat element '\{e.name}' has a zero-progress head",
              "give the repeat head a token-consuming element",
            ),
          )
        }
      }
      None => ()
    }
  }
  for c in def.commands {
    collect_zero_progress(c.body, registry, out)
  }
}

///|
/// circular ref (DR-054): registry template гБЃ head-position ref chain гБМ loop вЖТ зД°йЩРжІЛйА†е±ХйЦЛгАВ
/// repeat зФ±жЭ•гБЃиЗ™еПВзЕІгБѓ pass (head гБМжґИи≤ї node)гАВеЕ®дїґеПОйЫЖгАВ
fn collect_circular_ref(
  registry : Map[String, @engine.Node],
  out : Array[@engine.DefError],
) -> Unit {
  for name, _ in registry {
    // repeat installer зЩїйМ≤гБЃ lazy-marker key ("lazy:<name>") гБѓгВєгВ≠гГГгГЧгАВ
    if name.length() >= 5 && name[0:5] == "lazy:" {
      continue
    }
    if head_cycles(name, registry, []) {
      out.push(
        def_err(
          name,
          @engine.CircularRef,
          "ref template '\{name}' is circular (infinite structural expansion)",
          "break the ref cycle or add a token-consuming head before the self-reference",
        ),
      )
    }
  }
}

///|
/// absent ref (DR-054 / DR-032): и¶Бзі† ref_target гБЃиІ£ж±ЇеЕИгБМзД°гБД (init_sb гБЃ repeat lowering + дЇЛеЙН
/// зЩїйМ≤жЄИгБњ template гВТеРЂгВА registry гБІ check)гАВеЕ®дїґеПОйЫЖгАВ
fn collect_absent_ref(
  def : @engine.Definition,
  registry : Map[String, @engine.Node],
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.options {
    check_elem_absent_ref(e, registry, out)
  }
  for e in def.positionals {
    check_elem_absent_ref(e, registry, out)
  }
  for c in def.commands {
    collect_absent_ref(c.body, registry, out)
  }
}

///|
fn check_elem_absent_ref(
  e : @engine.ElementDef,
  registry : Map[String, @engine.Node],
  out : Array[@engine.DefError],
) -> Unit {
  match e.ref_target {
    Some(r) =>
      match registry.get(r) {
        Some(_) => ()
        None =>
          out.push(
            def_err(
              e.name,
              @engine.AbsentRef,
              "ref target '\{r}' is not defined in scope or definitions",
              "define '\{r}' as a template (definitions) or in the scope",
            ),
          )
      }
    None => ()
  }
}

///|
/// invalid value range (DR-054 / DR-052): repeat min > maxгАВеЕ®дїґеПОйЫЖгАВ
fn collect_invalid_range(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.positionals {
    match e.repeat {
      Some(spec) =>
        match spec.max {
          Some(mx) =>
            if spec.min > mx {
              out.push(
                def_err(
                  e.name,
                  @engine.InvalidRange,
                  "repeat min \{spec.min} > max \{mx}",
                  "set the repeat max >= min",
                ),
              )
            }
          None => ()
        }
      None => ()
    }
  }
  for c in def.commands {
    collect_invalid_range(c.body, out)
  }
}

///|
/// codex гГђгГУгГ•гГЉжМЗжСШ 4 (2026-07-09 зѓАзЫЃгГђгГУгГ•гГЉ): an option's `ref` + `repeat` lowering
/// (`inst_long`'s `Some(_)` arm) only wires a SINGLE `@engine.GreedyRepeat` spine slot вАФ correct for
/// `min <= 1` (no mandatory-head unrolling, `elem_repeat`'s `Some(spec) => spec.min - 1`
/// mandatory heads collapses to 0), but a `min > 1` spec WOULD unroll extra mandatory heads that
/// `inst_long` silently folds into the SAME single tail (`@engine.Seq(spine)`) вАФ losing both еЕИй£ЯгБД
/// suppression and the greedy еПЦгВКеИЖйБЄе•љ for those extra reps while still parsing "successfully"
/// (issue 2026-07-09-ref-template-result-shape: жЬ™еѓЊењЬжІЛжИРгБѓйїЩгБ£гБ¶и™§еЛХдљЬгБХгБЫгБЪ definition error
/// гБІеПѓи¶ЦеМЦгБЩгВЛе•СзіДгАБ[[retreat-is-last-resort]] еРМеЮЛгБЃгАМе£КгВМгБЯгБЊгБЊеЛХгБЛгБЩгВИгВКиРљгБ®гБЩгАНеИ§жЦ≠)гАВReject at
/// definition time until `@engine.GreedyRepeat` carries multiple spine slots.
fn collect_unsupported_option_ref_repeat(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.options {
    if e.ref_target is Some(_) {
      match elem_repeat(e) {
        Some(spec) =>
          if spec.min > 1 {
            out.push(
              def_err(
                e.name,
                @engine.InvalidRange,
                "option repeat min \{spec.min} > 1 is not supported for a `ref` element (@engine.GreedyRepeat wires a single spine slot only)",
                "use repeat: {\"min\": 0} or {\"min\": 1} on this option, or move the mandatory reps to a positional",
              ),
            )
          }
        None => ()
      }
    }
  }
  for c in def.commands {
    collect_unsupported_option_ref_repeat(c.body, out)
  }
}

///|
/// issue 2026-07-09-accum-fold-update-default-ops (team-lead и£БеЃЪ 2026-07-10гАБ`collect_unsupported_
/// option_ref_repeat` гБЃеЕДеЉЯ вАФ еРМгБШгАМжІЛйА†зЪДгБЂеЃ£и®АгБІгБНгВЛгБМеЃЯи£ЕгБМеѓЊењЬгБІгБНгБ™гБДзµДеРИгБЫгВТ definition-error
/// гБІиРљгБ®гБЩгАНе•СзіД): an `update` variant (DR-077 ¬І1's `:update:<transform>` DSL) targeting a `multiple`
/// (accum) element is REJECTED at definition time. DR-077's `update` semantics are `cell = f(old)`
/// where `old` is the CELL'S CURRENT VALUE вАФ for an accum cell that value is the accumulated array
/// (T[]), but every filters-registry transform is T=>T (scalar, `@engine.FilterSignature`,
/// DR-077 ¬І2 "дљњгБИгВЛгБЃгБѓ transform гВЈгВ∞гГНгГБгГ£ T=>T гБЃ filter гБЃгБњ"). Applying a scalar transform to an
/// array is a STRUCTURAL type mismatch with no legal resolution today (no Acc=>Acc transform exists
/// in the registry) вАФ rather than let it reach the ACCUMULATE fold and fail unpredictably there
/// (or silently coerce), this closes the gap at the SAME layer DR-077 ¬І2 already closes "unknown
/// transform name" / "validate-only signature" (`classify_long_spelling`'s `Invalid` path, both
/// folded into `@engine.UnknownVocab` there) вАФ `multiple` + `update` is a third static-known-bad
/// combination, just discovered one step later (after `normalize_surface` has resolved `variants`,
/// unlike the two above which classify_long_spelling catches at DSL-parse time). `@engine.InvalidRange` is
/// reused (not a new `@engine.DefErrorKind`) for the same reason `classify_long_spelling`'s comment gives:
/// introducing a finer-grained kind is a spec-side DR-054 decision, not kuu.mbt's to make alone.
///
/// spec fixture pin зКґж≥Б (2026-07-10 team-lead йА£зµ°): definition_error format иЗ™дљУгБМ DR-065 гБІдЇИзіДгБЃ
/// гБњгБІжЬ™зҐЇеЃЪгБ™гБЯгВБгАБspec еБігБЃгБУгБЃ reject гБЃ fixture еМЦгБѓдњЭзХЩ (issue иµЈз•®жЄИгБњгАБformat еЃЯдЊЛеМЦгБѓ kawaz
/// и£БеЃЪеЊЕгБ°) вАФ гБУгБЃж§ЬжЯїгБѓ kuu.mbt еБігБЃ wbtest гБІгБЃгБњ pin гБЩгВЛ (`collect_unsupported_option_ref_repeat`
/// гБЃ min>1 reject гВВеРМеЮЛгБЃ wbtest-only pin гБЃеЙНдЊЛ)гАВ
fn collect_unsupported_accum_update(
  def : @engine.Definition,
  out : Array[@engine.DefError],
  extensions : @engine.Registry,
) -> Unit {
  for e in def.options {
    if e.multiple {
      for v in e.variants {
        match v.op {
          @engine.Invoke(_) =>
            out.push(
              def_err(
                e.name,
                @engine.InvalidRange,
                "update variant '\{v.trigger}' targets a multiple (accum) element вАФ every filters-registry transform is T=>T (scalar) but this cell's current value is an accumulated array (T[]), a structural type mismatch with no legal transform today",
                "remove the update variant from this element, or move the transform to a non-multiple (scalar) element",
              ),
            )
          _ => ()
        }
      }
    }
  }
  for e in def.positionals {
    if e.multiple {
      for v in e.variants {
        match v.op {
          @engine.Invoke(_) =>
            out.push(
              def_err(
                e.name,
                @engine.InvalidRange,
                "update variant '\{v.trigger}' targets a multiple (accum) element вАФ every filters-registry transform is T=>T (scalar) but this cell's current value is an accumulated array (T[]), a structural type mismatch with no legal transform today",
                "remove the update variant from this element, or move the transform to a non-multiple (scalar) element",
              ),
            )
          _ => ()
        }
      }
    }
  }
  // codex гГђгГУгГ•гГЉ High 1 (2026-07-10): alias гБЃ `long_override` (DR-057 ¬І3 еЈЃеИЖдЄКжЫЄгБН) гБѓ canonical
  // еБігБЃ `variants` гВТзµМзФ±гБЫгБЪзЛђиЗ™гБЂ colon DSL гВТиІ£йЗИгБЩгВЛ вАФ дЄКгБЃ 2 гГЂгГЉгГЧгБѓ `def.options`/
  // `def.positionals` гБЃ (гБУгБЃжЩВзВєгБЃ) variants гБЧгБЛи¶ЛгБ™гБДгБЯгВБгАБalias зµМзФ±гБЃ `:update:<transform>`
  // гБМеРМгБШж§ЬжЯїгВТгБЩгВКжКЬгБСгБ¶ `parse_definition` гВТйАЪйБОгБЧгАБзЩЇзБЂжЩВгБЂ canonical (multiple и¶Бзі†) гБЄгБЃ
  // @engine.Update binding гБМе±КгБДгБ¶ `resolve.mbt`'s accum еИЖе≤РгБЃ abort гБЂеИ∞йБФгБЩгВЛ
  // (repro: canonical `{"name":"tags","multiple":true}` + alias `{"target":"tags",
  // "long_override":["bump:update:increment"]}` + args `["--bump-t"]`)гАВ`desugar_aliases` (гБУгБЃ
  // ж§ЬжЯїгВИгВКеЊМгБЂиµ∞гВЛ) гБМ alias зФ®гБЃ entry-copy гВТдљЬгБ£гБЯеЊМгБ†гБ®гАБгБЭгБЃcopyиЗ™иЇЂгБѓ `multiple: false`
  // еЫЇеЃЪ (`alias_entry`) гБЂгБ™гВКеИ§еЃЪгБМеИ•гГ≠гВЄгГГгВѓгВТи¶БгВЛ вАФ гБУгБУ (desugar еЙНгАБ`def.aliases` гВТзЫіжО•и¶ЛгВЛ)
  // гБІ `collect_invalid_alias_long_override` гБ®еРМгБШгГСгВњгГЉгГ≥ (colon DSL гВТ `classify_long_spelling`
  // гБІеИЖй°Ю + `find_elem` гБІ alias еЕИ canonical гВТеЉХгБП) гВТеЖНеИ©зФ®гБЩгВЛжЦєгБМжЧҐе≠Ши¶ПзіДгБ®дЄАи≤ЂгБЧгАБ
  // `parse_definition` еЕ®дљУгБЃеЃЯи°Мй†ЖеЇПгВВе§ЙгБИгБЪгБЂжЄИгВАгАВ
  for a in def.aliases {
    match a.long_override {
      Some(List(strs)) =>
        match find_elem(def, a.target) {
          Some(canon) =>
            if canon.multiple {
              let alias_name = match a.name {
                Some(n) => n
                None => a.target
              }
              for l in strs {
                match
                  classify_long_spelling(l, alias_name, canon.ty, extensions) {
                  Variant(v) =>
                    match v.op {
                      @engine.Invoke(_) =>
                        out.push(
                          def_err(
                            canon.name,
                            @engine.InvalidRange,
                            "alias long_override update variant '\{v.trigger}' targets '\{canon.name}', a multiple (accum) element вАФ every filters-registry transform is T=>T (scalar) but this cell's current value is an accumulated array (T[]), a structural type mismatch with no legal transform today",
                            "remove the update variant from this alias's long_override, or move the transform to a non-multiple (scalar) element",
                          ),
                        )
                      _ => ()
                    }
                  Main(_) | Invalid(_, _) => ()
                }
              }
            }
          None => () // dangling alias target вАФ absent-ref check гБМеИ•йАФжЛЊгБЖ
        }
      Some(Forms(forms)) =>
        match find_elem(def, a.target) {
          Some(canon) =>
            if canon.multiple {
              let alias_name = match a.name {
                Some(n) => n
                None => a.target
              }
              for form in forms {
                match
                  classify_long_form(form, alias_name, canon.ty, extensions) {
                  Variant(v) =>
                    match v.op {
                      @engine.Invoke(_) =>
                        out.push(
                          def_err(
                            canon.name,
                            @engine.InvalidRange,
                            "alias long_override cell-fn variant '\{v.trigger}' targets an accumulated element whose structured Value aggregation is not implemented",
                            "use a direct set operation or target a scalar element",
                          ),
                        )
                      _ => ()
                    }
                  Main(_) | Invalid(_, _) => ()
                }
              }
            }
          None => ()
        }
      Some(Bool(_)) => ()
      None => ()
    }
  }
  for c in def.commands {
    collect_unsupported_accum_update(c.body, out, extensions)
  }
}

///|
/// codex гГђгГУгГ•гГЉ High 2 (2026-07-10): `collect_unsupported_accum_update` гБЃ variant иµ∞жЯї (дЄКи®Ш) гБѓ
/// `count_increment_variant` зµМзФ± (`long:true` з≥Ци°£гАБDR-077 ¬І3) гБЃ `:update:increment` гБѓжНХгБЊгБИгВЛгБМгАБ
/// count_type() гБЃ **short** зЩЇзБЂ (`builtins/matcher_residents.mbt` гБЃ `walk_short`'s `count_type()` arm) гБѓ variant гВТдЄАеИЗзµМзФ±гБЫгБЪ
/// `Binding::effect(e.name, @engine.Update("increment", []), @engine.Cli)` гВТзЫіжО•зФЯжИРгБЩгВЛ вАФ variants гВТжМБгБЯгБ™гБД firing гБ™гБЃгБІ
/// variant иµ∞жЯїгБІгБѓгБЭгВВгБЭгВВи¶ЛгБИгБ™гБД (repro: `{"name":"n","type":"count","short":["n"],
/// "multiple":true}` + args `["-n"]` гБІ resolve.mbt гБЃ accum еИЖе≤РгБЃ abort гБЂеИ∞йБФ)гАВ
///
/// DR-077 ¬І3 гБІ count гБѓ `number + default:0 + update:increment гБЃзґігВКеРИжИР` гБ®и¶ПеЃЪгБХгВМгБ¶гБДгВЛ вАФ
/// count гБ®гБДгБЖ TYPE гБЭгБЃгВВгБЃгБМгАМupdate(increment) еКєжЮЬгВТжМБгБ§гАНгБ®гБДгБЖе•СзіДгВТйБЛгБґгБЃгБІгАБfiring гБЃзґігВК
/// (short/long/жШОз§Їvariant) гВТеХПгВПгБЪгАБ**count_type() и¶Бзі†гБЄгБЃ `multiple` еЃ£и®АгБЭгБЃгВВгБЃ**гБМ accum√Чupdate гБ®
/// жІЛйА†зЪДгБЂеРМгБШжЬ™еѓЊењЬжІЛжИР (T=>T transform vs зіѓз©НзКґжЕЛ T[]) гБЂгБ™гВЛгАВvariant гБЃжЬЙзД°гБЂдЊЭе≠ШгБЧгБ™гБДи¶Бзі†
/// гГђгГЩгГЂгБЃж§ЬжЯїгБ®гБЧгБ¶гАБ`collect_unsupported_accum_update` гБ®гБѓеИ•жЭ°дїґгБІеЃЯи£ЕгБЩгВЛ (variant иµ∞жЯїгВТ
/// count_type() гБЂгВВеЇГгБТгВЛгБЃгБІгБѓгБ™гБПгАБcount_type()√Чmultiple гБ®гБДгБЖзµДеРИгБЫиЗ™дљУгВТйЦЙгБШгВЛ вАФ short зµМзФ±гБѓгБЭгВВгБЭгВВ
/// variant гВТзФЯжИРгБЧгБ™гБДгБЯгВБгАБvariant иµ∞жЯїгВТеЇГгБТгБ¶гВВжНХгБЊгБИгВЙгВМгБ™гБД)гАВ
fn collect_unsupported_count_multiple(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.options {
    if e.ty.name() == "count" && e.multiple {
      out.push(
        def_err(
          e.name,
          @engine.InvalidRange,
          "a `count` element cannot declare `multiple` вАФ count's type contract IS an update(increment) effect (DR-077 ¬І3), and every filters-registry transform is T=>T (scalar) while a multiple (accum) cell's current value is an accumulated array (T[]), a structural type mismatch with no legal transform today",
          "remove `multiple` from this count element, or use a plain `number` element with an explicit `:update:<transform>` variant on a non-multiple cell",
        ),
      )
    }
  }
  for e in def.positionals {
    if e.ty.name() == "count" && e.multiple {
      out.push(
        def_err(
          e.name,
          @engine.InvalidRange,
          "a `count` element cannot declare `multiple` вАФ count's type contract IS an update(increment) effect (DR-077 ¬І3), and every filters-registry transform is T=>T (scalar) while a multiple (accum) cell's current value is an accumulated array (T[]), a structural type mismatch with no legal transform today",
          "remove `multiple` from this count element, or use a plain `number` element with an explicit `:update:<transform>` variant on a non-multiple cell",
        ),
      )
    }
  }
  for c in def.commands {
    collect_unsupported_count_multiple(c.body, out)
  }
}

///|
/// DR-083 ¬І5: a non-accum (truly scalar) element's declared default must decode to EXACTLY one
/// piece вАФ an array-shaped JSON default (`length != 1`) for such an element is a STRUCTURAL
/// mismatch known entirely at definition time (no I/O needed, unlike DR-050's config array whose
/// structural mismatch IS a runtime Error precisely because config is read at runtime) вАФ
/// `collect_unsupported_accum_update`'s sibling "жІЛйА†зЪДгБЂеЃ£и®АгБІгБНгВЛгБМеЃЯи£ЕгБМеѓЊењЬгБІгБНгБ™гБДзµДеРИгБЫгВТ
/// definition-error гБІиРљгБ®гБЩ" contract.
///
/// "non-accum" mirrors `ensure_entity`'s OWN accum-eligibility derivation exactly (`e.multiple ||
/// elem_repeat(e) is Some(_) || e.separator is Some(_)`) вАФ computed here on the pre-`ensure_entity`
/// `@engine.ElementDef` fields directly, since this check runs before `@engine.Entity`/`@engine.Entity.accum` exist. Using
/// the narrower `e.multiple` alone would misfire on a `repeat`-only or bare-`separator` element
/// (both legitimately accum cells per `ensure_entity`, DR-043/034) declaring a multi-piece default
/// вАФ this derivation must stay IN SYNC with `ensure_entity`'s if it ever changes.
fn collect_scalar_array_default(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn is_accum_elem(e : @engine.ElementDef) -> Bool {
    e.multiple || elem_repeat(e) is Some(_) || e.separator is Some(_)
  }

  fn check(e : @engine.ElementDef) -> Unit {
    if !is_accum_elem(e) {
      match e.default_values {
        Some(vs) =>
          if vs.length() != 1 {
            out.push(
              def_err(
                e.name,
                @engine.InvalidRange,
                "a non-multiple (scalar) element's declared default must be exactly ONE piece, got \{vs.length()} вАФ an array-shaped default is only legal for a multiple/repeat/separator (accum) element (DR-083 ¬І1/¬І5)",
                "wrap this element's default in `multiple`/`repeat` if it should accumulate, or write a single scalar default value",
              ),
            )
          }
        None => ()
      }
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_scalar_array_default(c.body, out)
  }
}

///|
/// DR-089 ¬І4: none гБЂгБѓеА§з©ЇйЦУгБМзД°гБДгБЃгБІгАБеА§жЇРгВТеЃ£и®АгБЩгВЛ `env`/`config_key`/`inherit` гБѓйЭЩзЪДгБЂжЧҐзЯ•гБЃдЄНжИРзЂЛжІЛжИР
/// вАФ гАМйЭЩзЪДгБЂжЧҐзЯ•гБѓеЃЪзЊ©жЩВгБЂеАТгБЩгАН(DR-083 ¬І5) гБЃз≠ЛгБІ definition-error гБЂгБЩгВЛгАВеЃЯи°МжЩВеБі
/// (`env_value`/`@engine.config_to_value` гБЃ none_type() armгАБresolve.mbt/value.mbt) гБѓйШ≤еЊ° (гБУгБЃгГБгВІгГГгВѓгБМ
/// еЕИгБЂиРљгБ®гБЩгБЃгБІ unreachable жГ≥еЃЪ) гБ®гБЧгБ¶жЃЛгБЩгАВconfig_key гБЃжШОз§ЇеЃ£и®АгБЃгБњгВТеѓЊи±°гБ®гБЧгАБ
/// `config_seat` (config_file и¶Бзі†гБЃе≠ШеЬ®гБІиЗ™еЛХзЪДгБЂеЕ® value cell гБЄеРМеЮЛдїШдЄОгБХгВМгВЛеЄ≠гАБDR-050 ¬І3)
/// гБѓгБУгБУгБІгБѓеѓЊи±°е§Ц вАФ иСЧиАЕгБМжШОз§ЇзЪДгБЂжЫЄгБДгБЯеЃ£и®АгБ†гБСгВТж§ЬжЯїгБЩгВЛ (config_seat гБѓеАЛгАЕгБЃи¶Бзі†гБЃжДПеЫ≥гБІгБѓ
/// гБ™гБПгВєгВ≥гГЉгГЧеЕ®дљУгБЃиЗ™еЛХеЄ∞зµРгБ™гБЃгБІгАБеРМгБШгАМиСЧиАЕгБЃи™§гВКгАНгВЂгГЖгВігГ™гБЂе±ЮгБХгБ™гБД)гАВ
fn collect_none_value_source_decl(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn check(e : @engine.ElementDef) -> Unit {
    if e.ty.name() == "none" {
      if e.env.length() > 0 {
        out.push(
          def_err(
            e.name,
            @engine.InvalidRange,
            "'\{e.name}' is type none (no value space) but declares env вАФ a none element cannot have a value source (DR-089 ¬І4)",
            "remove 'env' from '\{e.name}', or give it a real value type",
          ),
        )
      }
      if e.config_key is Some(_) {
        out.push(
          def_err(
            e.name,
            @engine.InvalidRange,
            "'\{e.name}' is type none (no value space) but declares config_key вАФ a none element cannot have a value source (DR-089 ¬І4)",
            "remove 'config_key' from '\{e.name}', or give it a real value type",
          ),
        )
      }
      if e.is_inherit {
        out.push(
          def_err(
            e.name,
            @engine.InvalidRange,
            "'\{e.name}' is type none (no value space) but declares inherit вАФ a none element cannot have a value source (DR-089 ¬І4)",
            "remove 'inherit' from '\{e.name}', or give it a real value type",
          ),
        )
      }
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_none_value_source_decl(c.body, out)
  }
}

///|
/// DR-102 ¬І1/¬І3 (е±ЮжАІеИЖеЙ≤гАБissue accum-post-filters-stage7 гБЃеЊМзґЩ): `final_filters` (TвЖТT, scalar
/// filter registry, non-accum и¶Бзі†е∞ВзФ®) гБ® `accum_filters` (AccвЖТAcc, ARRAY filter registry, accum
/// и¶Бзі†е∞ВзФ®) гБѓгАБи¶Бзі†гБЃ accum йБ©ж†ЉжАІ (`multiple`/`repeat`/`separator` вАФ `ensure_entity`/
/// `collect_scalar_array_default` гБ®еРМгБШ `is_accum_elem` е∞ОеЗЇ) гБ®жОТдїЦзЪДгБЂеѓЊењЬгБЩгВЛгАВи¶Бзі†гБЂгБЭгВВгБЭгВВ
/// е≠ШеЬ®гБЧгБ™гБДеБігБЃе±ЮжАІгВТжЫЄгБПгБЃгБѓжІЛйА†дЄНдЄАиЗігБІгБВгВКгАБ`collect_scalar_array_default` (йЭЮ accum и¶Бзі†гБЄгБЃ
/// йЕНеИЧ default еЃ£и®А) гБ®еРМеЮЛгБЃ "жІЛйА†зЪДгБЂеЃ£и®АгБІгБНгВЛгБМеЃЯи£ЕгБМеѓЊењЬгБІгБНгБ™гБДзµДеРИгБЫгВТ definition-error гБІ
/// иРљгБ®гБЩ" е•СзіДгБІ kind=invalid-range гВТ reject гБЩгВЛ (fixtures/definition-error/
/// accum-filters-on-non-multiple-invalid-range.json / final-filters-on-multiple-invalid-range.json)гАВ
/// 1 е±ЮжАІ 1 registry гБЃеѓЊењЬ (DR-102 ¬І2) гБЂгВИгВКгАБзґігВКгБЃ registry жЬ™зЩїйМ≤гБѓ `collect_unknown_filter` гБМ
/// еНШзЛђгБІеИ§еЃЪгБЩгВЛ вАФ жЬђ gate гБѓе±ЮжАІгБ®и¶Бзі†гБЃељҐгБЃдЄНдЄАиЗі (layer йБХгБДгБІгБѓгБ™гБПжІЛйА†йБХеПН) гБ†гБСгВТи¶ЛгВЛгАВ
///
/// DR-102 ¬І3 гБЃжШОзҐЇеМЦ note (codex гГђгГУгГ•гГЉ M-9): `type:"none"` и¶Бзі† (еА§з©ЇйЦУгБ™гБЧгАБDR-089) гБЄгБЃ
/// `final_filters` еЃ£и®АгВВеРМгБШ invalid-range гБЂе±ЮгБЩгВЛ вАФ `final_filters` гБѓ TвЖТT гБІеА§з©ЇйЦУгБЃеЮЛ T гБЄгБЃ
/// е§ЙжПЫ/ж§Ьи®ЉгВТеЙНжПРгБ®гБЩгВЛгБМгАБnone гБЂгБѓеА§з©ЇйЦУгБЭгБЃгВВгБЃгБМзД°гБП T гБМе≠ШеЬ®гБЧгБ™гБДгБЯгВБжІЛжИРдЄНиГљ
/// (DR-089 ¬І4 гБ®еРМеЮЛгБЃеЄ∞зµР)гАВaccum йБ©ж†ЉгБ™ none и¶Бзі†гБЃ `accum_filters` (AccвЖТAcc) еЃ£и®АгВВеРМгБШзРЖгБІ
/// invalid-range вАФ йЭЮ accum гБ™ none и¶Бзі†гБЃ `accum_filters` гБѓжЧҐгБЂдЄКгБЃ wrong-seat еИ§еЃЪгБІгВЂгГРгГЉгБХгВМгВЛ
/// гБЯгВБгАБnone еЫЇжЬЙгБЃињљеК†еИ§еЃЪгБѓ accum и¶Бзі†гБЃе†іеРИгБЃгБњењЕи¶БгАВ
fn collect_invalid_filter_attribute_mismatch(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn is_accum_elem(e : @engine.ElementDef) -> Bool {
    e.multiple || elem_repeat(e) is Some(_) || e.separator is Some(_)
  }

  fn check(e : @engine.ElementDef) -> Unit {
    let accum = is_accum_elem(e)
    let none_ty = e.ty.name() == "none"
    if e.final_filters.length() > 0 {
      if none_ty {
        out.push(
          def_err(
            e.name,
            @engine.InvalidRange,
            "a type:\"none\" element has no value space (DR-089) вАФ final_filters (TвЖТT, DR-102 ¬І1) requires a T to operate over, which does not exist here",
            "remove final_filters from this element, or give it a real value type",
          ),
        )
      } else if accum {
        out.push(
          def_err(
            e.name,
            @engine.InvalidRange,
            "an accum (multiple/repeat/separator) element cannot declare final_filters (TвЖТT, non-accum-only final-value gate, DR-102 ¬І1) вАФ this element's final gate is accum_filters (AccвЖТAcc, over the whole accumulated array)",
            "move this chain to accum_filters, or remove multiple/repeat/separator from this element",
          ),
        )
      }
    }
    if e.accum_filters.length() > 0 {
      if !accum {
        out.push(
          def_err(
            e.name,
            @engine.InvalidRange,
            "a non-accum (scalar) element cannot declare accum_filters (AccвЖТAcc, accum-only whole-array gate, DR-102 ¬І1) вАФ this element's final gate is final_filters (TвЖТT, over the single resolved value)",
            "move this chain to final_filters, or declare multiple/repeat/separator on this element",
          ),
        )
      } else if none_ty {
        out.push(
          def_err(
            e.name,
            @engine.InvalidRange,
            "a type:\"none\" element has no value space (DR-089) вАФ accum_filters (AccвЖТAcc, DR-102 ¬І1) requires a T domain to operate over, which does not exist here",
            "remove accum_filters from this element, or give it a real value type",
          ),
        )
      }
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_invalid_filter_attribute_mismatch(c.body, out)
  }
}

///|
/// DR-101 / DR-102 ¬І1/¬І2: filter chain 4 е±ЮжАІ (`value_filters` / `piece_filters` / `final_filters` /
/// `accum_filters`) гБЂжМЗеЃЪгБХгВМгБЯ filter еРНгБМгАБгБЭгБЃе±ЮжАІгБМи¶Бж±ВгБЩгВЛ registry гБЃ owns йЫЖеРИгБЂзЩїйМ≤гБХгВМгБ¶
/// гБДгБ™гБДе†іеРИгБѓ definition-error (kind=`unknown-vocab`)гАВDR-042 ¬І5 гБЃ installer / filter registry
/// еРМж†ЉеОЯеЙЗгБЂгВИгВКгАБlong variant DSL гБЃ update transform еРНж§ЬжЯї (`classify_long_spelling` гБЃ
/// DR-077 ¬І2 йБ©зФ®) гБ®еРМжЧПгБЃеИ§еЃЪгАВ
///
/// `value_filters`/`piece_filters`/`final_filters` гБѓ scalar filter registry (TвЖТT, `lookup_filter`)
/// гВТгАБ`accum_filters` гБѓ ARRAY filter registry (AccвЖТAcc, `lookup_array_filter`) гВТи¶Бж±ВгБЩгВЛ вАФ 1
/// е±ЮжАІ 1 registry гБЃеѓЊењЬ (DR-102 ¬І2) гБЂгВИгВКгАБеРДе±ЮжАІгБѓиЗ™еИЖгБЃ registry гБЃ owns йЫЖеРИгБЃгБњгВТи¶ЛгБ¶
/// unknown-vocab гВТдЄАжДПеИ§еЃЪгБЩгВЛгАВдїЦ registry гБ®гБЃе±§йБХгБДжѓФиЉГ (DR-101 ¬І3гАБSuperseded) гБѓзЩЇзФЯгБЧгБ™гБДгАВ
///
/// гБУгБЃеНШзіФеМЦгБЂгВИгВКгАБ`filters.mbt` гБЃ `apply_filter_chain`/`apply_accum_filter_chain` гБЂеИ∞йБФгБЩгВЛ
/// жЩВзВєгБІеЕ® filter еРНгБМжЧҐгБЂзЩїйМ≤жЄИгБњдњЭи®ЉгБ®гБ™гВКгАБruntime `unknown_filter` reason гБѓ wire гБЛгВЙжґИжїЕгБЩгВЛ
/// (DR-101 ¬І1)гАВ
///
/// DR-102 ¬І3 гБЃжШОзҐЇеМЦ note (codex гГђгГУгГ•гГЉ M-6/M-9): `final_filters`/`accum_filters` гБМи¶Бзі†гБЂгБ®гБ£гБ¶
/// wrong-seat (`collect_invalid_filter_attribute_mismatch` гБМ invalid-range гВТеЗЇгБЩйЭЮ accum и¶Бзі†гБЃ
/// accum_filtersгГїaccum и¶Бзі†гБЃ final_filtersгГї`type:"none"` и¶Бзі†гБЃгБДгБЪгВМгБЛ) гБЃе†іеРИгАБжЬђ gate гБѓгБЭгБЃ
/// е±ЮжАІгБЃдЄ≠иЇЂгВТдЄАеИЗиІ£йЗИгБЧгБ™гБД (unknown-vocab еИ§еЃЪгВТгВєгВ≠гГГгГЧгБЩгВЛ) вАФ wrong-seat еИ§еЃЪгБМжІЛйА†гВ≤гГЉгГИеЕИи°М
/// гБІгБВгВКгАБзґігВКгБЃзЩїйМ≤жЬЙзД°гВТеХПгВПгБЪ invalid-range гБЃгБњгБМе†±еСКгБХгВМгВЛ (definition_error гБЃ
/// `expect.errors` гБѓеЕ®гВ®гГ©гГЉгБЃеЃМеЕ®дЄАиЗійЫЖеРИгАБдЇМйЗНе†±еСКгВТйБњгБСгВЛ)гАВ
fn collect_unknown_filter(
  def : @engine.Definition,
  out : Array[@engine.DefError],
  extensions : @engine.Registry,
) -> Unit {
  fn is_accum_elem(e : @engine.ElementDef) -> Bool {
    e.multiple || elem_repeat(e) is Some(_) || e.separator is Some(_)
  }

  fn push_unknown(
    elem_name : String,
    phase : String,
    fs_name : String,
  ) -> Unit {
    out.push(
      def_err(
        elem_name,
        @engine.UnknownVocab,
        "filter '" +
        fs_name +
        "' in " +
        phase +
        " is not registered in the filters registry (DR-101)",
        "use a registered filter name (see DR-095 ¬І3 canonical filter vocabulary) or remove this chain entry",
      ),
    )
  }

  fn check(e : @engine.ElementDef) -> Unit {
    // value_filters (TвЖТT, scalar filter registry): зґігВКдЄНеЬ®гБѓ unknown-vocab (DR-101 ¬І1)
    for fs in e.value_filters {
      if extensions.lookup_filter(fs.name) is None {
        push_unknown(e.name, "value_filters", fs.name)
      }
    }
    // piece_filters (StringвЖТString, scalar filter registry еЖЕгБЃ string еЯЯ): зґігВКдЄНеЬ®гБѓ
    // unknown-vocab (value_filters гБ®еИ§еЃЪеЕ•еКЫеРМдЄАгАБDR-101 ¬І1)
    for fs in e.piece_filters {
      if extensions.lookup_filter(fs.name) is None {
        push_unknown(e.name, "piece_filters", fs.name)
      }
    }
    // final_filters (TвЖТT, scalar filter registry, non-accum е∞ВзФ®гАБDR-102 ¬І1): ж≠£гБЧгБДеЄ≠ (йЭЮ accum
    // гБЛгБ§ йЭЮ none) гБЃе†іеРИгБЃгБњ unknown-vocab еИ§еЃЪгАВwrong-seat/none-type гБѓ
    // `collect_invalid_filter_attribute_mismatch` гБЃ invalid-range гБЂдЄАдїї (M-6/M-9 жІЛйА†гВ≤гГЉгГИеЕИи°М)гАВ
    if !is_accum_elem(e) && e.ty.name() != "none" {
      for fs in e.final_filters {
        if extensions.lookup_filter(fs.name) is None {
          push_unknown(e.name, "final_filters", fs.name)
        }
      }
    }
    // accum_filters (AccвЖТAcc, ARRAY filter registry, accum е∞ВзФ®гАБDR-102 ¬І1): ж≠£гБЧгБДеЄ≠ (accum гБЛгБ§
    // йЭЮ none) гБЃе†іеРИгБЃгБњ unknown-vocab еИ§еЃЪгАВ
    if is_accum_elem(e) && e.ty.name() != "none" {
      for fs in e.accum_filters {
        if extensions.lookup_array_filter(fs.name) is None {
          push_unknown(e.name, "accum_filters", fs.name)
        }
      }
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_unknown_filter(c.body, out, extensions)
  }
}

///|
/// DR-085 ¬І1 и®Вж≠£ (kawaz и£БеЃЪ 2026-07-10): a `regex_match` filter entry's pattern compile failure is
/// a definition-error (kind=invalid-argument, DR-054 ¬І4 жЫіжЦ∞2 / DR-082 ¬І3) вАФ the pattern is part of
/// the definition and compile validity is statically knowable at definition time (same "йЭЩзЪДгБЂжЧҐзЯ•
/// гБѓеЃЪзЊ©жЩВгБЂеАТгБЩ" posture `collect_scalar_array_default` uses). Checked across all 4 filter-chain
/// phases (piece_filters/value_filters/final_filters/accum_filters, DR-034/DR-009/DR-102) вАФ a
/// `regex_match` entry name-matches unconditionally regardless of which registry the declaring
/// phase actually requires (an `accum_filters` entry named `regex_match` is ALSO independently
/// rejected as unknown-vocab by `collect_unknown_filter`, since `regex_match` isn't a registered
/// ARRAY filter вАФ DR-054's "enumerate ALL errors, no first-error жЙУгБ°еИЗгВК" means both fire, not a
/// conflict). Uses `filters.mbt`'s `@engine.compile_regex` вАФ the SAME compile path `filter_regex_match`
/// runs at match time, so a pattern that passes this gate is guaranteed compilable at runtime too.
/// A wrong arg count (not exactly 1) is left to the runtime "regex_match requires exactly 1 arg"
/// Err (`filter_regex_match`) rather than duplicated here as a second definition-time check вАФ this
/// gate's sole job is "does the pattern compile", not general arity validation.
/// DR-090 ¬І2: a dd element's `match` regex вАФ compile failure is a definition-error, the same
/// treatment `collect_invalid_regex_pattern` gives `regex_match` filter-chain patterns (same
/// `@engine.compile_regex` compile path, same `@engine.InvalidArgument` kind вАФ "pattern compile failure is a
/// definition-time fact, known statically without I/O").
fn collect_invalid_dd_pattern(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn check(e : @engine.ElementDef) -> Unit {
    match e.dd_match {
      Some(pattern) =>
        if compile_regex(pattern) is None {
          out.push(
            def_err(
              e.name,
              @engine.InvalidArgument,
              "dd match pattern '" + pattern + "' failed to compile",
              "fix the pattern syntax for this host's regex dialect (DR-085 ¬І2 / DR-090 ¬І2)",
            ),
          )
        }
      None => ()
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_invalid_dd_pattern(c.body, out)
  }
}

///|
/// DR-102 ¬І2 гБЃжШОзҐЇеМЦ note (codex гГђгГУгГ•гГЉ M-5): registry жЙАжЬЙгВ≤гГЉгГИ вАФ `regex_match` гБѓ scalar
/// filter registry гБЃгБњгБМжЙАжЬЙгБЩгВЛ descriptor (ARRAY filter registry гБѓжЙАжЬЙгБЧгБ™гБД) гБ™гБЃгБІгАБpattern
/// compile ж§ЬжЯїгБѓ `regex_match` гВТеЃЯйЪЫгБЂжЙАжЬЙгБЩгВЛ registry гВТи¶Бж±ВгБЩгВЛе±ЮжАІ (`piece_filters`/
/// `value_filters`/`final_filters`) гБЂгБЃгБњиµ∞гВЛгАВ`accum_filters` (ARRAY filter registry е∞ВзФ®) гБЂгБѓ
/// дЄАеИЗиµ∞гВЙгБ™гБД вАФ зґігВКгБМ `regex_match` гБІгВВ ARRAY registry гБЃ owns йЫЖеРИгБЂзД°гБДгБЃгБІ
/// `collect_unknown_filter` гБМеНШзіФгБ™ unknown-vocab гБІ reject гБЩгВЛгБ†гБСгБІгБВгВКгАБlayer йБХгБДгБЃеЙѓжђ°ж§ЬжЯїгБѓ
/// зЩЇзФЯгБЧгБ™гБД (DR-102 ¬І2 гБЃгАМиЗ™ registry гБЃгБњгВТи¶ЛгВЛгАНеНШзіФеМЦгБ®зЯЫзЫЊгБЧгБ™гБДгБЯгВБгБЃйЩРеЃЪ)гАВ
///
/// DR-102 ¬І3 гБЃжШОзҐЇеМЦ note (codex гГђгГУгГ•гГЉ M-6): `final_filters` гБМ wrong-seat (accum и¶Бзі†гБЊгБЯгБѓ
/// `type:"none"` и¶Бзі†гАБ`collect_invalid_filter_attribute_mismatch` гБМ invalid-range гВТеЗЇгБЩгВ±гГЉгВє)
/// гБЃе†іеРИгАБжЬђ gate гБѓгБЭгБЃдЄ≠иЇЂ (pattern compile) гВТдЄАеИЗиІ£йЗИгБЧгБ™гБД вАФ жІЛйА†гВ≤гГЉгГИеЕИи°МгБІдЇМйЗНе†±еСКгВТйБњгБСгВЛгАВ
fn collect_invalid_regex_pattern(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn is_accum_elem(e : @engine.ElementDef) -> Bool {
    e.multiple || elem_repeat(e) is Some(_) || e.separator is Some(_)
  }

  fn check_chain(name : String, chain : Array[@engine.FnInvocation]) -> Unit {
    for fs in chain {
      if fs.name == "regex_match" &&
        fs.args.length() == 1 &&
        compile_regex(fs.args[0]) is None {
        out.push(
          def_err(
            name,
            @engine.InvalidArgument,
            "regex_match pattern '" + fs.args[0] + "' failed to compile",
            "fix the pattern syntax for this host's regex dialect (DR-085 ¬І2)",
          ),
        )
      }
    }
  }

  fn check(e : @engine.ElementDef) -> Unit {
    check_chain(e.name, e.piece_filters)
    check_chain(e.name, e.value_filters)
    // final_filters: ж≠£гБЧгБДеЄ≠ (йЭЮ accum гБЛгБ§ йЭЮ none) гБЃе†іеРИгБЃгБњ pattern compile ж§ЬжЯї
    // (M-6 wrong-seat gate еЕИи°М)гАВ
    if !is_accum_elem(e) && e.ty.name() != "none" {
      check_chain(e.name, e.final_filters)
    }
    // accum_filters: ARRAY filter registry гБѓ regex_match гВТжЙАжЬЙгБЧгБ™гБДгБЯгВБеЄЄгБЂгВєгВ≠гГГгГЧ
    // (M-5 registry жЙАжЬЙгВ≤гГЉгГИ)гАВ
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_invalid_regex_pattern(c.body, out)
  }
}

///|
/// DR-084 ¬І3 (issue multiple-ref-accum-gap): merge accumulator √Ч ref is a definition-error. The
/// merge marker vocabulary (DR-080 ¬І2) presupposes a separator-split STRING piece list (whole-
/// piece match against `@`/`-x`/`+`) вАФ a `ref` element's firing value is a row (the referenced
/// template's or-branch consumption result, DR-078 ¬І1), which never has a piece list at all, so
/// there is nothing for a marker to match against. Both `ref` and `multiple:{accumulator:"merge"}`
/// are declared, so the mismatch is known statically without I/O вАФ same "жІЛйА†зЪДгБЂеЃ£и®АгБІгБНгВЛгБМеЃЯи£Е
/// гБМеѓЊењЬгБІгБНгБ™гБДзµДеРИгБЫгВТ definition-error гБІиРљгБ®гБЩ" contract `collect_scalar_array_default`/
/// `collect_invalid_filter_attribute_mismatch` use.
fn collect_ref_merge_accum(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn check(e : @engine.ElementDef) -> Unit {
    if e.ref_target is Some(_) && e.accumulator is Some("merge") {
      out.push(
        def_err(
          e.name,
          @engine.InvalidRange,
          "a `ref` element cannot use the merge accumulator вАФ merge's marker vocabulary (DR-080 ¬І2) requires a separator-split string piece list, but a ref element's firing value is a row (DR-078 ¬І1), which has no piece list to match markers against",
          "use `multiple: \"append\"` (or omit `accumulator`, which defaults to append) instead of `accumulator: \"merge\"` on this ref element",
        ),
      )
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_ref_merge_accum(c.body, out)
  }
}

///|
/// DR-105 ¬І2 (зµ±жЛђи£БеЃЪ M-16, е≠ШеЬ®гГЩгГЉгВє): `multiple.flatten` гБѓ `append` accumulator е∞ВзФ®гБЃгГАгВ§гГ§гГЂ
/// (DR-105 ¬І1) вАФ `merge`/`kv_map` з≠ЙгБЭгВМдї•е§ЦгБЃ accumulator гБЂ `flatten` гВ≠гГЉгБМеЃ£и®АгБХгВМгБ¶гБДгВЛгБУгБ®
/// иЗ™дљУ (true/false гБ©гБ°гВЙгБЃеА§гБІгВВ) гБМжІЛйА†дЄНдЄАиЗігБІгБВгВКгАБ`collect_ref_merge_accum`/
/// `collect_invalid_filter_attribute_mismatch` гБ®еРМеЮЛгБЃ "жІЛйА†зЪДгБЂеЃ£и®АгБІгБНгВЛгБМеЃЯи£ЕгБМеѓЊењЬгБІгБНгБ™гБД
/// зµДеРИгБЫгВТ definition-error гБІиРљгБ®гБЩ" е•СзіДгБІ kind=invalid-range гВТ reject гБЩгВЛ (DR-102 ¬І3 гБЃ
/// wrong-seat еИ§еЃЪгБ®еРМеЮЛ вАФ дЄ≠иЇЂгБЃеА§гБѓиІ£йЗИгБЧгБ™гБДгАБеЃ£и®АгБЃжЬЙзД°гБ†гБСгВТи¶ЛгВЛ)гАВ`e.flatten is Some(_)` гБѓ
/// `dec_multiple` гБМгАМгВ≠гГЉгБМ JSON гБЂе≠ШеЬ®гБЧгБЯгБЛгАНгВТгБЭгБЃгБЊгБЊйБЛгБґ Option (`@engine.ElementDef.flatten`'s doc
/// comment) вАФ `Some(false)` (жШОз§Ї `flatten:false` еЃ£и®А) гВВйБХеПНгБ®гБЧгБ¶жЙ±гБЖгАВ
fn collect_flatten_non_append(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn check(e : @engine.ElementDef) -> Unit {
    if e.multiple && e.flatten is Some(_) && e.accumulator is Some(_) {
      out.push(
        def_err(
          e.name,
          @engine.InvalidRange,
          "'\{e.name}' declares multiple.flatten but its accumulator is not \"append\" (DR-105 ¬І2) вАФ flatten is an append-only dial, and this element's accumulator is \"" +
          e.accumulator.unwrap() +
          "\"",
          "remove 'flatten' from this element, or use accumulator:\"append\" (or omit accumulator, which defaults to append)",
        ),
      )
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_flatten_non_append(c.body, out)
  }
}

///|
/// Every accumulated cell must resolve both descriptor seats before lowering. Explicit accumulator
/// names use that resident; repeat, multiple, and separator declarations require the implicit
/// `append` resident. A collector attached to that accumulated cell must also resolve independently.
fn collect_unknown_accumulation_resident(
  def : @engine.Definition,
  extensions : @engine.Registry,
  out : Array[@engine.DefError],
) -> Unit {
  fn check(e : @engine.ElementDef) -> Unit {
    let accumulator = if e.multiple {
      match e.accumulator {
        Some(name) => Some(name)
        None => Some("append")
      }
    } else if elem_repeat(e) is Some(_) || e.separator is Some(_) {
      Some("append")
    } else {
      None
    }
    match accumulator {
      Some(name) => {
        if extensions.lookup_accumulator(name) is None {
          out.push(
            def_err(
              e.name,
              @engine.UnknownVocab,
              "'\{e.name}' requires accumulator '" +
              name +
              "' but no resident with that name is registered",
              "register accumulator '" + name + "' in the active assembly",
            ),
          )
        }
        match e.collector {
          Some(collector) =>
            if collector.name == "from_entries" && collector.args is None {
              out.push(
                def_err(
                  e.name,
                  @engine.InvalidArgument,
                  "collector 'from_entries' requires its canonical argument form",
                  "use {\"from_entries\":\"entries\"}, {\"from_entries\":[\"key\",\"value\"]}, or {\"from_entries\":\"key\"}",
                ),
              )
            } else if extensions.lookup_collector(collector.name) is None {
              out.push(
                def_err(
                  e.name,
                  @engine.UnknownVocab,
                  "'\{e.name}' requires collector '" +
                  collector.name +
                  "' but no resident with that name is registered",
                  "register collector '" +
                  collector.name +
                  "' in the active assembly",
                ),
              )
            }
          None => ()
        }
      }
      None => ()
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_unknown_accumulation_resident(c.body, extensions, out)
  }
}

///|
/// DR-105 ¬І5/¬І8 (зµ±жЛђи£БеЃЪ M-18): `in_range`(scalar filter registry) / `length_range`(ARRAY filter
/// registry, DR-105 ¬І5 жЦ∞и®≠) гБЃ DSL еЉХжХ∞гВТ definition time гБЂйЭЩзЪДж§ЬжЯїгБЩгВЛ вАФ `collect_invalid_regex_
/// pattern` гБЃ regex pattern compile ж§ЬжЯїгБ®еРМеЮЛ ("йЭЩзЪДгБЂжЧҐзЯ•гБѓеЃЪзЊ©жЩВгБЂеАТгБЩ", DR-083 ¬І5 / DR-082 ¬І3)гАВ
/// еЉХжХ∞еАЛжХ∞дЄНдЄАиЗігГїйЭЮжХ∞еА§гБѓ kind=invalid-argument (DR-082 ¬І3 гБЃгАМеНШдЄАеЉХжХ∞еА§гБЭгБЃгВВгБЃгБМи£ЕзљЃгБЃеПЧзРЖзѓДеЫ≤е§ЦгАН)гАБ
/// min>max гБѓ kind=invalid-range (DR-082 ¬І2 гБЃгАМи§ЗжХ∞е±ЮжАІгБЃзµДеРИгБЫгБМеА§еЯЯе§ЦгАНгАБ`@engine.InvalidRange` гБЃ
/// min>max еЙНдЊЛгБ®еРМеЮЛ)гАВfilters.mbt гБЃ `filter_in_range`/`array_filter_length_range` иЗ™иЇЂгБМжМБгБ§
/// runtime fallback (`filter_rejected`) гВТзљЃжПЫгБЩгВЛгБЃгБІгБѓгБ™гБПгАБгБЭгБЃжЙЛеЙНгБІ definition-error гБ®гБЧгБ¶
/// зҐЇеЃЪгБХгБЫгВЛ вАФ `regex_match` гБЃ pattern compile ж§ЬжЯїгБ®еРМгБШгАМruntime еИ∞йБФеЙНгБЂеАТгБЩгАНгГСгВњгГЉгГ≥гАВ
/// еРД filter еРНгБѓиЗ™еИЖгБЃ registry гВТи¶Бж±ВгБЩгВЛе±ЮжАІгБІгБЃгБњж§ЬжЯїгБЩгВЛ (`in_range` гБѓ piece/value/final_filtersгАБ
/// `length_range` гБѓ accum_filters гБЃгБњ) вАФ cross-registry гБЃзґігВКи°Эз™Б (`collect_unknown_filter` гБМ
/// еИ•йАФ unknown-vocab гБІеЉЊгБП) гБ®дЇМйЗНе†±еСКгБЧгБ™гБДгБЯгВБгБЃйЩРеЃЪ (DR-102 ¬І2 гБЃгАМиЗ™ registry гБЃгБњгВТи¶ЛгВЛгАНгБ®
/// еРМгБШйЩРеЃЪгВТиЄПи•≤)гАВwrong-seat (`collect_invalid_filter_attribute_mismatch` гБМ invalid-range гВТеЗЇгБЩ
/// accum и¶Бзі†гБЃ final_filtersгГїйЭЮ accum и¶Бзі†гБЃ accum_filtersгГї`type:"none"` и¶Бзі†) гБѓ
/// `collect_invalid_regex_pattern` гБ®еРМгБШжІЛйА†гВ≤гГЉгГИеЕИи°МгБІжЬђ gate гВТгВєгВ≠гГГгГЧгБЩгВЛ (M-6/M-9 гБ®еРМеЮЛ)гАВ
fn collect_invalid_numeric_filter_args(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn is_accum_elem(e : @engine.ElementDef) -> Bool {
    e.multiple || elem_repeat(e) is Some(_) || e.separator is Some(_)
  }

  // DR-105 ¬І5 жШОзҐЇеМЦ note (a) (codex #3 еПНжШ†): `length_range` гБЃ bound гБѓйЭЮи≤†жХіжХ∞йЩРеЃЪ вАФ йЕНеИЧйХЈгБ®гБДгБЖ
  // еА§еЯЯгБЭгБЃгВВгБЃгБЃеИґзіДгБІгБВгВКгАБ`in_range` гБЃ canonical number (и≤†жХ∞гГїе∞ПжХ∞гВВе¶•ељУ) гБ®гБѓеИ•гБЃеАЛеИ•и¶ПеЙЗгАВ
  // `n.to_int().to_double() == n` гБѓжХіжХ∞жАІеИ§еЃЪ (value.mbt гБЃ `@engine.value_str` гБЃеРМеЮЛгГСгВњгГЉгГ≥гВТжµБзФ®)гАВ
  fn is_nonneg_int(n : Double) -> Bool {
    n >= 0.0 && n.to_int().to_double() == n
  }

  // `nonneg_int`: true гБ™гВЙ `length_range` е∞ВзФ®гБЃйЭЮи≤†жХіжХ∞еИґзіД (min/max гБЭгВМгБЮгВМзЛђзЂЛгБЂ
  // kind=invalid-argumentгАБDR-082 ¬І3гАМи£ЕзљЃеЉХжХ∞гБЃеА§гБЭгБЃгВВгБЃгБМдЄНж≠£гАН) гВТињљеК†гБІи™≤гБЩгАВ`in_range` гБѓ
  // false гБЃгБЊгБЊ (canonical numberгАБжЧҐе≠ШжМЩеЛХгВТе§ЙгБИгБ™гБД)гАВ
  fn check_two_arg(
    name : String,
    fs : @engine.FnInvocation,
    nonneg_int : Bool,
  ) -> Unit {
    if fs.args.length() != 2 {
      out.push(
        def_err(
          name,
          @engine.InvalidArgument,
          "'\{fs.name}' requires exactly 2 args (min, max), got \{fs.args.length()}",
          "provide exactly 2 numeric args, e.g. '\{fs.name}:1:5'",
        ),
      )
      return
    }
    let min = parse_number(fs.args[0])
    let max = parse_number(fs.args[1])
    match (min, max) {
      (None, _) =>
        out.push(
          def_err(
            name,
            @engine.InvalidArgument,
            "'\{fs.name}' min '" + fs.args[0] + "' is not a number",
            "provide a numeric min",
          ),
        )
      (_, None) =>
        out.push(
          def_err(
            name,
            @engine.InvalidArgument,
            "'\{fs.name}' max '" + fs.args[1] + "' is not a number",
            "provide a numeric max",
          ),
        )
      (Some(mn), Some(mx)) => {
        if nonneg_int {
          if !is_nonneg_int(mn) {
            out.push(
              def_err(
                name,
                @engine.InvalidArgument,
                "'\{fs.name}' min \{mn} is not a non-negative integer",
                "provide a non-negative integer min, e.g. '\{fs.name}:0:5'",
              ),
            )
          }
          if !is_nonneg_int(mx) {
            out.push(
              def_err(
                name,
                @engine.InvalidArgument,
                "'\{fs.name}' max \{mx} is not a non-negative integer",
                "provide a non-negative integer max, e.g. '\{fs.name}:0:5'",
              ),
            )
          }
        }
        if mn > mx {
          out.push(
            def_err(
              name,
              @engine.InvalidRange,
              "'\{fs.name}' min \{mn} is greater than max \{mx}",
              "swap min/max so min <= max",
            ),
          )
        }
      }
    }
  }

  fn check_scalar_chain(
    name : String,
    chain : Array[@engine.FnInvocation],
  ) -> Unit {
    for fs in chain {
      if fs.name == "in_range" {
        check_two_arg(name, fs, false)
      }
    }
  }

  fn check_array_chain(
    name : String,
    chain : Array[@engine.FnInvocation],
  ) -> Unit {
    for fs in chain {
      if fs.name == "length_range" {
        check_two_arg(name, fs, true)
      }
    }
  }

  fn check(e : @engine.ElementDef) -> Unit {
    check_scalar_chain(e.name, e.piece_filters)
    check_scalar_chain(e.name, e.value_filters)
    if !is_accum_elem(e) && e.ty.name() != "none" {
      check_scalar_chain(e.name, e.final_filters)
    }
    if is_accum_elem(e) && e.ty.name() != "none" {
      check_array_chain(e.name, e.accum_filters)
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_invalid_numeric_filter_args(c.body, out)
  }
}

///|
/// жЬ®гБЃгБ©гБУгБЛгБЂ `type:"config_file"` и¶Бзі†гБМгБВгВЛгБЛ (DR-050): гБВгВМгБ∞еРМеЮЛ config seat гБМеЕ® value cell гБЂзЂЛгБ§гАВ
fn has_config_file(def : @engine.Definition) -> Bool {
  for e in def.options {
    if e.is_config_file {
      return true
    }
  }
  for e in def.positionals {
    if e.is_config_file {
      return true
    }
  }
  for c in def.commands {
    if has_config_file(c.body) {
      return true
    }
  }
  false
}

///|
/// config cycle (DR-050 ¬І5 / DR-054): config_file и¶Бзі†гБѓ config_key гВТжМБгБ¶гБ™гБД (иЗ™ path гВТ config гБЛгВЙ
/// еЉХгБПеЊ™зТ∞)гАВеЕ®дїґеПОйЫЖгАВ
fn collect_config_cycle(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.options {
    if e.is_config_file && e.config_key is Some(_) {
      out.push(
        def_err(
          e.name,
          @engine.ConfigCycle,
          "config_file element '\{e.name}' cannot have a config_key (еЊ™зТ∞з¶Бж≠Ґ)",
          "remove config_key from the config_file element",
        ),
      )
    }
  }
  for e in def.positionals {
    if e.is_config_file && e.config_key is Some(_) {
      out.push(
        def_err(
          e.name,
          @engine.ConfigCycle,
          "config_file element '\{e.name}' cannot have a config_key (еЊ™зТ∞з¶Бж≠Ґ)",
          "remove config_key from the config_file element",
        ),
      )
    }
  }
  for c in def.commands {
    collect_config_cycle(c.body, out)
  }
}

///|
/// UsefulAST вЖТ AtomicAST гВТ installer chain гБ®гБЧгБ¶йБВи°М (DR-042)гАВ`order` гБѓйБ©зФ® installer еИЧгАБ5
/// invariants гБЂгВИгВКзµРжЮЬгБѓй†ЖеЇПзД°дЊЭе≠ШгАВ
///
/// chain гБѓжЬ®еЕ®дљУгБІ FIXPOINT гБЊгБІеЫЮгВЛ (global гБМзљЃгБДгБЯеЃ£и®АгВТеЊМжЃµ pass гБІ long гБМе±ХйЦЛгБЩгВЛз≠ЙгБЃ
/// inter-installer дЊЭе≠ШгВТ repeat гБІиІ£ж±Ї)гАВtermination: add-if-absent гБ® finite element√Чscope з©ЇйЦУ
/// (copy of copy гБѓ name еРМдЄАгБІ add-if-absent ж≠ҐгБЊгВЛ) гБЂгВИгВК build е±§гБМ monotonically жИРйХЈгБЧгАБе§ЙеМЦгБ™гБЧ
/// pass = fixpointгАВ
///
/// Returns Ok(atomic scope) or Err(еЕ® definition-time errors)гАВstatic check гБѓеЕ®гБ¶иµ∞гБ£гБ¶ 1 list гБЂ append
/// (жЙУгБ°еИЗгВКгБ™гБЧ)гАВеРД @engine.DefError гБѓ {element, kind, message, hint} гВТжМБгБ§гАВ
pub(all) struct LoweredDefinition {
  scope : @engine.Scope
  declaration : @engine.Definition
}

///|
fn element_has_completion_script(element : @engine.ElementDef) -> Bool {
  if element.ty.name() == "completion_script" {
    return true
  }
  match element.body {
    @engine.Cell | @engine.Enum(_) => false
    @engine.Group(items) => {
      for item in items {
        if element_has_completion_script(item) {
          return true
        }
      }
      false
    }
    @engine.Or(branches) => {
      for branch in branches {
        for item in branch.items {
          if element_has_completion_script(item) {
            return true
          }
        }
      }
      false
    }
  }
}

///|
fn definition_has_completion_script(definition : @engine.Definition) -> Bool {
  for element in definition.options {
    if element_has_completion_script(element) {
      return true
    }
  }
  for element in definition.positionals {
    if element_has_completion_script(element) {
      return true
    }
  }
  for command in definition.commands {
    if definition_has_completion_script(command.body) {
      return true
    }
  }
  false
}

///|
/// Definition-wide internal target for the completion_script preset. Public entities retain their
/// own result-facing names and point here through Entity.link; the target is rooted once even when a
/// preset entry lives under a command scope.
fn completion_script_internal_entity() -> @engine.Entity {
  {
    name: "#completion_script",
    link: None,
    ty: string_type(),
    env_key: None,
    config_seat: false,
    config_key: None,
    is_config_file: false,
    is_inherit: false,
    accum: None,
    flatten: false,
    is_multiple_decl: false,
    collector: None,
    default_values: None,
    default_fn: None,
    separator: None,
    piece_filters: [],
    value_filters: [],
    final_filters: [],
    accum_filters: [],
    extension: entity_ext(),
  }
}

///|
fn lower_definition_snapshot_impl(
  def0 : @engine.Definition,
  order : Array[&@engine.InstallerExt],
  extensions : @engine.Registry,
  registry : Map[String, @engine.Node],
) -> Result[LoweredDefinition, Array[@engine.DefError]] {
  let def = clone_def(def0)
  // DR-076 ¬І2 flag еЈЃгБЧжЫњгБИ/и£ЬеЃМгБЃ alias еБійБ©зФ® (issue 2026-07-08 dec-alias-long-override-flag-sugar-
  // gap): `desugar_aliases` гБѓ canonical и¶Бзі†гБЃгАМеЕГгБЃеЮЛгАН(flag_type() гБЃгБЊгБЊгАБresolve_long гБЃи¶ПеЙЗ1еИ§еЃЪгБЂ
  // ењЕй†И) гВТењЕи¶БгБ®гБЩгВЛгБМгАБ`normalize_surface` гБѓ canonical и¶Бзі†гВТ bool_type() гБЄжЫЄгБНжПЫгБИгБ¶гБЧгБЊгБДгАБгБУгБЃжГЕе†±
  // гВТ post-normalize гБ™ `def` гБЛгВЙеПЦгВКжИїгБЫгБ™гБДгАВnormalize еЙНгБЃи§Зи£љгВТеИ•йАФдњЭжМБгБЧгАБalias иІ£ж±ЇжЩВгБ†гБС
  // гБЭгБ°гВЙгВТеПВзЕІгБЩгВЛ (def иЗ™дљУгБЂгБѓ normalize гВТйАЪеЄЄгБ©гБКгВКйБ©зФ®гБЩгВЛ вАФ дЇМйЗН pipeline гБЂгБЧгБ™гБД)гАВ
  let orig = clone_def(def0)
  let errs : Array[@engine.DefError] = []
  // зіФжІЛжЦЗ pre-pass (LOWERING ¬ІA / ¬ІC.4): `:set` вЖТ kebab (Fix 2, DR-071) + dd name жЧҐеЃЪ "--" (Fix 3, DR-064 ¬І5)
  normalize_surface(def, extensions)
  // init_sb гБМ registry гБЂ repeat-lowering template гВТж§НгБИгВЛ (йЭЩзЪД ref check гБМи¶ЛгБИгВЛгВИгБЖгБЂ)гАВ
  // alias entry-copies гБѓ ref/repeat гВТжМБгБЯгБЪгАБcommand alias гБѓ check жЄИ body гВТ clone гБЩгВЛгБЃгБІгАБ
  // static check гБѓ pre-desugar def гБІеЫЮгБЩ (гБУгБЃ 1 жЬђзЫЃгБЃ tree гБѓ registry ж§НгБИиЊЉгБњгБЃгБњгБМзЫЃзЪД)гАВ
  let _ = init_sb(def, registry, extensions)
  for error in @engine.collect_installer_vocab_errors(def, order) {
    errs.push(error)
  }
  collect_unknown_accumulation_resident(def, extensions, errs)
  let view = @engine.DefsView::new(orig, def, registry, extensions)
  for installer in order {
    for error in installer.collect_defs_errors(view) {
      errs.push(error)
    }
  }
  collect_default_fn_errors(def, errs, extensions)
  if errs.length() > 0 {
    return Err(errs) // ALL definition-error еИЧжМЩ
  }
  // alias еЃ£и®А desugar (DR-057): еЃМеЕ®жАІж§ЬжЯї pass еЊМгАБж±ЇеЃЪзЪД pre-passгАВoption entry-copies /
  // command defs гВТињљеК† вАФ fixpoint installer гБМе±ХйЦЛгБЩгВЛгАВ
  desugar_aliases(def, orig, extensions)
  let sb = init_sb(def, registry, extensions) // desugar жЄИ def гБІ scope tree еЖНжІЛзѓЙ
  if definition_has_completion_script(def) {
    sb.output().push_entity(completion_script_internal_entity())
  }
  // еРМеЮЛ default (DR-050 ¬І3): config_file и¶Бзі†гБМгБВгВМгБ∞еЕ® value cell гБЂ config seat гВТеЃ£и®АгАВ1 еЇ¶и®ИзЃЧгАБ
  // ensure_entity гБЂ threadгАВ
  let has_cf = has_config_file(def)
  match
    @engine.run_installer_fixpoint(sb, order, fn(builder) {
      ensure_entities(builder, has_cf)
    }) {
    Ok(scope) => Ok({ scope, declaration: def })
    Err(errors) => Err(errors)
  }
}

///|
pub fn lower_definition(
  def0 : @engine.Definition,
  order : Array[&@engine.InstallerExt],
  extensions : @engine.Registry,
  registry? : Map[String, @engine.Node] = Map([], capacity=0),
) -> Result[@engine.Scope, Array[@engine.DefError]] {
  match lower_definition_snapshot_impl(def0, order, extensions, registry) {
    Ok(lowered) => Ok(lowered.scope)
    Err(errors) => Err(errors)
  }
}

///|
/// installer fixpoint еЊМгБЃ lowered scope гБ®гАБglobal / alias / inheritable гБЃеЃ£и®Ае±§еѓДдЄОгВТ
/// йБ©зФ®гБЧзµВгБИгБЯ declaration snapshot гВТеРМжЩВгБЂињФгБЩгАВ
pub fn lower_definition_snapshot(
  def0 : @engine.Definition,
  order : Array[&@engine.InstallerExt],
  extensions : @engine.Registry,
  registry? : Map[String, @engine.Node] = Map([], capacity=0),
) -> Result[LoweredDefinition, Array[@engine.DefError]] {
  lower_definition_snapshot_impl(def0, order, extensions, registry)
}
