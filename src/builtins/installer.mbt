// installer.mbt Рђћ builtin parse_definition as a chain of installers (DR-042).
//
// UsefulAST (@engine.ElemDef / @engine.Definition / Рђд) Рєњ AtomicAST (@engine.Scope / @engine.Node / @engine.Entity / Рђд) сѓњухёсЂ┐уФІсЂдсѓІ lowering т▒цсђѓ
// тљё installer сЂ» special vocab (long / short / env / dd / ...) сѓњТЅђТюЅсЂЌсђЂapply ТЎѓсЂФ (1) сЂЮсЂ« vocab сѓњ
// READ (тЅіжЎцсЂЌсЂфсЂё Рђћ т«БУеђт▒цсЂ» read-only, invariant РЉа'), (2) greedy УАЏТўЪ / matcher / re-scoping сѓњ
// add-if-absent сЂД implant сЂЎсѓІ, (3) т«ЪСйЊ (@engine.Entity) сЂ« seat (env / inherit) сѓњт«БУеђсЂЎсѓІсђѓ5 invariants сЂФсѓѕсѓі
// chain сЂ«жаєт║ЈсЂФСЙЮтГўсЂЏсЂџсђЂidempotentсђѓт«їтЁеТђДсЂ»сђїchain сЂ«сЂЕсЂ« installer сЂФсѓѓТЅђТюЅсЂЋсѓїсЂфсЂё special vocabсђЇсЂ«ТцюТЪ╗сђѓ
//
// MDR-002 ┬Д3 Т║ќТІа: installer сЂ» node / value / matcher / resolve сЂФСЙЮтГўсЂЌсђЂУЕЋСЙАтЎе (eval) сЂФсЂ»СЙЮтГўсЂЌсЂфсЂёсђѓ
// MDR-002 У┐йУеўсђїCPS сЂ«т░ёуеІсђЇсЂ« installer УдЈу┤ё: repeat сЂ»сѓ╣сЃЉсѓцсЃ│тйб (positional сЂ« Ref / @engine.BoundedTail /
// @engine.ScopeNode) сЂФсЂ«сЂ┐ТГБУдЈтїќсЂЌсђЂ@engine.Or / @engine.Seq / @engine.Rooted тєЁжЃесЂИсЂ«тЪІсѓЂУЙ╝сЂ┐сЂ»ућЪТѕљсЂЌсЂфсЂё (тЈќсѓітѕєжЂИтЦйсЂ«т▒ђТЅђтїќсѓњжЂ┐сЂЉсѓІсЂЪсѓЂ)сђѓ
// MDR-003 тЉйтљЇУдЈу┤ё: bare С║ѕу┤ёУфъсЂ»ТюФт░Й `_` тїќ Рђћ @engine.RepeatSpec сЂ« bare `lazy` сЂ» `lazy_` сЂФ renameсђѓ
// @engine.Entity тЂ┤сЂ« `inherit_` сЂ» node.mbt сЂї rename ТИѕсЂ┐сђѓ

///|
/// One `long` DSL string (DR-011/071/076), classified. `":set"` (bare sentinel) is `LMain`; any
/// OTHER colon form is `LVariant` (an empty prefix, e.g. `":set:true"`, is the element's own
/// bare-degenerate main entry Рђћ DR-076 ┬Д4 Рђћ a NON-empty prefix, e.g. `"no:set:false"`, is a
/// separately-triggered named variant Рђћ DR-011). DR-011 Тўјуб║тїќ (kawaz УБЂт«џ 2026-07-08): a colon-less
/// string (e.g. `"verbose"`) and a colon-having string whose effect word is outside the vocabulary
/// (`set`/`default`/`unset`/`empty`) are BOTH a variant DSL syntax error, not a literal spelling
/// fallback Рђћ `LInvalid` carries the offending string for the caller to surface as a DR-054
/// definition-error `unknown-vocab`. An explicit-spelling entry point belongs to DR-057's alias
/// element, not to `long`'s DSL (there is no "colon-less = literal" escape hatch here anymore).
pub(all) enum LongSpelling {
  LMain(String) // resolved main-entry spelling (`own_name`, verbatim Рђћ see `classify_long_spelling`)
  LVariant(@engine.Variant) // a fully-built variant (trigger/op/operand already resolved against own_name)
  LInvalid(String) // syntax error (colon-less, or unrecognized effect word) Рђћ the original string
} derive(Eq, Debug)

///|
/// Naive scalar coercion for a colon-DSL operand string (`no:set:false`'s `"false"`, `:set:true`'s
/// `"true"`, etc.) into the element's `@engine.Value` per its type Рђћ mirrors `@engine.config_to_value`'s per-type
/// parsers (DR-074/075/076 canonical lexicons) but with a permissive `@engine.VStr` fallback instead of an
/// Error: a DSL operand is a literal the DEFINITION author wrote (not untrusted CLI input), so an
/// unparseable operand degrading to a string is a defensive fallback, not a silent-coercion concern.
fn dsl_operand_value(ty : &@engine.TypeExt, s : String) -> @engine.Value {
  match ty.parse_token(s) {
    Ok(value) => value
    Err(_) =>
      if ty.name() == "flag" || ty.name() == "bool" {
        @engine.VBool(s == "true" || s == "1")
      } else {
        @engine.VStr(s)
      }
  }
}

///|
/// Classify one `long`/`long_override` DSL string against `own_name` (the caller decides WHICH name
/// applies Рђћ a canonical element's own kebab name for `resolve_long`/`normalize_option`, or an
/// alias's re-derived name for `@engine.AliasDef.long_override` desugaring, DR-057 ┬Д3) and the element's
/// type (for `LVariant`'s operand parsing, DR-074/075/076). This is the SOLE interpreter of the
/// colon DSL (DR-011/071/076 wire vocab) Рђћ both `resolve_long` (main `long` attribute) and
/// `desugar_aliases` (alias override desugaring) call this so the two paths can never drift apart
/// (issue 2026-07-08 alias `long_override` gap: aliases used to skip DSL classification entirely,
/// silently misinterpreting `":set:true"` as a literal `"--:set:true"` spelling).
pub fn classify_long_spelling(
  s : String,
  own_name : String,
  ty : &@engine.TypeExt,
) -> LongSpelling {
  if s == ":set" {
    return LMain(own_name)
  }
  let parts = split_colon(s)
  if parts.length() == 1 {
    // DR-011 Тўјуб║тїќ: colon-less сЂ»ТќЄТ│ЋсѓесЃЕсЃ╝ (literal уХ┤сѓісЂИсЂ« fallback сЂ»СИЇТјАуће)сђѓ
    return LInvalid(s)
  }
  let prefix = parts[0]
  let trigger = if prefix == "" { own_name } else { prefix + "-" + own_name }
  // DR-077 ┬Д2 `update` (5th effect word): a SEPARATE arity from set/unset/empty/default Рђћ parts[2]
  // is the filters-registry TRANSFORM NAME (not an operand to coerce via dsl_operand_value), and
  // any remaining segments (parts[3..]) are that transform's own args, threaded through unchecked
  // (arity is a RUNTIME concern Рђћ `apply_transform`, resolve.mbt Рђћ the same split DR-009's filter
  // chain already uses: definition-time only gates existence + signature, DR-077 ┬Д2 "сѓисѓ░сЃЇсЃЂсЃБСИЇжЂЕтљѕ
  // Рєњ definition-error"). `unknown-vocab` (DR-054, ┬Д2 "СИЇтюе Рєњ unknown-vocab") is realized by folding
  // BOTH failure modes into `LInvalid` HERE Рђћ this reuses `push_invalid_long`'s existing
  // @engine.DUnknownVocab collection wholesale instead of a parallel definition-error check
  // (design-priority: ТЌбтГўсЂ«ТъаухёсЂ┐сЂ«ухёсЂ┐тљѕсѓЈсЂЏсЂДУДБТ▒║). codex ТїЄТЉў (issue 2026-07-09, DR-047 сЂ«УеГУеѕ
  // та▒тЉісЂетљїсЂўу»ђуЏ«сЃгсЃЊсЃЦсЃ╝): ТЌДт«ЪУБЁсЂ» `parts[2] == "increment"` сЂ«сЃЈсЃ╝сЃЅсѓ│сЃ╝сЃЅ allowlist сЂасЂБсЂЪ Рђћ
  // DR-077 ┬Д2 сЂ«тЦЉу┤ёжђџсѓі filters registry сѓњт«ЪжџЏсЂФт╝ЋсЂёсЂд signature сѓњТцюТЪ╗сЂЎсѓІтйбсЂФуй«ТЈЏсђѓСИЇтюе
  // (registry сЂФуёАсЂётљЇтЅЇ) сЂесђЂтГўтюесЂЎсѓІсЂї `Validate` signature (transform сЂесЂЌсЂдСй┐сЂѕсЂфсЂёсђЂ
  // DR-077 ┬Д2 "validate-only filters cannot be used as an update transform" сЂетљїсЂўтѕцт«џ) сЂ« 2 сЂцсѓњ
  // тї║тѕЦсЂЌсЂдт╝ЙсЂЈ Рђћ сЂЕсЂАсѓЅсѓѓуЈЙУАї `@engine.DefErrKind` тѕЌТїЎ (DR-054) сЂФ "invalid-signature" уЏИтйЊсЂ«у┤░тѕє kind сЂї
  // уёАсЂёсЂЪсѓЂсђЂСИАТќ╣сЂесѓѓ `@engine.DUnknownVocab` сЂ«сЂЙсЂЙ kind сЂ»тЁ▒жђџсђЂсЃАсЃЃсѓ╗сЃ╝сѓИТќЄУеђсЂасЂЉсЂДуљєућ▒сѓњтѕєсЂЉсѓІ
  // (т«ЪУБЁсЂ«УБЂжЄЈсђЂу┤░тѕє kind У┐йтіасЂ» spec тЂ┤сЂ« DR-054 ТІАт╝хтѕцТќГсЂїУдЂсѓІсЂЪсѓЂУдІжђЂсѓі Рђћ та▒тЉісЂФТўјУеў)сђѓ
  if parts[1] == "update" {
    if parts.length() >= 3 {
      let transform = parts[2]
      match lookup_filter(transform) {
        None => return LInvalid(s) // СИЇтюе: unknown-vocab (registry сЂФуёАсЂётљЇтЅЇ)
        Some(d) =>
          if d.signature.is_transform() {
            let args : Array[String] = []
            let mut i = 3
            while i < parts.length() {
              args.push(parts[i])
              i = i + 1
            }
            return LVariant({
              trigger,
              op: @engine.Update(transform, args),
              operand: None,
            })
          } else {
            return LInvalid(s) // тГўтюесЂЎсѓІсЂї Validate signature: transform сЂесЂЌсЂдСй┐сЂѕсЂфсЂё
          }
      }
    }
    return LInvalid(s)
  }
  let op : @engine.EffectOp? = match parts[1] {
    "set" => Some(@engine.Set)
    "unset" => Some(@engine.Unset)
    "empty" => Some(@engine.Empty)
    "default" => Some(@engine.Default)
    _ => None
  }
  match op {
    // DR-011 Тўјуб║тїќ: УфътйЎтцќсЂ« effect word сѓѓТќЄТ│ЋсѓесЃЕсЃ╝ (colon-less сЂетљїсЂўТЅ▒сЂё Рђћ typo сЂїсђїсЃъсЃЃсЃЂсЂЌсЂфсЂё
    // тЁЦтЈБсђЇсЂесЂЌсЂдж╗ЎсЂБсЂджђџсѓІсЂ«сѓњжў▓сЂљсђЂDR-054 сЂ«ТЕЪТб░ТцютЄ║ТђЮТЃ│)сђѓ
    None => LInvalid(s)
    Some(o) => {
      let operand = if parts.length() >= 3 {
        Some(dsl_operand_value(ty, parts[2]))
      } else {
        None
      }
      LVariant({ trigger, op: o, operand })
    }
  }
}

///|
/// DR-076 ┬Д2: the `:set:true` variant (bare-trigger fire Рєњ literal `true`) a flag's longт▒ЋжќІ
/// composes in Рђћ `classify_long_spelling(":set:true", kebab(name), flag_type())` would build the SAME
/// value (colon-DSL round-trip), this just skips the string-splitting for the one fixed shape.
fn flag_bare_true_variant(name : String) -> @engine.Variant {
  { trigger: kebab(name), op: @engine.Set, operand: Some(@engine.VBool(true)) }
}

///|
/// DR-077 ┬Д3: the `:update:increment` variant (bare-trigger fire Рєњ apply the `increment` transform
/// to the linked cell's old value) a count's longт▒ЋжќІ composes in Рђћ mirrors `flag_bare_true_variant`
/// exactly, just with `@engine.Update("increment", [])` in place of `@engine.Set`/`true` (count has no operand to
/// carry; the fired value depends on the cell's running state, computed by resolve.mbt's fold).
fn count_increment_variant(name : String) -> @engine.Variant {
  { trigger: kebab(name), op: @engine.Update("increment", []), operand: None }
}

///|
/// `@engine.LongDecl` (wire С║їтйб) Рєњ (main-entry spellings Рђћ kebab т▒ЋжќІТИѕсЂ┐, variants)сђѓDR-071 ┬Д1's
/// type-independent `long: true` Рєњ `[":set"]` sugar is what every OTHER type gets; DR-076 ┬Д2 gives
/// `type:"flag"` a DIFFERENT sugar (УдЈтЅЄ1: ти«сЂЌТЏ┐сЂѕ) and an explicit non-empty list gets `:set:true`
/// COMPOSED IN alongside whatever the author wrote (УдЈтЅЄ2: УБют«їсђЂidempotent). DR-077 ┬Д3 gives
/// `type:"count"` the SAME two-rule treatment with `:update:increment` in place of `:set:true` Рђћ
/// count is the 2nd instance of this exact у│ќУАБти«сЂЌТЏ┐сЂѕ+УБют«ї machinery (not a parallel mechanism).
/// This is the ONLY place that needs the bool/array distinction `@engine.LongDecl` preserves Рђћ once
/// collapsed to `Array[String]` (the old design), `long:true` and `long:[":set"]` become
/// indistinguishable, yet DR-076/077 require different flag/count sugar for each (kawaz УБЂт«џ
/// 2026-07-08, spec DR-071 ┬Д1 "wire сЂФсЂ»С║їтйбсЂесѓѓУ╝ЅсѓІсђЂт▒ЋжќІсЂ» long installer сЂ«УДБжЄѕ"). `LInvalid`
/// spellings (DR-011 Тўјуб║тїќ: colon-less / УфътйЎтцќ effect, DR-077 ┬Д2 unknown transform) are silently
/// skipped here Рђћ the caller (`normalize_option`) only reaches this AFTER
/// `collect_invalid_long_dsl` has already surfaced them as definition-errors and `parse_definition`
/// has returned early on any error, so none should be live at this point in practice.
fn resolve_long(
  decl : @engine.LongDecl,
  name : String,
  ty : &@engine.TypeExt,
) -> (Array[String], Array[@engine.Variant]) {
  match decl {
    LBool(false) => ([], [])
    LBool(true) =>
      if ty.name() == "flag" {
        ([], [flag_bare_true_variant(name)])
      } else if ty.name() == "count" {
        ([], [count_increment_variant(name)])
      } else if ty.name() == "none" {
        // DR-089 ┬Д2 сЂ«сђїТХѕУ▓╗ 0 сЂ«у┤ћсЃѕсЃфсѓгсђЇcanonical СЙІ (`{"name": "sep", "long": true}`) Рђћ
        // flag_type()/count_type() сЂетљїсЂўсђїmain entry сѓњТїЂсЂЪсЂџ bare-true variant сЂасЂЉсђЇсЂ« 3 СЙІуЏ«сђѓnone сЂФсЂ»
        // жЂІсЂХтђцсЂїуёАсЂёсЂ«сЂД `flag_bare_true_variant` сЂ«сЃЌсЃгсЃ╝сѓ╣сЃЏсЃФсЃђ (`@engine.Set @engine.VBool(true)`) сѓњсЂЮсЂ«сЂЙсЂЙ
        // тєЇтѕЕућесЂЌсЂдсѓѕсЂё Рђћ сЂЊсЂ« @engine.Binding сЂ» `build_result` тЂ┤сЂД `@engine.NoneCell` сЂФсѓѕсѓіухљТъюсЂІсѓЅжЎцтцќсЂЋсѓїсѓІ
        // (`resolve.mbt` тЈѓуЁД)сђЂcommitted тЈѓтіа (conflicts/exclusive/requires сЃѕсЃфсѓгтЂ┤) сЂасЂЉсЂїућЪсЂЇсѓІсђѓ
        ([], [flag_bare_true_variant(name)])
      } else {
        ([kebab(name)], [])
      }
    LList(strs) => {
      let longs : Array[String] = []
      let vars : Array[@engine.Variant] = []
      for l in strs {
        match classify_long_spelling(l, kebab(name), ty) {
          LMain(n) => longs.push(n)
          LVariant(v) => vars.push(v)
          LInvalid(_) => ()
        }
      }
      if ty.name() == "flag" && (longs.length() > 0 || vars.length() > 0) {
        let bare_true = flag_bare_true_variant(name)
        let mut already = false
        for v in vars {
          if v == bare_true {
            already = true
          }
        }
        if !already {
          vars.push(bare_true)
        }
      }
      if ty.name() == "count" && (longs.length() > 0 || vars.length() > 0) {
        let bare_inc = count_increment_variant(name)
        let mut already = false
        for v in vars {
          if v == bare_inc {
            already = true
          }
        }
        if !already {
          vars.push(bare_inc)
        }
      }
      (longs, vars)
    }
  }
}

///|
pub fn owned_vocab(installer : &@engine.InstallerExt) -> String {
  match installer.vocab() {
    [first, ..] => first
    [] => ""
  }
}

///|
/// тђцсЃЌсЃфсЃЪсЃєсѓБсЃќсЂ«тћ»СИђсЂ«ТДІу»Ѕуѓ╣ (positional / long / short сЂёсЂџсѓїсЂ« value slot сѓѓсЂЊсЂЊсѓњжђџсѓІ,
/// issue 2026-07-09-separator-non-string-type-parse-gap Т«х1: С╗ЦтЅЇсЂ» `elem_head` сЂасЂЉсЂї
/// `separator` сѓњУдІсЂд `separated resident` сЂФтѕєт▓љсЂЌсђЂlong/short main entry сЂ»сЂЊсЂ«жќбТЋ░сѓњ `separator` ТіюсЂЇсЂД
/// уЏ┤ТјЦтЉ╝сѓЊсЂДсЂёсЂЪсЂЪсѓЂсђЂlong/short option сЂД `multiple + separator` сѓњт«БУеђсЂЌсЂдсѓѓтѕєтЅ▓сЂїСИђтѕЄті╣сЂІсЂфсЂё
/// ТЌбтГўсЃљсѓ░сЂїсЂѓсЂБсЂЪ Рђћ `separator` сѓњсЂЊсЂ«жќбТЋ░УЄфУ║ФсЂ«тѕєт▓љсЂФТа╝СИісЂњсЂЌсђЂтЉ╝сЂ│тЄ║сЂЌтЁЃ (positional сЂ«
/// `elem_head` / long сЂ« `inst_long` main entry) сЂїтљїсЂўтѕцТќГсѓњтЁ▒ТюЅсЂЎсѓІсѓѕсЂєСИђтЁЃтїќсЂЌсЂЪсђѓ`separator`
/// сЂї `Some` сЂфсѓЅ `separated resident` сѓњТДІу»ЅсЂЌсђЂтъІТЃЁта▒ (ty/int_round/allow_base_prefix) сѓњсЂЮсЂ«сЂЙсЂЙжЂІТљгсЂЎсѓІ
/// (Т«х2: separated resident УЄфУ║ФсЂї piece сЂћсЂесЂФтъІ parse сѓњУАїсЂєсђЂ`sep_binds` тЈѓуЁД) Рђћ Т«х1 (тѕєтЅ▓УЄфСйЊсѓњжЁЇуиџ) сЂе
/// Т«х2 (тѕєтЅ▓тЙїсЂ«тъІ parse) сЂ»тљїСИђсѓхсѓцсѓ»сЃФсЂДт░јтЁЦт┐Ёжаѕ (issue У┐йУеў2: Т«х1 тЇўуІгсЂДсЂ»ТѕљтіЪу│╗сЂї regress сЂЎсѓІ
/// т«ЪТИгуб║УфЇТИѕсЂ┐)сђѓ
/// `merge` (DR-080 Т│бтЈіу»ђ): `@engine.ElemDef.accumulator == Some("merge")` сЂ«у┤ажђџсЂЌсђѓСИАтЉ╝сЂ│тЄ║сЂЌтЁЃ
/// (`elem_head` / `inst_long` main entry) сЂїтљїсЂўтѕцТќГ (`e.accumulator` сѓњУдІсѓІ) сѓњтЁ▒ТюЅсЂЎсѓІсђѓ
///
/// codex Medium У┐йтЙЊ (2026-07-10, issue merge-no-separator-marker-gap): ухїУи»жЂИТіъсЂ»
/// `separator is Some(_)` **тЇўуІг**сЂДсЂ»сЂфсЂЈ `separator is Some(_) || merge` Рђћ merge т«БУеђУдЂу┤асЂ»
/// `separator` Тюфт«БУеђсЂДсѓѓ `separated resident` (piece тЄдуљє) тЂ┤сЂИжђ▓сѓђсђѓ`separator` сЂ» `separated resident` сЂИсЂЮсЂ«сЂЙсЂЙ
/// `String?` сЂДжЂІсЂ│ (`sep_binds` сЂї `None` сѓњсђї1 piece = тЁеСйЊсђЇсЂесЂЌсЂдТЅ▒сЂєсђЂDR-034 ┬Д6.3 сЂ«уИ«жђђ)сђЂ
/// сЃъсЃ╝сѓФсЃ╝УфЇУГў (`@engine.classify_merge_piece`) сЂ» piece ТЋ░сЂФжќбсѓЈсѓЅсЂџтљїсЂў pipeline сЂДті╣сЂЈ Рђћ `--fields -a`
/// (separator уёАсЂЌсђЂсѓ│сЃ│сЃъсЂДтЅ▓сѓІСйЎтю░сЂїуёАсЂё) сЂДсѓѓ `-a` сЂї remove сЃъсЃ╝сѓФсЃ╝сЂесЂЌсЂдУДБжЄѕсЂЋсѓїсѓІсђѓ
/// merge сЂДсЂфсЂёУдЂу┤асЂ»тЙЊТЮЦжђџсѓі `separator is Some(_)` сЂ«сЂ┐сЂї gate (сЂЊсЂ«тѕєт▓љсЂ»СИЇтцЅ)сђѓ
///
/// `kv_map` (DR-091 ┬Д2): `@engine.ElemDef.accumulator == Some("kv_map")` сЂ» `merge`/`separator` сЂ« separated resident
/// ухїУи»сЂесЂ»тѕЦТъЮ Рђћ kv_map сЂ»сђї1 token = 1 pieceсђЇсЂД separator тѕєтЅ▓сѓњт┐ЁУдЂсЂесЂЌсЂфсЂё (`k=v` сЂ« `=` тѕєтЅ▓сЂ»
/// сЂЊсЂ« node сЂ«С╗ЋС║ІсЂДсЂ»сЂфсЂЈ `resolve.mbt`'s `build_result` сЂїуЋ│сЂ┐ТЎѓсЂФУАїсЂєсђЂnode.mbt сЂ« `kv resident` doc
/// commentтЈѓуЁД)сђѓ`merge` сѓѕсѓітЁѕсЂФтѕцт«џсЂЎсѓІсЂ«сЂ»СИцУђЁсЂїтљїТЎѓсЂФуюЪсЂФсЂфсѓІсЂЊсЂесЂ»уёАсЂё (decode т▒ц `dec_multiple`
/// сЂї `accumulator` сѓњтЇўСИђ `String?` сЂесЂЌсЂдсЂЌсЂІжЂІсЂ░сЂфсЂёсђЂDR-080/DR-091 сЂ«сЂЕсЂАсѓЅсЂІСИђТќ╣сЂ«УфътйЎ) сЂЪсѓЂ
/// жаєт║ЈсЂФТёЈтЉ│сЂ»уёАсЂёсЂїсђЂkv resident сЂї separated resident сЂ«тѕєт▓љсЂФти╗сЂЇУЙ╝сЂЙсѓїсЂфсЂёсѓѕсЂєТюђтѕЮсЂФтѕЄсѓітЄ║сЂЎсђѓ
fn value_prim(
  ty : &@engine.TypeExt,
  name : String,
  int_round : @engine.RoundMode,
  allow_base_prefix : Bool,
  bool_config : @engine.BoolConfig,
  piece_filters : Array[@engine.FilterSpelling],
  separator? : String? = None,
  merge? : Bool = false,
  kv_map? : Bool = false,
) -> @engine.Node {
  let configured = configured_type(
    ty, int_round, allow_base_prefix, bool_config,
  )
  if kv_map {
    kv_arg(name, piece_filters)
  } else if separator is Some(_) || merge {
    separated_arg(
      name, separator, configured, int_round, allow_base_prefix, bool_config, piece_filters,
      merge,
    )
  } else {
    match ty.name() {
      "number" => number_arg(name, allow_base_prefix, piece_filters)
      "int" => int_arg(name, int_round, allow_base_prefix, piece_filters)
      "float" => float_arg(name, piece_filters)
      "bool" => bool_arg(name, bool_config, piece_filters)
      "string" => string_arg(name, piece_filters)
      _ =>
        // A value-less resident still consumes its positional token structurally; the
        // placeholder binding is removed through the element's NoneCell metadata.
        if configured.has_value_slot() {
          typed_arg(name, configured, piece_filters)
        } else {
          string_arg(name, piece_filters)
        }
    }
  }
}

///|
fn copy_strs(a : Array[String]) -> Array[String] {
  let r : Array[String] = []
  for x in a {
    r.push(x)
  }
  r
}

///|
/// Deep-copy an `Array[@engine.FilterSpelling]` Рђћ mirrors `copy_strs`'s discipline (global/alias desugaring
/// pushes COPIES into descendant scopes, `clone_elem`'s doc comment) but also copies each entry's
/// own `args : Array[String]` (a mutable nested array `copy_strs`-style aliasing would otherwise
/// share across scope copies).
fn copy_filter_spellings(
  a : Array[@engine.FilterSpelling],
) -> Array[@engine.FilterSpelling] {
  let r : Array[@engine.FilterSpelling] = []
  for fs in a {
    r.push({ name: fs.name, args: copy_strs(fs.args) })
  }
  r
}

///|
/// ТюЅті╣ long уХ┤сѓіСИђУдД (post-normalize; `:set` сЂ»ТЌбсЂФ kebab(name) сЂФт▒ЋжќІТИѕсЂ┐сђЂ`normalize_option` сЂї
/// `@engine.LongDecl` сѓњ `LList([<kebab main entries>])` сЂФуб║т«џсЂЋсЂЏсЂЪтЙїсЂ«тйб)сђѓ[] = main-entry сЂфсЂЌ (DR-071)сђѓ
/// pre-normalize сЂф `LBool` сЂ»сЂЊсЂЊсЂФТЮЦсЂфсЂётЅЇТЈљ (тЉ╝сЂ│тЄ║сЂЌсЂ»тЁесЂд normalize тЙї)сђѓ
fn long_of(e : @engine.ElemDef) -> Array[String] {
  match e.long {
    LList(strs) => strs
    LBool(_) => []
  }
}

///|
fn copy_long(l : @engine.LongDecl) -> @engine.LongDecl {
  match l {
    LBool(b) => LBool(b)
    LList(strs) => LList(copy_strs(strs))
  }
}

///|
fn copy_chars(a : Array[Char]) -> Array[Char] {
  let r : Array[Char] = []
  for x in a {
    r.push(x)
  }
  r
}

///|
fn copy_variants(a : Array[@engine.Variant]) -> Array[@engine.Variant] {
  let r : Array[@engine.Variant] = []
  for x in a {
    r.push(x)
  }
  r
}

///|
fn clone_elem(e : @engine.ElemDef) -> @engine.ElemDef {
  {
    name: e.name,
    ty: e.ty,
    long: copy_long(e.long),
    variants: copy_variants(e.variants),
    short: copy_chars(e.short),
    env: copy_strs(e.env),
    is_tty: e.is_tty,
    tty_stream: e.tty_stream,
    tty_cygwin: e.tty_cygwin,
    is_dd: e.is_dd,
    is_exact: e.is_exact,
    dd_match: e.dd_match,
    dd_self_keep: e.dd_self_keep,
    is_global: e.is_global,
    is_inherit: e.is_inherit,
    is_inheritable: e.is_inheritable,
    link_depth: e.link_depth,
    ref_target: e.ref_target,
    repeat: e.repeat,
    optional: e.optional,
    multiple: e.multiple,
    accumulator: e.accumulator,
    flatten: e.flatten,
    separator: e.separator,
    collector: e.collector,
    fail_action: e.fail_action,
    is_config_file: e.is_config_file,
    config_key: e.config_key,
    export_key: e.export_key,
    requires: e.requires,
    conflicts_with: e.conflicts_with,
    exclusive_group: e.exclusive_group,
    required_group: e.required_group,
    required: e.required,
    value_requires: e.value_requires,
    deprecated: e.deprecated,
    is_alias: e.is_alias,
    hidden: e.hidden,
    completer: e.completer,
    default_values: e.default_values,
    int_round: e.int_round,
    allow_base_prefix: e.allow_base_prefix,
    bool_config: e.bool_config,
    piece_filters: copy_filter_spellings(e.piece_filters),
    value_filters: copy_filter_spellings(e.value_filters),
    final_filters: copy_filter_spellings(e.final_filters),
    accum_filters: copy_filter_spellings(e.accum_filters),
    long_prefix: e.long_prefix,
    short_prefix: e.short_prefix,
    env_prefix: e.env_prefix,
    auto_env: e.auto_env,
    long_eq_sep: e.long_eq_sep,
    short_combine: e.short_combine,
    short_attached_value: e.short_attached_value,
    body: clone_body(e.body),
  }
}

///|
/// MDR-004: deep-clone `@engine.ElemBody`'s nested `@engine.ElemDef`s (mirrors the Array-field deep-copy discipline
/// `clone_elem` already applies to `long`/`variants`/`short`/`env` Рђћ global/alias desugaring pushes
/// COPIES into descendant scopes, so aliasing the same mutable nested arrays across scopes would be
/// a bug).
fn clone_body(b : @engine.ElemBody) -> @engine.ElemBody {
  match b {
    BCell => BCell
    BOr(branches) => {
      let out : Array[@engine.OrBranch] = []
      for br in branches {
        let items : Array[@engine.ElemDef] = []
        for it in br.items {
          items.push(clone_elem(it))
        }
        out.push({ id: br.id, items })
      }
      BOr(out)
    }
    BGroup(items) => {
      let out : Array[@engine.ElemDef] = []
      for it in items {
        out.push(clone_elem(it))
      }
      BGroup(out)
    }
    BEnum(values) => BEnum(copy_strs(values))
  }
}

///|
/// snake_case Рєњ kebab-case (DR-022): AST key сЂ» snake, CLI long сЂ» kebabсђѓASCII сЂ«сЂ┐ТЃ│т«џсђѓ
fn kebab(name : String) -> String {
  let buf = StringBuilder::new()
  for c in name {
    if c == '_' {
      buf.write_char('-')
    } else {
      buf.write_char(c)
    }
  }
  buf.to_string()
}

///|
/// у┤ћТДІТќЄ pre-pass (LOWERING ┬ДA / ┬ДC.4)сђѓstatic check сЂе installer fixpoint сЂ«тЅЇсЂФУх░сѓІ:
///   Fix 2 (┬ДB.1 / DR-071 / DR-076 ┬Д2, kawaz УБЂт«џ 2026-07-08): `resolve_long` сЂї `@engine.LongDecl` (wire С║їтйб)
///   сѓњУДБжЄѕсЂЌсђЂmain entry (kebab т▒ЋжќІТИѕсЂ┐) сЂе variants сЂФуб║т«џсЂЋсЂЏсѓІсђѓу│ќУАБт▒ЋжќІсЃ╗flag ти«сЂЌТЏ┐сЂѕ/УБют«їсЃ╗
///   colon DSL тѕєжАъсЂ»сЂЊсЂЊсЂФжЏєу┤ё Рђћ decode т▒ц (dec_long) сЂ»сѓѓсЂє wire сЂ«тйбсѓњтєЎсЂЎсЂасЂЉ (С║їтйбсЂ«тї║тѕЦсЂ» decode
///   тЙїсЂФТй░сЂЋсЂфсЂёсђЂ`resolve_long` сЂ«сѓ│сЃАсЃ│сЃѕтЈѓуЁД)сђѓ
///   Fix 3 (DR-064 ┬Д5): dd УдЂу┤асЂД name ТюфТїЄт«џсЂфсѓЅ trigger уХ┤сѓісѓњ "--" сЂФТЌбт«џ
///   Fix 4 (LOWERING ┬ДA.5 / DR-076 ┬Д2): flag_type() сЂ«тђцсѓ╗сЃФсѓњ bool_type() сЂИти«сЂЌТЏ┐сЂѕ (flag = bool + default:false +
///   long уХ┤сѓітљѕТѕљ)сђѓсЂЊсѓїсЂФсѓѕсѓі inst_long / eq_entries сЂ» flag_type() сѓњуЅ╣Т«іТЅ▒сЂёсЂЎсѓІт┐ЁУдЂсЂїсЂфсЂЈсЂфсѓісђЂbool сЂе
///   т«їтЁетљїСИђсЂ« lowering ухїУи»сЂФУЄфуёХсЂФС╣ЌсѓІ (flag тЏ║ТюЅсЂ« lowering тѕєт▓љсѓњсђїтъІти«сЂЌТЏ┐сЂѕ + resolve_longсђЇсЂ«
///   2 уѓ╣сЂасЂЉсЂФуИ«жђђсЂЋсЂЏсѓІсђЂDR-076 ┬Д2 УдЈтЅЄ4)сђѓ
fn normalize_surface(def : @engine.Definition) -> Unit {
  let mut i = 0
  while i < def.options.length() {
    def.options[i] = normalize_option(def.options[i])
    i = i + 1
  }
  i = 0
  while i < def.positionals.length() {
    def.positionals[i] = normalize_dd_name(def.positionals[i])
    i = i + 1
  }
  for c in def.commands {
    normalize_surface(c.body)
  }
}

///|
/// DR-076 ┬Д2: flag сЂ«т▒ЋжќІтЙїсЂ«тђцсѓ╗сЃФсЂ» bool (LOWERING ┬ДA.5) Рђћ resolve_long сЂ»тЁЃсЂ«тъІ (e.ty, сЂЙсЂа flag_type())
/// сЂДтѕцт«џсЂЎсѓІт┐ЁУдЂсЂїсЂѓсѓІсЂ«сЂДсђЂтъІти«сЂЌТЏ┐сЂѕсѓѕсѓітЁѕсЂФтЉ╝сЂХсђѓ`flag_type() Рєњ bool_type()` сЂ»сЂЊсЂЊсЂДуб║т«џсЂЌсЂдсѓѕсЂё Рђћ `bool_type()`
/// тъІсЂ« short/eq-split ТїЎтІЋсЂ» "bool_type() тЁеУѕгсЂФућ╗СИђуџёсЂфсЃФсЃ╝сЃФ" (жЮъТХѕУ▓╗сЃ╗тЏ║т«џ true) сЂДжќЅсЂўсѓІсЂ«сЂДсђЂтцЅТЈЏтЙїсѓѓ
/// сђїтЁЃ flag сЂасЂБсЂЪсЂІсђЇсѓњУдџсЂѕсЂдсЂісЂЈт┐ЁУдЂсЂїуёАсЂё (builtins/matcher_residents.mbt сЂ« `flag_type() | bool_type()` сѓбсЃ╝сЃасЂїСИАТќ╣ flag тъІсЂе
/// сЂЌсЂдТЅ▒сЂєсЂ«сЂ»сЂЊсЂ«ућ╗СИђТђДсЂ«сЂісЂІсЂњ)сђѓ
///
/// DR-077 ┬Д3 (`count_type()`) сЂ»т»ЙуД░уџёсЂфу│ќУАБсЂФУдІсЂѕсЂд **сЂЊсЂЊсЂДсЂ» number_type() сЂФтцЅТЈЏсЂЌсЂфсЂё** Рђћ count ућ▒ТЮЦсЂ« short/
/// eq-split ТїЎтІЋ (жЮъТХѕУ▓╗сЃ╗тЏ║т«џ increment) сЂ»сђїnumber_type() тЁеУѕгсђЇсЂФсЂ»жЂЕућесЂДсЂЇсЂфсЂё (ordinary number сЂ« short
/// сЂ»тђцсѓњТХѕУ▓╗сЂЎсѓІсЂ«сЂїТГБсЂЌсЂёТїЎтІЋсђЂ`-n5` уГЅ) сЂ«сЂДсђЂflag сЂежЂЋсЂБсЂдсђїтъІтцЅТЈЏтЙїсѓѓтЁЃ count сЂасЂБсЂЪсЂІсђЇсѓњУдџсЂѕсЂд
/// сЂісЂЈт┐ЁУдЂсЂїсЂѓсѓІсђѓ@engine.ElemDef сЂФт░ѓућесЃъсЃ╝сѓФсЃ╝сѓњТќ░УеГсЂЎсѓІС╗БсѓЈсѓісЂФсђЂ**count_type() сЂесЂёсЂєсѓ┐сѓ░УЄфСйЊсѓњ installer chain
/// сЂ«жќЊсЂџсЂБсЂеС┐ЮТїЂсЂЌсђЂтђцсѓ╗сЃФсЂ«т«ЪСйЊтъІ (@engine.Entity.ty = number_type()) сЂИсЂ«тЈјТЮЪсѓњ `ensure_entity` сЂЙсЂДжЂЁт╗ХсЂЋсЂЏсѓІ**
/// (`ensure_entity` сЂ«сѓ│сЃАсЃ│сЃѕтЈѓуЁД) Рђћ ТЌбтГўсЂ«тъІсЂЮсЂ«сѓѓсЂ«сЂїТЃЁта▒сѓњжЂІсЂХУеГУеѕсЂ»т┤ЕсЂЋсЂџсђЂcollapse сЂ«сѓ┐сѓцсЃЪсЃ│сѓ░сЂасЂЉ
/// тЙїсѓЇсЂФсЂџсѓЅсЂЎсђѓshort/eq-split matcher (builtins/matcher_residents.mbt) сЂ» `count_type()` сѓњ `flag_type() | bool_type()` сЂеСИдсЂХугг 3 сЂ«
/// жЮъТХѕУ▓╗ТїЎтІЋсЂесЂЌсЂдТЅ▒сЂєсђѓ
fn normalize_option(e : @engine.ElemDef) -> @engine.ElemDef {
  if e.is_dd {
    normalize_dd_name(e)
  } else {
    let (longs, vars) = resolve_long(e.long, e.name, e.ty)
    // flag_type() сЂ» bool_type() сЂИТЏИсЂЇТЈЏсѓЈсѓі `ensure_entity` тѕ░жЂћТЎѓсЂФсЂ»тЁЃ flag_type() сЂасЂБсЂЪсЂІсѓњтѕцтѕЦсЂДсЂЇсЂфсЂЈсЂфсѓІ
    // сЂЪсѓЂсђЂflag preset сЂ« default:false (LOWERING ┬ДA.5) сЂ»сЂЊсЂ«тъІти«сЂЌТЏ┐сЂѕсЂетљїсЂўта┤ТЅђсЂДуб║т«џсЂЋсЂЏсѓІ
    // (issue group-inner-bool-default-false-duplicate-top-level: plain bool_type() сЂ»ТџЌж╗Ў default сѓњ
    // ТїЂсЂЪсЂфсЂёсЂ«сЂД `ensure_entity` тЂ┤сЂ«Т│етЁЦт»ЙУ▒АсѓњухъсѓІСИђТќ╣сђЂflag ућ▒ТЮЦсЂ« bool_type() сЂ» preset сѓњуХГТїЂсЂЎсѓІ
    // т┐ЁУдЂсЂїсЂѓсѓІ Рђћ Тўјуц║ default сЂїсЂѓсѓїсЂ░сЂЮсЂАсѓЅсЂїтІЮсЂцсЂ«сЂ»тцЅсѓЈсѓЅсЂфсЂё)сђѓ
    let default_values2 = if e.ty.name() == "flag" && e.default_values is None {
      Some([@engine.VBool(false)])
    } else {
      e.default_values
    }
    let ty2 = if e.ty.name() == "flag" { bool_type() } else { e.ty }
    {
      ..e,
      ty: ty2,
      default_values: default_values2,
      long: LList(longs),
      variants: vars,
    }
  }
}

///|
fn normalize_dd_name(e : @engine.ElemDef) -> @engine.ElemDef {
  if e.is_dd && e.name == "" {
    { ..e, name: "--" } // DR-064 ┬Д5
  } else {
    e
  }
}

///|
fn clone_def(d : @engine.Definition) -> @engine.Definition {
  let os : Array[@engine.ElemDef] = []
  for e in d.options {
    os.push(clone_elem(e))
  }
  let ps : Array[@engine.ElemDef] = []
  for e in d.positionals {
    ps.push(clone_elem(e))
  }
  let cs : Array[@engine.CommandDef] = []
  for c in d.commands {
    cs.push({ name: c.name, body: clone_def(c.body), export_key: c.export_key })
  }
  let als : Array[@engine.AliasDef] = []
  for a in d.aliases {
    als.push(a) // @engine.AliasDef сЂ» immutable value data (nested mutable array сѓњТїЂсЂЪсЂфсЂё)
  }
  { options: os, positionals: ps, commands: cs, aliases: als }
}

///|
/// ухљТъюсѓГсЃ╝ map сЂ«ТДІу»Ѕ (DR-052)сђѓУдЂу┤а/сѓ│сЃъсЃ│сЃЅтљЇ Рєњ export_keyсђѓpost-parse сЂ«ухљТъю remap ућесђѓalias
/// сѓњ desugar ТИѕсЂ┐сЂ« clone сЂФт»ЙсЂЌсЂдтЈјжЏєсЂЎсѓІ Рђћ command alias сЂ« export_key = @engine.EkKey(canonical) сЂї
/// т╗║сЂБсЂЪ @engine.Scope сЂ« keying сЂеСИђУЄ┤сЂЎсѓІсѓѕсЂєсЂФсђѓ
pub fn build_export_map(
  def : @engine.Definition,
) -> Map[String, @engine.ExportKey] {
  let d = clone_def(def)
  // `d` сЂ» normalize_surface сѓњухїсЂдсЂёсЂфсЂёућЪсЂ« (= pre-normalize) УцЄУБйсЂфсЂ«сЂДсђЂ`orig` т╝ЋТЋ░сЂФсѓѓ
  // тљїсЂў `d` сѓњТИАсЂЌсЂдсѓѕсЂё (flag_type() уГЅсЂ«тЁЃсЂ«тъІсЂ»сЂЙсЂаТЏИсЂЇТЈЏсѓЈсЂБсЂдсЂёсЂфсЂё)сђѓ
  desugar_aliases(d, d)
  let m : Map[String, @engine.ExportKey] = Map([], capacity=0)
  collect_export(d, m)
  m
}

///|
fn collect_export(
  def : @engine.Definition,
  m : Map[String, @engine.ExportKey],
) -> Unit {
  for e in def.options {
    collect_export_body(e, m)
  }
  for e in def.positionals {
    collect_export_body(e, m)
  }
  for c in def.commands {
    m.set(c.name, c.export_key)
    collect_export(c.body, m)
  }
}

///|
/// MDR-004 ┬Д3b: `collect_export` needs to recurse into `@engine.ElemBody` Рђћ a `BGroup`/`BOr` element's
/// nested leaves (e.g. transparent-seq's `k`, export_key:null) each have their OWN export_key that
/// must reach the map, or their `export_key:null` УБИтђцтїќ (DR-052 ┬Д2) never gets applied downstream
/// (resolve's export-key remap only consults this map). `BGroup` registers BOTH the wrapper (the
/// array cell itself) and its inner leaves; `BOr`'s wrapper has no export_key of its own concern
/// (structural dispatcher, no scalar/array value) Рђћ only its branch leaves register.
fn collect_export_body(
  e : @engine.ElemDef,
  m : Map[String, @engine.ExportKey],
) -> Unit {
  match e.body {
    BCell => m.set(e.name, e.export_key)
    BOr(branches) =>
      for br in branches {
        for it in br.items {
          collect_export_body(it, m)
        }
      }
    BGroup(items) => {
      m.set(e.name, e.export_key)
      for it in items {
        collect_export_body(it, m)
      }
    }
    // BEnum (issue values-decode-support): same standing as BCell Рђћ a single named cell whose
    // consumption structure happens to be an exact-value enum (no nested leaves to recurse into).
    BEnum(_) => m.set(e.name, e.export_key)
  }
}

///|
/// УдЂу┤асЂ« lowered head: тђцсЃЌсЃфсЃЪсЃєсѓБсЃќ / Ref (ref_target) / separated resident (separator, `value_prim` тЂ┤сЂФжЏєу┤ё
/// ТИѕсЂ┐ Рђћ сЂЊсЂ«сЃўсЃФсЃЉсЃ╝УЄфУ║ФсЂ«тй╣уЏ«сЂ» ref_target сЂ«тѕєт▓љсЂ«сЂ┐)сђѓissue
/// 2026-07-15-audit-node-nodashstr-deprmark-variants тЅ»ТгАуЎ║УдІсЂ«уЕ┤тЪІсѓЂ: `is_exact` (positional-face
/// nameless exact-match leaf, `@engine.ElemDef.is_exact` doc comment) сЂ» ref_target тѕєт▓љсѓѕсѓітЁѕсЂФтѕцт«џсЂЎсѓІ Рђћ
/// value_prim/Ref сЂЕсЂАсѓЅсЂ«ухїУи»сѓѓжђџсѓЅсЂџ `@engine.Exact(name)` сЂИуЏ┤ТјЦ lower сЂЎсѓІсђЂbare `@engine.Exact` node сЂ»сђїliteral
/// token match; binds nothing, consumes 1сђЇ(node.mbt) сЂїсЂЮсЂ«сЂЙсЂЙТг▓сЂЌсЂёТїЎтІЋсЂЮсЂ«сѓѓсЂ«сђѓсЂЊсЂ«ухїУи»сЂ»
/// `BOr`/`BGroup` сЂ«тєЁтЂ┤сЃфсЃ╝сЃЋ (`or_branch_node`/`lower_positional` сЂ« BGroup тѕєт▓љсЂї `elem_head` сѓњ
/// тЁ▒ТюЅсЂЎсѓІ) сЂФсѓѓУЄфтІЋуџёсЂФтЈісЂХ Рђћ DR-063 A.1 сЂ«УБИТќЄтГЌтѕЌТГБУдЈтїќсЂї or ТъЮтєЁсЂДсѓѓТѕљуФІсЂЎсѓІтйбсЂет»ЙуД░сђѓ
pub fn elem_head(e : @engine.ElemDef) -> @engine.Node {
  if e.is_exact {
    return @engine.Exact(e.name)
  }
  match e.ref_target {
    Some(r) => Ref(r)
    None =>
      value_prim(
        e.ty,
        e.name,
        e.int_round,
        e.allow_base_prefix,
        e.bool_config,
        e.piece_filters,
        separator=e.separator,
        merge=e.accumulator == Some("merge"),
        kv_map=e.accumulator == Some("kv_map"),
      )
  }
}

///|
/// DESIGN ┬Д5.3 (values сЂ» or сЂ«сѓисЃДсЃ╝сЃѕсЃЈсЃ│сЃЅ) / DR-028 У┐йУеў (values сѓњТїЂсЂц node сЂ» type сЃЋсѓБсЃ╝сЃФсЃЅ
/// сЂфсЂЌсЂД enum тъІсѓњтЁ╝сЂГсѓІ): the consumption structure for a `BEnum` cell Рђћ ONE token that must
/// match one of the exact values, or the whole read doesn't exist (DR-028 ┬Д3.1 "enum уџёсЃєсЃ│сЃЌсЃгсЂИсЂ«
/// Тюфт«џуЙЕтђцсЂ» or тЁеТъЮсЂ«уХ┤сѓіСИЇСИђУЄ┤ (Reject)" Рђћ no held error, same posture bare `@engine.Exact` already has:
/// a non-matching token means every branch of the `@engine.Or` below fails to @engine.Accept, so the read simply
/// isn't there Рђћ no separate "reject" signal needed). Each matching branch's @engine.Bind value goes
/// through `dsl_operand_value` (the SAME type coercion `classify_long_spelling`'s DSL operand
/// parsing already uses for variant operands) so a non-string-typed enum would get a correctly-
/// typed value Рђћ moot for today's only callers (string-only `values`, this issue's scope) since
/// `dsl_operand_value(string_type(), s) = @engine.VStr(s)`.
pub fn enum_value_node(
  name : String,
  ty : &@engine.TypeExt,
  values : Array[String],
) -> @engine.Node {
  let branches : Array[@engine.Node] = []
  for v in values {
    branches.push(
      @engine.Seq([
        @engine.Exact(v),
        @engine.Bind(name, dsl_operand_value(ty, v)),
      ]),
    )
  }
  @engine.Or(branches)
}

///|
/// DR-078 ┬Д1 result тєЎтЃЈ (issue 2026-07-09-ref-template-result-shape): wrap ONE repeat rep's
/// `head` (a ref element's consumption unit) so its bindings land nested under `name` (the
/// result scope, DESIGN ┬Д2.3/┬Д2.4) with a leading "#row" sentinel marking the row boundary
/// (`resolve.mbt`'s `build_result` ROW-GROUP branch groups same-scope bindings into one array
/// element per "#row"). `@engine.Bind`'s 0-token binding rides IN FRONT of `head`'s own bindings within
/// the SAME `@engine.Scoped` wrap, so both land at scope=[name] together in args order Рђћ this is safe to
/// apply per-rep (rather than wrapping the whole repeat spine once) because it changes only the
/// CONTENT of one head-consumption, never the spine shape that drives тЈќсѓітѕєжЂИтЦй/тЁѕжБЪсЂё
/// (`lower_repeat_head` / `ref_choice` / `bounded_tail_step` remain untouched).
fn ref_row_head(name : String, head : @engine.Node) -> @engine.Node {
  @engine.Scoped(
    name,
    @engine.Seq([@engine.Bind("#row", @engine.VBool(false)), head]),
  )
}

///|
/// MDR-004 ┬Д3: one `@engine.OrBranch`'s consumption grammar node Рђћ a single node for a 1-item branch, a
/// `@engine.Seq` of value primitives (consumed in order) for a multi-item branch. Each item's own `name`
/// carries through `elem_head` unchanged, so held-Error / binding attribution lands on the LEAF
/// (e.g. `a`/`s`/`b`/`r`/`g`/`b`/`name`) with no extra provenance wiring needed (┬Д4).
pub fn or_branch_node(br : @engine.OrBranch) -> @engine.Node {
  if br.items.length() == 1 {
    elem_head(br.items[0])
  } else {
    let nodes : Array[@engine.Node] = []
    for it in br.items {
      nodes.push(elem_head(it))
    }
    @engine.Seq(nodes)
  }
}

///|
/// ТюЅті╣ repeat spec (DR-043)сђѓ`optional:true` сЂ» `{min:0,max:1}` сЂ«у│ќУАБ (уІгуФІТдѓт┐хсЂДсЂ»сЂфсЂё)сђѓ
fn elem_repeat(e : @engine.ElemDef) -> @engine.RepeatSpec? {
  match e.repeat {
    Some(s) => Some(s)
    None =>
      if e.optional {
        Some({ min: 0, max: Some(1), lazy_: false })
      } else {
        None
      }
  }
}

///|
/// `Opt(X)` = `@engine.Or([X, @engine.Seq([])])`сђѓуЕ║ @engine.Seq сЂї 0 сЃѕсЃ╝сѓ»сЃ│СИђУЄ┤сђѓ
fn opt_node(x : @engine.Node) -> @engine.Node {
  @engine.Or([x, @engine.Seq([])])
}

///|
/// DR-088 ┬Д1: сђїт«БУеђсЂЋсѓїсЂЪтђцТ║љсЂ»сЃЄсЃЋсѓЕсЃФсЃѕсЂ«тГўтюесђЇРђћ `default_values` (Тўјуц║ default) сЂасЂЉсЂДсЂфсЂЈ
/// `env`/`config_key`/`inherit` сЂ«т«БУеђсѓѓсђїжЂЁт╗ХУДБТ▒║сЂЎсѓІ default_fn сЂїУеГт«џсЂЋсѓїсЂдсЂёсѓІсЂ«сЂетљїтъІсђЇсђѓ
/// `eval.mbt`'s `value_declared` (resolve-first-constraint-pipeline / value-present-ladder-gap сЂ«
/// жЮЎуџёт«БУеђУ┐░Уфъ) сЂетљїсЂў4УдЂу┤атѕцт«џсѓњсђЂinstaller т▒ц (lowering ТЎѓуѓ╣сђЂ@engine.ElemDef сЃЎсЃ╝сѓ╣) сЂДУАїсЂєуЅѕсђѓ
fn has_declared_value_source(e : @engine.ElemDef) -> Bool {
  e.default_values is Some(_) ||
  e.env.length() > 0 ||
  e.config_key is Some(_) ||
  e.is_inherit
}

///|
/// positional face сЂ« loweringсђѓrepeat УдЂу┤а (DR-043) сЂ» Ref тєЇтИ░: template
/// `name = @engine.Seq([head, Opt(Ref(name))])` сѓњ registry сЂФуЎ╗жї▓сЂЌсђЂspine сЂФсЂ» `min-1` mandatory + Ref
/// (min >= 1 сЂ«сЂ┐ Рђћ `Ref` УЄфСйЊсЂ»т┐ЁсЂџ >= 1 head сѓњТХѕУ▓╗сЂЎсѓІТДІжђасЂДсђї0 сЂДсѓѓсѓѕсЂёсђЇсѓњУАеуЈЙсЂДсЂЇсЂфсЂёсђЂ
/// `consume_head` сЂФсђї0 сЂфсѓЅ silent stopсђЇсЂ«тѕєт▓љсЂїуёАсЂёсЂЪсѓЂ)сђѓ`min:0` сЂ« UNBOUNDED сЂ»С╗БсѓЈсѓісЂФ
/// `@engine.Many(head)` сѓњуЏ┤ТјЦуЕЇсѓђ (СИІУеўУЕ│у┤░)сђѓbounded (max ТюЅжЎљ) сЂ» Ref тєЇтИ░сЂфсЂЌсЂД @engine.BoundedTail сЂФУљйсЂАсѓІ
/// (LOWERING ┬ДB.8сђЂmin:0 сЂ» budget=max сЂ« @engine.BoundedTail сЂїТюђтѕЮсЂІсѓЅТГБсЂЌсЂЈТЅ▒сЂє)сђѓdd УдЂу┤асЂ» spine сЂФ
/// У╝ЅсЂЏсЂфсЂёсђѓ
///
/// MDR-002 ┬ДCPS УдЈу┤ё: repeat сЂ»сЂЊсЂЊсЂДсѓ╣сЃЉсѓцсЃ│тйб (positional сЂ« Ref / @engine.BoundedTail / @engine.ScopeNode /
/// **@engine.Many**) сЂФсЂ«сЂ┐ТГБУдЈтїќсЂЌсђЂ@engine.Or/@engine.Seq/@engine.Rooted тєЁжЃесЂИсЂ«тЪІсѓЂУЙ╝сЂ┐сЂ»ућЪТѕљсЂЌсЂфсЂё (тЈќсѓітѕєжЂИтЦйсЂ«т▒ђТЅђтїќсѓњжЂ┐сЂЉ
/// сѓІсЂЪсѓЂ)сђѓ`@engine.Many` сЂ» `Ref`/`@engine.BoundedTail` сЂет»ЙуД░сЂфтЈќсѓітѕєжЂИтЦй (ТЌбт«џ greedy = жЋисЂёТќ╣сЂІсѓЅУЕдсЂЎсђЂ
/// `lazy:true` сЂДтЈЇУ╗б = уЪГсЂёТќ╣сЂІсѓЅУЕдсЂЎсђЂ`has_full_k` сЂД pruning) сѓњ scope_consume тЂ┤сЂФТїЂсЂц spine тйб
/// (eval.mbt сЂ« `@engine.Many(inner, lazy_) =>` сѓбсЃ╝сЃасђЂ"parity with Ref/@engine.BoundedTail тЈќсѓітѕєжЂИтЦй spec
/// DR-043")сђѓУ╝фжЃГсЂ» fixtures/path-search/ambiguous-receptacles.json сЂїтЏ║т«џсЂЎсѓІсђѓ

///|
/// DR-043 repeat lowering for a single positional `head` node, shared by `BCell` (head =
/// `elem_head(e)`) and `BOr` (head = `@engine.Or(branch_node...)`, issue
/// 2026-07-09-positional-or-repeat-lowering-gap: BOr used to push `@engine.Or(nodes)` directly and
/// silently ignore `elem_repeat(e)` entirely Рђћ a structural-or head is JUST a head like any other
/// for repeat's purposes, DR-043 ┬Дсђїrepeat сЂ«т»ЙУ▒АУдЂу┤асЂ»тйбсѓњтЋЈсѓЈсЂфсЂёсђЇalready says this for `ref`
/// heads, it applies identically to an `@engine.Or` head). When `elem_repeat(e)` is `None` the bare `head`
/// is pushed unchanged Рђћ the branches inside an `@engine.Or` head still each read one head via `@engine.Or`'s
/// existing multi-branch semantics (DR-038); `elem_repeat` only ever governs REPETITION count,
/// never branch structure.
fn lower_repeat_head(
  e : @engine.ElemDef,
  head : @engine.Node,
  registry : Map[String, @engine.Node],
  out : Array[@engine.Node],
) -> Unit {
  match elem_repeat(e) {
    None => out.push(head)
    Some(spec) =>
      match spec.max {
        None =>
          if spec.min == 0 {
            // UNBOUNDED min:0 (DR-043): a bare `Ref(e.name)` cannot express "0 is fine" (its
            // arm in scope_consume has no fallback for `consume_head` failing to progress), and
            // wrapping it in a plain `@engine.Or([Ref(name), @engine.Seq([])])` would lose the тЈќсѓітѕєжЂИтЦй (plain
            // `eval()`'s `@engine.Or` arm has no preference Рђћ both branches survive whenever they BOTH
            // reach a full parse, producing @engine.Ambiguous instead of the greedy-left-longest single
            // reading DR-043 requires Рђћ exactly this fixture's 3 divergences). `@engine.Many(head)` is
            // the existing spine form with the IDENTICAL preference algorithm already wired in
            // scope_consume, so no registry/self-ref is needed at all (each further rep re-enters
            // the SAME `@engine.Many` node at the same `pidx`, not a named template). `spec.lazy_` rides
            // straight into `@engine.Many`'s 2nd field (issue 2026-07-08 min0-lazy-repeat-gap resolved:
            // @engine.BoundedTail's 3rd field is the same seat for the bounded sibling, DR-043 lazy is
            // declarative preference regardless of min/max shape).
            out.push(@engine.Many(head, spec.lazy_))
          } else {
            // UNBOUNDED min>=1 (DR-043): `name#cons = @engine.Seq([head, Opt(Ref(name#cons))])` сЂ« porous
            // УЄфтЈѓуЁДсђѓ`#cons` сѓхсЃЋсѓБсЃЃсѓ»сѓ╣ (DR-046 ┬Д4 сЂ«УЄфтІЋ id уЕ║жќЊсђЂ`#` сЂ» user ns тцќсЂ«ТЌбУБЂт«џ) сЂД
            // mangle сЂЎсѓІ Рђћ DR-078 сЂД `definitions.templates` сЂїсЂЊсЂ«тљїсЂў `registry` сѓњтЁ▒ТюЅсЂЎсѓІсѓѕсЂєсЂФ
            // сЂфсЂБсЂЪсЂЪсѓЂсђЂсЃЌсЃгсЃ╝сЃ│ `e.name` сѓГсЃ╝сЂ»сђїrepeat УдЂу┤асЂетљїтљЇсЂ«сЃдсЃ╝сѓХ templateсђЇсЂДУАЮуфЂсЂЌсЂєсѓІ
            // (spec `fixtures/lowering/repeat/basic.json` сЂ« golden сѓѓтЁЃсђЁсЂЊсЂ« mangled тйб
            // `"src#cons"` сѓњТюЪтЙЁсЂЌсЂдсЂісѓісђЂ`canon_tmpl` сЂ«уиЕТ»ћУ╝Ѓ (тЁѕжаГ `#` тї║тѕЄсѓісЂДТГБУдЈтїќ) сЂїсЂЊсѓїсЂЙсЂД
            // т«ЪУБЁтЂ┤сЂ«сЃЌсЃгсЃ╝сЃ│тљЇсЂесЂ«ти«сѓњтљИтЈјсЂЌсЂджџасЂЌсЂдсЂёсЂЪсЂасЂЉ Рђћ Тюг mangle сЂД golden сЂет«ЪСйЊсЂїСИђУЄ┤сЂЎсѓІ)сђѓ
            let cons = e.name + "#cons"
            registry.set(cons, @engine.Seq([head, opt_node(Ref(cons))]))
            if spec.lazy_ {
              // lazy marker (evaluator сЂї split жЂИтЦйсѓњт╝ЋсЂЈсЂЪсѓЂсЂ« mangled key)
              registry.set("lazy:" + cons, @engine.Exact("lazy"))
            }
            let m = spec.min
            let mut k = 0
            while k < m - 1 {
              out.push(head) // mandatory unrolled heads (DR-043 min)
              k = k + 1
            }
            out.push(Ref(cons)) // >= 1 porous recursive tail
          }
        Some(mx) => {
          // BOUNDED (LOWERING ┬ДB.8): min mandatory heads + @engine.BoundedTail(head, max-min)
          let m = if spec.min < 0 { 0 } else { spec.min }
          let mut k = 0
          while k < m {
            out.push(head)
            k = k + 1
          }
          let budget = if mx - m < 0 { 0 } else { mx - m }
          out.push(@engine.BoundedTail(head, budget, spec.lazy_))
        }
      }
  }
}

///|
fn lower_positional(
  def : @engine.Definition,
  registry : Map[String, @engine.Node],
) -> Array[@engine.Node] {
  let out : Array[@engine.Node] = []
  for e in def.positionals {
    if not_dd(e) {
      match e.body {
        BOr(branches) => {
          // MDR-004 ┬Д3 "BOr (positional, тї┐тљЇ)": spine сЂФ @engine.Or([branch_node...]) сѓњуЏ┤ТјЦуЕЇсѓђсђѓУЕЋСЙАтЎесЂ«
          // ТЌбтГў @engine.Or ТёЈтЉ│УФќ (тЁеТъЮУЕЋСЙА + @engine.Held тЁеС┐ЮТїЂсђЂDR-053 ┬Д2 / т«їтЁеухїУи» 2 ТюгС╗ЦСИісЂД ambiguous С┐ЮтГўсђЂ
          // DR-038) сЂїсЂЮсЂ«сЂЙсЂЙУ╝фжЃГсѓњТ║ђсЂЪсЂЎсђѓDR-043 repeat сЂесЂ«ухётљѕсЂЏ (issue
          // 2026-07-09-positional-or-repeat-lowering-gap сЂДТа╣Т▓╗): `@engine.Or(nodes)` сѓњ head сЂесЂЌсЂд
          // `lower_repeat_head` сЂФТИАсЂЎ Рђћ repeat сЂ«сЃгсЃ│сѓ║сЂФсЂ»сђїТДІжђа or сЂ« 1 уЎ║уЂФсђЇсѓѓС╗ќсЂ« head сЂе
          // тљїсЂў 1 unit сЂДсђЂRef/@engine.Many/@engine.BoundedTail сЂ«сЂЕсѓїсЂФсЂфсѓІсЂІсЂ» head сЂ«тйб (@engine.Or сЂІ string resident сЂІ) сЂФ
          // СЙЮтГўсЂЌсЂфсЂёсђѓ
          let nodes : Array[@engine.Node] = []
          for br in branches {
            nodes.push(or_branch_node(br))
          }
          lower_repeat_head(e, @engine.Or(nodes), registry, out)
        }
        BGroup(items) => {
          // MDR-004 ┬Д3 "BGroup + repeat": @engine.IdxRepeat(label=name, head=@engine.Seq(inner cells), min,
          // budget) сЂФ lowerсђѓbudget (issue
          // 2026-07-13-positional-group-trailing-missing-operand) = `max - min` (bounded сЂ«
          // сЂесЂЇ) / `None` (max:null сЂ« UNBOUNDEDсђЂсЂЙсЂЪсЂ» repeat т▒ъТђДУЄфСйЊсЂїуёАсЂёта┤тљѕ Рђћ
          // сЂЕсЂАсѓЅсѓѓтЙЊТЮЦсЂЕсЂісѓі greedy-max-forever)сђѓС╗ЦтЅЇсЂ» `elem_repeat(e).max` сѓњСИИсЂћсЂеуёАУдќ
          // сЂЌсЂдсЂісѓісђЂ`repeat:{min:1,max:1}` сЂ«сѓѕсЂєсЂф bounded named-group сЂДсѓѓтИИсЂФ unbounded
          // сЂесЂЌсЂдУЕЋСЙАсЂЋсѓїсЂдсЃѕсЃ╝сѓ»сЃ│сѓњ over-consume сЂЌсЂдсЂёсЂЪ (`fixtures/repeat-parse/group-
          // trailing-positional.json` сЂї pin сЂЎсѓІ Рђћ group сЂ«уЏ┤тЙїсЂФтѕЦ positional сЂїуХџсЂЈтйбсЂасЂЉ
          // сЂДжАЋтюетїќсЂЎсѓІ)сђѓ
          //
          // bounded-head тЅЇТЈљ (issue 2026-07-08 greedy-once-and-idxrepeat-premises ┬Д2, kawaz УБЂт«џ
          // тЙЁсЂА Рђћ installer УдЈу┤ёсЂесЂЌсЂдсЂ«ТўјТќЄтїќсѓњжЂИТіъсђЂeval тЂ┤сЂИсЂ« backtrack У┐йтіасЂ»УдІжђЂсѓі): `idx_repeat_eval`
          // (eval.mbt) сЂ»т«БУеђСИі deterministic сЂф greedy-max сЂДсђЂСИІТхЂтц▒ТЋЌТЎѓсЂ«тЙїжђђ (regex backtracking,
          // DR-043 сЂ«жђџтИИ repeat сЂї `ref_choice` сЂДТїЂсЂцТЕЪТДІ) сѓњТїЂсЂЪсЂфсЂёсђѓhead сЂї permissive (bare string
          // primitive уГЅсђЂуёАтѕХжЎљсЂФсЂЕсѓЊсЂфсЃѕсЃ╝сѓ»сЃ│сЂДсѓѓТХѕУ▓╗сЂДсЂЇсѓІ) сЂасЂесђЂbudget сЂї None (UNBOUNDED) сЂ«
          // сЂесЂЇсЂ»тЙїуХџсЂ«т┐Ёжаѕ positional сЂ«сЂХсѓЊсЂЙсЂД greedy-max сЂФжБЪсѓЈсѓїсЂд starve сЂЌсЂєсѓІ (backtrack сЂї
          // уёАсЂёсЂ«сЂДтЏътЙЕсЂЌсЂфсЂё) Рђћ жђџтИИ repeat сЂ« backtrack.json fixture сЂїтЏ║т«џсЂЎсѓІсђїуИ«т░ЈтєЇтѕєтЅ▓сђЇсЂ«
          // С┐ЮУе╝сЂ» @engine.IdxRepeat сЂФсЂ»тЈісЂ░сЂфсЂёсђѓbudget сЂї Some (bounded) сЂ«сЂесЂЇсЂ» over-consume УЄфСйЊсЂї
          // УхисЂЇсЂфсЂёсЂЪсѓЂсЂЊсЂ« GAP сѓњУИЈсЂЙсЂфсЂёсђѓUNBOUNDED сЂ«сЂЙсЂЙТюФт░ЙсЂФт┐Ёжаѕ positional сѓњуХџсЂЉсѓІУеГУеѕсѓњ
          // ТЏИсЂЈжџЏсЂ» head сЂ«тЁѕжаГсЂФТўјуц║уџёсЂф trigger (@engine.Exact уГЅ) сѓњТїЂсЂЪсЂЏсѓІсЂЊсЂесђѓ
          let head = if items.length() == 1 {
            elem_head(items[0])
          } else {
            let nodes : Array[@engine.Node] = []
            for it in items {
              nodes.push(elem_head(it))
            }
            @engine.Seq(nodes)
          }
          let (min, budget) = match elem_repeat(e) {
            Some(spec) =>
              (
                spec.min,
                match spec.max {
                  Some(mx) =>
                    Some(if mx - spec.min < 0 { 0 } else { mx - spec.min })
                  None => None
                },
              )
            None => (0, None)
          }
          out.push(@engine.IdxRepeat(e.name, head, min, budget))
        }
        BCell =>
          match e.ref_target {
            // DR-078 ┬Д1 result тєЎтЃЈ (issue 2026-07-09-ref-template-result-shape): a `ref`
            // element's own `name` must create a result scope (DESIGN ┬Д2.3/┬Д2.4) Рђћ `elem_head`
            // returns the bare `Ref(target)`, discarding `e.name` entirely, so without this the
            // referenced template's OWN leaf names (colorname/r/g/b) surface at the TOP level
            // instead of nested under `e.name`.
            Some(_) =>
              match elem_repeat(e) {
                // no repeat: single occurrence, degenerate row (DESIGN ┬Д6.1 сЂ«жђє Рђћ repeat сЂї
                // сђїжЁЇтѕЌсЂФтїЁсѓђсђЇТЊЇСйюсѓњТІЁсЂєсђЂтцќсЂЎсЂе row сЂїсЂЮсЂ«сЂЙсЂЙтђцсЂФсЂфсѓІ) Рђћ no "#row" marker
                // needed, `sub_under(binds, e.name)` already yields the row's flat leaves.
                None => out.push(@engine.Scoped(e.name, elem_head(e)))
                Some(_) =>
                  lower_repeat_head(
                    e,
                    ref_row_head(e.name, elem_head(e)),
                    registry,
                    out,
                  )
              }
            None =>
              // DR-088 ┬Д2 (issue dr-088-positional-default-verification): a plain (no
              // repeat/optional) positional that declares a value source (default/env/
              // config_key/inherit) is structurally COMPLETE with 0 tokens too Рђћ the declared
              // source is "a default_fn scheduled to resolve later" (DR-088 ┬Д1), so the path
              // must not starve into `missing_operand` just because no token showed up here.
              // `opt_node` (`@engine.Or([head, @engine.Seq([])])`, already used by `elem_repeat`'s min:0 paths)
              // makes the ONE occurrence optional at the structural level WITHOUT touching
              // `elem_repeat`/`lower_repeat_head`'s array-producing repeat machinery Рђћ the
              // entity stays a genuine SCALAR cell (no `accum`), and an unconsumed occurrence
              // leaves it uncommitted, so `resolve.mbt`'s existing default-seat ladder
              // (`resolve_ladder_below_cli`) fills it in exactly as it already does for options.
              // Declared-but-unresolved-at-runtime (e.g. env var absent) still falls through to
              // the scalar's OWN default_values / lower ladder rungs as usual Рђћ this only fixes
              // the STRUCTURAL completeness gate, not the value resolution itself.
              if elem_repeat(e) is None && has_declared_value_source(e) {
                lower_repeat_head(e, opt_node(elem_head(e)), registry, out)
              } else {
                lower_repeat_head(e, elem_head(e), registry, out)
              }
          }
        // BEnum (issue values-decode-support): `dec_positional` never produces this shape today
        // (positionals only decode structural "or"/"positionals" Рђћ DESIGN ┬Д5.3's value-enum
        // shorthand is option-only, `dec_positional`'s own comment). Wired anyway (not aborted) so
        // a future positional-values fixture works without another round-trip here Рђћ same
        // `enum_value_node` consumption structure the option side (`inst_long`) uses.
        BEnum(values) =>
          lower_repeat_head(
            e,
            enum_value_node(e.name, e.ty, values),
            registry,
            out,
          )
      }
    }
  }
  out
}

///|
/// (cloned) @engine.Definition tree сЂІсѓЅ scope-builder tree сѓњухёсѓђсђѓpositional сЂ» 1 т║дсЂасЂЉ lower (С╗ЦтЙїсЂ»ТѕљжЋи
/// сЂЌсЂфсЂё Рђћ global copy сЂ» greedy тЂ┤сЂФтЁЦсѓІ)сђѓentities / greedy сЂ» fixpoint pass сЂДтЪІсѓЂсѓІсђѓ
fn init_sb(
  def : @engine.Definition,
  registry : Map[String, @engine.Node],
) -> @engine.InstallBuilder {
  let positional = lower_positional(def, registry)
  let children : Array[@engine.InstallChild] = []
  for c in def.commands {
    children.push(@engine.InstallChild::new(c.name, init_sb(c.body, registry)))
  }
  @engine.InstallBuilder::new(
    def,
    @engine.InstallBuild::new(positional),
    children,
    registry,
  )
}

///|
/// Core lowering (installer сЂДсЂ»сЂфсЂё Рђћ Т▒║т«џуџёсђЂжаєт║ЈуёАСЙЮтГў): option/positional сЂћсЂесЂФ entity 1 тђІсѓњ
/// name тЅ▓тйЊсЂД ensure (add-if-absent)сђѓТ»ј pass Ух░сѓІ (global-copied option сѓѓ entity сѓњтЙЌсѓІсЂЪсѓЂ)сђѓ
///
/// dd УдЂу┤асЂ» entity сѓњТїЂсЂЪсЂфсЂё (LOWERING ┬ДB.4сђїтђцсЂфсЂЌсђЇ/ DR-064 ┬Д1)сђѓlink_depth == 0 сЂ«сЂ┐ ensure
/// (global link COPY сЂ» declaring cell сЂИ link тљїТюЪсЂЎсѓІсЂЪсѓЂтГљ scope тЂ┤ entity сЂ»СИЇУдЂ Рђћ DR-070 ┬Д1b gap 5)сђѓ
fn ensure_entities(sb : @engine.InstallBuilder, has_cf : Bool) -> Unit {
  for e in sb.definition().options {
    if not_dd(e) && e.link_depth == 0 {
      ensure_entity_body(sb.output(), e, has_cf)
    }
  }
  for e in sb.definition().positionals {
    if not_dd(e) {
      ensure_entity_body(sb.output(), e, has_cf)
    }
  }
}

///|
/// MDR-004 ┬Д3b: register `e` (and any `@engine.ElemBody`-nested leaves) as top-level entities Рђћ the
/// evaluator's `@engine.Or`/`@engine.Seq`/`@engine.IdxRepeat` nodes don't know about entities at all, so this recursive
/// walk is the ONLY registration point. `BOr`'s wrapper is a structural dispatcher with no
/// scalar/array value of its own (e.g. "color" never itself holds a value Рђћ only its branch leaves
/// r/g/b/name do), so ONLY the branch leaves register. `BGroup`'s wrapper DOES need its own entity
/// (the array cell Рђћ `elem_repeat` on it still drives the existing "flatten" accumulator path,
/// unaffected by `body`) in ADDITION to its inner leaves (e.g. transparent-seq's `k`, its own cell
/// with `entity=k` effects).
///
/// codex сЃгсЃЊсЃЦсЃ╝ Major 4 (issue 2026-07-15-audit-node-nodashstr-deprmark-variants тЅ»ТгАуЎ║УдІ): the
/// `is_exact` guard used to live ONLY at `ensure_entities`' top-level positionals loop (removed
/// above) Рђћ a `BOr`/`BGroup` RECURSIVE call into this same function (branch leaves / group inner
/// items, both below) bypassed it entirely, so an `is_exact` leaf nested inside a structural or /
/// named group would fall into the `BCell`/`ref_target is None` arm and get a phantom
/// `@engine.Entity{name: spelling, ty: none_type()}` Рђћ occupying the namespace and blocking a real same-named
/// entity's `ensure_entity` (add-if-absent already returns early once ANY entity with that name
/// exists). Guarding HERE (single entry point every recursive path funnels through) closes both the
/// top-level and the nested cases with one check, and any future `@engine.ElemBody` arm added to this match
/// inherits the guard automatically (installer.mbt's `@engine.ElemDef.is_exact` doc comment: "value_prim/
/// entity ухїУи»сѓњСИђтѕЄжђџсѓЅсЂфсЂё" is the invariant this enforces).
fn ensure_entity_body(
  build : @engine.InstallBuild,
  e : @engine.ElemDef,
  has_cf : Bool,
) -> Unit {
  if e.is_exact {
    return
  }
  match e.body {
    BCell =>
      // DR-078 ┬Д1 result тєЎтЃЈ (issue 2026-07-09-ref-template-result-shape): a `ref` element is
      // ALSO a structural dispatcher with no scalar/array value of its own Рђћ its "value" is a
      // name-scoped projection of the REFERENCED template's own leaves (installer.mbt's
      // `ref_row_head` / `lower_positional`/`inst_long`'s `@engine.Scoped` wrap), never a flat binding on
      // `e.name` itself. Registering an entity here is (a) dead for the value-source-ladder side
      // (nothing ever binds flatly to `e.name`, so `resolve_entity` always seats `Ok([])` and
      // contributes no binding) Рђћ harmless, not "spurious".
      //
      // issue 2026-07-09-accum-fold-update-default-ops У┐йУеў (2026-07-10, codex сЃгсЃЊсЃЦсЃ╝ућ▒ТЮЦсЂ«
      // ref-repeat-sibling-trigger.json mismatch): a repeat-bearing ref element (`elem_repeat(e)
      // is Some(_)`) DOES need the entity now, specifically for its `accum: Some("flatten")` Рђћ
      // DR-051 ┬Д2bсђїтЈЇтЙЕу│╗сЂ» 0 тЏъуЎ║уЂФсЂДсѓѓ `[]`сђЇсЂ» ref+repeat сѓ╗сЃФсЂФсѓѓтЈісЂХсЂїсђЂ0 тЏъуЎ║уЂФсЂДсЂ» "#row"
      // (`ref_row_head`) сЂїСИђтѕЄућЪсЂЙсѓїсЂџсђЂbuild_result сЂ« ROW-GROUP тѕєт▓љ (`has_direct_key(binds,
      // "#row")`) сЂїу┤ажђџсѓісЂЌсЂдУфцсЂБсЂд `{}` (OBJECT ухїУи») сЂФУљйсЂАсЂдсЂёсЂЪ (repro:
      // `{"ref":"color","repeat":{"min":0}}` + уЏ┤тЙїсЂФ sibling trigger сЂД 0 тЈЇтЙЕ)сђѓ`accum_cells`
      // (resolve.mbt) сЂї `sc.entities` сЂасЂЉсѓњУдІсѓІтЅЇТЈљсѓњС┐ЮсЂБсЂЪсЂЙсЂЙсђЂсЂЊсЂ« entity уЎ╗жї▓сЂДсЂЮсЂ«Ух░ТЪ╗сЂФ
      // ref+repeat сѓ╗сЃФсѓњС╣ЌсЂЏсђЂbuild_result сЂ« UNIFORM ARRAY Т│етЁЦ (DR-044 ┬Д1) сЂД `[]` сѓњтЄ║сЂЎсђѓ
      // 1 тЏъС╗ЦСИіуЎ║уЂФсЂЌсЂЪта┤тљѕсЂ«сђїdouble-rendersсђЇТЄИт┐х ("#row" ухїућ▒сЂ«УАїжЁЇтѕЌсЂе UNIFORM ARRAY Т│етЁЦсЂ«
      // С║їжЄЇТЈЈућ╗) сЂ»сђЂbuild_result тЂ┤сЂ«сѓгсЃ╝сЃЅсѓњ `named` сЂасЂЉсЂДсЂфсЂЈ `segs` (nested scope СИђУдД) сѓѓ
      // УдІсѓІсѓѕсЂєТІАт╝хсЂЌсЂджќЅсЂўсЂдсЂёсѓІ (resolve.mbt сЂ«сѓ│сЃАсЃ│сЃѕтЈѓуЁД) Рђћ ROW-GROUP сЂїтЁѕсЂФУ┐ћсЂЌсЂЪ path сЂ»
      // `segs` ухїућ▒сЂД obj сЂФУ╝ЅсѓІсЂ«сЂДсђЂUNIFORM ARRAY тЂ┤сЂ» `segs` сЃЂсѓДсЃЃсѓ»сЂДжЄЇУцЄТ│етЁЦсѓњсѓ╣сѓГсЃЃсЃЌсЂЎсѓІсђѓ
      // repeat уёАсЂЌсЂ«тЇўуЎ║ ref (`elem_repeat(e) is None`) сЂ»тЁЃсЂ«сѓ│сЃАсЃ│сЃѕсЂ«ТЄИт┐хсЂїсЂЮсЂ«сЂЙсЂЙТюЅті╣
      // (accum сЂїуФІсЂЪсЂфсЂёсЂ«сЂДТГ╗сѓЊсЂа entity сѓњтбЌсѓёсЂЎсЂасЂЉ) сЂфсЂ«сЂДсђЂт»ЙУ▒Асѓњ repeat С╗ўсЂЇсЂФжЎљт«џсЂЎсѓІ Рђћ
      // сЂЪсЂасЂЌ DR-084 ┬Д1 (issue multiple-ref-accum-gap): `multiple` С╗ўсЂЇсЂ« repeat уёАсЂЌ ref сЂ»
      // "dead" сЂДсЂ»сЂфсЂёсђѓсЂЊсЂ«та┤тљѕсЂ« accum сЂ» "append" (ensure_entity сЂ«сЃЄсЃЋсѓЕсЃФсЃѕтєЎтЃЈ) сЂФсЂфсѓісђЂ
      // `inst_long`/`lower_positional` тЂ┤ (сЂЊсЂ«сЃЋсѓАсѓцсЃФсђЂ`ref_row_head` тѕєт▓љсЂ«ТЮАС╗Х) сЂїуЎ║уЂФсЂћсЂесЂФ
      // "#row" сѓњТЅЊсЂцсѓѕсЂєжђБтІЋсЂЌсЂдтцЅсѓЈсѓІ Рђћ СИАУђЁсЂ»тљїсЂў `e.multiple` сѓгсЃ╝сЃЅсЂДТЈЃсЂѕсѓІт┐ЁУдЂсЂїсЂѓсѓІсђѓ
      if e.ref_target is None {
        ensure_entity(build, e, has_cf)
      } else if elem_repeat(e) is Some(_) || e.multiple {
        ensure_entity(build, e, has_cf)
      }
    BOr(branches) =>
      for br in branches {
        for it in br.items {
          ensure_entity_body(build, it, has_cf)
        }
      }
    BGroup(items) =>
      // The wrapper (e.g. "xs") lowers to @engine.IdxRepeat (MDR-004 ┬Д3): its array is built entirely by
      // eval.mbt's array_marker/nest_index scope mechanism, never via the accum-entity ladder. If
      // registered here, ensure_entity would set accum:flatten (elem_repeat(e) is Some for a
      // repeat group), making accum_cells double-count "xs" and inject a spurious extra `[]`
      // alongside the nested-scope array resolve.mbt already builds from the @engine.IdxRepeat bindings.
      // Only the inner leaf cells (value-source-ladder participants) need entities.
      for it in items {
        ensure_entity_body(build, it, has_cf)
      }
    // BEnum (issue values-decode-support): a single named cell like BCell (the enum's exact-value
    // branches all bind the SAME `e.name`, unlike BOr's per-branch leaves) Рђћ never has a
    // `ref_target` (values/or on a `ref` element is not a decodable shape today), so this always
    // registers unconditionally, simpler than BCell's ref_target-gated arm above.
    BEnum(_) => ensure_entity(build, e, has_cf)
  }
}

///|
fn ensure_entity(
  build : @engine.InstallBuild,
  e : @engine.ElemDef,
  has_cf : Bool,
) -> Unit {
  for ent in build.entities() {
    if ent.name == e.name {
      return
    }
  }
  // repeat / multiple / separator сЂ»тђц LIST Рђћ тљЇтЅЇС╗ўсЂЇ accumulator registry сЂФУљйсЂесЂЎ (DR-036)сђѓ
  //   repeat (multiple уёАсЂЌ) Рєњ "append" + flatten:true (DR-105 ┬Д3: ТЌДуІгуФІ "flatten" accumulator сЂ«
  //     т╗ЃТГбсђЂrepeat installer сЂ« cons unfold [T,[T,Рђд]] Рєњ T[] сЂ» append accumulator сЂ« flatten
  //     сЃђсѓцсЃцсЃФсЂДУАеуЈЙсЂЎсѓІ)
  //   multiple / separator Рєњ "append" (DR-034)сђЂсЂѓсѓІсЂёсЂ» `e.accumulator` сЂїТўјуц║ТїЄт«џсЂЌсЂдсЂёсѓїсЂ░
  //     сЂЮсѓї (DR-080 ┬Д1: `multiple: {accumulator: "merge", ...}` Рђћ ТЌДсђїmultiple сЂфсѓЅтИИсЂФ appendсђЇ
  //     тЏ║т«џтєЎтЃЈсѓњсђЂт«БУеђсЂЋсѓїсЂЪ accumulator тљЇсЂ«СИђУѕгтєЎтЃЈсЂФуй«сЂЇТЈЏсЂѕсѓІ)сђѓсЂЊсЂ«ТЎѓуѓ╣сЂД `e.accumulator` сЂ»
  //     definition-error gate (`collect_unknown_accumulator`) сѓњжђџжЂјТИѕсЂ┐сЂфсЂ«сЂД "merge"/"kv_map" сЂ«
  //     сЂёсЂџсѓїсЂІсЂ«сЂ┐ (M-17)сђѓ
  // СИАТќ╣уФІсЂБсЂЪта┤тљѕсЂ» multiple сЂ« (accumulator ТїЄт«џ or) append сЂїтІЮсЂц (тђц fold сЂїТћ»жЁЇ)сђѓ
  // DR-044 ┬Д1 (kawaz УБЂт«џ): repeat / multiple / separator сЂ» cardinality СИЇтЋЈсЂДтИИсЂФжЁЇтѕЌ
  //   (`repeat:{min:0,max:1}` = optional у│ќУАБсѓѓ [] / [x] Рђћ scalar ТўЄТа╝сЂ» collector тЂ┤сЂ«У▓гтІЎ)сђѓ
  // is_multiple_decl (DR-084 ┬Д2, DR-105 Т│бтЈі): `e.multiple` сѓњсЂЮсЂ«сЂЙсЂЙ carry сЂЎсѓІ Рђћ resolve.mbt сЂ«
  // SEGS-loop тѕцт«џ (ref+repeat cons cell сЂ« discard-earlier-firings сЂе ref+repeat+multiple сЂ«
  // firing-preserving сѓњтї║тѕЦсЂЎсѓІ) сЂїсђЂaccum тљЇсЂїСИАУђЁсЂесѓѓ "append" сЂФТЈЃсЂБсЂЪтЙїсѓѓсЂЊсЂ«У╗ИсЂДтѕцтѕЦсЂЎсѓІсђѓ
  let (accum, flatten, is_multiple_decl) : (String?, Bool, Bool) = if e.multiple {
    let acc_name = match e.accumulator {
      Some(a) => a
      None => "append"
    }
    let flat = match e.flatten {
      Some(b) => b
      None => false
    }
    (Some(acc_name), flat, true)
  } else {
    match elem_repeat(e) {
      Some(_) => (Some("append"), true, false)
      None =>
        if e.separator is Some(_) {
          (Some("append"), false, false)
        } else {
          (None, false, false)
        }
    }
  }
  // тљїтъІ config seat (DR-050 ┬Д3): config_file УдЂу┤асЂїтГўтюесЂЎсѓїсЂ░тЁе value cell сЂФ config seat сѓњт«БУеђ
  // (УЄфУ║ФсЂї config_file сЂ«УдЂу┤асЂ»тЙфуњ░удЂТГбсЂДжЎцсЂЈ)сђѓconfig_key сЂ» path override; None = тљїтъІсђѓ
  let config_seat = has_cf && !e.is_config_file
  // Preset defaults are resident-owned: flag supplies false and count supplies 0 only
  // when no explicit default exists. Ordinary bool/number residents remain absent.
  // DR-083 keeps every scalar default in the uniform length-1 array representation.
  // DR-099 ┬Д2: is_tty УдЂу┤асЂ» bool_type() сЂ«ТџЌж╗Ў default:false сЃЌсЃфсѓ╗сЃЃсЃѕсѓњтЈЌсЂЉсЂфсЂё Рђћ у┤асЂ« bool сЂежЂЋсЂёсђЂ
  // is_tty УдЂу┤асЂ« default тИГсЂ» `resolve.mbt`'s `resolve_ladder_below_cli` сЂї `fold(Уд│ТИг) ?? т«БУеђ
  // default ?? absent` сЂесЂёсЂєуІгУЄфУдЈтЅЄсЂДУДБТ▒║сЂЎсѓІсђѓсЂЊсЂЊсЂДтЁѕтЏъсѓісЂФ false сѓњТ│етЁЦсЂЌсЂдсЂЌсЂЙсЂєсЂесђїт«БУеђ
  // default уёАсЂЌсђЇсЂесЂёсЂєуіХТЁІсЂїтц▒сѓЈсѓїсђЂfold сЂїУд│ТИгсЂфсЂЌсЂ«та┤тљѕсЂФ absent сЂИУљйсЂАсѓІСйЎтю░сЂїуёАсЂЈсЂфсѓІ
  // (тИИсЂФ false сЂїТх«сЂІсЂ│СИісЂїсЂБсЂдсЂЌсЂЙсЂє) Рђћ is_tty УдЂу┤асЂ» default_values сѓњт«БУеђсЂЋсѓїсЂЪсЂесЂісѓі (уёАТїЄт«џ
  // сЂфсѓЅ None) сЂФТїЂсЂАтЏъсѓісђЂfold сЂ«тЂ┤сЂДтљИтЈјсЂЋсЂЏсѓІсђѓ
  let default_values : Array[@engine.Value]? = match e.default_values {
    Some(vs) => Some(vs)
    None =>
      if e.is_tty {
        None
      } else {
        match e.ty.default_seat_resolver(@engine.seat_ctx(None)) {
          Some(value) => Some([value])
          None => None
        }
      }
  }
  let ty2 = if e.ty.name() == "count" { number_type() } else { e.ty }
  build
  .entities()
  .push({
    name: e.name,
    ty: ty2,
    env_key: None,
    config_seat,
    config_key: e.config_key,
    is_config_file: e.is_config_file,
    inherit_: false, // MDR-003: node.mbt тЂ┤ @engine.Entity.inherit_
    // DR-099 ┬Д1: is_tty/tty_stream/tty_cygwin сЂ» @engine.ElemDef сЂІсѓЅсЂЮсЂ«сЂЙсЂЙ carry сЂЎсѓІсЂасЂЉ (int_round сЂе
    // тљїсЂўсЃЉсѓ┐сЃ╝сЃ│) Рђћ т░ѓуће installer сЂїтЙїсЂІсѓЅтЪІсѓЂсѓІ mutable seat сЂДсЂ»сЂфсЂёсђѓ
    is_tty: e.is_tty,
    tty_stream: e.tty_stream,
    tty_cygwin: e.tty_cygwin,
    accum,
    // DR-105 ┬Д1/┬Д3: flatten (append-only dial) and is_multiple_decl (DR-084 ┬Д2 origin marker) Рђћ
    // both already false-by-construction whenever `accum` is None (the tuple above only ever
    // produces a non-false pair alongside `Some(_)`), mirroring `collector`'s "dead attribute never
    // rides a scalar cell" posture without a redundant guard here.
    flatten,
    is_multiple_decl,
    // DR-036: collector only means anything alongside an accum cell (@engine.Entity.collector's doc
    // comment, node.mbt) Рђћ a scalar cell (accum is None) drops any declared collector rather than
    // carrying a dead attribute forward.
    collector: if accum is Some(_) {
      e.collector
    } else {
      None
    },
    default_values,
    separator: e.separator,
    piece_filters: e.piece_filters,
    value_filters: e.value_filters,
    // DR-102 ┬Д1: final_filters (TРєњT) only means anything for a scalar (non-accum) cell, accum_filters
    // (AccРєњAcc) only for an accum cell Рђћ same "drop the attribute that doesn't apply to this cell's
    // shape" posture `collector` above already uses. `collect_invalid_filter_attribute_mismatch`
    // (definition-error, kind=invalid-range) already rejects the OTHER combination at parse_definition
    // time, so in practice at most one side is ever non-empty here; this split is defense-in-depth.
    final_filters: if accum is Some(_) {
      []
    } else {
      e.final_filters
    },
    accum_filters: if accum is Some(_) {
      e.accum_filters
    } else {
      []
    },
    hidden: e.hidden,
    completer: e.completer,
  })
}

///|
fn not_dd(e : @engine.ElemDef) -> Bool {
  !e.is_dd
}

// РћђРћђ тљё installer РћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђ

///|
/// DR-091 ┬Д3: `eq_split` bundles every eq-split entry it carries under ONE `prefix` (`node.mbt`'s
/// `eq_split(prefix~, entries~)` Рђћ a single matcher instance, single prefix). Before this DR every
/// element shared the hardcoded `"--"`, so one `eq_split` per `@engine.Definition` was correct; now an
/// element MAY declare its own `long_prefix` (`if=`/`of=`'s `long_prefix: ""`), so `inst_long`
/// groups eq entries by their declaring element's `long_prefix` and emits one `eq_split` per
/// distinct value actually present Рђћ `prefixes`/`groups` are parallel arrays (insertion order),
/// mirroring this file's existing dedup-by-linear-scan style (`resolve.mbt`'s `named`/`segs`
/// arrays) rather than a `Map` (whose iteration order this codebase doesn't otherwise rely on).
fn eq_group(
  prefixes : Array[String],
  groups : Array[Array[EqEntry]],
  prefix : String,
) -> Array[EqEntry] {
  let mut i = 0
  while i < prefixes.length() {
    if prefixes[i] == prefix {
      return groups[i]
    }
    i = i + 1
  }
  let g : Array[EqEntry] = []
  prefixes.push(prefix)
  groups.push(g)
  g
}

///|
/// codex сЃгсЃЊсЃЦсЃ╝ Major 2 (issue 2026-07-15-audit-node-nodashstr-deprmark-variants тЅ»ТгАуЎ║УдІ) / DR-058
/// ┬Д2: append a trailing deprecation resident to a main-entry satellite's node array when `e.deprecated`
/// Рђћ shared by EVERY `inst_long` main-entry arm (BOr / BEnum / ref┬▒repeat / BCell, all below) so a
/// deprecated element warns regardless of its value structure (DR-058 ┬Д2's contract is тђцТДІжђажЮъСЙЮтГў;
/// the previous fix only wired the BCell arm, missing the other 4). Centralizing the append here (one
/// call site per arm, right before `@engine.Seq(...)`) means a FUTURE `e.body`/`ref_target` arm added to
/// `inst_long` inherits the warning automatically as long as it routes its satellite nodes through
/// this helper Рђћ the same "single funnel, no per-arm opt-in to forget" shape `ensure_entity_body`'s
/// `is_exact` guard (Major 4 fix) uses.
fn with_depr(
  e : @engine.ElemDef,
  nodes : Array[@engine.Node],
) -> Array[@engine.Node] {
  if e.deprecated {
    nodes.push(deprecation_mark(e.name))
  }
  nodes
}

///|
/// long: `long` сѓњ READсђЂname сЂѓсЂЪсѓі greedy exact УАЏТўЪ (space form) сЂесђЂvalue у│╗сЂфсѓЅ eq-split matcher
/// сѓњ add-if-absent сЂДУ┐йтіасђѓУАЏТўЪсЂ» name сЂД entity сЂФ link (DR-042 ┬Дт▒ЋжќІсЂ«ТеЎТ║ќсЃЉсѓ┐сЃ╝сЃ│)сђѓ
fn inst_long(
  def : @engine.Definition,
  build : @engine.InstallBuild,
  registry : Map[String, @engine.Node],
) -> Unit {
  let eq_prefixes : Array[String] = []
  let eq_groups : Array[Array[EqEntry]] = []
  for e in def.options {
    for l in long_of(e) {
      // DR-091 ┬Д3: `e.long_prefix` replaces the old hardcoded `"--"` (ТЌбт«џтђцсЂ» `"--"` сЂЮсЂ«сѓѓсЂ«сЂфсЂ«сЂД
      // this element's own trigger is unchanged unless it explicitly overrides).
      let trigger = e.long_prefix + l
      match e.body {
        // MDR-004 ┬Д3: BOr option (variable-arity) Рђћ greedy satellite
        // @engine.Seq([@engine.Exact(trigger), @engine.Or([branch_node...])]). `e.ty` is unused (a BOr wrapper carries no
        // value of its own); each branch's own leaf name(s) flow through unchanged via
        // or_branch_node/elem_head, so held-Error / binding attribution lands on the leaf with no
        // extra provenance wiring (┬Д4).
        BOr(branches) => {
          let branch_nodes : Array[@engine.Node] = []
          for br in branches {
            branch_nodes.push(or_branch_node(br))
          }
          add_greedy(
            build,
            maybe_root(
              e.link_depth,
              @engine.Seq(
                with_depr(e, [@engine.Exact(trigger), @engine.Or(branch_nodes)]),
              ),
            ),
          )
        }
        // BEnum (issue values-decode-support, DESIGN ┬Д5.3 / DR-028 У┐йУеў): main entry сЂ«тђцсѓ╣сЃГсЃЃсЃѕ
        // ТХѕУ▓╗ТДІжђасЂї `enum_value_node` (exact тђцсЂ« or т▒ЋжќІ) сЂФсЂфсѓІ Рђћ BCell сЂ« `value_prim` сЂФуЏИтйЊсЂЎсѓІ
        // ти«сЂЌТЏ┐сЂѕсђѓDR-086 ┬Д1 сЂ« cut (тљїСИђ trigger сЂ« 0т╝ЋТЋ░ @engine.Set variant сЂесЂ«уФХтљѕУДБТ▒║) сЂ» lowering
        // ТДІжђа (сЂЊсЂЊсЂДуЕЇсѓђ greedy УАЏТўЪсЂ«тђІТЋ░сЃ╗тйб) сѓњтцЅсЂѕсЂџ eval.mbt тЂ┤сЂДТЅ▒сЂє (lowering query fixture
        // сЂИсЂ«тй▒жЪ┐тЏъжЂ┐сђЂteam-lead УБЂт«џ 2026-07-10) Рђћ сЂЊсЂЊсЂДсЂ»жђџтИИсЂ« main entry сЂетљїсЂўтйбсЂДтЇўуІгуЎ╗жї▓
        // сЂЎсѓІсЂасЂЉсЂДсѓѕсЂёсђѓ
        BEnum(values) =>
          add_greedy(
            build,
            maybe_root(
              e.link_depth,
              @engine.Seq(
                with_depr(e, [
                  @engine.Exact(trigger),
                  enum_value_node(e.name, e.ty, values),
                ]),
              ),
            ),
          )
        _ =>
          match e.ref_target {
            // DR-078 ┬Д1 option repeat (issue 2026-07-09-ref-template-result-shape, new
            // capability): mirrors `lower_positional`'s BCell/ref_target arm Рђћ a `ref` element's
            // own `name` creates a result scope, and (when repeated) each rep's row groups under
            // a "#row" sentinel (`ref_row_head`, `resolve.mbt`'s ROW-GROUP branch).
            Some(_) =>
              match elem_repeat(e) {
                None =>
                  add_greedy(
                    build,
                    maybe_root(
                      e.link_depth,
                      @engine.Seq(
                        with_depr(e, [
                          @engine.Exact(trigger),
                          // DR-084 ┬Д1 (issue multiple-ref-accum-gap): a `multiple` repeat-less ref
                          // element's row is the ACCUMULATOR's fold unit (one fire = one row) Рђћ
                          // tag it with "#row" (`ref_row_head`, same sentinel repeat-bearing ref
                          // uses) so `resolve.mbt`'s ROW-GROUP branch splits each firing into its
                          // own row-group instead of merging every firing's leaves flat into one
                          // object (the pre-DR-084 bug: 2 fires of an or-branch ref would land BOTH
                          // branches' leaves under the same bare `@engine.Scoped(e.name, ...)`, e.g.
                          // `{colorname:"red", r:0, g:128, b:255}` instead of 2 separate rows). No
                          // `multiple` (the `ref-template-no-repeat-degenerate.json` baseline) keeps
                          // the bare `@engine.Scoped` wrap Рђћ a single scalar row, never array-wrapped.
                          if e.multiple {
                            ref_row_head(e.name, elem_head(e))
                          } else {
                            @engine.Scoped(e.name, elem_head(e))
                          },
                        ]),
                      ),
                    ),
                  )
                Some(_) => {
                  // The repeat spine (mandatory heads + Ref/@engine.BoundedTail/@engine.Many tail) collapses to
                  // ONE node for `min <= 1` (no mandatory-head unrolling) Рђћ the only shape any
                  // fixture exercises today (`last-wins-repeat-rows.json`'s `{"min":1}`). A
                  // `min > 1` option repeat would need `@engine.GreedyRepeat` to carry multiple
                  // `sc'.positional` slots (eval.mbt's `step_greedy_repeat`), not yet wired.
                  let spine : Array[@engine.Node] = []
                  lower_repeat_head(
                    e,
                    ref_row_head(e.name, elem_head(e)),
                    registry,
                    spine,
                  )
                  let tail = if spine.length() == 1 {
                    spine[0]
                  } else {
                    @engine.Seq(spine)
                  }
                  add_greedy(
                    build,
                    maybe_root(
                      e.link_depth,
                      @engine.Seq(
                        with_depr(e, [
                          @engine.Exact(trigger),
                          // DR-034 last-wins-whole-cell (multiple уёАсЂЌсЂ«тєЇуЎ║уЂФсЂ»сѓ╗сЃФСИИсЂћсЂеСИіТЏИсЂЇ):
                          // "#fire" marks this firing's start so `resolve.mbt`'s ROW-GROUP branch
                          // can discard every EARLIER firing's rows wholesale rather than merging
                          // leaf-by-leaf (which would wrongly keep a superseded rep whose position
                          // the later, shorter firing never touched).
                          @engine.Scoped(
                            e.name,
                            @engine.Bind("#fire", @engine.VBool(false)),
                          ),
                          @engine.GreedyRepeat(tail),
                        ]),
                      ),
                    ),
                  )
                }
              }
            None =>
              // DR-076 ┬Д1/┬Д2/┬Д4: every value-typed main entry (bool included, flag ALREADY
              // normalized to bool_type() by `normalize_option`, DR-076 ┬Д2) is a NORMAL value satellite
              // Рђћ `:set` always takes a value (space form here; eq form via eq_entries below). A
              // bare `--x` fire (the classic flag shape) needs the explicit `:set:true` variant
              // (decoded as a @engine.Set-op @engine.Variant with operand @engine.VBool(true), lowered by the "@engine.Variant
              // entries" loop below, which also carries the fail_action failure resident Рђћ flag's
              // presence-only lowering has fully collapsed into that generic variant path; this
              // arm no longer special-cases flag_type()/bool_type() bare-true at all).
              //
              // DESIGN ┬Д7.2 / DR-096 ┬Д1: `long_eq_sep == @engine.EsRequire` withholds THIS space-form main
              // entry Рђћ the only entry point left is the eq-split form registered below (`eq_group`
              // push). Paired with `long_prefix: ""` (DR-096 ┬Д3.3, node.mbt's `@engine.ElemDef.long_prefix`
              // doc comment), this is the mechanism an app can opt into to definitionally eliminate
              // the bare-operand collision: with no space-form trigger, `trigger` (== `l` when
              // `long_prefix` is `""`) never matches a bare token Рђћ only `eq_split`, which fires
              // exclusively on tokens containing `=`, can reach this element. Neither `long_prefix`
              // nor `long_eq_sep` requires this pairing Рђћ an unpaired empty prefix is legal and any
              // resulting collision surfaces as @engine.Ambiguous instead.
              if e.long_eq_sep != @engine.EsRequire {
                // DR-058 ┬Д2: a deprecated element's space-form main entry carries a `deprecation resident`
                // warning marker after its value slot (node.mbt's `deprecation resident` doc shape), mirroring
                // `inst_short`'s `depr: e.deprecated` on the SAME element (`e.deprecated` covers
                // both a directly-deprecated canonical entry and a deprecated alias entry-copy,
                // DR-057 ┬Д3 `alias_entry` Рђћ both fold into this ONE `@engine.ElemDef.deprecated` bool by
                // the time lowering runs, so no alias-specific branch is needed here). Routed
                // through `with_depr` (codex сЃгсЃЊсЃЦсЃ╝ Major 2) so this arm shares the SAME funnel
                // as BOr/BEnum/ref┬▒repeat above.
                add_greedy(
                  build,
                  maybe_root(
                    e.link_depth,
                    @engine.Seq(
                      with_depr(e, [
                        @engine.Exact(trigger),
                        value_prim(
                          e.ty,
                          e.name,
                          e.int_round,
                          e.allow_base_prefix,
                          e.bool_config,
                          e.piece_filters,
                          separator=e.separator,
                          merge=e.accumulator == Some("merge"),
                          kv_map=e.accumulator == Some("kv_map"),
                        ),
                      ]),
                    ),
                  ),
                )
              }
          }
      }
      // eq-split value form (`--key=value`): every value-typed main entry gets this (bool included,
      // DR-076 ┬Д1) Рђћ a flag's default sugar carries NO main entry at all (`e.long` stays [], DR-076
      // ┬Д2), so this loop never runs for a bare classic flag; an explicit `long:[":set"]` flag DOES
      // register its value-slot form here, coexisting with the bare `:set:true` variant (DR-076 ┬Д2
      // "valueтйб+УБИсЂ«тљїт▒Ё"). DR-076 ┬Д3: bool_type()'s variant-guard exclusion (eq-split withheld when the
      // element ALSO carries `--x`/`--no-x` variant spellings) is REPEALED Рђћ bool's eq-split and
      // variant triggers coexist (fixtures/lowering/long/variant.json's ssl: `--ssl=false` fires
      // alongside `--ssl`/`--no-ssl`).
      // DR-075 ┬Д2: int_type() сЂ« eq-split (`--v=2.5`) сЂї factory config int_round сѓњтЈЇТўасЂЎсѓІсѓѕсЂєсђЂ
      // @engine.ElemDef.int_round сѓњ EqEntry сЂФТїЂсЂАУЙ╝сѓђ (int_type() С╗ЦтцќсЂ» entry тЂ┤сЂДтЈѓуЁДсЂЋсѓїсЂфсЂё)сђѓ
      // MDR-004 ┬Д3: a BOr element's eq-split registers only for a single-value-cell branch (using
      // that leaf's own name/ty/int_round/allow_base_prefix, never the wrapper's) Рђћ a multi-cell
      // branch's `=` form is undefined (`--color=v` cannot supply 3 leaves).
      // DR-091 ┬Д2: a `kv_map`-accumulator leaf does NOT register an eq-split entry (unlike merge,
      // which shares the same `sep_binds` pipeline as the space form) Рђћ `run_eq_split` (builtins/matcher_residents.mbt)
      // builds its binding through `sep_binds`, which has no "the piece must contain `=`" gate (that
      // gate lives in the `kv resident` node, `value_prim`'s dedicated kv_map branch, which `EqEntry`
      // never routes through). Registering here would let `--define=NOEQUALSIGN` silently produce
      // `{NOEQUALSIGN: ""}` instead of DR-091 ┬Д2's required Reject Рђћ same deliberate-absence posture
      // as `BEnum`'s "OUT OF SCOPE" comment below, not an oversight.
      //
      // DR-014сђї--name=value сЂ«Уе▒тЈ»сђЇ/ DESIGN ┬Д7.2 / DR-096 ┬Д1: `e.long_eq_sep` (scope config,
      // decode-time baked Рђћ always the WRAPPING option's resolved value, never a BOr leaf's unbaked
      // default, same reasoning `eq_group(..., e.long_prefix)` already applies below) gates every
      // arm Рђћ `@engine.EsDeny` withholds the eq-split entry entirely, leaving only the space form registered
      // above.
      match e.body {
        BOr(branches) =>
          for br in branches {
            if br.items.length() == 1 {
              let leaf = br.items[0]
              if e.long_eq_sep != @engine.EsDeny &&
                leaf.accumulator != Some("kv_map") {
                eq_group(eq_prefixes, eq_groups, e.long_prefix).push(
                  eq_entry(
                    l,
                    leaf.name,
                    configured_type(
                      leaf.ty,
                      leaf.int_round,
                      leaf.allow_base_prefix,
                      leaf.bool_config,
                    ),
                    leaf.piece_filters,
                    leaf.separator,
                    merge=leaf.accumulator == Some("merge"),
                    depr=leaf.deprecated,
                  ),
                )
              }
            }
          }
        BGroup(_) => () // positional-only shape (MDR-004 ┬Д3 scope) Рђћ no long spelling applies
        BCell =>
          // DR-076 ┬Д2: no `e.ty.name() != "flag"` guard needed here anymore Рђћ a classic flag never reaches
          // this loop body at all (its `e.long` is empty, `long_of(e)` yields no `l` to iterate), so
          // the guard was always vacuous for it; an explicit `long:[":set"]` flag (now bool_type()) SHOULD
          // register its eq-split form, which this unconditional push now does correctly (the guard
          // used to wrongly suppress it while `e.ty` still read flag_type() pre-normalize_option).
          if e.long_eq_sep != @engine.EsDeny && e.accumulator != Some("kv_map") {
            eq_group(eq_prefixes, eq_groups, e.long_prefix).push(
              eq_entry(
                l,
                e.name,
                configured_type(
                  e.ty,
                  e.int_round,
                  e.allow_base_prefix,
                  e.bool_config,
                ),
                e.piece_filters,
                e.separator,
                merge=e.accumulator == Some("merge"),
                depr=e.deprecated,
              ),
            )
          }
        // BEnum (issue values-decode-support): eq-split (`--color=always`) for an enum-constrained
        // cell is OUT OF SCOPE for this issue (no target fixture exercises `--key=value` against a
        // `values`/`or` value-enum element) Рђћ the EqEntry type resident has no
        // enum-value set. Registering nothing avoids accepting an unvalidated value.
        BEnum(_) => ()
      }
    }
  }
  // DR-091 ┬Д3: emit one `eq_split` matcher PER DISTINCT `long_prefix` seen (was: a single
  // `eq_split(prefix="--", ...)` for the whole @engine.Definition Рђћ `eq_group`'s doc comment).
  let mut gi = 0
  while gi < eq_prefixes.length() {
    if eq_groups[gi].length() > 0 {
      add_greedy(
        build,
        @engine.NativeMatch(eq_split(eq_prefixes[gi], eq_groups[gi])),
      )
    }
    gi = gi + 1
  }
  // @engine.Variant entries (DR-011 / DR-045): `{exact, link (by name), effect}` сЂФ loweringсђѓ
  // `set` variant сЂ» @engine.Bind (SET degenerate); default/unset/empty сЂ» effect resident (0-token effect)сђѓ
  // DR-076 ┬Д2/┬Д4: a flag's classic bare-fire trigger IS a @engine.Set variant now (`:set:true`, composed in
  // by dec_long) Рђћ it rides through here, not through the old flag_type()-only branch above. A fail_action
  // element (DR-048, e.g. help) additionally emits a failure resident alongside its @engine.Set variant's @engine.Bind, so
  // this loop must carry the SAME fail_action attachment the collapsed flag_type() branch used to (a
  // fail_action flag firing here Рђћ its ONLY main-entry shape post-DR-076 ┬Д2 Рђћ must still be able to
  // select as a failed-parse action).
  for e in def.options {
    for v in e.variants {
      // issue scope-config-object-gap codex ТїЄТЉў Major 2: main entry (inst_long тєњжаГ) сЂе eq-split
      // (eq_group) сЂ»ТЌбсЂФ e.long_prefix сѓњСй┐сЂє Рђћ variant сЂасЂЉ "--" тЏ║т«џсЂасЂетљїСИђ option family сЂ«
      // уХ┤сѓісЂї long_prefix жЮъТЌбт«џТЎѓсЂФтѕєУБѓсЂЎсѓІ (DR-091 ┬Д3 сЂ«СИђУ▓ФТђДсѓњ variant сЂФсѓѓтЈісЂ╝сЂЎ)сђѓТЌбт«џ
      // "--" сЂфсЂ«сЂДТЌбтГўТїЎтІЋ (main entry сЂеТЈЃсЂБсЂЪ "--" уХ┤сѓі) сЂ»СИЇтцЅсђѓ
      let trigger = e.long_prefix + v.trigger
      // DR-058 ┬Д2: a deprecated element's variant satellite (@engine.Set's @engine.Bind OR a non-@engine.Set effect resident) also
      // carries a trailing `deprecation resident` Рђћ every long entry point this element owns fires the SAME
      // warning, symmetric with `inst_short`'s per-char `depr: e.deprecated` (a short cluster char
      // has no variant/main-entry split, so ONE application point covers it; long's split into
      // main-entry (above) + variant (here) needs both covered for parity).
      let nodes : Array[@engine.Node] = match v.op {
        @engine.Set => {
          let operand = match v.operand {
            Some(val) => val
            None => @engine.VBool(true)
          }
          if e.fail_action {
            [
              @engine.Exact(trigger),
              @engine.Bind(e.name, operand),
              failure_mark(e.name),
            ]
          } else {
            [@engine.Exact(trigger), @engine.Bind(e.name, operand)]
          }
        }
        _ => [@engine.Exact(trigger), effect_mark(e.name, v.op)]
      }
      add_greedy(
        build,
        maybe_root(e.link_depth, @engine.Seq(with_depr(e, nodes))),
      )
    }
  }
}

///|
/// global link COPY (link_depth > 0) сѓњ `@engine.Rooted(node, depth)` сЂДтїЁсѓђ Рђћ bindings сЂї declaring scope сЂ«
/// entity сЂФ landing сЂЎсѓІсѓѕсЂє escape сЂЎсѓІ (DR-042 link-sync)сђѓlink_depth == 0 сЂ»УЄфт«БУеђсЂД wrap сЂЌсЂфсЂёсђѓ
fn maybe_root(link_depth : Int, node : @engine.Node) -> @engine.Node {
  if link_depth > 0 {
    @engine.Rooted(node, link_depth)
  } else {
    node
  }
}

///|
/// DESIGN ┬Д7.2 / LOWERING ┬ДB.2: mirrors `eq_group` (long installer, DR-091 ┬Д3) Рђћ bundles every
/// short-cluster entry under ONE `(short_prefix, short_combine)` PAIR per `short_combine` matcher
/// instance. Keying on the pair (not `short_prefix` alone) matters because a `@engine.Definition`'s
/// `def.options` can mix elements from 2 sources with different defaults: elements decoded in THIS
/// scope (uniform `short_prefix`/`short_combine`, both baked from the SAME resolved `ScopeConfig`
/// by `dec_definition`) and elements COPIED in from elsewhere (`add_inheritable_copy`/`alias_entry`,
/// which hardcode the canonical defaults `"-"`/`true` regardless of the current scope's config,
/// mirroring `long_prefix`'s existing "--" hardcode at those same call sites). If 2 elements
/// disagreed on `short_combine` while sharing `short_prefix`, merging them into ONE matcher would
/// require inventing a tie-break policy (spec is silent) Рђћ keying on the pair instead routes each
/// distinct combination to its own matcher, so no policy is ever needed.
fn short_group(
  prefixes : Array[String],
  combines : Array[Bool],
  groups : Array[Array[ShortEntry]],
  prefix : String,
  combine : Bool,
) -> Array[ShortEntry] {
  let mut i = 0
  while i < prefixes.length() {
    if prefixes[i] == prefix && combines[i] == combine {
      return groups[i]
    }
    i = i + 1
  }
  let g : Array[ShortEntry] = []
  prefixes.push(prefix)
  combines.push(combine)
  groups.push(g)
  g
}

///|
/// short: `short` сѓњ READсђЂcluster/value-attach matcher сѓњ 1 Тюг add-if-absentсђѓPoC сЂДсЂ» single-char
/// (`-v`, `-p 8080`) сѓѓ matcher сЂФжЏєу┤ёсЂЎсѓІсЂЪсѓЂсђЂshort сЂ»уІгуФІ exact УАЏТўЪсѓњуЎ║сЂЌсЂфсЂё (matcher-seat)сђѓ
/// DESIGN ┬Д7.2: `e.short_prefix` replaces the old hardcoded `"-"` Рђћ one `short_combine` matcher PER
/// DISTINCT `(short_prefix, short_combine)` pair actually present (was: a single
/// `short_combine(prefix="-", ...)` for the whole `@engine.Definition`), same generalization DR-091 ┬Д3
/// already applied to `inst_long`/`eq_split`. `e.short_combine` (issue scope-config-object-gap
/// УДБжЄѕA, team-lead УБЂт«џ 2026-07-11) rides straight through to the matcher's `combine` param Рђћ
/// `run_short`/`walk_short` (builtins/matcher_residents.mbt) are the sole consumers of the flag's actual meaning.
fn inst_short(def : @engine.Definition, build : @engine.InstallBuild) -> Unit {
  let sh_prefixes : Array[String] = []
  let sh_combines : Array[Bool] = []
  let sh_groups : Array[Array[ShortEntry]] = []
  for e in def.options {
    for c in e.short {
      // DR-058: deprecated alias entry-copy сЂ» cluster entry сЂДсѓѓУГдтЉісЂЎсѓІ
      // DR-075 ┬Д2: short cluster / space-tail ухїУи»сЂ« int_type() (`-n1.5` / `-n 1.5`) сѓѓ factory config сѓњтЈЇТўа
      short_group(
        sh_prefixes,
        sh_combines,
        sh_groups,
        e.short_prefix,
        e.short_combine,
      ).push(
        short_entry(
          c,
          e.name,
          configured_short_type(
            e.ty,
            e.int_round,
            e.allow_base_prefix,
            e.bool_config,
          ),
          e.piece_filters,
          e.separator,
          depr=e.deprecated,
          merge=e.accumulator == Some("merge"),
          short_attached_value=e.short_attached_value,
          is_alias=e.is_alias,
        ),
      )
    }
  }
  let mut gi = 0
  while gi < sh_prefixes.length() {
    if sh_groups[gi].length() > 0 {
      add_greedy(
        build,
        @engine.NativeMatch(
          short_combine(sh_prefixes[gi], sh_groups[gi], sh_combines[gi]),
        ),
      )
    }
    gi = gi + 1
  }
}

///|
/// env: `env` сѓњ READсђЂentity сЂ« env seat сЂФуЎ╗жї▓ (invariant РЉБ)сђѓladder жаєт║ЈсЂ» engine ТЅђТюЅ (DR-031)сђЂ
/// default_fn сѓњ wrap сЂЌсЂфсЂёсђѓтљї seat тєЇт«БУеђсЂ» no-op (idempotent in-place set)сђѓ
fn inst_env(def : @engine.Definition, build : @engine.InstallBuild) -> Unit {
  for e in def.options {
    if e.env.length() > 0 {
      seat_env(build, e.name, e.env[0])
    }
  }
  for e in def.positionals {
    if e.env.length() > 0 {
      seat_env(build, e.name, e.env[0])
    }
  }
}

///|
fn seat_env(build : @engine.InstallBuild, name : String, key : String) -> Unit {
  for ent in build.entities() {
    if ent.name == name {
      ent.env_key = Some(key)
    }
  }
}

///|
/// dd: `type:"dd"` сѓњ READсђЂgreedy exact УАЏТўЪ (@engine.DdSat) сѓњ add-if-absent (DR-041 rev)сђѓfire ТЎѓсЂФ spine
/// walk сЂїсђїseveredсђЇсЃбсЃ╝сЃЅсЂФтѕЄсѓіТЏ┐сѓЈсѓіС╗ЦжЎЇ greedy off Рђћ greedy internal consumption СИђСйЊтїќсЃФсЃ╝сЃФсђѓ
///
/// DR-064 ┬Д2 жЁЇуй«СИЇтЋЈтЏътЈј: dd сЂ» canonical сЂФсЂ» options[] сЂасЂї positionals[] сЂФуй«сЂёсЂдсѓѓтЏътЈјсЂЎсѓІ
/// (env / inherit сЂетљїсЂўсЂЈСИА face сѓњ walk сЂЎсѓІт»ЙуД░тйб)сђѓadd-if-absent (add_greedy) сЂїжЄЇУцЄт«БУеђсѓњ collapseсђѓ
fn inst_dd(def : @engine.Definition, build : @engine.InstallBuild) -> Unit {
  // DR-064 ┬Д5: dd сЂ« name сЂ» trigger уХ┤сѓісЂФті╣сЂЈ (normalize_surface сЂїТЌбт«џ "--" сѓњСЙЏухдсђЂТўјуц║сЂ»СИіТЏИсЂЇ)сђѓ
  // DR-090 ┬Д2: `dd_match` сЂї None сЂІсЂц `dd_self_keep` сЂї false (СИАУ╗ИсЂесѓѓТЌбт«џ) сЂ«УдЂу┤асЂасЂЉсђЂТЌбтГў
  // `@engine.DdSat` (exact/drop т░ѓућесЃјсЃ╝сЃЅ) сѓњсЂЮсЂ«сЂЙсЂЙСй┐сЂє Рђћ т«їтЁесЂфтЙїТќ╣С║њТЈЏ (ТЌбтГў wbtest сЂ« `@engine.DdSat("--")`
  // ТЅІухёсЂ┐сЂеТДІжђаСИђУЄ┤сЂЌуХџсЂЉсѓІ)сђѓсЂЕсЂАсѓЅсЂІсЂ«У╗ИсЂїТЌбт«џсЂІсѓЅтцќсѓїсЂЪсѓЅСИђУѕгтїќсЃјсЃ╝сЃЅ `@engine.DdMatchSat` сѓњуЕЇсѓђ
  // (`match` сЂї Some сЂ«сЂесЂЇ name сЂ»сЃѕсЃфсѓгуХ┤сѓісЂФСй┐сѓЈсѓїсЂфсЂёсђЂ┬Д2 сЂ«УдЈт«џжђџсѓі `e.name` сЂ«С╗БсѓЈсѓісЂФ
  // `dd_match` сЂ« pattern сѓњ spelling сЂФСй┐сЂє)сђѓ
  fn dd_node(e : @engine.ElemDef) -> @engine.Node {
    if e.dd_match is None && !e.dd_self_keep {
      @engine.DdSat(e.name)
    } else {
      match e.dd_match {
        Some(pattern) =>
          @engine.DdMatchSat(pattern, true, e.dd_self_keep, e.name)
        None => @engine.DdMatchSat(e.name, false, e.dd_self_keep, e.name)
      }
    }
  }

  for e in def.options {
    if e.is_dd {
      add_greedy(build, dd_node(e))
    }
  }
  for e in def.positionals {
    if e.is_dd {
      add_greedy(build, dd_node(e))
    }
  }
}

///|
/// add-if-absent (invariant РЉа' жЮътЅіжЎц): ТДІжђауГЅСЙАсЂфТЌбтГўсЂїсЂѓсѓїсЂ░У┐йтіасЂЌсЂфсЂёсђѓтєЇжЂЕућесѓњ no-op сЂФсђЂfixpoint
/// сѓњтЈјТЮЪсЂЋсЂЏсѓІсђѓ
fn add_greedy(build : @engine.InstallBuild, g : @engine.Node) -> Unit {
  for existing in build.greedy() {
    if existing == g {
      return
    }
  }
  build.greedy().push(g)
}

///|
/// inherit: `inherit` сѓњ READсђЂentity сЂФ inherit seat сѓњт«БУеђ (invariant РЉБ, DR-031 cli>env>inherit>default)сђѓ
/// seat сЂ«т«Ъ lookup сђїТюђУ┐ЉуЦќтЁѕсЂ«тљїтљЇ entity тђцсђЇсЂ» runtime (resolve_scope) сЂДУДБсЂЈсђѓenv сЂет»ЙуД░сЂ« seat т«БУеђтъІсђѓ
fn inst_inherit(def : @engine.Definition, build : @engine.InstallBuild) -> Unit {
  for e in def.options {
    if e.is_inherit {
      seat_inherit(build, e.name)
    }
  }
  for e in def.positionals {
    if e.is_inherit {
      seat_inherit(build, e.name)
    }
  }
}

///|
fn seat_inherit(build : @engine.InstallBuild, name : String) -> Unit {
  for ent in build.entities() {
    if ent.name == name {
      ent.inherit_ = true // MDR-003
    }
  }
}

///|
/// global: `global` сѓњ READсђЂoption т«БУеђсѓњтГљтГФ command scope сЂ«т«БУеђт▒цсЂФсѓ│сЃћсЃ╝ (invariant РЉА)сђѓ
/// long/short сЂ»ТгА pass С╗ЦжЎЇсЂДтГљсЂДт▒ЋжќІсЂЎсѓІсђѓshadowing (DR-032/033, Тюђт░Ј scope): тГљсЂїтљїсЃѕсЃфсѓгсѓњТЌбсЂФ
/// т«БУеђсЂЌсЂдсЂёсѓїсЂ░ copy сЂЌсЂфсЂё (УЄфтЅЇсЂїтІЮсЂц)сђѓcopy сЂ» `is_global` сѓњС┐ЮТїЂсЂЌсђЂfixpoint сЂДТЏ┤сЂФСИІСйЇсЂИтєЇС╝ЮТњГсђѓ
fn inst_global(sb : @engine.InstallBuilder) -> Unit {
  for opt in sb.definition().options {
    if opt.is_global {
      for child in sb.children() {
        copy_global_into(child.body(), opt)
      }
    }
  }
}

///|
fn copy_global_into(
  child : @engine.InstallBuilder,
  opt : @engine.ElemDef,
) -> Unit {
  for existing in child.definition().options {
    if triggers_overlap(existing, opt) {
      return // shadow сЂЙсЂЪсЂ»ТЌбсЂФ copy ТИѕ (idempotent, сЃѕсЃфсѓгтЪ║Т║ќ)
    }
    // DR-057 alias СйхућесЃЉсѓ┐сЃ╝сЃ│ (canonical тЂ┤сЂ» global сЂасЂїсЃѕсЃфсѓгсѓњТїЂсЂЪсЂфсЂё = long/short/variants
    // тЁесЂдуЕ║сЂДсђЂalias тЂ┤сЂасЂЉсЂїт«ЪжџЏсЂ«сЃѕсЃфсѓгсѓњтѕЦУдЂу┤асЂесЂЌсЂдТїЂсЂц) сЂДуЎ║УдІ: `triggers_overlap` сЂ»СИАУђЁсЂесѓѓ
    // сЃѕсЃфсѓгжЏєтљѕсЂїуЕ║сЂасЂетИИсЂФ false сѓњУ┐ћсЂЎсЂЪсѓЂсђЂСИісЂ«сЃЂсѓДсЃЃсѓ»сЂасЂЉсЂДсЂ»сђїТЌбсЂФсѓ│сЃћсЃ╝ТИѕсЂ┐сЂ« trigger-less
    // canonicalсђЇсѓњТцютЄ║сЂДсЂЇсЂџсђЂfixpoint сЂ«сЂЪсЂ│сЂФтљїсЂўУдЂу┤асѓњтєЇсѓ│сЃћсЃ╝сЂЌуХџсЂЉсЂдтЈјТЮЪсЂЌсЂфсЂё
    // (installer chain did not converge)сђѓтљїтљЇ + link_depth>0 (= сѓ│сЃћсЃ╝ућ▒ТЮЦ) сЂ«ТЌбтГўУдЂу┤асЂїсЂѓсѓїсЂ░сђЂ
    // idempotent сЂесЂ┐сЂфсЂЎ Рђћ сЂЪсЂасЂЌтѕцт«џсЂ»сЃѕсЃфсѓгжЏєтљѕсѓѓСИђУЄ┤сЂЎсѓІта┤тљѕсЂФжЎљсѓІ (codex ТїЄТЉўсђЂт«ЪТЕЪуб║УфЇТИѕсЂ┐
    // regression: тљїтљЇсЂасЂї**тѕЦсЃѕсЃфсѓг**сЂ« 2 сЂцсЂ« global сЂїуЦќтЁѕсЃЂсѓДсЃ╝сЃ│сЂ«уЋ░сЂфсѓІТ«хсЂДсЂЮсѓїсЂъсѓїуІгуФІсЂФт«БУеђ
    // сЂЋсѓїсЂдсЂёсѓІта┤тљѕсђЂ`name` сЂасЂЉсЂДтѕцт«џсЂЎсѓІсЂетЁѕсЂФсѓ│сЃћсЃ╝сЂЋсѓїсЂЪТќ╣сЂїтЙїуХџсЂ«тѕЦсЃѕсЃфсѓг copy сѓњУфцсЂБсЂд
    // ТіЉТГбсЂЌсђЂтГФсѓ╣сѓ│сЃ╝сЃЌсЂИСИђТќ╣сЂ«сЃѕсЃфсѓгсЂїС╝ЮТњГсЂЌсЂфсЂЈсЂфсѓІ Рђћ conformance сЂ« parse() ухїућ▒сЃєсѓ╣сЃѕсЂДсЂ»
    // DR-041 ┬Д4 ТЌЕжќЅсЂў+porous сЂїУд│ТИгухљТъюсѓњтЂХуёХС┐ЮтГўсЂЌсЂдсЂЌсЂЙсЂёТцютЄ║сЂДсЂЇсЂфсЂІсЂБсЂЪсЂЪсѓЂсђЂ`materialize` тЙї
    // сЂ« @engine.Scope ТДІжђа (@engine.Rooted УАЏТўЪсЂ«ТюгТЋ░) сѓњуЏ┤ТјЦТцюТЪ╗сЂЎсѓІ wbtest сЂДуб║УфЇсЂЌсЂЪ)сђѓсЃѕсЃфсѓгжЏєтљѕсЂїСИАТќ╣сЂесѓѓ
    // уЕ║жЏєтљѕсЂ«та┤тљѕсЂ»сђїжЏєтљѕСИђУЄ┤сђЇсѓѓУЄфТўјсЂФТѕљуФІсЂЎсѓІсЂ«сЂДсђЂтЁЃсЂ« trigger-less canonical сЃљсѓ░сЂ«С┐«ТГБсЂ»
    // сЂЊсЂ«сЂЙсЂЙуХГТїЂсЂЋсѓїсѓІсђѓ
    if existing.name == opt.name &&
      existing.link_depth > 0 &&
      trigger_sets_equal(existing, opt) {
      return
    }
  }
  // copy сЂ» link УАЏТўЪ (DR-042): declaring scope сЂ« entity сѓњ bind (тГљсЂ»УЄф cell сѓњТїЂсЂЪсЂфсЂё)сђѓ
  // link_depth = declaring scope сЂІсѓЅсЂ«Т«хТЋ░ (+1 per re-propagation)сђѓlong/short сЂї @engine.Rooted(node, depth)
  // сЂД wrap сЂЎсѓІсђѓ
  //
  // INVARIANT (install-time count Рєћ eval-time decrement, уЈЙтѕХу┤ё): сЂЊсЂ« +1 сЂ» SCOPE (name/command) copy
  // level сЂ«сЂ┐ТЋ░сЂѕсѓІ (copy_global_into 1 Т«хсЂФсЂцсЂЇ 1)сђѓeval тЂ┤сЂ« @engine.Rooted `link` counter сЂ» 2 уе«сЂ« nesting
  // (nest = scope Т«х / nest_index = rep #k Т«х) сЂДТИЏу«ЌсЂЋсѓїсѓІсђѓсЂЌсЂЪсЂїсЂБсЂдсђїlink_depth == УАЏТўЪсЂе declaring
  // scope сЂ«жќЊсЂ« eval nesting Т«хТЋ░сђЇсЂ«СИЇтцЅТЮАС╗ХсЂ»сђї@engine.Rooted УАЏТўЪсЂї @engine.IdxRepeat сЂ«СИІсЂФуй«сЂІсѓїсЂфсЂёсђЇТЮАС╗ХСИІсЂДсЂ«сЂ┐
  // ТѕљуФІсЂЎсѓІ Рђћ уЈЙУАї lowering сЂ» @engine.Rooted сѓњ scope spine сЂД wrap сЂЌсђЂrepeat head тєЁсЂФсЂ»тЁЦсѓїсЂфсЂёсЂ«сЂДТ║ђсЂЪсЂЎсђѓ
  // т░єТЮЦ nested-group сЂї scope/global сѓњ repeat уЙцсЂФУе▒т«╣сЂЎсѓІсЂфсѓЅсђЂсЂЊсЂ« +1 сЂФ rep-nesting depth сѓѓтіау«ЌсЂЎсѓІсђѓ
  let copy = clone_elem(opt)
  child.definition().options.push({
    name: copy.name,
    ty: copy.ty,
    long: copy.long,
    variants: copy.variants,
    short: copy.short,
    env: copy.env,
    is_tty: copy.is_tty,
    tty_stream: copy.tty_stream,
    tty_cygwin: copy.tty_cygwin,
    is_dd: copy.is_dd,
    is_exact: copy.is_exact,
    dd_match: copy.dd_match,
    dd_self_keep: copy.dd_self_keep,
    is_global: copy.is_global,
    is_inherit: copy.is_inherit,
    is_inheritable: copy.is_inheritable,
    link_depth: copy.link_depth + 1,
    ref_target: copy.ref_target,
    repeat: copy.repeat,
    optional: copy.optional,
    multiple: copy.multiple,
    accumulator: copy.accumulator,
    flatten: copy.flatten,
    separator: copy.separator,
    collector: copy.collector,
    fail_action: copy.fail_action,
    is_config_file: copy.is_config_file,
    config_key: copy.config_key,
    export_key: copy.export_key,
    requires: copy.requires,
    conflicts_with: copy.conflicts_with,
    exclusive_group: copy.exclusive_group,
    required_group: copy.required_group,
    required: copy.required,
    value_requires: copy.value_requires,
    deprecated: copy.deprecated,
    is_alias: copy.is_alias,
    hidden: copy.hidden,
    completer: copy.completer,
    default_values: copy.default_values,
    int_round: copy.int_round,
    allow_base_prefix: copy.allow_base_prefix,
    bool_config: copy.bool_config,
    piece_filters: copy.piece_filters,
    value_filters: copy.value_filters,
    final_filters: copy.final_filters,
    accum_filters: copy.accum_filters,
    long_prefix: copy.long_prefix,
    short_prefix: copy.short_prefix,
    env_prefix: copy.env_prefix,
    auto_env: copy.auto_env,
    long_eq_sep: copy.long_eq_sep,
    short_combine: copy.short_combine,
    short_attached_value: copy.short_attached_value,
    body: copy.body,
  })
}

///|
/// An element's every long CLI trigger spelling (kebab, sans `--` prefix) Рђћ `long_of` (the resolved
/// `:set` main entry, post `resolve_long`) AND `variants` (each colon-DSL variant's own trigger,
/// DR-011/076) combined. The two arrays are just WHERE a spelling landed post-`resolve_long`
/// (main-entry sentinel vs. colon-DSL variant); the actual `--xxx` wire spelling they produce is the
/// same kind of string either way, so any trigger-identity comparison (`triggers_overlap`) must look
/// at both together Рђћ otherwise the SAME spelling can hide in `long` on one element and `variants` on
/// the other (e.g. a flag's `:set:true` composed bare-fire trigger lands in `variants`, DR-076 ┬Д2,
/// while a plain `:set` main entry lands in `long`) and a real collision goes undetected.
fn all_long_triggers(e : @engine.ElemDef) -> Array[String] {
  let out : Array[String] = []
  for l in long_of(e) {
    out.push(l)
  }
  for v in e.variants {
    out.push(v.trigger)
  }
  out
}

///|
/// 2 УдЂу┤асЂ«сЃѕсЃфсѓгжЏєтљѕсЂїт«їтЁеСИђУЄ┤сЂЎсѓІсЂІ (жаєт║ЈуёАУдќсђЂ`all_long_triggers` сЂ«жЏєтљѕсЂесЂЌсЂдТ»ћУ╝Ѓ)сђѓ
/// `copy_global_into` сЂ« idempotent тѕцт«џ (тљїтљЇ + сѓ│сЃћсЃ╝ућ▒ТЮЦ + сЃѕсЃфсѓгжЏєтљѕСИђУЄ┤) т░ѓуће Рђћ сЃѕсЃфсѓгжЏєтљѕсЂї
/// СИАТќ╣сЂесѓѓуЕ║сЂфсѓЅУЄфТўјсЂФСИђУЄ┤сЂЎсѓІ (trigger-less canonical сЂ« idempotent тѕцт«џсѓњС┐ЮсЂц)сђѓ
fn trigger_sets_equal(a : @engine.ElemDef, b : @engine.ElemDef) -> Bool {
  let ta = all_long_triggers(a)
  let tb = all_long_triggers(b)
  if ta.length() != tb.length() {
    return false
  }
  for t in ta {
    if !str_in(tb, t) {
      return false
    }
  }
  true
}

///|
/// сЃѕсЃфсѓгУАЮуфЂ: 2 option сЂї long / short / long variant сЂёсЂџсѓїсЂІсѓњтЁ▒ТюЅсЂЎсѓїсЂ░УАЮуфЂ (shadow сЂ»сЃѕсЃфсѓгтЪ║Т║ќ =
/// тљїтљЇсЃѕсЃфсѓг)сђѓlong сЂ« main entry сЂе variant сЂ»Та╝у┤Їта┤ТЅђсЂїжЂЋсЂєсЂасЂЉсЂДтљїсЂў trigger УфътйЎ (`all_long_triggers`
/// тЈѓуЁД) сЂфсЂ«сЂДсђЂТ»ћУ╝ЃсЂ»СИАУђЁсѓњтљѕсѓЈсЂЏсЂЪжЏєтљѕтљїтБФсЂДУАїсЂєсђѓ
fn triggers_overlap(a : @engine.ElemDef, b : @engine.ElemDef) -> Bool {
  for ta in all_long_triggers(a) {
    for tb in all_long_triggers(b) {
      if ta == tb {
        return true
      }
    }
  }
  for ca in a.short {
    for cb in b.short {
      if ca == cb {
        return true
      }
    }
  }
  false
}

// РћђРћђ driver + completeness РћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђ

///|
/// inheritable installer (DR-059): global сЂ« REVERSE Тќ╣тљЉсђѓтГљтГФсЂ« inheritable УдЂу┤асѓњтЁеуЦќтЁѕ scope сЂФ
/// `<т«џуЙЕсѓ╣сѓ│сЃ╝сЃЌтљЇ>-<name>` уХ┤сѓісЂДсѓ│сЃћсЃ╝ (┬Д1)сђѓуЦќтЁѕсЂ« `--socket-ttl` сЂїуЦќтЁѕ `ttl` cell сЂФ bindсђѓ
/// тЁе `ttl` cell (т«џуЙЕ + уЦќтЁѕсѓ│сЃћсЃ╝) сЂФ inherit seat сЂїуФІсЂцсЂ«сЂДсђЂС╗╗ТёЈт▒цсЂ«тђцсЂїтГљтГФсЂ« default сЂесЂЌсЂдТхЂсѓїСИІсѓІ
/// (┬Д3 тђцТёЈтЉ│УФќ Рђћ inherit seat сЂ«т»Й DR-031)сђѓуЦќтЁѕсЂїтљїсЃѕсЃфсѓгсѓњУЄфт«БУеђсЂфсѓЅ shadow сЂД copy сЂЌсЂфсЂё (global т»ЙуД░)сђѓ
fn inst_inheritable(sb : @engine.InstallBuilder) -> Unit {
  // (1) тГљтГФсЂ« inheritable Рєњ THIS (уЦќтЁѕ) scope сЂ«т«БУеђт▒цсЂФ prefixed write-entry сѓњУ┐йтіа
  let entries : Array[(String, @engine.ElemDef)] = []
  gather_inheritable(sb.children(), entries)
  for de in entries {
    let defining_name = de.0
    let e = de.1
    let trigger = defining_name + "-" + e.name // тЁеуЦќтЁѕтљїуХ┤сѓі (┬Д1)
    add_inheritable_copy(sb, e, trigger)
  }
  // (2) subtree сЂ« inheritable т»ЙУ▒АтљЇ (УЄфт«БУеђ + уЦќтЁѕсѓ│сЃћсЃ╝) тЁесЂдсЂФ inherit seat сѓњТЅЊсЂц (┬Д3)
  let names : Array[String] = []
  for e in sb.definition().options {
    if e.is_inheritable && !str_in(names, e.name) {
      names.push(e.name)
    }
  }
  for de in entries {
    if !str_in(names, de.1.name) {
      names.push(de.1.name)
    }
  }
  for name in names {
    seat_inherit(sb.output(), name)
  }
}

///|
/// тГљтГФ scope сЂ« inheritable УдЂу┤асѓњтЁесЂдтЏътЈј (т«џуЙЕсѓ╣сѓ│сЃ╝сЃЌтљЇсЂД tag Рђћ ┬Д1 сЂ« prefix)сђѓтЁе subtree сѓњтєЇтИ░сђѓ
fn gather_inheritable(
  children : Array[@engine.InstallChild],
  out : Array[(String, @engine.ElemDef)],
) -> Unit {
  for ch in children {
    for e in ch.body().definition().options {
      if e.is_inheritable {
        out.push((ch.name(), e))
      }
    }
    gather_inheritable(ch.body().children(), out)
  }
}

///|
/// уЦќтЁѕ scope сЂ«т«БУеђт▒цсЂФ prefixed write-entry сѓњУ┐йтіа (add-if-absent, shadow-aware)сђѓуЦќтЁѕсЂїтљїсЃѕсЃфсѓгсѓњ
/// ТЌбсЂФт«БУеђ (┬Д3 global т»ЙуД░ shadow) сЂфсѓЅ copy сЂЌсЂфсЂёсђѓDR-076 тЙїсЂ»УБИуЎ║уЂФсЃѕсЃфсѓгсЂї `variants` тЂ┤сЂФтЁЦсѓІ
/// (СЙІ: alias `[":set:true"]` ућ▒ТЮЦ) сЂЪсѓЂсђЂ`long_of` (main long сЂ«сЂ┐) сЂДсЂ»сЂфсЂЈ `all_long_triggers`
/// (long + variants ТефТќГ) сЂДтѕцт«џсЂЎсѓІт┐ЁУдЂсЂїсЂѓсѓІ Рђћ codex ТїЄТЉўсђЂт«ЪТЕЪуб║УфЇТИѕсЂ┐ regression: alias сЂї
/// variants тЂ┤сЂДТЈљСЙЏсЂЎсѓІсЃѕсЃфсѓгсѓњ `long_of` сЂасЂЉсЂДсЂ»УдІУљйсЂесЂЌсђЂтљїсЂўуХ┤сѓісЂ« inheritable сѓ│сЃћсЃ╝сѓњжЄЇУцЄ
/// У┐йтіасЂЌсЂдсЂЌсЂЙсЂє (materialize тЙїсЂ« @engine.Scope сЂФтљїСИђсЃѕсЃфсѓгсЂ« greedy УАЏТўЪсЂї 2 ТюгуФІсЂц)сђѓ
fn add_inheritable_copy(
  sb : @engine.InstallBuilder,
  e : @engine.ElemDef,
  trigger : String,
) -> Unit {
  for existing in sb.definition().options {
    if str_in(all_long_triggers(existing), trigger) {
      return // УЄфтЅЇтёфтЁѕ (shadow) / ТЌб copy (idempotent)
    }
  }
  sb.definition().options.push({
      name: e.name, // уЦќтЁѕ write-target cell сЂ»УдЂу┤атљЇтЁ▒ТюЅ (inherit-by-name)
      ty: e.ty,
      long: LList([trigger]), // prefixed inheritable trigger (post-normalize уЏИтйЊсЂ«уб║т«џтйбсђЂresolve_long сѓњухїућ▒сЂЌсЂфсЂё)
      variants: [],
      short: [],
      env: [],
      is_tty: false, // write-target copy сЂ» tty preset сѓњТїЂсЂЪсЂфсЂё (env_prefix сЂетљїсЂўсђїcanonical default уЏИтйЊсђЇ)
      tty_stream: None,
      tty_cygwin: true,
      is_dd: false,
      is_exact: false,
      dd_match: None,
      dd_self_keep: false,
      is_global: false,
      is_inherit: false, // inherit seat сЂ» inst_inheritable step(2) сЂїуФІсЂдсѓІ
      is_inheritable: false, // copy УЄфСйЊсЂ» plain entry (тєЇС╝ЮТњГсЂЌсЂфсЂё)
      link_depth: 0,
      ref_target: None,
      repeat: None,
      optional: false,
      multiple: false,
      accumulator: None,
      flatten: None,
      separator: None,
      collector: None,
      fail_action: false,
      is_config_file: false,
      config_key: None,
      export_key: @engine.export_key_unset(),
      requires: [],
      conflicts_with: [],
      exclusive_group: [],
      required_group: [],
      required: false, // write-target copy сЂ» required тѕХу┤ёсѓњТїЂсЂЪсЂфсЂё (requires/exclusive_group сЂетљїсЂўуљєућ▒)
      value_requires: [],
      deprecated: false,
      is_alias: false, // write-target copy сЂ» alias/hidden т«БУеђухїУи»сѓњТїЂсЂЪсЂфсЂё (canonical default уЏИтйЊ)
      hidden: false,
      completer: None, // write-target copy сЂ» completer т«БУеђухїУи»сѓњТїЂсЂЪсЂфсЂё (hidden сЂетљїсЂўуљєућ▒)
      default_values: None, // write-target сЂФ default сѓњуй«сЂІсЂфсЂё (┬Д3): т«ЪТЏИсЂЇУЙ╝сЂ┐сЂ«сЂ┐сЂїС╝ЮТњГсЂЎсѓІ
      int_round: @engine.RError,
      allow_base_prefix: false, // canonical default (DR-075 ┬Д2): write-target сЂ» int_round сѓњТїЂсЂЪсЂфсЂё
      // canonical default (DR-074 ┬Д2): write-target сЂ» base prefix opt-in сѓњТїЂсЂЪсЂфсЂё
      bool_config: bool_config_canonical(), // canonical default (DR-074 ┬Д4): write-target сЂ» bool_parser opt-in сѓњТїЂсЂЪсЂфсЂё
      piece_filters: [], // write-target сЂ» filter chain сѓњТїЂсЂЪсЂфсЂё (Т║љ e сЂ« value_filters сЂ» source тЂ┤сЂДТЌбсЂФжЂЕућеТИѕсЂ┐)
      value_filters: [],
      final_filters: [],
      accum_filters: [],
      long_prefix: "--", // жђџтИИсЂ« long уХ┤сѓі (kebab, Тюф prefix) Рђћ inst_long сЂїТЌбт«џ "--" сѓњтЅЇуй«сЂЎсѓІ
      short_prefix: "-", // write-target copy сЂ» short spelling сѓњТїЂсЂЪсЂфсЂё (canonical default уЏИтйЊ)
      env_prefix: "", // write-target copy сЂ» env тИГсѓњТїЂсЂЪсЂфсЂё (canonical default уЏИтйЊ)
      auto_env: false,
      long_eq_sep: @engine.EsAllow,
      short_combine: true,
      short_attached_value: @engine.AtAllow,
      body: BCell,
    }, // canonical default (┬Д3 сЂетљїсЂўсђїжђџтИИТїЎтІЋсђЇ)
    // canonical default
    // canonical default
  )
}

///|
/// `node` сЂїтђцсѓњТЮЪуИЏсЂЎсѓІтЁесЂдсЂ« leaf name сѓњтєЇтИ░уџёсЂФжЏєсѓЂсѓІ (DR-093 сЂ« or/ref УдфтЁЁУХ│тѕцт«џсЂ«т«ЪСйЊУДБТ▒║ Рђћ
/// `required_candidates` сЂ« `ref_target` тѕєт▓љсЂїСй┐сЂє)сђѓopen value resident сЂе `@engine.ReqArg` сЂ« name сЂї
/// т»ЙУ▒Асђѓ`@engine.Or`/`@engine.Seq`/`@engine.Many`/`@engine.BoundedTail`/`@engine.Rooted`/`@engine.Scoped`/`@engine.GreedyRepeat`/`@engine.IdxRepeat` сЂ»тђц
/// сЃљсѓцсЃ│сЃЄсѓБсЃ│сѓ░сѓњТїЂсЂЪсЂфсЂёТДІжђасЃЕсЃЃсЃЉсЃ╝сЂфсЂ«сЂДтєЁжЃесѓњтєЇтИ░уџёсЂФУЙ┐сѓІсђѓ`Ref` сЂ» registry сѓњУЙ┐сЂБсЂдтЈѓуЁДтЁѕ
/// сЃєсЃ│сЃЌсЃгсЃ╝сЃѕсЂФтєЇтИ░сЂЎсѓІ (`visiting` сЂ» `head_cycles` сЂетљїсЂўсђїУефтЋЈТИѕсЂ┐ template тљЇсђЇжў▓тЙА Рђћ тЙфуњ░
/// ref сЂ» `collect_circular_ref` сЂїтѕЦжђћ definition-error сЂДт╝ЙсЂЈтЅЇТЈљсЂасЂїсђЂжў▓тЙАуџёсЂФуёАжЎљтєЇтИ░сѓњжЂ┐сЂЉсѓІ)сђѓ
fn collect_value_names(
  node : @engine.Node,
  registry : Map[String, @engine.Node],
  visiting : Array[String],
  out : Array[String],
) -> Unit {
  match node {
    Ext(_) =>
      match node_resident_name(node) {
        Some(name) => out.push(name)
        None => ()
      }
    @engine.ReqArg(name) => out.push(name)
    @engine.Or(alts) =>
      for a in alts {
        collect_value_names(a, registry, visiting, out)
      }
    @engine.Seq(items) =>
      for it in items {
        collect_value_names(it, registry, visiting, out)
      }
    @engine.Many(inner, _) =>
      collect_value_names(inner, registry, visiting, out)
    @engine.BoundedTail(inner, _, _) =>
      collect_value_names(inner, registry, visiting, out)
    @engine.Rooted(inner, _) =>
      collect_value_names(inner, registry, visiting, out)
    @engine.Scoped(_, inner) =>
      collect_value_names(inner, registry, visiting, out)
    @engine.GreedyRepeat(inner) =>
      collect_value_names(inner, registry, visiting, out)
    @engine.IdxRepeat(_, inner, _, _) =>
      collect_value_names(inner, registry, visiting, out)
    Ref(r) =>
      if !str_in(visiting, r) {
        match registry.get(r) {
          Some(tpl) => {
            visiting.push(r)
            collect_value_names(tpl, registry, visiting, out)
            let _ = visiting.pop()
          }
          None => ()
        }
      }
    _ => ()
  }
}

///|
/// DR-093 ┬Д1/┬Д2 сЂ«тъІтДћУГ▓тѕцт«џсЂїсђїтђцсЂїт«ЪжџЏсЂФуЮђтю░сЂЎсѓІ cellсђЇсѓњУдІсѓІсЂЪсѓЂсЂ«тђЎУБюсѓ╗сЃФУДБТ▒║ (codex сЃгсЃЊсЃЦсЃ╝
/// M-2 С┐«ТГБ): т«БУеђУдЂу┤а `e` сЂЮсЂ«сѓѓсЂ«сЂїтђцсѓњТїЂсЂцсЂесЂ»жЎљсѓЅсЂфсЂёсђѓ
///
/// `e.ref_target` сЂї `Some(_)` (ref УдЂу┤а) сЂ«сЂесЂЇсђЂ`e.body` сЂ»тИИсЂФ `BCell` сЂ«сЂЙсЂЙ (ref т▒ЋжќІсЂ»
/// registry СИісЂ« `@engine.Node` сЂесЂЌсЂдтГўтюесЂЌсђЂ`@engine.ElemDef.body` сЂФсЂ»тЈЇТўасЂЋсѓїсЂфсЂё Рђћ
/// `ensure_entity_body`/`elem_head` сЂ« doc comment тЈѓуЁД)сђѓтЈѓуЁДтЁѕсЃєсЃ│сЃЌсЃгсЃ╝сЃѕсЂї structural or сЂ«
/// сѓѕсЂєсЂфУцЄтљѕТДІжђасѓњТїЂсЂцта┤тљѕсђЂ`e.name` сЂесЂёсЂєсѓ╗сЃФсЂ»ухљТъюсЂФтГўтюесЂЏсЂџ (DR-025 сЂ«жю▓тЄ║УдЈтЅЄ)сђЂтђцсЂ»т▒ЋжќІтЙїсЂ«
/// ТъЮсЂ« leaf entity сЂФуЮђтю░сЂЎсѓІ Рђћ `collect_value_names` сЂД registry СИісЂ«т«ЪСйЊсѓњУЙ┐сЂБсЂдтђЎУБюжЏєтљѕсѓњтЙЌсѓІ
/// (DR-007сђїref сЂ»ТДІжђат«џуЙЕтЁесЂдсѓњт╝ЋсЂЇуХЎсЂљсђЇсЂ«тъІтДћУГ▓тѕцт«џсЂИсЂ«тЈЇТўа)сђѓ
///
/// `e.ref_target` сЂї `None` сЂІсЂц `e.body` сЂї `BOr` (уЏ┤ТЏИсЂЇ structural orсђЂтъІС╗ўсЂЇТъЮ) сЂ«сЂесЂЇсЂ»сђЂBOr
/// wrapper УЄфУ║Ф (`e.name`) сЂ»тђцсѓњТїЂсЂЪсЂфсЂёТДІжђасЃЄсѓБсѓ╣сЃЉсЃЃсЃЂсЃБсЂД (ensure_entity_body сЂ« BOr сѓ│сЃАсЃ│сЃѕ
/// тЈѓуЁД)сђЂтђцсЂ»жЂИсЂ░сѓїсЂЪТъЮсЂ« leaf entity сЂФсЂ«сЂ┐ commit сЂЋсѓїсѓІсђѓтђЎУБюжЏєтљѕсѓњтљёТъЮсЂ« leaf name сЂФт▒ЋжќІсЂЌсђЂ
/// сђїсЂЕсЂ«ТъЮсЂДсЂѓсѓїуЎ║уЂФсЂЌсЂдтђцсЂїуб║т«џсЂЌсЂдсЂёсѓїсЂ░тЁЁУХ│сђЇ(DR-093 сЂ« or УдфтЁЁУХ│сЂ«тъІтДћУГ▓тјЪуљє) сѓњтЉ╝сЂ│тЄ║сЂЌтЂ┤
/// (`CRequired`/`CRequiredGroup`) сЂ«тѕцт«џсЂФТїЂсЂАУЙ╝сѓђсђѓBEnum (value-enum тйб) сЂ»тЁеТъЮсЂї SAME name/cell
/// (`e.name`) сЂФуЮђтю░сЂЎсѓІсЂЪсѓЂсЂЊсЂ«т▒ЋжќІсЂ»СИЇУдЂ (`[e.name]` сЂ«сЂЙсЂЙсЂДтЁЃсђЁТГБсЂЌсЂё Рђћ т»ЙуЁД fixture
/// `required-value-enum-or-branch.json` сЂїТЌбсЂФ green сЂфсЂ«сЂ»сЂЊсЂ«сЂЪсѓЂ)сђѓ
///
/// `CRequired` (required тЇўжаЁ) сЂе `CRequiredGroup` (required_group, DR-103) сЂ«СИАТќ╣сЂїсЂЊсЂ«сЃўсЃФсЃЉсЃ╝сѓњ
/// тЁ▒ТюЅсЂЎсѓІсЂЊсЂесЂДсђЂсђїrequired тЇўжаЁсЂе required_group сЂДтђЎУБюсѓ╗сЃФУДБТ▒║сЂїжБЪсЂёжЂЋсЂєсђЇТДІжђауџёсЂфСйЎтю░сѓњуёАсЂЈсЂЎ
/// (M-2 сЂ«тєЇуЎ║жў▓ТГбсђЂissue codex-review-dr102-dr103-postland)сђѓ
///
/// Тѕ╗сѓітђцсЂ» `@engine.RequiredCandidate` (name + wrapper) Рђћ ref ухїућ▒сЂ«та┤тљѕсђЂтђцсЂ»т«БУеђтЁЃ `e` УЄфУ║ФсЂ« @engine.Scoped
/// жЃетѕєТюе (`@engine.Scoped(e.name, ...)`сђЂ`inst_long`/`lower_positional` сЂ« ref тѕєт▓љсЂїСйюсѓІ) сЂФуЮђтю░сЂЎсѓІсЂЪсѓЂсђЂ
/// `wrapper: Some(e.name)` сѓњС╗ўсЂЉсЂдтѕцт«џтЂ┤ (`eval.mbt`/`resolve.mbt`) сЂїсђїт«БУеђтЁЃУдЂу┤аУЄфУ║ФсЂ«жЃетѕєТюетєЁсђЇ
/// сЂасЂЉсѓњТјбсЂЎсѓѕсЂєсЂФсЂЎсѓІ (DESIGN ┬Д2.4/2.5 сЂ«жю▓тЄ║УдЈтЅЄсђЂуёАтѕХжЎљжђЈжЂјсЂДсЂ»сЂфсЂЈУдЂу┤аУЄфУ║ФсЂ«жЃетѕєТюесЂФжЎљт«џ Рђћ
/// `@engine.RequiredCandidate` сЂ« doc comment тЈѓуЁД)сђѓуЏ┤ТЏИсЂЇ BOr сЂ«та┤тљѕсђЂтђцсЂ»Удф scope сЂФуЏ┤ТјЦ bind сЂЋсѓїсѓІсЂЪсѓЂ
/// `wrapper: None`сђѓ
fn required_candidates(
  e : @engine.ElemDef,
  registry : Map[String, @engine.Node],
) -> Array[@engine.RequiredCandidate] {
  match e.ref_target {
    Some(r) => {
      let names : Array[String] = []
      collect_value_names(Ref(r), registry, [], names)
      if names.length() > 0 {
        let out : Array[@engine.RequiredCandidate] = []
        for n in names {
          out.push({ name: n, wrapper: Some(e.name) })
        }
        out
      } else {
        [{ name: e.name, wrapper: None }]
      }
    }
    None =>
      match e.body {
        BOr(branches) => {
          let out : Array[@engine.RequiredCandidate] = []
          for br in branches {
            for it in br.items {
              out.push({ name: it.name, wrapper: None })
            }
          }
          out
        }
        _ => [{ name: e.name, wrapper: None }]
      }
  }
}

///|
/// constraint installer (DR-055 / DR-042 тИГт«БУеђтъІ): requires / conflicts_with / exclusive_group /
/// required / required_group (DR-103) / value_requires сѓњ scope сЂ«жЂЁт╗ХУ┐░УфъсЂесЂЌсЂдуЎ╗жї▓сђѓТДІжђаУАЏТўЪсЂ»
/// уёАсЂЌ (DR-047 т«їтЁе path сЂ«ТюђухѓуіХТЁІсЂДУЕЋСЙА)сђѓ
fn inst_constraint(
  def : @engine.Definition,
  build : @engine.InstallBuild,
  registry : Map[String, @engine.Node],
) -> Unit {
  let all : Array[@engine.ElemDef] = []
  for e in def.options {
    all.push(e)
  }
  for e in def.positionals {
    all.push(e)
  }
  for e in all {
    if e.requires.length() > 0 {
      add_constraint(build, CRequires(e.name, copy_strs(e.requires)))
    }
    if e.conflicts_with.length() > 0 {
      add_constraint(build, CConflicts(e.name, copy_strs(e.conflicts_with)))
    }
    if e.required {
      // DR-093 ┬Д1/┬Д2: required:true сЂ«УдЂу┤аУЄфУ║Фсѓњт»ЙУ▒АсЂФсЂЌсЂЪ CRequired сѓњ 1 тђІуЎ╗жї▓сђѓтђЎУБюсѓ╗сЃФУДБТ▒║сЂ»
      // `required_candidates` (CRequiredGroup сЂетЁ▒ТюЅ)сђѓ
      add_constraint(build, CRequired(e.name, required_candidates(e, registry)))
    }
    for vr in e.value_requires {
      // DR-055 ┬Д1 / DR-052 ┬ДтђцТъЮ id уЏ┤С║ц: 4-tuple = (entity, branch_id, value, targets)сђѓentity сЂ»
      // committed тѕцт«џ / тђцуЁДтљѕсЂ«т»ЙУ▒А (Удф name)сђЂbranch_id сЂ»жЂЋтЈЇТЎѓсЂ« error.element (ТъЮсЂ« id)сђѓ
      add_constraint(build, CRequiresIf(e.name, vr.0, vr.1, copy_strs(vr.2)))
    }
  }
  // exclusive_group: label per scope сЂДсЃАсЃ│сЃљсѓњжЏєу┤ё Рєњ 1 CExclusive per label
  let groups : Array[String] = []
  for e in all {
    for g in e.exclusive_group {
      if !str_in(groups, g) {
        groups.push(g)
      }
    }
  }
  for g in groups {
    let members : Array[String] = []
    for e in all {
      if str_in(e.exclusive_group, g) {
        members.push(e.name)
      }
    }
    add_constraint(build, CExclusive(g, members))
  }
  // required_group (DR-103 ┬Д1/┬Д3/┬Д7 С┐«ТГБсђЂcodex M-2): exclusive_group сЂетљїсЂўжЏєу┤ёсЃЉсѓ┐сЃ╝сЃ│сђЂуІгуФІ
  // сЂЌсЂЪтљЇтЅЇуЕ║жќЊ (тѕЦсЂ« groups жЁЇтѕЌ)сђѓmember сЂ»т«БУеђУдЂу┤атљЇсЂДсЂфсЂЈ `required_candidates` сЂ«тђЎУБюсѓ╗сЃФ
  // (structural or сЂфсѓЅтљёТъЮсЂ« leaf name) сѓњсЂЮсЂ«сЂЙсЂЙжЏєсѓЂсѓІ Рђћ сѓ░сЃФсЃ╝сЃЌтЁЁУХ│сЂ»сђїсЂёсЂџсѓїсЂІсЂ« member сЂ«
  // сЂёсЂџсѓїсЂІсЂ«тђЎУБюсѓ╗сЃФсЂїтъІтДћУГ▓тЁЁУХ│сЂЌсЂдсЂёсѓїсЂ░ OKсђЇсЂесЂёсЂєУФќуљєтњїсЂДсђЂтђЎУБюсѓ╗сЃФсѓњсЃЋсЃЕсЃЃсЃѕсЂФжЏєу┤ёсЂЌсЂдсѓѓ
  // ТЋ░тГдуџёсЂФуГЅСЙА (OR(member1_candidates) OR OR(member2_candidates) OR ... = OR(тЁе candidates))сђѓ
  // 1 CRequiredGroup per labelсђѓ
  let rg_groups : Array[String] = []
  for e in all {
    for g in e.required_group {
      if !str_in(rg_groups, g) {
        rg_groups.push(g)
      }
    }
  }
  for g in rg_groups {
    let members : Array[@engine.RequiredCandidate] = []
    for e in all {
      if str_in(e.required_group, g) {
        for c in required_candidates(e, registry) {
          members.push(c)
        }
      }
    }
    add_constraint(build, CRequiredGroup(g, members))
  }
}

///|
fn str_in(xs : Array[String], v : String) -> Bool {
  for x in xs {
    if x == v {
      return true
    }
  }
  false
}

// РћђРћђ alias desugaring (DR-057) РћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђРћђ

///|
/// `s` сЂФжЃетѕєТќЄтГЌтѕЌ `sub` сѓњтљФсѓђсЂІ (name-derived variant тѕцт«џ: variant.trigger сЂї canonical.name сѓњ
/// жЃетѕєТќЄтГЌтѕЌсЂФтљФсѓђсЂфсѓЅ name-derived Рђћ DR-057 ┬Д3)сђѓ
fn str_has_sub(s : String, sub : String) -> Bool {
  if sub.length() == 0 {
    return true
  }
  let cs = @engine.to_chars(s)
  let cu = @engine.to_chars(sub)
  if cu.length() > cs.length() {
    return false
  }
  let mut i = 0
  while i + cu.length() <= cs.length() {
    let mut k = 0
    let mut ok = true
    while k < cu.length() {
      if cs[i + k] != cu[k] {
        ok = false
        break
      }
      k = k + 1
    }
    if ok {
      return true
    }
    i = i + 1
  }
  false
}

///|
/// `s` сЂ«ТюђтѕЮсЂ« `from` тЄ║уЈЙсѓњ `to` сЂФуй«ТЈЏ (name-derived variant сѓњ alias тљЇсЂДтєЇт░јтЄ║: DR-057 ┬Д3
/// "--no-ssl" (canonical ssl) Рєњ alias tls сЂД "--no-tls")сђѓ
fn str_replace_first(s : String, from : String, to : String) -> String {
  let cs = @engine.to_chars(s)
  let cf = @engine.to_chars(from)
  if cf.length() == 0 || cf.length() > cs.length() {
    return s
  }
  let mut i = 0
  while i + cf.length() <= cs.length() {
    let mut k = 0
    let mut ok = true
    while k < cf.length() {
      if cs[i + k] != cf[k] {
        ok = false
        break
      }
      k = k + 1
    }
    if ok {
      let buf = StringBuilder::new()
      buf.write_string(@engine.chars_to_str(cs, 0, i))
      buf.write_string(to)
      buf.write_string(@engine.chars_to_str(cs, i + cf.length(), cs.length()))
      return buf.to_string()
    }
    i = i + 1
  }
  s
}

///|
/// canonical option / positional УдЂу┤асѓњ name сЂДТцюу┤бсђѓ
fn find_elem(def : @engine.Definition, name : String) -> @engine.ElemDef? {
  for e in def.options {
    if e.name == name {
      return Some(e)
    }
  }
  for e in def.positionals {
    if e.name == name {
      return Some(e)
    }
  }
  None
}

///|
fn find_command(def : @engine.Definition, name : String) -> @engine.CommandDef? {
  for c in def.commands {
    if c.name == name {
      return Some(c)
    }
  }
  None
}

///|
/// alias entry-copy сЂ«уЕ║ body: entry уХ┤сѓі + canonical name сЂ«сЂ┐Тљ║УАїсђЂтђцТ║љ / ухљТъюсѓГсЃ╝ / тѕХу┤ёсЂ»т«ЪСйЊтЂ┤сЂ«
/// сЂЙсЂЙ (DR-057 ┬Д3)сђЂсЂЮсѓїсѓЅ field сЂ» set сЂЌсЂфсЂёсђѓ
fn alias_entry(
  canonical_name : String,
  ty : &@engine.TypeExt,
  long : Array[String],
  variants : Array[@engine.Variant],
  short : Array[Char],
  deprecated : Bool,
) -> @engine.ElemDef {
  {
    name: canonical_name, // effect / entity / result key сЂ»тЁесЂд canonical name сЂД keying (link тљїтъІ)
    ty,
    // ТЌбсЂФт░јтЄ║ТИѕсЂ┐ explicit уХ┤сѓітѕЌ (`:set` сЂ»тљФсЂЙсЂфсЂё Рђћ normalize/resolve_long сЂ«т»ЙУ▒АтцќсђЂpost-normalize
    // уЏИтйЊсЂ«уб║т«џтйбсЂесЂЌсЂдуЏ┤ТјЦ LList сЂДТїЂсЂц)сђѓalias entry-copies сЂ» fixpoint installer (inst_long уГЅ) сЂї
    // сЂЮсЂ«сЂЙсЂЙтЄдуљєсЂЎсѓІт»ЙУ▒АсЂДсђЂС║їт║дуЏ«сЂ« resolve_long сЂ»УхисЂЇсЂфсЂёсђѓ
    long: LList(long),
    variants,
    short,
    env: [],
    is_tty: false, // alias entry-copy сѓѓтђцТ║љсЂ»т«ЪСйЊтЂ┤сЂ«сЂЙсЂЙ (┬Д3 сЂетљїсЂўуљєућ▒сђЂenv сЂет»ЙуД░)
    tty_stream: None,
    tty_cygwin: true,
    is_dd: false,
    is_exact: false,
    dd_match: None,
    dd_self_keep: false,
    is_global: false,
    is_inherit: false,
    is_inheritable: false,
    link_depth: 0,
    ref_target: None,
    repeat: None,
    optional: false,
    multiple: false,
    accumulator: None,
    flatten: None,
    separator: None,
    collector: None,
    fail_action: false,
    is_config_file: false,
    config_key: None,
    export_key: @engine.export_key_unset(),
    requires: [],
    conflicts_with: [],
    exclusive_group: [],
    required_group: [],
    required: false, // alias entry сЂ» @engine.AliasDef УЄфСйЊсЂФ required т«БУеђухїУи»сѓњТїЂсЂЪсЂфсЂё (requires/exclusive_group сЂетљїсЂўуљєућ▒)
    value_requires: [],
    deprecated,
    // DR-104 ┬Д2/┬Д3: alias entry-copy сЂ»тИИсЂФ is_alias:true (сЂЊсЂ«жќбТЋ░УЄфСйЊсЂї alias т«БУеђућ▒ТЮЦ entry-copy
    // т░ѓућесЂ«сѓ│сЃ│сѓ╣сЃѕсЃЕсѓ»сѓ┐)сђѓhidden сЂ» @engine.AliasDef сЂФуІгуФІт«БУеђухїУи»сѓњТїЂсЂЪсЂфсЂё (deprecated сЂежЂЋсЂёсђЂуЈЙУАї
    // fixture сЂФ alias тЂ┤сЂ«уІгуФІ hidden сѓњУдЂТ▒ѓсЂЎсѓІсѓѓсЂ«сЂїуёАсЂё) сЂ«сЂД canonical сЂетљїсЂў false ТЌбт«џсђѓ
    is_alias: true,
    hidden: false,
    completer: None,
    default_values: None,
    int_round: @engine.RError,
    allow_base_prefix: false,
    bool_config: bool_config_canonical(),
    piece_filters: [],
    value_filters: [],
    final_filters: [],
    accum_filters: [],
    long_prefix: "--",
    short_prefix: "-",
    env_prefix: "",
    auto_env: false,
    long_eq_sep: @engine.EsAllow,
    short_combine: true,
    short_attached_value: @engine.AtAllow,
    body: BCell,
  }
}

///|
/// alias т«БУеђ (DR-057) сѓњ option entry-copies / command defs сЂФ desugarсђѓт«їтЁеТђДТцюТЪ╗сЂї the alias installer resident сЂ«
/// "alias" ТЅђТюЅсѓњуб║УфЇсЂЌсЂЪтЙїсђЂinit_sb тЅЇсЂФ 1 т║дсЂасЂЉУх░сѓІТ▒║т«џуџё pre-passсђѓтљё entry-copy сЂ» canonical name
/// сЂД keying (satellites сЂї canonical cell сѓњ bindсђЂухљТъюсѓГсЃ╝сѓѓ canonical)сђЂтєЇт░јтЄ║уХ┤сѓісѓњТљ║УАїсЂЌсђЂfixpoint
/// сЂ« long/short/command installer сЂїт▒ЋжќІсЂЎсѓІ (DR-057 ┬Д4)сђѓcommand subtree сЂФсѓѓтєЇтИ░сђѓ
///
/// `orig` сЂ» normalize_surface жЂЕућетЅЇсЂ«УцЄУБй (issue 2026-07-08 dec-alias-long-override-flag-sugar-
/// gap): `def` тЂ┤сЂ« canonical УдЂу┤асЂ»ТЌбсЂФ flag_type()Рєњbool_type() тцЅТЈЏТИѕсЂ┐сЂфсЂ«сЂДсђЂDR-076 ┬Д2 УдЈтЅЄ1 (flag сЂ«
/// `long:true` у│ќУАБсЂ» `:set:true` сЂИти«сЂЌТЏ┐сЂѕ) сѓњтѕцт«џсЂЎсѓІТЮљТќЎ (тЁЃсЂ«тъІ flag_type()) сЂїтц▒сѓЈсѓїсЂдсЂёсѓІсђѓ`orig`
/// сЂІсѓЅтљїсЂў target УдЂу┤асЂ«тцЅТЈЏтЅЇсЂ« `ty`/`long` сѓњт╝ЋсЂЇсђЂ`resolve_long` сѓњ canonical тЂ┤сЂетљїсЂўтйбсЂД
/// жђџсЂЎсЂЊсЂесЂДсђЂalias тЂ┤сЂФсѓѓтљїсЂўУдЈтЅЄ1/2 сѓњжЂЕућесЂЎсѓІсђѓ
fn desugar_aliases(def : @engine.Definition, orig : @engine.Definition) -> Unit {
  for a in def.aliases {
    let alias_name = match a.name {
      Some(n) => n
      None => a.target // Тўјуц║ name уёАсЂЌ Рєњ canonical тљЇсѓњТхЂуће (e.g. short-only alias)
    }
    match find_elem(def, a.target) {
      Some(canon) => {
        let (orig_ty, orig_long) = match find_elem(orig, a.target) {
          Some(oc) => (oc.ty, oc.long)
          None => (canon.ty, canon.long) // уљєУФќСИіУхисЂЇсЂфсЂёжў▓тЙАуџёсЃЋсѓЕсЃ╝сЃФсЃљсЃЃсѓ»
        }
        // canonical УЄфУ║ФсЂ« (pre-normalize) long сѓњ canonical тљЇсЃ╗тЁЃсЂ«тъІсЂДУДБТ▒║сЂЎсѓІ Рђћ тЪ║т║Ћ long уХ┤сѓі
        // (name-derived СИ╗тЁЦтЈБсЂ«ТюЅуёА) сЂесђЂуХЎТЅ┐сЂЎсЂ╣сЂЇ NAME-DERIVED variants сЂ«СИАТќ╣сѓњсЂЊсЂЊсЂІсѓЅт░јсЂЈсђѓ
        // resolve_long сѓњжђџсЂЎсЂЊсЂесЂДсђЂcanonical сЂї flag сЂфсѓЅУдЈтЅЄ1/2 (:set:true ти«сЂЌТЏ┐сЂѕ/УБют«ї) сѓњ
        // тЈЇТўасЂЌсЂЪтйбсЂД `canon_vars` сЂїТЅІсЂФтЁЦсѓІсђѓ
        let (canon_longs, canon_vars) = resolve_long(
          orig_long,
          canon.name,
          orig_ty,
        )
        let long : Array[String] = []
        if str_in(canon_longs, kebab(canon.name)) {
          long.push(alias_name)
        }
        // Тўјуц║ `long` override (DR-007 ти«тѕєСИіТЏИсЂЇ) сЂ»УЄфуХ┤сѓісѓњ addсђЂуХЎТЅ┐ variants сѓњ cutсђѓalias УЄфУ║ФсЂ«
        // long сѓѓ canonical сЂетљїсЂў `resolve_long` (colon DSL тѕєжАъ + flag УдЈтЅЄ1/2) сѓњ alias тљЇсЃ╗
        // canonical сЂ«тЁЃсЂ«тъІсЂДжђџсЂЎ Рђћ тъІСЙЮтГўсЂ«у│ќУАБти«сЂЌТЏ┐сЂѕсЂї alias тЂ┤сЂДсѓѓ canonical сЂеТЈЃсЂє
        // (issue 2026-07-08 dec-alias-long-override-flag-sugar-gap сЂ«Та╣Т▓╗)сђѓ
        let variants : Array[@engine.Variant] = []
        match a.long_override {
          Some(decl) => {
            let (longs, vars) = resolve_long(decl, alias_name, orig_ty)
            for n in longs {
              if !str_in(long, n) {
                long.push(n)
              }
            }
            for v in vars {
              variants.push(v)
            }
          }
          None =>
            // canonical сЂ« NAME-DERIVED variants (СИісЂД resolve_long ТИѕсЂ┐) сѓњ alias тљЇсЂДтєЇт░јтЄ║сђѓ
            // variant.trigger сЂї canonical.name сѓњжЃетѕєТќЄтГЌтѕЌсЂФтљФсѓЂсЂ░ name-derived (DR-057 ┬Д3);
            // Тўјуц║ trigger (e.g. compress сЂ« "gzip") сЂ»жЮъуХЎТЅ┐ (Тўјуц║уХ┤сѓіжЮъуХЎТЅ┐)сђѓ
            for v in canon_vars {
              if str_has_sub(v.trigger, canon.name) {
                variants.push({
                  trigger: str_replace_first(v.trigger, canon.name, alias_name),
                  op: v.op,
                  operand: v.operand,
                })
              }
            }
        }
        def.options.push(
          alias_entry(
            canon.name,
            canon.ty,
            long,
            variants,
            copy_chars(a.short),
            a.deprecated,
          ),
        )
      }
      None =>
        // command alias: co Рєњ checkout жЃетѕєТюе, ухљТъюсѓГсЃ╝сЂ» checkout сЂФт»ёсЂЏсѓІ (DR-057 ┬Д2)
        match find_command(def, a.target) {
          Some(cmd) =>
            def.commands.push({
              name: alias_name,
              body: clone_def(cmd.body),
              export_key: @engine.export_key(a.target),
            })
          None => () // dangling alias target Рђћ т░єТЮЦсЂ« absent-ref check ућесЂФТ«Іуй«
        }
    }
  }
  for c in def.commands {
    let orig_body = match find_command(orig, c.name) {
      Some(oc) => oc.body
      None => c.body // уљєУФќСИіУхисЂЇсЂфсЂёжў▓тЙАуџёсЃЋсѓЕсЃ╝сЃФсЃљсЃЃсѓ» (orig тЂ┤сЂ«т»Йт┐ю command сЂїУдІсЂцсЂІсѓЅсЂфсЂё)
    }
    desugar_aliases(c.body, orig_body)
  }
}

///|
fn add_constraint(build : @engine.InstallBuild, c : @engine.Constraint) -> Unit {
  for existing in build.constraints() {
    if existing == c {
      return
    }
  }
  build.constraints().push(c)
}

///|
fn def_err(
  element : String,
  kind : @engine.DefErrKind,
  message : String,
  hint : String,
) -> @engine.DefError {
  { element, kind, message, hint }
}

///|
/// DR-011 Тўјуб║тїќ (kawaz УБЂт«џ 2026-07-08): `long` сЂ« array тйбсЂ«тљёУдЂу┤асЂ» `classify_long_spelling` сЂї
/// `LMain`/`LVariant` сЂФтѕєжАъсЂДсЂЇсѓІтйбсЂДсЂфсЂЉсѓїсЂ░сЂфсѓЅсЂфсЂё Рђћ colon-less сЂфТќЄтГЌтѕЌсђЂсЂЙсЂЪсЂ»УфътйЎтцќ effect
/// word сѓњТїЂсЂцТќЄтГЌтѕЌ (`LInvalid`) сЂ»ТќЄТ│ЋсѓесЃЕсЃ╝сЂД `unknown-vocab` (DR-054) сЂФУљйсЂесЂЎсђѓ`normalize_option`
/// (`resolve_long` ухїућ▒) сЂ«**тЅЇ**сЂФТцюТЪ╗сЂЎсѓІт┐ЁУдЂсЂїсЂѓсѓІ Рђћ `resolve_long` сЂ» `LInvalid` сѓњж╗ЎсЂБсЂдТЇесЂдсѓІ
/// (тЉ╝сЂ│тЄ║сЂЌтЅЇТЈљсЂїсђїуёАті╣ТќЄтГЌтѕЌсЂ»ТЌбсЂФ definition-error сЂесЂЌсЂдТцютЄ║ТИѕсЂ┐сђЇсЂфсЂ«сЂД) сЂЪсѓЂсђЂnormalize тЙїсЂ«
/// `e.long` сЂФсЂ»уёАті╣сЂфућЪТќЄтГЌтѕЌсЂїсѓѓсЂєТ«ІсЂБсЂдсЂёсЂфсЂёсђѓ
fn collect_invalid_long_dsl(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.options {
    push_invalid_long(e, out)
  }
  for e in def.positionals {
    push_invalid_long(e, out)
  }
  for c in def.commands {
    collect_invalid_long_dsl(c.body, out)
  }
}

///|
fn push_invalid_long(
  e : @engine.ElemDef,
  out : Array[@engine.DefError],
) -> Unit {
  match e.long {
    LBool(_) => () // bool у│ќУАБсЂ»тИИсЂФтдЦтйЊ (DR-071 ┬Д1 / DR-076 ┬Д2)
    LList(strs) =>
      for l in strs {
        match classify_long_spelling(l, kebab(e.name), e.ty) {
          LInvalid(s) =>
            out.push(
              def_err(
                e.name,
                @engine.DUnknownVocab,
                "long spelling '\{s}' is not valid variant DSL (colon-less, or an unrecognized effect word) Рђћ DR-011 Тўјуб║тїќ 2026-07-08",
                "use `:set` / a colon-DSL variant (e.g. `:set:true`, `no:set:false`), or a DR-057 alias element for an explicit spelling",
              ),
            )
          LMain(_) | LVariant(_) => ()
        }
      }
  }
}

///|
/// DR-011 Тўјуб║тїќ (kawaz УБЂт«џ 2026-07-08): alias `long_override` (DR-057 ┬Д3 ти«тѕєСИіТЏИсЂЇ) сЂ» canonical
/// тЂ┤сЂ« `long` сЂетљїсЂў colon DSL сѓњтЁ▒ућесЂЎсѓІ (`classify_long_spelling`сђЂinstaller.mbt:1497 сЂ«сѓ│сЃАсЃ│сЃѕ
/// сђїС║їухїУи»сЂї drift сЂЌсЂфсЂёсѓѕсЂєтѕєжАътЎесѓњтЁ▒ућесђЇтЈѓуЁД) Рђћ Тўјуб║тїќсЂ»сЂЊсЂ« DSL сЂїуЈЙсѓїсѓІ**тЁесЂдсЂ«та┤ТЅђ**сЂФСИђТДўсЂФті╣сЂЈ
/// УдЈтЅЄсЂфсЂ«сЂДсђЂcolon-less / УфътйЎтцќ effect сЂ» canonical тЂ┤ (`push_invalid_long`) сЂетљїсЂўсЂЈ `unknown-vocab`
/// (DR-054) сЂФУљйсЂесЂЎсђѓcanonical тЂ┤сЂетѕЦжќбТЋ░сЂФсЂЌсЂдсЂёсѓІсЂ«сЂ»сђЂtarget canonical УдЂу┤асЂ« `ty` сѓњ
/// `find_elem` сЂДт╝ЋсЂЈт┐ЁУдЂсЂїсЂѓсѓі (`classify_long_spelling` сЂ« operand УДБжЄѕсЂФСй┐сЂє)сђЂ`push_invalid_long`
/// сЂ«сђїУЄфтѕєсЂ« @engine.ElemDef сѓњТцюТЪ╗сЂЎсѓІсђЇтйбсЂетЁЦтіЏсЂ«тйбсЂїжЂЋсЂєсЂЪсѓЂ Рђћ dangling alias target (УдІсЂцсЂІсѓЅсЂфсЂёта┤тљѕ)
/// сЂ» absent-ref check сЂїтѕЦжђћТІЙсЂєсЂ«сЂДсЂЊсЂЊсЂДсЂ»жЮЎсЂІсЂФсѓ╣сѓГсЃЃсЃЌсЂЎсѓІсђѓdesugar_aliases (LInvalid сѓњ
/// rename-only сЂДжђџсЂЎухїУи») сѓѕсѓітЅЇсђЂstatic check сЃЋсѓДсЃ╝сѓ║сЂДТцютЄ║сЂЎсѓІсђѓ
fn collect_invalid_alias_long_override(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  for a in def.aliases {
    match a.long_override {
      Some(decl) => {
        let alias_name = match a.name {
          Some(n) => n
          None => a.target
        }
        match find_elem(def, a.target) {
          Some(canon) =>
            match decl {
              LBool(_) => () // bool у│ќУАБсЂ»тИИсЂФтдЦтйЊ (DR-071 ┬Д1 / DR-076 ┬Д2)
              LList(strs) =>
                for l in strs {
                  match classify_long_spelling(l, alias_name, canon.ty) {
                    LInvalid(s) =>
                      out.push(
                        def_err(
                          alias_name,
                          @engine.DUnknownVocab,
                          "alias long_override spelling '\{s}' is not valid variant DSL (colon-less, or an unrecognized effect word) Рђћ DR-011 Тўјуб║тїќ 2026-07-08",
                          "use `:set` / a colon-DSL variant (e.g. `:set:true`, `no:set:false`) in long_override",
                        ),
                      )
                    LMain(_) | LVariant(_) => ()
                  }
                }
            }
          None => () // dangling alias target Рђћ absent-ref check сЂїтѕЦжђћТІЙсЂє
        }
      }
      None => ()
    }
  }
  for c in def.commands {
    collect_invalid_alias_long_override(c.body, out)
  }
}

///|
/// DR-099 ┬Д3/┬Д7: `builtin/tty` preset сЂ«т┐Ёжаѕ config `tty_stream` сЂїТюфТїЄт«џсЂфУдЂу┤асЂ» definition-error
/// (kind=invalid-range)сђѓbare `type:"tty"` / `type:"builtin/tty"` (config сѓњСЙЏухдсЂЎсѓІухїУи»УЄфСйЊсЂїуёАсЂё Рђћ
/// уЏ┤ТјЦтЈѓуЁДсЂ»тИИсЂФсЂЊсЂ«тйбсђЂdecode т▒цсЂї `is_tty=true, tty_stream=None` сЂДжђџсЂЎ) сЂесђЂdefinitions.types
/// ухїућ▒сЂД `tty_stream` сѓњТЏИсЂЇт┐ўсѓїсЂЪ shadow сЂ«СИАТќ╣сѓњсЂЊсЂ«СИђТюгсЂДТІЙсЂєсђѓ
///
/// DR-098 ┬Д4 сЂїт┐ЁУдЂсЂесЂЌсЂдсЂёсЂЪ 3 тѕєжАъ (жЮъ bool тъІсЃ╗тђцсЂфсЂЌУдЂу┤асЃ╗flag/count сЃЌсЃфсѓ╗сЃЃсЃѕсЂИсЂ« `tty:`
/// С╗ўСИј) сЂ»сђЂ`type:` сЂїтЇўСИђжЂИТіъсЂ«сЃЋсѓБсЃ╝сЃФсЃЅсЂДсЂѓсѓІС╗ЦСИісђЂpreset тъІсЂИсЂ«У╗бТЈЏсЂДТДІТќЄуџёсЂФуЎ║ућЪсЂЌсЂфсЂЈсЂфсЂБсЂЪ
/// (DR-099 ┬Д1сђїТјАућесЂЌсЂфсЂІсЂБсЂЪТАѕсђЇ) Рђћ Т«ІсѓІтћ»СИђсЂ« definition-error сЂ»сЂЊсЂ« factory УЄфУ║ФсЂ« config ТцюУе╝
/// сЂасЂЉ (DR-061 ┬Д4сђїconfig тђцсЂ«ТцюУе╝сЂ» factory УЄфУ║ФсЂ«У▓гтІЎсђЇ)сђѓis_tty/tty_stream сЂ» `type:` УДБТ▒║сЂ«
/// decode ТЎѓуѓ╣сЂДуб║т«џсЂЌ normalize_surface сЂ«тй▒жЪ┐сѓњтЈЌсЂЉсЂфсЂёсЂЪсѓЂ (flag_type()Рєњbool_type() тцЅТЈЏсЂ«сѓѕсЂєсЂф pre/post
/// тї║тѕЦсЂ»СИЇУдЂ)сђЂС╗ќсЂ« post-normalize сЂф collect_* уЙцсЂетљїсЂўСИдсЂ│сЂДтЉ╝сѓЊсЂДсѓѕсЂёсђѓ
fn collect_tty_stream_missing(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn check(e : @engine.ElemDef) -> Unit {
    if e.is_tty && e.tty_stream is None {
      out.push(
        def_err(
          e.name,
          @engine.DInvalidRange,
          "'\{e.name}' selects the builtin/tty preset but its factory config is missing 'tty_stream' Рђћ bare type:\"tty\"/\"builtin/tty\" has no channel to supply it (DR-099 ┬Д3)",
          "declare a definitions.types entry with config.tty_stream set to \"stdin\"|\"stdout\"|\"stderr\", and reference that name from 'type'",
        ),
      )
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_tty_stream_missing(c.body, out)
  }
}

///|
/// zero-progress жЮЎуџё guard (DR-043): repeat head сЂ» >= 1 token ТХѕУ▓╗сЂїт┐ЁУдЂ (тєЇтИ░ unfold сЂ« loop сѓњжў▓ТГб)сђѓ
/// ref head сЂ»сђїtarget сЂї >= 1 ТХѕУ▓╗сђЇсЂФжѓётЁЃ (ТХѕУ▓╗ node сЂ«сЂфсЂё ref cycle сѓѓТЇЋТЇЅ)сђѓ
fn head_progresses(
  node : @engine.Node,
  registry : Map[String, @engine.Node],
  visiting : Array[String],
) -> Bool {
  match node {
    @engine.ReqArg(_)
    | @engine.Exact(_)
    | @engine.NativeMatch(_)
    | @engine.DdSat(_)
    | @engine.CmdSat(_, _) => true
    // DR-090: progress depends on `self_keep` Рђћ `drop` (false) consumes 1 token like `@engine.DdSat`,
    // `keep` (true) is a 0-token @engine.Accept (same standing as `@engine.Bind`/`effect resident` below).
    @engine.DdMatchSat(_, _, self_keep, _) => !self_keep
    Ext(extension) => !extension.consumes_zero_tokens()
    @engine.IdxRepeat(_, _, _, _) => true // тљЇтЅЇС╗ўсЂЇ indexed repeat сЂ» head сѓњТХѕУ▓╗
    @engine.BoundedTail(_, budget, _) => budget >= 1 // >= 1 head тЈќсѓїсѓІТЎѓсЂ«сЂ┐ТХѕУ▓╗
    @engine.Rooted(inner, _) => head_progresses(inner, registry, visiting)
    @engine.Bind(_, _) => false // 0-token
    Ref(r) => {
      for v in visiting {
        if v == r {
          return false // ТХѕУ▓╗ node сЂфсЂЌсЂ« cycle Рєњ уёА progress
        }
      }
      match registry.get(r) {
        Some(tpl) => {
          visiting.push(r)
          let ok = head_progresses(tpl, registry, visiting)
          let _ = visiting.pop()
          ok
        }
        None => false // unresolved ref
      }
    }
    @engine.Or(alts) => {
      for a in alts {
        if !head_progresses(a, registry, visiting) {
          return false
        }
      }
      alts.length() > 0
    }
    @engine.Seq(items) =>
      if items.length() >= 1 {
        head_progresses(items[0], registry, visiting)
      } else {
        false
      }
    @engine.Many(_) | @engine.Scoped(_, _) | @engine.ScopeNode(_) => true
    @engine.GreedyRepeat(inner) => head_progresses(inner, registry, visiting)
  }
}

///|
/// HEAD position сЂ« ref (ТюђтѕЮсЂФТХѕУ▓╗сЂЋсѓїсѓІУдЂу┤асЂ« ref), уёАсЂЉсѓїсЂ░ NoneсђѓТХѕУ▓╗ head сЂ«тЙїсЂ« ref (repeat сЂ«
/// cons tail `@engine.Seq([head, Opt(Ref(self))])` уГЅ) сЂ» head СйЇуй«сЂДсЂ»сЂфсЂёсЂ«сЂДсђЂТГБтйЊсЂф repeat УЄфтЈѓуЁДсЂ» None сѓњУ┐ћсЂЎсђѓ
fn head_ref_of(node : @engine.Node) -> String? {
  match node {
    Ref(r) => Some(r)
    @engine.Seq(items) =>
      if items.length() >= 1 {
        head_ref_of(items[0])
      } else {
        None
      }
    @engine.Or(alts) => {
      for a in alts {
        match head_ref_of(a) {
          Some(r) => return Some(r)
          None => ()
        }
      }
      None
    }
    @engine.Rooted(inner, _) => head_ref_of(inner)
    _ => None
  }
}

///|
/// `name` сЂІсѓЅ head-position ref сѓњУЙ┐сѓІсЂе loop сЂЎсѓІсЂІ (уёАжЎљТДІжђат▒ЋжќІсЂ« circular ref, DR-054)сђѓrepeat
/// УЄфтЈѓуЁД (head сЂїТХѕУ▓╗ node) сЂ»сЂЊсЂЊсЂД loop сЂЌсЂфсЂёсђѓ
fn head_cycles(
  name : String,
  registry : Map[String, @engine.Node],
  visiting : Array[String],
) -> Bool {
  for v in visiting {
    if v == name {
      return true
    }
  }
  match registry.get(name) {
    Some(tpl) =>
      match head_ref_of(tpl) {
        Some(next) => {
          visiting.push(name)
          let r = head_cycles(next, registry, visiting)
          let _ = visiting.pop()
          r
        }
        None => false
      }
    None => false
  }
}

///|
/// node сЂ« head-position ref сЂї cycle сЂФтѕ░жЂћсЂЎсѓІсЂІ (circular ref сЂїтљїТЎѓсЂФ zero-progress сЂесЂЌсЂд 2 жЄЇ
/// та▒тЉісЂЋсѓїсЂфсЂёсѓѕсЂєтї║тѕЦсЂЎсѓІућежђћ)сђѓ
fn head_node_cycles(
  node : @engine.Node,
  registry : Map[String, @engine.Node],
) -> Bool {
  match head_ref_of(node) {
    Some(r) => head_cycles(r, registry, [])
    None => false
  }
}

///|
/// zero-progress guard (DR-043 / DR-054): repeat head сЂ» >= 1 ТХѕУ▓╗сЂїт┐ЁУдЂсђѓтЁеС╗ХтЈјжЏє Рђћ сЂЪсЂасЂЌ ref
/// cycle сЂФсѓѕсѓІ жЮъ progress сЂ» circular ref (collect_circular_ref) тЂ┤сЂДта▒тЉісЂЎсѓІсЂ«сЂДсђЂсЂЊсЂЊсЂДсЂ»жЎцтцќсЂЎсѓІ
/// (kind сѓњ distinct сЂФС┐ЮсЂц)сђѓ
fn collect_zero_progress(
  def : @engine.Definition,
  registry : Map[String, @engine.Node],
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.positionals {
    match elem_repeat(e) {
      Some(_) => {
        let head = elem_head(e)
        if !head_progresses(head, registry, []) &&
          !head_node_cycles(head, registry) {
          out.push(
            def_err(
              e.name,
              @engine.DZeroProgress,
              "repeat element '\{e.name}' has a zero-progress head",
              "give the repeat head a token-consuming element",
            ),
          )
        }
      }
      None => ()
    }
  }
  for c in def.commands {
    collect_zero_progress(c.body, registry, out)
  }
}

///|
/// circular ref (DR-054): registry template сЂ« head-position ref chain сЂї loop Рєњ уёАжЎљТДІжђат▒ЋжќІсђѓ
/// repeat ућ▒ТЮЦсЂ«УЄфтЈѓуЁДсЂ» pass (head сЂїТХѕУ▓╗ node)сђѓтЁеС╗ХтЈјжЏєсђѓ
fn collect_circular_ref(
  registry : Map[String, @engine.Node],
  out : Array[@engine.DefError],
) -> Unit {
  for name, _ in registry {
    // repeat installer уЎ╗жї▓сЂ« lazy-marker key ("lazy:<name>") сЂ»сѓ╣сѓГсЃЃсЃЌсђѓ
    if name.length() >= 5 && name[0:5] == "lazy:" {
      continue
    }
    if head_cycles(name, registry, []) {
      out.push(
        def_err(
          name,
          @engine.DCircularRef,
          "ref template '\{name}' is circular (infinite structural expansion)",
          "break the ref cycle or add a token-consuming head before the self-reference",
        ),
      )
    }
  }
}

///|
/// absent ref (DR-054 / DR-032): УдЂу┤а ref_target сЂ«УДБТ▒║тЁѕсЂїуёАсЂё (init_sb сЂ« repeat lowering + С║ІтЅЇ
/// уЎ╗жї▓ТИѕсЂ┐ template сѓњтљФсѓђ registry сЂД check)сђѓтЁеС╗ХтЈјжЏєсђѓ
fn collect_absent_ref(
  def : @engine.Definition,
  registry : Map[String, @engine.Node],
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.options {
    check_elem_absent_ref(e, registry, out)
  }
  for e in def.positionals {
    check_elem_absent_ref(e, registry, out)
  }
  for c in def.commands {
    collect_absent_ref(c.body, registry, out)
  }
}

///|
fn check_elem_absent_ref(
  e : @engine.ElemDef,
  registry : Map[String, @engine.Node],
  out : Array[@engine.DefError],
) -> Unit {
  match e.ref_target {
    Some(r) =>
      match registry.get(r) {
        Some(_) => ()
        None =>
          out.push(
            def_err(
              e.name,
              @engine.DAbsentRef,
              "ref target '\{r}' is not defined in scope or definitions",
              "define '\{r}' as a template (definitions) or in the scope",
            ),
          )
      }
    None => ()
  }
}

///|
/// invalid value range (DR-054 / DR-052): repeat min > maxсђѓтЁеС╗ХтЈјжЏєсђѓ
fn collect_invalid_range(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.positionals {
    match e.repeat {
      Some(spec) =>
        match spec.max {
          Some(mx) =>
            if spec.min > mx {
              out.push(
                def_err(
                  e.name,
                  @engine.DInvalidRange,
                  "repeat min \{spec.min} > max \{mx}",
                  "set the repeat max >= min",
                ),
              )
            }
          None => ()
        }
      None => ()
    }
  }
  for c in def.commands {
    collect_invalid_range(c.body, out)
  }
}

///|
/// codex сЃгсЃЊсЃЦсЃ╝ТїЄТЉў 4 (2026-07-09 у»ђуЏ«сЃгсЃЊсЃЦсЃ╝): an option's `ref` + `repeat` lowering
/// (`inst_long`'s `Some(_)` arm) only wires a SINGLE `@engine.GreedyRepeat` spine slot Рђћ correct for
/// `min <= 1` (no mandatory-head unrolling, `elem_repeat`'s `Some(spec) => spec.min - 1`
/// mandatory heads collapses to 0), but a `min > 1` spec WOULD unroll extra mandatory heads that
/// `inst_long` silently folds into the SAME single tail (`@engine.Seq(spine)`) Рђћ losing both тЁѕжБЪсЂё
/// suppression and the greedy тЈќсѓітѕєжЂИтЦй for those extra reps while still parsing "successfully"
/// (issue 2026-07-09-ref-template-result-shape: Тюфт»Йт┐юТДІТѕљсЂ»ж╗ЎсЂБсЂдУфцтІЋСйюсЂЋсЂЏсЂџ definition error
/// сЂДтЈ»УдќтїќсЂЎсѓІтЦЉу┤ёсђЂ[[retreat-is-last-resort]] тљїтъІсЂ«сђїтБісѓїсЂЪсЂЙсЂЙтІЋсЂІсЂЎсѓѕсѓіУљйсЂесЂЎсђЇтѕцТќГ)сђѓReject at
/// definition time until `@engine.GreedyRepeat` carries multiple spine slots.
fn collect_unsupported_option_ref_repeat(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.options {
    if e.ref_target is Some(_) {
      match elem_repeat(e) {
        Some(spec) =>
          if spec.min > 1 {
            out.push(
              def_err(
                e.name,
                @engine.DInvalidRange,
                "option repeat min \{spec.min} > 1 is not supported for a `ref` element (@engine.GreedyRepeat wires a single spine slot only)",
                "use repeat: {\"min\": 0} or {\"min\": 1} on this option, or move the mandatory reps to a positional",
              ),
            )
          }
        None => ()
      }
    }
  }
  for c in def.commands {
    collect_unsupported_option_ref_repeat(c.body, out)
  }
}

///|
/// issue 2026-07-09-accum-fold-update-default-ops (team-lead УБЂт«џ 2026-07-10сђЂ`collect_unsupported_
/// option_ref_repeat` сЂ«тЁёт╝Ъ Рђћ тљїсЂўсђїТДІжђауџёсЂФт«БУеђсЂДсЂЇсѓІсЂїт«ЪУБЁсЂїт»Йт┐юсЂДсЂЇсЂфсЂёухётљѕсЂЏсѓњ definition-error
/// сЂДУљйсЂесЂЎсђЇтЦЉу┤ё): an `update` variant (DR-077 ┬Д1's `:update:<transform>` DSL) targeting a `multiple`
/// (accum) element is REJECTED at definition time. DR-077's `update` semantics are `cell = f(old)`
/// where `old` is the CELL'S CURRENT VALUE Рђћ for an accum cell that value is the accumulated array
/// (T[]), but every filters-registry transform is T=>T (scalar, `filters.mbt`'s `FilterSignature`,
/// DR-077 ┬Д2 "Сй┐сЂѕсѓІсЂ«сЂ» transform сѓисѓ░сЃЇсЃЂсЃБ T=>T сЂ« filter сЂ«сЂ┐"). Applying a scalar transform to an
/// array is a STRUCTURAL type mismatch with no legal resolution today (no Acc=>Acc transform exists
/// in the registry) Рђћ rather than let it reach the ACCUMULATE fold and fail unpredictably there
/// (or silently coerce), this closes the gap at the SAME layer DR-077 ┬Д2 already closes "unknown
/// transform name" / "validate-only signature" (`classify_long_spelling`'s `LInvalid` path, both
/// folded into `@engine.DUnknownVocab` there) Рђћ `multiple` + `update` is a third static-known-bad
/// combination, just discovered one step later (after `normalize_surface` has resolved `variants`,
/// unlike the two above which classify_long_spelling catches at DSL-parse time). `@engine.DInvalidRange` is
/// reused (not a new `@engine.DefErrKind`) for the same reason `classify_long_spelling`'s comment gives:
/// introducing a finer-grained kind is a spec-side DR-054 decision, not kuu.mbt's to make alone.
///
/// spec fixture pin уіХТ│Ђ (2026-07-10 team-lead жђБухА): definition_error format УЄфСйЊсЂї DR-065 сЂДС║ѕу┤ёсЂ«
/// сЂ┐сЂДТюфуб║т«џсЂфсЂЪсѓЂсђЂspec тЂ┤сЂ«сЂЊсЂ« reject сЂ« fixture тїќсЂ»С┐ЮуЋЎ (issue УхиуЦеТИѕсЂ┐сђЂformat т«ЪСЙІтїќсЂ» kawaz
/// УБЂт«џтЙЁсЂА) Рђћ сЂЊсЂ«ТцюТЪ╗сЂ» kuu.mbt тЂ┤сЂ« wbtest сЂДсЂ«сЂ┐ pin сЂЎсѓІ (`collect_unsupported_option_ref_repeat`
/// сЂ« min>1 reject сѓѓтљїтъІсЂ« wbtest-only pin сЂ«тЅЇСЙІ)сђѓ
fn collect_unsupported_accum_update(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.options {
    if e.multiple {
      for v in e.variants {
        match v.op {
          @engine.Update(_, _) =>
            out.push(
              def_err(
                e.name,
                @engine.DInvalidRange,
                "update variant '\{v.trigger}' targets a multiple (accum) element Рђћ every filters-registry transform is T=>T (scalar) but this cell's current value is an accumulated array (T[]), a structural type mismatch with no legal transform today",
                "remove the update variant from this element, or move the transform to a non-multiple (scalar) element",
              ),
            )
          _ => ()
        }
      }
    }
  }
  for e in def.positionals {
    if e.multiple {
      for v in e.variants {
        match v.op {
          @engine.Update(_, _) =>
            out.push(
              def_err(
                e.name,
                @engine.DInvalidRange,
                "update variant '\{v.trigger}' targets a multiple (accum) element Рђћ every filters-registry transform is T=>T (scalar) but this cell's current value is an accumulated array (T[]), a structural type mismatch with no legal transform today",
                "remove the update variant from this element, or move the transform to a non-multiple (scalar) element",
              ),
            )
          _ => ()
        }
      }
    }
  }
  // codex сЃгсЃЊсЃЦсЃ╝ High 1 (2026-07-10): alias сЂ« `long_override` (DR-057 ┬Д3 ти«тѕєСИіТЏИсЂЇ) сЂ» canonical
  // тЂ┤сЂ« `variants` сѓњухїућ▒сЂЏсЂџуІгУЄфсЂФ colon DSL сѓњУДБжЄѕсЂЎсѓІ Рђћ СИісЂ« 2 сЃФсЃ╝сЃЌсЂ» `def.options`/
  // `def.positionals` сЂ« (сЂЊсЂ«ТЎѓуѓ╣сЂ«) variants сЂЌсЂІУдІсЂфсЂёсЂЪсѓЂсђЂalias ухїућ▒сЂ« `:update:<transform>`
  // сЂїтљїсЂўТцюТЪ╗сѓњсЂЎсѓіТіюсЂЉсЂд `parse_definition` сѓњжђџжЂјсЂЌсђЂуЎ║уЂФТЎѓсЂФ canonical (multiple УдЂу┤а) сЂИсЂ«
  // @engine.Update binding сЂїт▒ісЂёсЂд `resolve.mbt`'s accum тѕєт▓љсЂ« abort сЂФтѕ░жЂћсЂЎсѓІ
  // (repro: canonical `{"name":"tags","multiple":true}` + alias `{"target":"tags",
  // "long_override":["bump:update:increment"]}` + args `["--bump-t"]`)сђѓ`desugar_aliases` (сЂЊсЂ«
  // ТцюТЪ╗сѓѕсѓітЙїсЂФУх░сѓІ) сЂї alias ућесЂ« entry-copy сѓњСйюсЂБсЂЪтЙїсЂасЂесђЂсЂЮсЂ«copyУЄфУ║ФсЂ» `multiple: false`
  // тЏ║т«џ (`alias_entry`) сЂФсЂфсѓітѕцт«џсЂїтѕЦсЃГсѓИсЃЃсѓ»сѓњУдЂсѓІ Рђћ сЂЊсЂЊ (desugar тЅЇсђЂ`def.aliases` сѓњуЏ┤ТјЦУдІсѓІ)
  // сЂД `collect_invalid_alias_long_override` сЂетљїсЂўсЃЉсѓ┐сЃ╝сЃ│ (colon DSL сѓњ `classify_long_spelling`
  // сЂДтѕєжАъ + `find_elem` сЂД alias тЁѕ canonical сѓњт╝ЋсЂЈ) сѓњтєЇтѕЕућесЂЎсѓІТќ╣сЂїТЌбтГўУдЈу┤ёсЂеСИђУ▓ФсЂЌсђЂ
  // `parse_definition` тЁеСйЊсЂ«т«ЪУАїжаєт║ЈсѓѓтцЅсЂѕсЂџсЂФТИѕсѓђсђѓ
  for a in def.aliases {
    match a.long_override {
      Some(LList(strs)) =>
        match find_elem(def, a.target) {
          Some(canon) =>
            if canon.multiple {
              let alias_name = match a.name {
                Some(n) => n
                None => a.target
              }
              for l in strs {
                match classify_long_spelling(l, alias_name, canon.ty) {
                  LVariant(v) =>
                    match v.op {
                      @engine.Update(_, _) =>
                        out.push(
                          def_err(
                            canon.name,
                            @engine.DInvalidRange,
                            "alias long_override update variant '\{v.trigger}' targets '\{canon.name}', a multiple (accum) element Рђћ every filters-registry transform is T=>T (scalar) but this cell's current value is an accumulated array (T[]), a structural type mismatch with no legal transform today",
                            "remove the update variant from this alias's long_override, or move the transform to a non-multiple (scalar) element",
                          ),
                        )
                      _ => ()
                    }
                  LMain(_) | LInvalid(_) => () // not an update variant; other errors caught by collect_invalid_alias_long_override
                }
              }
            }
          None => () // dangling alias target Рђћ absent-ref check сЂїтѕЦжђћТІЙсЂє
        }
      Some(LBool(_)) => () // bool у│ќУАБ (:set/:set:true уЏИтйЊ) сЂ» update DSL сѓњтљФсЂЙсЂфсЂё
      None => ()
    }
  }
  for c in def.commands {
    collect_unsupported_accum_update(c.body, out)
  }
}

///|
/// codex сЃгсЃЊсЃЦсЃ╝ High 2 (2026-07-10): `collect_unsupported_accum_update` сЂ« variant Ух░ТЪ╗ (СИіУеў) сЂ»
/// `count_increment_variant` ухїућ▒ (`long:true` у│ќУАБсђЂDR-077 ┬Д3) сЂ« `:update:increment` сЂ»ТЇЋсЂЙсЂѕсѓІсЂїсђЂ
/// count_type() сЂ« **short** уЎ║уЂФ (`builtins/matcher_residents.mbt` сЂ« `walk_short`'s `count_type()` arm) сЂ» variant сѓњСИђтѕЄухїућ▒сЂЏсЂџ
/// `mk_eff(e.name, @engine.Update("increment", []), @engine.Cli)` сѓњуЏ┤ТјЦућЪТѕљсЂЎсѓІ Рђћ variants сѓњТїЂсЂЪсЂфсЂё firing сЂфсЂ«сЂД
/// variant Ух░ТЪ╗сЂДсЂ»сЂЮсѓѓсЂЮсѓѓУдІсЂѕсЂфсЂё (repro: `{"name":"n","type":"count","short":["n"],
/// "multiple":true}` + args `["-n"]` сЂД resolve.mbt сЂ« accum тѕєт▓љсЂ« abort сЂФтѕ░жЂћ)сђѓ
///
/// DR-077 ┬Д3 сЂД count сЂ» `number + default:0 + update:increment сЂ«уХ┤сѓітљѕТѕљ` сЂеУдЈт«џсЂЋсѓїсЂдсЂёсѓІ Рђћ
/// count сЂесЂёсЂє TYPE сЂЮсЂ«сѓѓсЂ«сЂїсђїupdate(increment) ті╣ТъюсѓњТїЂсЂцсђЇсЂесЂёсЂєтЦЉу┤ёсѓњжЂІсЂХсЂ«сЂДсђЂfiring сЂ«уХ┤сѓі
/// (short/long/Тўјуц║variant) сѓњтЋЈсѓЈсЂџсђЂ**count_type() УдЂу┤асЂИсЂ« `multiple` т«БУеђсЂЮсЂ«сѓѓсЂ«**сЂї accum├Ќupdate сЂе
/// ТДІжђауџёсЂФтљїсЂўТюфт»Йт┐юТДІТѕљ (T=>T transform vs у┤»уЕЇуіХТЁІ T[]) сЂФсЂфсѓІсђѓvariant сЂ«ТюЅуёАсЂФСЙЮтГўсЂЌсЂфсЂёУдЂу┤а
/// сЃгсЃЎсЃФсЂ«ТцюТЪ╗сЂесЂЌсЂдсђЂ`collect_unsupported_accum_update` сЂесЂ»тѕЦТЮАС╗ХсЂДт«ЪУБЁсЂЎсѓІ (variant Ух░ТЪ╗сѓњ
/// count_type() сЂФсѓѓт║ЃсЂњсѓІсЂ«сЂДсЂ»сЂфсЂЈсђЂcount_type()├Ќmultiple сЂесЂёсЂєухётљѕсЂЏУЄфСйЊсѓњжќЅсЂўсѓІ Рђћ short ухїућ▒сЂ»сЂЮсѓѓсЂЮсѓѓ
/// variant сѓњућЪТѕљсЂЌсЂфсЂёсЂЪсѓЂсђЂvariant Ух░ТЪ╗сѓњт║ЃсЂњсЂдсѓѓТЇЋсЂЙсЂѕсѓЅсѓїсЂфсЂё)сђѓ
fn collect_unsupported_count_multiple(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.options {
    if e.ty.name() == "count" && e.multiple {
      out.push(
        def_err(
          e.name,
          @engine.DInvalidRange,
          "a `count` element cannot declare `multiple` Рђћ count's type contract IS an update(increment) effect (DR-077 ┬Д3), and every filters-registry transform is T=>T (scalar) while a multiple (accum) cell's current value is an accumulated array (T[]), a structural type mismatch with no legal transform today",
          "remove `multiple` from this count element, or use a plain `number` element with an explicit `:update:<transform>` variant on a non-multiple cell",
        ),
      )
    }
  }
  for e in def.positionals {
    if e.ty.name() == "count" && e.multiple {
      out.push(
        def_err(
          e.name,
          @engine.DInvalidRange,
          "a `count` element cannot declare `multiple` Рђћ count's type contract IS an update(increment) effect (DR-077 ┬Д3), and every filters-registry transform is T=>T (scalar) while a multiple (accum) cell's current value is an accumulated array (T[]), a structural type mismatch with no legal transform today",
          "remove `multiple` from this count element, or use a plain `number` element with an explicit `:update:<transform>` variant on a non-multiple cell",
        ),
      )
    }
  }
  for c in def.commands {
    collect_unsupported_count_multiple(c.body, out)
  }
}

///|
/// DR-083 ┬Д5: a non-accum (truly scalar) element's declared default must decode to EXACTLY one
/// piece Рђћ an array-shaped JSON default (`length != 1`) for such an element is a STRUCTURAL
/// mismatch known entirely at definition time (no I/O needed, unlike DR-050's config array whose
/// structural mismatch IS a runtime Error precisely because config is read at runtime) Рђћ
/// `collect_unsupported_accum_update`'s sibling "ТДІжђауџёсЂФт«БУеђсЂДсЂЇсѓІсЂїт«ЪУБЁсЂїт»Йт┐юсЂДсЂЇсЂфсЂёухётљѕсЂЏсѓњ
/// definition-error сЂДУљйсЂесЂЎ" contract.
///
/// "non-accum" mirrors `ensure_entity`'s OWN accum-eligibility derivation exactly (`e.multiple ||
/// elem_repeat(e) is Some(_) || e.separator is Some(_)`) Рђћ computed here on the pre-`ensure_entity`
/// `@engine.ElemDef` fields directly, since this check runs before `@engine.Entity`/`@engine.Entity.accum` exist. Using
/// the narrower `e.multiple` alone would misfire on a `repeat`-only or bare-`separator` element
/// (both legitimately accum cells per `ensure_entity`, DR-043/034) declaring a multi-piece default
/// Рђћ this derivation must stay IN SYNC with `ensure_entity`'s if it ever changes.
fn collect_scalar_array_default(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn is_accum_elem(e : @engine.ElemDef) -> Bool {
    e.multiple || elem_repeat(e) is Some(_) || e.separator is Some(_)
  }

  fn check(e : @engine.ElemDef) -> Unit {
    if !is_accum_elem(e) {
      match e.default_values {
        Some(vs) =>
          if vs.length() != 1 {
            out.push(
              def_err(
                e.name,
                @engine.DInvalidRange,
                "a non-multiple (scalar) element's declared default must be exactly ONE piece, got \{vs.length()} Рђћ an array-shaped default is only legal for a multiple/repeat/separator (accum) element (DR-083 ┬Д1/┬Д5)",
                "wrap this element's default in `multiple`/`repeat` if it should accumulate, or write a single scalar default value",
              ),
            )
          }
        None => ()
      }
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_scalar_array_default(c.body, out)
  }
}

///|
/// DR-089 ┬Д4: none сЂФсЂ»тђцуЕ║жќЊсЂїуёАсЂёсЂ«сЂДсђЂтђцТ║љсѓњт«БУеђсЂЎсѓІ `env`/`config_key`/`inherit` сЂ»жЮЎуџёсЂФТЌбуЪЦсЂ«СИЇТѕљуФІТДІТѕљ
/// Рђћ сђїжЮЎуџёсЂФТЌбуЪЦсЂ»т«џуЙЕТЎѓсЂФтђњсЂЎсђЇ(DR-083 ┬Д5) сЂ«уГІсЂД definition-error сЂФсЂЎсѓІсђѓт«ЪУАїТЎѓтЂ┤
/// (`env_value`/`@engine.config_to_value` сЂ« none_type() armсђЂresolve.mbt/value.mbt) сЂ»жў▓тЙА (сЂЊсЂ«сЃЂсѓДсЃЃсѓ»сЂї
/// тЁѕсЂФУљйсЂесЂЎсЂ«сЂД unreachable ТЃ│т«џ) сЂесЂЌсЂдТ«ІсЂЎсђѓconfig_key сЂ«Тўјуц║т«БУеђсЂ«сЂ┐сѓњт»ЙУ▒АсЂесЂЌсђЂ
/// `config_seat` (config_file УдЂу┤асЂ«тГўтюесЂДУЄфтІЋуџёсЂФтЁе value cell сЂИтљїтъІС╗ўСИјсЂЋсѓїсѓІтИГсђЂDR-050 ┬Д3)
/// сЂ»сЂЊсЂЊсЂДсЂ»т»ЙУ▒Атцќ Рђћ УЉЌУђЁсЂїТўјуц║уџёсЂФТЏИсЂёсЂЪт«БУеђсЂасЂЉсѓњТцюТЪ╗сЂЎсѓІ (config_seat сЂ»тђІсђЁсЂ«УдЂу┤асЂ«ТёЈтЏ│сЂДсЂ»
/// сЂфсЂЈсѓ╣сѓ│сЃ╝сЃЌтЁеСйЊсЂ«УЄфтІЋтИ░ухљсЂфсЂ«сЂДсђЂтљїсЂўсђїУЉЌУђЁсЂ«УфцсѓісђЇсѓФсЃєсѓ┤сЃфсЂФт▒ъсЂЋсЂфсЂё)сђѓ
fn collect_none_value_source_decl(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn check(e : @engine.ElemDef) -> Unit {
    if e.ty.name() == "none" {
      if e.env.length() > 0 {
        out.push(
          def_err(
            e.name,
            @engine.DInvalidRange,
            "'\{e.name}' is type none (no value space) but declares env Рђћ a none element cannot have a value source (DR-089 ┬Д4)",
            "remove 'env' from '\{e.name}', or give it a real value type",
          ),
        )
      }
      if e.config_key is Some(_) {
        out.push(
          def_err(
            e.name,
            @engine.DInvalidRange,
            "'\{e.name}' is type none (no value space) but declares config_key Рђћ a none element cannot have a value source (DR-089 ┬Д4)",
            "remove 'config_key' from '\{e.name}', or give it a real value type",
          ),
        )
      }
      if e.is_inherit {
        out.push(
          def_err(
            e.name,
            @engine.DInvalidRange,
            "'\{e.name}' is type none (no value space) but declares inherit Рђћ a none element cannot have a value source (DR-089 ┬Д4)",
            "remove 'inherit' from '\{e.name}', or give it a real value type",
          ),
        )
      }
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_none_value_source_decl(c.body, out)
  }
}

///|
/// DR-102 ┬Д1/┬Д3 (т▒ъТђДтѕєтЅ▓сђЂissue accum-post-filters-stage7 сЂ«тЙїуХЎ): `final_filters` (TРєњT, scalar
/// filter registry, non-accum УдЂу┤ат░ѓуће) сЂе `accum_filters` (AccРєњAcc, ARRAY filter registry, accum
/// УдЂу┤ат░ѓуће) сЂ»сђЂУдЂу┤асЂ« accum жЂЕТа╝ТђД (`multiple`/`repeat`/`separator` Рђћ `ensure_entity`/
/// `collect_scalar_array_default` сЂетљїсЂў `is_accum_elem` т░јтЄ║) сЂеТјњС╗ќуџёсЂФт»Йт┐юсЂЎсѓІсђѓУдЂу┤асЂФсЂЮсѓѓсЂЮсѓѓ
/// тГўтюесЂЌсЂфсЂётЂ┤сЂ«т▒ъТђДсѓњТЏИсЂЈсЂ«сЂ»ТДІжђаСИЇСИђУЄ┤сЂДсЂѓсѓісђЂ`collect_scalar_array_default` (жЮъ accum УдЂу┤асЂИсЂ«
/// жЁЇтѕЌ default т«БУеђ) сЂетљїтъІсЂ« "ТДІжђауџёсЂФт«БУеђсЂДсЂЇсѓІсЂїт«ЪУБЁсЂїт»Йт┐юсЂДсЂЇсЂфсЂёухётљѕсЂЏсѓњ definition-error сЂД
/// УљйсЂесЂЎ" тЦЉу┤ёсЂД kind=invalid-range сѓњ reject сЂЎсѓІ (fixtures/definition-error/
/// accum-filters-on-non-multiple-invalid-range.json / final-filters-on-multiple-invalid-range.json)сђѓ
/// 1 т▒ъТђД 1 registry сЂ«т»Йт┐ю (DR-102 ┬Д2) сЂФсѓѕсѓісђЂуХ┤сѓісЂ« registry ТюфуЎ╗жї▓сЂ» `collect_unknown_filter` сЂї
/// тЇўуІгсЂДтѕцт«џсЂЎсѓІ Рђћ Тюг gate сЂ»т▒ъТђДсЂеУдЂу┤асЂ«тйбсЂ«СИЇСИђУЄ┤ (layer жЂЋсЂёсЂДсЂ»сЂфсЂЈТДІжђажЂЋтЈЇ) сЂасЂЉсѓњУдІсѓІсђѓ
///
/// DR-102 ┬Д3 сЂ«Тўјуб║тїќ note (codex сЃгсЃЊсЃЦсЃ╝ M-9): `type:"none"` УдЂу┤а (тђцуЕ║жќЊсЂфсЂЌсђЂDR-089) сЂИсЂ«
/// `final_filters` т«БУеђсѓѓтљїсЂў invalid-range сЂФт▒ъсЂЎсѓІ Рђћ `final_filters` сЂ» TРєњT сЂДтђцуЕ║жќЊсЂ«тъІ T сЂИсЂ«
/// тцЅТЈЏ/ТцюУе╝сѓњтЅЇТЈљсЂесЂЎсѓІсЂїсђЂnone сЂФсЂ»тђцуЕ║жќЊсЂЮсЂ«сѓѓсЂ«сЂїуёАсЂЈ T сЂїтГўтюесЂЌсЂфсЂёсЂЪсѓЂТДІТѕљСИЇУЃй
/// (DR-089 ┬Д4 сЂетљїтъІсЂ«тИ░ухљ)сђѓaccum жЂЕТа╝сЂф none УдЂу┤асЂ« `accum_filters` (AccРєњAcc) т«БУеђсѓѓтљїсЂўуљєсЂД
/// invalid-range Рђћ жЮъ accum сЂф none УдЂу┤асЂ« `accum_filters` сЂ»ТЌбсЂФСИісЂ« wrong-seat тѕцт«џсЂДсѓФсЃљсЃ╝сЂЋсѓїсѓІ
/// сЂЪсѓЂсђЂnone тЏ║ТюЅсЂ«У┐йтіатѕцт«џсЂ» accum УдЂу┤асЂ«та┤тљѕсЂ«сЂ┐т┐ЁУдЂсђѓ
fn collect_invalid_filter_attribute_mismatch(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn is_accum_elem(e : @engine.ElemDef) -> Bool {
    e.multiple || elem_repeat(e) is Some(_) || e.separator is Some(_)
  }

  fn check(e : @engine.ElemDef) -> Unit {
    let accum = is_accum_elem(e)
    let none_ty = e.ty.name() == "none"
    if e.final_filters.length() > 0 {
      if none_ty {
        out.push(
          def_err(
            e.name,
            @engine.DInvalidRange,
            "a type:\"none\" element has no value space (DR-089) Рђћ final_filters (TРєњT, DR-102 ┬Д1) requires a T to operate over, which does not exist here",
            "remove final_filters from this element, or give it a real value type",
          ),
        )
      } else if accum {
        out.push(
          def_err(
            e.name,
            @engine.DInvalidRange,
            "an accum (multiple/repeat/separator) element cannot declare final_filters (TРєњT, non-accum-only final-value gate, DR-102 ┬Д1) Рђћ this element's final gate is accum_filters (AccРєњAcc, over the whole accumulated array)",
            "move this chain to accum_filters, or remove multiple/repeat/separator from this element",
          ),
        )
      }
    }
    if e.accum_filters.length() > 0 {
      if !accum {
        out.push(
          def_err(
            e.name,
            @engine.DInvalidRange,
            "a non-accum (scalar) element cannot declare accum_filters (AccРєњAcc, accum-only whole-array gate, DR-102 ┬Д1) Рђћ this element's final gate is final_filters (TРєњT, over the single resolved value)",
            "move this chain to final_filters, or declare multiple/repeat/separator on this element",
          ),
        )
      } else if none_ty {
        out.push(
          def_err(
            e.name,
            @engine.DInvalidRange,
            "a type:\"none\" element has no value space (DR-089) Рђћ accum_filters (AccРєњAcc, DR-102 ┬Д1) requires a T domain to operate over, which does not exist here",
            "remove accum_filters from this element, or give it a real value type",
          ),
        )
      }
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_invalid_filter_attribute_mismatch(c.body, out)
  }
}

///|
/// DR-101 / DR-102 ┬Д1/┬Д2: filter chain 4 т▒ъТђД (`value_filters` / `piece_filters` / `final_filters` /
/// `accum_filters`) сЂФТїЄт«џсЂЋсѓїсЂЪ filter тљЇсЂїсђЂсЂЮсЂ«т▒ъТђДсЂїУдЂТ▒ѓсЂЎсѓІ registry сЂ« owns жЏєтљѕсЂФуЎ╗жї▓сЂЋсѓїсЂд
/// сЂёсЂфсЂёта┤тљѕсЂ» definition-error (kind=`unknown-vocab`)сђѓDR-042 ┬Д5 сЂ« installer / filter registry
/// тљїТа╝тјЪтЅЄсЂФсѓѕсѓісђЂlong variant DSL сЂ« update transform тљЇТцюТЪ╗ (`classify_long_spelling` сЂ«
/// DR-077 ┬Д2 жЂЕуће) сЂетљїТЌЈсЂ«тѕцт«џсђѓ
///
/// `value_filters`/`piece_filters`/`final_filters` сЂ» scalar filter registry (TРєњT, `lookup_filter`)
/// сѓњсђЂ`accum_filters` сЂ» ARRAY filter registry (AccРєњAcc, `lookup_array_filter`) сѓњУдЂТ▒ѓсЂЎсѓІ Рђћ 1
/// т▒ъТђД 1 registry сЂ«т»Йт┐ю (DR-102 ┬Д2) сЂФсѓѕсѓісђЂтљёт▒ъТђДсЂ»УЄфтѕєсЂ« registry сЂ« owns жЏєтљѕсЂ«сЂ┐сѓњУдІсЂд
/// unknown-vocab сѓњСИђТёЈтѕцт«џсЂЎсѓІсђѓС╗ќ registry сЂесЂ«т▒цжЂЋсЂёТ»ћУ╝Ѓ (DR-101 ┬Д3сђЂSuperseded) сЂ»уЎ║ућЪсЂЌсЂфсЂёсђѓ
///
/// сЂЊсЂ«тЇўу┤ћтїќсЂФсѓѕсѓісђЂ`filters.mbt` сЂ« `apply_filter_chain`/`apply_accum_filter_chain` сЂФтѕ░жЂћсЂЎсѓІ
/// ТЎѓуѓ╣сЂДтЁе filter тљЇсЂїТЌбсЂФуЎ╗жї▓ТИѕсЂ┐С┐ЮУе╝сЂесЂфсѓісђЂruntime `unknown_filter` reason сЂ» wire сЂІсѓЅТХѕТ╗ЁсЂЎсѓІ
/// (DR-101 ┬Д1)сђѓ
///
/// DR-102 ┬Д3 сЂ«Тўјуб║тїќ note (codex сЃгсЃЊсЃЦсЃ╝ M-6/M-9): `final_filters`/`accum_filters` сЂїУдЂу┤асЂФсЂесЂБсЂд
/// wrong-seat (`collect_invalid_filter_attribute_mismatch` сЂї invalid-range сѓњтЄ║сЂЎжЮъ accum УдЂу┤асЂ«
/// accum_filtersсЃ╗accum УдЂу┤асЂ« final_filtersсЃ╗`type:"none"` УдЂу┤асЂ«сЂёсЂџсѓїсЂІ) сЂ«та┤тљѕсђЂТюг gate сЂ»сЂЮсЂ«
/// т▒ъТђДсЂ«СИГУ║ФсѓњСИђтѕЄУДБжЄѕсЂЌсЂфсЂё (unknown-vocab тѕцт«џсѓњсѓ╣сѓГсЃЃсЃЌсЂЎсѓІ) Рђћ wrong-seat тѕцт«џсЂїТДІжђасѓ▓сЃ╝сЃѕтЁѕУАї
/// сЂДсЂѓсѓісђЂуХ┤сѓісЂ«уЎ╗жї▓ТюЅуёАсѓњтЋЈсѓЈсЂџ invalid-range сЂ«сЂ┐сЂїта▒тЉісЂЋсѓїсѓІ (definition_error сЂ«
/// `expect.errors` сЂ»тЁесѓесЃЕсЃ╝сЂ«т«їтЁеСИђУЄ┤жЏєтљѕсђЂС║їжЄЇта▒тЉісѓњжЂ┐сЂЉсѓІ)сђѓ
fn collect_unknown_filter(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn is_accum_elem(e : @engine.ElemDef) -> Bool {
    e.multiple || elem_repeat(e) is Some(_) || e.separator is Some(_)
  }

  fn push_unknown(
    elem_name : String,
    phase : String,
    fs_name : String,
  ) -> Unit {
    out.push(
      def_err(
        elem_name,
        @engine.DUnknownVocab,
        "filter '" +
        fs_name +
        "' in " +
        phase +
        " is not registered in the filters registry (DR-101)",
        "use a registered filter name (see DR-095 ┬Д3 canonical filter vocabulary) or remove this chain entry",
      ),
    )
  }

  fn check(e : @engine.ElemDef) -> Unit {
    // value_filters (TРєњT, scalar filter registry): уХ┤сѓіСИЇтюесЂ» unknown-vocab (DR-101 ┬Д1)
    for fs in e.value_filters {
      if lookup_filter(fs.name) is None {
        push_unknown(e.name, "value_filters", fs.name)
      }
    }
    // piece_filters (StringРєњString, scalar filter registry тєЁсЂ« string тЪЪ): уХ┤сѓіСИЇтюесЂ»
    // unknown-vocab (value_filters сЂетѕцт«џтЁЦтіЏтљїСИђсђЂDR-101 ┬Д1)
    for fs in e.piece_filters {
      if lookup_filter(fs.name) is None {
        push_unknown(e.name, "piece_filters", fs.name)
      }
    }
    // final_filters (TРєњT, scalar filter registry, non-accum т░ѓућесђЂDR-102 ┬Д1): ТГБсЂЌсЂётИГ (жЮъ accum
    // сЂІсЂц жЮъ none) сЂ«та┤тљѕсЂ«сЂ┐ unknown-vocab тѕцт«џсђѓwrong-seat/none-type сЂ»
    // `collect_invalid_filter_attribute_mismatch` сЂ« invalid-range сЂФСИђС╗╗ (M-6/M-9 ТДІжђасѓ▓сЃ╝сЃѕтЁѕУАї)сђѓ
    if !is_accum_elem(e) && e.ty.name() != "none" {
      for fs in e.final_filters {
        if lookup_filter(fs.name) is None {
          push_unknown(e.name, "final_filters", fs.name)
        }
      }
    }
    // accum_filters (AccРєњAcc, ARRAY filter registry, accum т░ѓућесђЂDR-102 ┬Д1): ТГБсЂЌсЂётИГ (accum сЂІсЂц
    // жЮъ none) сЂ«та┤тљѕсЂ«сЂ┐ unknown-vocab тѕцт«џсђѓ
    if is_accum_elem(e) && e.ty.name() != "none" {
      for fs in e.accum_filters {
        if lookup_array_filter(fs.name) is None {
          push_unknown(e.name, "accum_filters", fs.name)
        }
      }
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_unknown_filter(c.body, out)
  }
}

///|
/// DR-085 ┬Д1 УеѓТГБ (kawaz УБЂт«џ 2026-07-10): a `regex_match` filter entry's pattern compile failure is
/// a definition-error (kind=invalid-argument, DR-054 ┬Д4 ТЏ┤Тќ░2 / DR-082 ┬Д3) Рђћ the pattern is part of
/// the definition and compile validity is statically knowable at definition time (same "жЮЎуџёсЂФТЌбуЪЦ
/// сЂ»т«џуЙЕТЎѓсЂФтђњсЂЎ" posture `collect_scalar_array_default` uses). Checked across all 4 filter-chain
/// phases (piece_filters/value_filters/final_filters/accum_filters, DR-034/DR-009/DR-102) Рђћ a
/// `regex_match` entry name-matches unconditionally regardless of which registry the declaring
/// phase actually requires (an `accum_filters` entry named `regex_match` is ALSO independently
/// rejected as unknown-vocab by `collect_unknown_filter`, since `regex_match` isn't a registered
/// ARRAY filter Рђћ DR-054's "enumerate ALL errors, no first-error ТЅЊсЂАтѕЄсѓі" means both fire, not a
/// conflict). Uses `filters.mbt`'s `@engine.compile_regex` Рђћ the SAME compile path `filter_regex_match`
/// runs at match time, so a pattern that passes this gate is guaranteed compilable at runtime too.
/// A wrong arg count (not exactly 1) is left to the runtime "regex_match requires exactly 1 arg"
/// Err (`filter_regex_match`) rather than duplicated here as a second definition-time check Рђћ this
/// gate's sole job is "does the pattern compile", not general arity validation.
/// DR-090 ┬Д2: a dd element's `match` regex Рђћ compile failure is a definition-error, the same
/// treatment `collect_invalid_regex_pattern` gives `regex_match` filter-chain patterns (same
/// `@engine.compile_regex` compile path, same `@engine.DInvalidArgument` kind Рђћ "pattern compile failure is a
/// definition-time fact, known statically without I/O").
fn collect_invalid_dd_pattern(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn check(e : @engine.ElemDef) -> Unit {
    match e.dd_match {
      Some(pattern) =>
        if @engine.compile_regex(pattern) is None {
          out.push(
            def_err(
              e.name,
              @engine.DInvalidArgument,
              "dd match pattern '" + pattern + "' failed to compile",
              "fix the pattern syntax for this host's regex dialect (DR-085 ┬Д2 / DR-090 ┬Д2)",
            ),
          )
        }
      None => ()
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_invalid_dd_pattern(c.body, out)
  }
}

///|
/// DR-102 ┬Д2 сЂ«Тўјуб║тїќ note (codex сЃгсЃЊсЃЦсЃ╝ M-5): registry ТЅђТюЅсѓ▓сЃ╝сЃѕ Рђћ `regex_match` сЂ» scalar
/// filter registry сЂ«сЂ┐сЂїТЅђТюЅсЂЎсѓІ descriptor (ARRAY filter registry сЂ»ТЅђТюЅсЂЌсЂфсЂё) сЂфсЂ«сЂДсђЂpattern
/// compile ТцюТЪ╗сЂ» `regex_match` сѓњт«ЪжџЏсЂФТЅђТюЅсЂЎсѓІ registry сѓњУдЂТ▒ѓсЂЎсѓІт▒ъТђД (`piece_filters`/
/// `value_filters`/`final_filters`) сЂФсЂ«сЂ┐Ух░сѓІсђѓ`accum_filters` (ARRAY filter registry т░ѓуће) сЂФсЂ»
/// СИђтѕЄУх░сѓЅсЂфсЂё Рђћ уХ┤сѓісЂї `regex_match` сЂДсѓѓ ARRAY registry сЂ« owns жЏєтљѕсЂФуёАсЂёсЂ«сЂД
/// `collect_unknown_filter` сЂїтЇўу┤ћсЂф unknown-vocab сЂД reject сЂЎсѓІсЂасЂЉсЂДсЂѓсѓісђЂlayer жЂЋсЂёсЂ«тЅ»ТгАТцюТЪ╗сЂ»
/// уЎ║ућЪсЂЌсЂфсЂё (DR-102 ┬Д2 сЂ«сђїУЄф registry сЂ«сЂ┐сѓњУдІсѓІсђЇтЇўу┤ћтїќсЂеуЪЏуЏЙсЂЌсЂфсЂёсЂЪсѓЂсЂ«жЎљт«џ)сђѓ
///
/// DR-102 ┬Д3 сЂ«Тўјуб║тїќ note (codex сЃгсЃЊсЃЦсЃ╝ M-6): `final_filters` сЂї wrong-seat (accum УдЂу┤асЂЙсЂЪсЂ»
/// `type:"none"` УдЂу┤асђЂ`collect_invalid_filter_attribute_mismatch` сЂї invalid-range сѓњтЄ║сЂЎсѓ▒сЃ╝сѓ╣)
/// сЂ«та┤тљѕсђЂТюг gate сЂ»сЂЮсЂ«СИГУ║Ф (pattern compile) сѓњСИђтѕЄУДБжЄѕсЂЌсЂфсЂё Рђћ ТДІжђасѓ▓сЃ╝сЃѕтЁѕУАїсЂДС║їжЄЇта▒тЉісѓњжЂ┐сЂЉсѓІсђѓ
fn collect_invalid_regex_pattern(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn is_accum_elem(e : @engine.ElemDef) -> Bool {
    e.multiple || elem_repeat(e) is Some(_) || e.separator is Some(_)
  }

  fn check_chain(name : String, chain : Array[@engine.FilterSpelling]) -> Unit {
    for fs in chain {
      if fs.name == "regex_match" &&
        fs.args.length() == 1 &&
        @engine.compile_regex(fs.args[0]) is None {
        out.push(
          def_err(
            name,
            @engine.DInvalidArgument,
            "regex_match pattern '" + fs.args[0] + "' failed to compile",
            "fix the pattern syntax for this host's regex dialect (DR-085 ┬Д2)",
          ),
        )
      }
    }
  }

  fn check(e : @engine.ElemDef) -> Unit {
    check_chain(e.name, e.piece_filters)
    check_chain(e.name, e.value_filters)
    // final_filters: ТГБсЂЌсЂётИГ (жЮъ accum сЂІсЂц жЮъ none) сЂ«та┤тљѕсЂ«сЂ┐ pattern compile ТцюТЪ╗
    // (M-6 wrong-seat gate тЁѕУАї)сђѓ
    if !is_accum_elem(e) && e.ty.name() != "none" {
      check_chain(e.name, e.final_filters)
    }
    // accum_filters: ARRAY filter registry сЂ» regex_match сѓњТЅђТюЅсЂЌсЂфсЂёсЂЪсѓЂтИИсЂФсѓ╣сѓГсЃЃсЃЌ
    // (M-5 registry ТЅђТюЅсѓ▓сЃ╝сЃѕ)сђѓ
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_invalid_regex_pattern(c.body, out)
  }
}

///|
/// DR-084 ┬Д3 (issue multiple-ref-accum-gap): merge accumulator ├Ќ ref is a definition-error. The
/// merge marker vocabulary (DR-080 ┬Д2) presupposes a separator-split STRING piece list (whole-
/// piece match against `@`/`-x`/`+`) Рђћ a `ref` element's firing value is a row (the referenced
/// template's or-branch consumption result, DR-078 ┬Д1), which never has a piece list at all, so
/// there is nothing for a marker to match against. Both `ref` and `multiple:{accumulator:"merge"}`
/// are declared, so the mismatch is known statically without I/O Рђћ same "ТДІжђауџёсЂФт«БУеђсЂДсЂЇсѓІсЂїт«ЪУБЁ
/// сЂїт»Йт┐юсЂДсЂЇсЂфсЂёухётљѕсЂЏсѓњ definition-error сЂДУљйсЂесЂЎ" contract `collect_scalar_array_default`/
/// `collect_invalid_filter_attribute_mismatch` use.
fn collect_ref_merge_accum(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn check(e : @engine.ElemDef) -> Unit {
    if e.ref_target is Some(_) && e.accumulator is Some("merge") {
      out.push(
        def_err(
          e.name,
          @engine.DInvalidRange,
          "a `ref` element cannot use the merge accumulator Рђћ merge's marker vocabulary (DR-080 ┬Д2) requires a separator-split string piece list, but a ref element's firing value is a row (DR-078 ┬Д1), which has no piece list to match markers against",
          "use `multiple: \"append\"` (or omit `accumulator`, which defaults to append) instead of `accumulator: \"merge\"` on this ref element",
        ),
      )
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_ref_merge_accum(c.body, out)
  }
}

///|
/// DR-105 ┬Д2 (ух▒ТІгУБЂт«џ M-16, тГўтюесЃЎсЃ╝сѓ╣): `multiple.flatten` сЂ» `append` accumulator т░ѓућесЂ«сЃђсѓцсЃцсЃФ
/// (DR-105 ┬Д1) Рђћ `merge`/`kv_map` уГЅсЂЮсѓїС╗ЦтцќсЂ« accumulator сЂФ `flatten` сѓГсЃ╝сЂїт«БУеђсЂЋсѓїсЂдсЂёсѓІсЂЊсЂе
/// УЄфСйЊ (true/false сЂЕсЂАсѓЅсЂ«тђцсЂДсѓѓ) сЂїТДІжђаСИЇСИђУЄ┤сЂДсЂѓсѓісђЂ`collect_ref_merge_accum`/
/// `collect_invalid_filter_attribute_mismatch` сЂетљїтъІсЂ« "ТДІжђауџёсЂФт«БУеђсЂДсЂЇсѓІсЂїт«ЪУБЁсЂїт»Йт┐юсЂДсЂЇсЂфсЂё
/// ухётљѕсЂЏсѓњ definition-error сЂДУљйсЂесЂЎ" тЦЉу┤ёсЂД kind=invalid-range сѓњ reject сЂЎсѓІ (DR-102 ┬Д3 сЂ«
/// wrong-seat тѕцт«џсЂетљїтъІ Рђћ СИГУ║ФсЂ«тђцсЂ»УДБжЄѕсЂЌсЂфсЂёсђЂт«БУеђсЂ«ТюЅуёАсЂасЂЉсѓњУдІсѓІ)сђѓ`e.flatten is Some(_)` сЂ»
/// `dec_multiple` сЂїсђїсѓГсЃ╝сЂї JSON сЂФтГўтюесЂЌсЂЪсЂІсђЇсѓњсЂЮсЂ«сЂЙсЂЙжЂІсЂХ Option (`@engine.ElemDef.flatten`'s doc
/// comment) Рђћ `Some(false)` (Тўјуц║ `flatten:false` т«БУеђ) сѓѓжЂЋтЈЇсЂесЂЌсЂдТЅ▒сЂєсђѓ
fn collect_flatten_non_append(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn check(e : @engine.ElemDef) -> Unit {
    if e.multiple && e.flatten is Some(_) && e.accumulator is Some(_) {
      out.push(
        def_err(
          e.name,
          @engine.DInvalidRange,
          "'\{e.name}' declares multiple.flatten but its accumulator is not \"append\" (DR-105 ┬Д2) Рђћ flatten is an append-only dial, and this element's accumulator is \"" +
          e.accumulator.unwrap() +
          "\"",
          "remove 'flatten' from this element, or use accumulator:\"append\" (or omit accumulator, which defaults to append)",
        ),
      )
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_flatten_non_append(c.body, out)
  }
}

///|
/// DR-105 ┬Д3 (ух▒ТІгУБЂт«џ M-17): `multiple.accumulator` сЂФт«БУеђсЂЋсѓїсЂЪтљЇтЅЇсЂї accumulators registry сЂ«
/// owns жЏєтљѕ (`"append"`(ТЌбт«џ, decode т▒цсЂД None сЂФтєЎсѓІ) / `"merge"`(DR-080) / `"kv_map"`(DR-091 ┬Д2))
/// сЂФуёАсЂЉсѓїсЂ░ definition-error kind=unknown-vocab Рђћ `collect_unknown_filter` (filter 4 т▒ъТђДсЂ«тљїтъІтѕцт«џ)
/// сЂ« accumulator уЅѕсђѓТЌДуІгуФІ "flatten" accumulator (DR-036/043сђЂDR-105 сЂДт╗ЃТГб) сЂ«уХ┤сѓісѓѓсЂЊсЂЊсЂДт╝ЙсЂІсѓїсѓІ
/// Рђћ т╗ЃТГбтЙїсЂ» `{"accumulator":"append","flatten":true}` сЂ«ухёсЂДУАеуЈЙсЂЎсѓІ (DR-105 ┬Д1/┬Д3)сђѓ
fn collect_unknown_accumulator(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn check(e : @engine.ElemDef) -> Unit {
    match e.accumulator {
      Some(a) =>
        if a != "merge" && a != "kv_map" {
          out.push(
            def_err(
              e.name,
              @engine.DUnknownVocab,
              "'\{e.name}' declares multiple.accumulator '" +
              a +
              "' which is not registered in the accumulators registry (DR-036/DR-105 ┬Д3) Рђћ the standalone \"flatten\" accumulator was retired by DR-105, use accumulator:\"append\" with flatten:true instead",
              "use a registered accumulator name (\"append\" [default, omit the key], \"merge\", \"kv_map\") or remove this declaration",
            ),
          )
        }
      None => ()
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_unknown_accumulator(c.body, out)
  }
}

///|
/// DR-105 ┬Д5/┬Д8 (ух▒ТІгУБЂт«џ M-18): `in_range`(scalar filter registry) / `length_range`(ARRAY filter
/// registry, DR-105 ┬Д5 Тќ░УеГ) сЂ« DSL т╝ЋТЋ░сѓњ definition time сЂФжЮЎуџёТцюТЪ╗сЂЎсѓІ Рђћ `collect_invalid_regex_
/// pattern` сЂ« regex pattern compile ТцюТЪ╗сЂетљїтъІ ("жЮЎуџёсЂФТЌбуЪЦсЂ»т«џуЙЕТЎѓсЂФтђњсЂЎ", DR-083 ┬Д5 / DR-082 ┬Д3)сђѓ
/// т╝ЋТЋ░тђІТЋ░СИЇСИђУЄ┤сЃ╗жЮъТЋ░тђцсЂ» kind=invalid-argument (DR-082 ┬Д3 сЂ«сђїтЇўСИђт╝ЋТЋ░тђцсЂЮсЂ«сѓѓсЂ«сЂїУБЁуй«сЂ«тЈЌуљєу»ётЏ▓тцќсђЇ)сђЂ
/// min>max сЂ» kind=invalid-range (DR-082 ┬Д2 сЂ«сђїУцЄТЋ░т▒ъТђДсЂ«ухётљѕсЂЏсЂїтђцтЪЪтцќсђЇсђЂ`@engine.DInvalidRange` сЂ«
/// min>max тЅЇСЙІсЂетљїтъІ)сђѓfilters.mbt сЂ« `filter_in_range`/`array_filter_length_range` УЄфУ║ФсЂїТїЂсЂц
/// runtime fallback (`filter_rejected`) сѓњуй«ТЈЏсЂЎсѓІсЂ«сЂДсЂ»сЂфсЂЈсђЂсЂЮсЂ«ТЅІтЅЇсЂД definition-error сЂесЂЌсЂд
/// уб║т«џсЂЋсЂЏсѓІ Рђћ `regex_match` сЂ« pattern compile ТцюТЪ╗сЂетљїсЂўсђїruntime тѕ░жЂћтЅЇсЂФтђњсЂЎсђЇсЃЉсѓ┐сЃ╝сЃ│сђѓ
/// тљё filter тљЇсЂ»УЄфтѕєсЂ« registry сѓњУдЂТ▒ѓсЂЎсѓІт▒ъТђДсЂДсЂ«сЂ┐ТцюТЪ╗сЂЎсѓІ (`in_range` сЂ» piece/value/final_filtersсђЂ
/// `length_range` сЂ» accum_filters сЂ«сЂ┐) Рђћ cross-registry сЂ«уХ┤сѓіУАЮуфЂ (`collect_unknown_filter` сЂї
/// тѕЦжђћ unknown-vocab сЂДт╝ЙсЂЈ) сЂеС║їжЄЇта▒тЉісЂЌсЂфсЂёсЂЪсѓЂсЂ«жЎљт«џ (DR-102 ┬Д2 сЂ«сђїУЄф registry сЂ«сЂ┐сѓњУдІсѓІсђЇсЂе
/// тљїсЂўжЎљт«џсѓњУИЈУЦ▓)сђѓwrong-seat (`collect_invalid_filter_attribute_mismatch` сЂї invalid-range сѓњтЄ║сЂЎ
/// accum УдЂу┤асЂ« final_filtersсЃ╗жЮъ accum УдЂу┤асЂ« accum_filtersсЃ╗`type:"none"` УдЂу┤а) сЂ»
/// `collect_invalid_regex_pattern` сЂетљїсЂўТДІжђасѓ▓сЃ╝сЃѕтЁѕУАїсЂДТюг gate сѓњсѓ╣сѓГсЃЃсЃЌсЂЎсѓІ (M-6/M-9 сЂетљїтъІ)сђѓ
fn collect_invalid_numeric_filter_args(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  fn is_accum_elem(e : @engine.ElemDef) -> Bool {
    e.multiple || elem_repeat(e) is Some(_) || e.separator is Some(_)
  }

  // DR-105 ┬Д5 Тўјуб║тїќ note (a) (codex #3 тЈЇТўа): `length_range` сЂ« bound сЂ»жЮъУ▓аТЋ┤ТЋ░жЎљт«џ Рђћ жЁЇтѕЌжЋисЂесЂёсЂє
  // тђцтЪЪсЂЮсЂ«сѓѓсЂ«сЂ«тѕХу┤ёсЂДсЂѓсѓісђЂ`in_range` сЂ« canonical number (У▓аТЋ░сЃ╗т░ЈТЋ░сѓѓтдЦтйЊ) сЂесЂ»тѕЦсЂ«тђІтѕЦУдЈтЅЄсђѓ
  // `n.to_int().to_double() == n` сЂ»ТЋ┤ТЋ░ТђДтѕцт«џ (value.mbt сЂ« `@engine.value_str` сЂ«тљїтъІсЃЉсѓ┐сЃ╝сЃ│сѓњТхЂуће)сђѓ
  fn is_nonneg_int(n : Double) -> Bool {
    n >= 0.0 && n.to_int().to_double() == n
  }

  // `nonneg_int`: true сЂфсѓЅ `length_range` т░ѓућесЂ«жЮъУ▓аТЋ┤ТЋ░тѕХу┤ё (min/max сЂЮсѓїсЂъсѓїуІгуФІсЂФ
  // kind=invalid-argumentсђЂDR-082 ┬Д3сђїУБЁуй«т╝ЋТЋ░сЂ«тђцсЂЮсЂ«сѓѓсЂ«сЂїСИЇТГБсђЇ) сѓњУ┐йтіасЂДУф▓сЂЎсђѓ`in_range` сЂ»
  // false сЂ«сЂЙсЂЙ (canonical numberсђЂТЌбтГўТїЎтІЋсѓњтцЅсЂѕсЂфсЂё)сђѓ
  fn check_two_arg(
    name : String,
    fs : @engine.FilterSpelling,
    nonneg_int : Bool,
  ) -> Unit {
    if fs.args.length() != 2 {
      out.push(
        def_err(
          name,
          @engine.DInvalidArgument,
          "'\{fs.name}' requires exactly 2 args (min, max), got \{fs.args.length()}",
          "provide exactly 2 numeric args, e.g. '\{fs.name}:1:5'",
        ),
      )
      return
    }
    let min = parse_number(fs.args[0])
    let max = parse_number(fs.args[1])
    match (min, max) {
      (None, _) =>
        out.push(
          def_err(
            name,
            @engine.DInvalidArgument,
            "'\{fs.name}' min '" + fs.args[0] + "' is not a number",
            "provide a numeric min",
          ),
        )
      (_, None) =>
        out.push(
          def_err(
            name,
            @engine.DInvalidArgument,
            "'\{fs.name}' max '" + fs.args[1] + "' is not a number",
            "provide a numeric max",
          ),
        )
      (Some(mn), Some(mx)) => {
        if nonneg_int {
          if !is_nonneg_int(mn) {
            out.push(
              def_err(
                name,
                @engine.DInvalidArgument,
                "'\{fs.name}' min \{mn} is not a non-negative integer",
                "provide a non-negative integer min, e.g. '\{fs.name}:0:5'",
              ),
            )
          }
          if !is_nonneg_int(mx) {
            out.push(
              def_err(
                name,
                @engine.DInvalidArgument,
                "'\{fs.name}' max \{mx} is not a non-negative integer",
                "provide a non-negative integer max, e.g. '\{fs.name}:0:5'",
              ),
            )
          }
        }
        if mn > mx {
          out.push(
            def_err(
              name,
              @engine.DInvalidRange,
              "'\{fs.name}' min \{mn} is greater than max \{mx}",
              "swap min/max so min <= max",
            ),
          )
        }
      }
    }
  }

  fn check_scalar_chain(
    name : String,
    chain : Array[@engine.FilterSpelling],
  ) -> Unit {
    for fs in chain {
      if fs.name == "in_range" {
        check_two_arg(name, fs, false)
      }
    }
  }

  fn check_array_chain(
    name : String,
    chain : Array[@engine.FilterSpelling],
  ) -> Unit {
    for fs in chain {
      if fs.name == "length_range" {
        check_two_arg(name, fs, true)
      }
    }
  }

  fn check(e : @engine.ElemDef) -> Unit {
    check_scalar_chain(e.name, e.piece_filters)
    check_scalar_chain(e.name, e.value_filters)
    if !is_accum_elem(e) && e.ty.name() != "none" {
      check_scalar_chain(e.name, e.final_filters)
    }
    if is_accum_elem(e) && e.ty.name() != "none" {
      check_array_chain(e.name, e.accum_filters)
    }
  }

  for e in def.options {
    check(e)
  }
  for e in def.positionals {
    check(e)
  }
  for c in def.commands {
    collect_invalid_numeric_filter_args(c.body, out)
  }
}

///|
/// ТюесЂ«сЂЕсЂЊсЂІсЂФ `type:"config_file"` УдЂу┤асЂїсЂѓсѓІсЂІ (DR-050): сЂѓсѓїсЂ░тљїтъІ config seat сЂїтЁе value cell сЂФуФІсЂцсђѓ
fn has_config_file(def : @engine.Definition) -> Bool {
  for e in def.options {
    if e.is_config_file {
      return true
    }
  }
  for e in def.positionals {
    if e.is_config_file {
      return true
    }
  }
  for c in def.commands {
    if has_config_file(c.body) {
      return true
    }
  }
  false
}

///|
/// config cycle (DR-050 ┬Д5 / DR-054): config_file УдЂу┤асЂ» config_key сѓњТїЂсЂдсЂфсЂё (УЄф path сѓњ config сЂІсѓЅ
/// т╝ЋсЂЈтЙфуњ░)сђѓтЁеС╗ХтЈјжЏєсђѓ
fn collect_config_cycle(
  def : @engine.Definition,
  out : Array[@engine.DefError],
) -> Unit {
  for e in def.options {
    if e.is_config_file && e.config_key is Some(_) {
      out.push(
        def_err(
          e.name,
          @engine.DConfigCycle,
          "config_file element '\{e.name}' cannot have a config_key (тЙфуњ░удЂТГб)",
          "remove config_key from the config_file element",
        ),
      )
    }
  }
  for e in def.positionals {
    if e.is_config_file && e.config_key is Some(_) {
      out.push(
        def_err(
          e.name,
          @engine.DConfigCycle,
          "config_file element '\{e.name}' cannot have a config_key (тЙфуњ░удЂТГб)",
          "remove config_key from the config_file element",
        ),
      )
    }
  }
  for c in def.commands {
    collect_config_cycle(c.body, out)
  }
}

///|
/// UsefulAST Рєњ AtomicAST сѓњ installer chain сЂесЂЌсЂджЂѓУАї (DR-042)сђѓ`order` сЂ»жЂЕуће installer тѕЌсђЂ5
/// invariants сЂФсѓѕсѓіухљТъюсЂ»жаєт║ЈуёАСЙЮтГўсђѓ
///
/// chain сЂ»ТюетЁеСйЊсЂД FIXPOINT сЂЙсЂДтЏъсѓІ (global сЂїуй«сЂёсЂЪт«БУеђсѓњтЙїТ«х pass сЂД long сЂїт▒ЋжќІсЂЎсѓІуГЅсЂ«
/// inter-installer СЙЮтГўсѓњ repeat сЂДУДБТ▒║)сђѓtermination: add-if-absent сЂе finite element├Ќscope уЕ║жќЊ
/// (copy of copy сЂ» name тљїСИђсЂД add-if-absent ТГбсЂЙсѓІ) сЂФсѓѕсѓі build т▒цсЂї monotonically ТѕљжЋисЂЌсђЂтцЅтїќсЂфсЂЌ
/// pass = fixpointсђѓ
///
/// Returns Ok(atomic scope) or Err(тЁе definition-time errors)сђѓstatic check сЂ»тЁесЂдУх░сЂБсЂд 1 list сЂФ append
/// (ТЅЊсЂАтѕЄсѓісЂфсЂЌ)сђѓтљё @engine.DefError сЂ» {element, kind, message, hint} сѓњТїЂсЂцсђѓ
pub fn lower_definition(
  def0 : @engine.Definition,
  order : Array[&@engine.InstallerExt],
  registry? : Map[String, @engine.Node] = Map([], capacity=0),
) -> Result[@engine.Scope, Array[@engine.DefError]] {
  let def = clone_def(def0)
  // DR-076 ┬Д2 flag ти«сЂЌТЏ┐сЂѕ/УБют«їсЂ« alias тЂ┤жЂЕуће (issue 2026-07-08 dec-alias-long-override-flag-sugar-
  // gap): `desugar_aliases` сЂ» canonical УдЂу┤асЂ«сђїтЁЃсЂ«тъІсђЇ(flag_type() сЂ«сЂЙсЂЙсђЂresolve_long сЂ«УдЈтЅЄ1тѕцт«џсЂФ
  // т┐Ёжаѕ) сѓњт┐ЁУдЂсЂесЂЎсѓІсЂїсђЂ`normalize_surface` сЂ» canonical УдЂу┤асѓњ bool_type() сЂИТЏИсЂЇТЈЏсЂѕсЂдсЂЌсЂЙсЂёсђЂсЂЊсЂ«ТЃЁта▒
  // сѓњ post-normalize сЂф `def` сЂІсѓЅтЈќсѓіТѕ╗сЂЏсЂфсЂёсђѓnormalize тЅЇсЂ«УцЄУБйсѓњтѕЦжђћС┐ЮТїЂсЂЌсђЂalias УДБТ▒║ТЎѓсЂасЂЉ
  // сЂЮсЂАсѓЅсѓњтЈѓуЁДсЂЎсѓІ (def УЄфСйЊсЂФсЂ» normalize сѓњжђџтИИсЂЕсЂісѓіжЂЕућесЂЎсѓІ Рђћ С║їжЄЇ pipeline сЂФсЂЌсЂфсЂё)сђѓ
  let orig = clone_def(def0)
  let errs : Array[@engine.DefError] = []
  // у┤ћТДІТќЄ pre-pass (LOWERING ┬ДA / ┬ДC.4): `:set` Рєњ kebab (Fix 2, DR-071) + dd name ТЌбт«џ "--" (Fix 3, DR-064 ┬Д5)
  normalize_surface(def)
  // init_sb сЂї registry сЂФ repeat-lowering template сѓњТцЇсЂѕсѓІ (жЮЎуџё ref check сЂїУдІсЂѕсѓІсѓѕсЂєсЂФ)сђѓ
  // alias entry-copies сЂ» ref/repeat сѓњТїЂсЂЪсЂџсђЂcommand alias сЂ» check ТИѕ body сѓњ clone сЂЎсѓІсЂ«сЂДсђЂ
  // static check сЂ» pre-desugar def сЂДтЏъсЂЎ (сЂЊсЂ« 1 ТюгуЏ«сЂ« tree сЂ» registry ТцЇсЂѕУЙ╝сЂ┐сЂ«сЂ┐сЂїуЏ«уџё)сђѓ
  let _ = init_sb(def, registry)
  for error in @engine.collect_installer_vocab_errors(def, order) {
    errs.push(error)
  }
  let view = @engine.DefsView::new(orig, def, registry)
  for installer in order {
    for error in installer.collect_defs_errors(view) {
      errs.push(error)
    }
  }
  if errs.length() > 0 {
    return Err(errs) // ALL definition-error тѕЌТїЎ
  }
  // alias т«БУеђ desugar (DR-057): т«їтЁеТђДТцюТЪ╗ pass тЙїсђЂТ▒║т«џуџё pre-passсђѓoption entry-copies /
  // command defs сѓњУ┐йтіа Рђћ fixpoint installer сЂїт▒ЋжќІсЂЎсѓІсђѓ
  desugar_aliases(def, orig)
  let sb = init_sb(def, registry) // desugar ТИѕ def сЂД scope tree тєЇТДІу»Ѕ
  // тљїтъІ default (DR-050 ┬Д3): config_file УдЂу┤асЂїсЂѓсѓїсЂ░тЁе value cell сЂФ config seat сѓњт«БУеђсђѓ1 т║дУеѕу«ЌсђЂ
  // ensure_entity сЂФ threadсђѓ
  let has_cf = has_config_file(def)
  @engine.run_installer_fixpoint(sb, order, fn(builder) {
    ensure_entities(builder, has_cf)
  })
}
